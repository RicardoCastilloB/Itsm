<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Garantías y Mantenimientos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
/* ── Design System — Light & Dark ── */
:root, [data-theme="light"] {
    --bg-main:    #f5f7fa;
    --bg-card:    #ffffff;
    --bg-header:  #fafbfc;
    --border-soft:#e2e8f0;
    --border-row: #f1f5f9;
    --text-main:  #1e293b;
    --text-muted: #64748b;
    --primary:    #3b82f6;
    --success:    #10b981;
    --warning:    #f59e0b;
    --info:       #06b6d4;
    --danger:     #ef4444;
    --purple:     #8b5cf6;
    --hover-row:  #f8fafc;
    --scrollbar-thumb: #cbd5e1;
    --scrollbar-track: #f1f5f9;
    --vencer-bg:       #fafbfc;
    --vencer-hover:    #f1f5f9;
    --maint-bg:        #f8fafc;
    --maint-hover:     #f1f5f9;
    --modal-footer-bg: #fafbfc;
    --tmpl-btn-bg:     #ffffff;
    --tmpl-btn-hover:  #eff6ff;
    --st-btn-bg:       #ffffff;
    --wpi-bg:          #ffffff;
    --ac-bg:           #ffffff;
    --ac-hover:        #f0f7ff;
    --ac-border:       #f1f5f9;
    --badge-light-bg:  #f1f5f9;
    --medal-other-bg:  #e2e8f0;
}
[data-theme="dark"] {
    --bg-main:    #0f172a;
    --bg-card:    #1e293b;
    --bg-header:  #162032;
    --border-soft:#2d3f55;
    --border-row: #2d3f55;
    --text-main:  #e2e8f0;
    --text-muted: #94a3b8;
    --primary:    #60a5fa;
    --success:    #34d399;
    --warning:    #fbbf24;
    --info:       #22d3ee;
    --danger:     #f87171;
    --purple:     #a78bfa;
    --hover-row:  #243348;
    --scrollbar-thumb: #334155;
    --scrollbar-track: #1e293b;
    --vencer-bg:       #1e293b;
    --vencer-hover:    #243348;
    --maint-bg:        #162032;
    --maint-hover:     #243348;
    --modal-footer-bg: #162032;
    --tmpl-btn-bg:     #1e293b;
    --tmpl-btn-hover:  #1e3a5f;
    --st-btn-bg:       #1e293b;
    --wpi-bg:          #1e293b;
    --ac-bg:           #1e293b;
    --ac-hover:        #243348;
    --ac-border:       #2d3f55;
    --badge-light-bg:  #2d3f55;
    --medal-other-bg:  #2d3f55;
}

body { margin:0; background:var(--bg-main); font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif; color:var(--text-main); transition:background 0.3s,color 0.3s; }
.dashboard-wrapper { width:100%; padding:12px; margin-top:60px; }
.dashboard-content { width:100%; max-width:1680px; margin:0 auto; }

.cards-4 { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:14px; }
@media(max-width:992px){.cards-4{grid-template-columns:repeat(2,1fr);}}
@media(max-width:576px){.cards-4{grid-template-columns:1fr;}}

.kpi-card {
    background:var(--bg-card); border-radius:12px; height:80px;
    padding:0 16px; display:flex; justify-content:space-between; align-items:center;
    border:1px solid var(--border-soft); box-shadow:0 1px 3px rgba(0,0,0,.05);
    transition:all .2s; cursor:default;
}
.kpi-card:hover { transform:translateY(-2px); box-shadow:0 4px 14px rgba(0,0,0,.09); }
.kpi-title { font-size:9px; letter-spacing:.6px; text-transform:uppercase; color:var(--text-muted); font-weight:700; margin-bottom:5px; }
.kpi-value { font-size:26px; font-weight:800; line-height:1; }
.kpi-icon  { font-size:30px; opacity:.18; }
.c-primary{color:var(--primary)!important;} .c-success{color:var(--success)!important;}
.c-warning{color:var(--warning)!important;} .c-danger{color:var(--danger)!important;}
.c-info{color:var(--info)!important;} .c-purple{color:var(--purple)!important;}

.row-bi { display:grid; grid-template-columns:1.6fr 1fr; gap:14px; margin-bottom:14px; }
@media(max-width:1200px){.row-bi{grid-template-columns:1fr;}}

.card-bi {
    background:var(--bg-card); border-radius:12px; border:1px solid var(--border-soft);
    box-shadow:0 1px 3px rgba(0,0,0,.05); display:flex; flex-direction:column;
    overflow:hidden; margin-bottom:14px; transition:background 0.3s,border-color 0.3s;
}
.card-bi-header {
    padding:13px 18px; border-bottom:1px solid var(--border-soft); font-weight:700; font-size:13px;
    display:flex; align-items:center; justify-content:space-between;
    background:var(--bg-header); flex-shrink:0; gap:8px; color:var(--text-main);
    transition:background 0.3s,border-color 0.3s,color 0.3s;
}
.card-bi-header .hdr-left { display:flex; align-items:center; gap:7px; }
.card-bi-body { padding:18px; flex:1; }

.table { width:100%; margin-bottom:0; font-size:13px; border-collapse:collapse; color:var(--text-main); }
.table thead th {
    font-size:9px; text-transform:uppercase; letter-spacing:.5px; color:var(--text-muted);
    background:var(--bg-header); border-bottom:2px solid var(--border-soft);
    padding:11px 14px; font-weight:700; text-align:center; position:sticky; top:0; z-index:2;
    transition:background 0.3s,color 0.3s,border-color 0.3s;
}
.table tbody td {
    padding:11px 14px; vertical-align:middle; text-align:center;
    border-bottom:1px solid var(--border-row); color:var(--text-main);
    transition:background 0.15s,border-color 0.3s,color 0.3s;
}
.table tbody td:first-child,.table tbody td:nth-child(2) { text-align:left; }
.table tbody tr:hover { background:var(--hover-row); }
[data-theme="dark"] .table { --bs-table-bg:transparent; }
[data-theme="dark"] .table-hover>tbody>tr:hover>* { --bs-table-accent-bg:var(--hover-row); background-color:var(--hover-row)!important; }

.badge { font-size:11px; padding:4px 9px; border-radius:6px; font-weight:600; }
.badge.bg-success  { background:#10b981!important; }
.badge.bg-primary  { background:#3b82f6!important; }
.badge.bg-warning  { background:#f59e0b!important; color:#000!important; }
.badge.bg-danger   { background:#ef4444!important; }
.badge.bg-info     { background:#06b6d4!important; }
.badge.bg-secondary{ background:#64748b!important; }
.badge.bg-light    { background:var(--badge-light-bg)!important; color:var(--text-main)!important; }
.badge.bg-purple   { background:#8b5cf6!important; }

.progress { height:5px; border-radius:4px; background:var(--border-soft); overflow:hidden; transition:background 0.3s; }
.progress-bar { border-radius:4px; transition:width .7s ease; }

.medal { width:24px; height:24px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:800; flex-shrink:0; }
.medal.gold   { background:linear-gradient(135deg,#fbbf24,#d97706); color:#fff; }
.medal.silver { background:linear-gradient(135deg,#94a3b8,#64748b); color:#fff; }
.medal.bronze { background:linear-gradient(135deg,#cd7c3a,#a05a2c); color:#fff; }
.medal.other  { background:var(--medal-other-bg); color:var(--text-muted); }

.vencer-item {
    display:flex; align-items:center; gap:10px; padding:9px 11px;
    border-radius:8px; margin-bottom:6px; border:1px solid var(--border-soft);
    background:var(--vencer-bg); transition:background .15s,border-color 0.3s;
}
.vencer-item:hover { background:var(--vencer-hover); }
.vencer-item:last-child { margin-bottom:0; }
.vencer-days {
    min-width:44px; height:44px; border-radius:9px;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    font-weight:800; flex-shrink:0; line-height:1.1;
}
.vencer-days span.d-num { font-size:15px; }
.vencer-days span.d-lbl { font-size:8px; text-transform:uppercase; letter-spacing:.4px; }
.vencer-days.ok     { background:#d1fae5; color:#065f46; }
.vencer-days.warn   { background:#fed7aa; color:#92400e; }
.vencer-days.urgent { background:#fecaca; color:#991b1b; }

.mes-row { display:grid; grid-template-columns:80px 1fr 100px; gap:7px 12px; align-items:center; }
.mes-label { font-size:11px; color:var(--text-muted); font-weight:600; text-align:right; }
.mes-val   { font-size:12px; font-weight:700; color:var(--text-main); }
.mes-count { font-size:10px; color:var(--text-muted); }

.mini-spin { display:inline-block; width:14px; height:14px; border:2px solid var(--border-soft); border-top-color:var(--primary); border-radius:50%; animation:spin .65s linear infinite; }
@keyframes spin{to{transform:rotate(360deg);}}
*::-webkit-scrollbar{width:5px;height:5px;}
*::-webkit-scrollbar-thumb{background:var(--scrollbar-thumb);border-radius:3px;}
*::-webkit-scrollbar-track{background:var(--scrollbar-track);}

.equip-card {
    background:var(--bg-card); border-radius:12px; border:1px solid var(--border-soft);
    box-shadow:0 1px 3px rgba(0,0,0,.05); margin-bottom:14px; overflow:hidden;
    transition:box-shadow .2s,background 0.3s,border-color 0.3s;
}
.equip-card:hover { box-shadow:0 4px 12px rgba(0,0,0,.08); }
.equip-card-header {
    padding:13px 18px; border-bottom:1px solid var(--border-soft); background:var(--bg-header);
    display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;
    transition:background 0.3s,border-color 0.3s;
}
.equip-card-title { font-weight:700; font-size:14px; display:flex; align-items:center; gap:8px; color:var(--text-main); }
.equip-card-meta  { font-size:11px; color:var(--text-muted); margin-top:2px; }
.equip-card-body  { padding:14px 18px; background:var(--bg-card); }

.info-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:10px; margin-bottom:14px; }
.info-item { display:flex; flex-direction:column; gap:2px; }
.info-label { font-size:9px; text-transform:uppercase; color:var(--text-muted); font-weight:700; letter-spacing:.5px; }
.info-value { font-size:13px; font-weight:600; color:var(--text-main); }

.warranty-status { padding:4px 11px; border-radius:20px; font-size:11px; font-weight:700; display:inline-flex; align-items:center; gap:5px; }
.warranty-active  { background:#d1fae5; color:#065f46; }
.warranty-warning { background:#fed7aa; color:#92400e; }
.warranty-expired { background:#fecaca; color:#991b1b; }

.maint-item {
    background:var(--maint-bg); border-left:4px solid var(--primary);
    padding:10px 13px; margin-bottom:7px; border-radius:0 8px 8px 0; transition:background .15s;
}
.maint-item:hover { background:var(--maint-hover); }
.maint-item:last-child { margin-bottom:0; }
.maint-item.t-cargador  { border-left-color:#f59e0b; }
.maint-item.t-bateria   { border-left-color:#ef4444; }
.maint-item.t-ram       { border-left-color:#8b5cf6; }
.maint-item.t-teclado   { border-left-color:#06b6d4; }
.maint-item.t-pantalla  { border-left-color:#ec4899; }
.maint-item.t-disco     { border-left-color:#10b981; }
.maint-item.t-limpieza  { border-left-color:#64748b; }
.maint-item.t-bios      { border-left-color:#3b82f6; }
.maint-item strong { color:var(--text-main); }

.btn-maint {
    background:var(--primary); border:none; color:#fff; padding:7px 16px;
    border-radius:8px; font-weight:600; font-size:12px; cursor:pointer;
    display:inline-flex; align-items:center; gap:5px; transition:all .2s;
}
.btn-maint:hover { background:#2563eb; transform:translateY(-1px); box-shadow:0 4px 12px rgba(59,130,246,.35); }

.no-results { text-align:center; padding:50px 20px; color:var(--text-muted); }
.loading-spinner { display:none; justify-content:center; align-items:center; padding:36px; }
.loading-spinner.active { display:flex; }

.autocomplete-container { position:relative; }
.autocomplete-results {
    position:absolute; top:calc(100% + 4px); left:0; right:0;
    background:var(--ac-bg); border:1px solid var(--border-soft); border-radius:10px;
    box-shadow:0 10px 36px rgba(0,0,0,.12); max-height:280px; overflow-y:auto; z-index:1060; display:none;
}
.autocomplete-results.show { display:block; animation:dropIn .15s ease; }
@keyframes dropIn{from{opacity:0;transform:translateY(-5px)}to{opacity:1;transform:translateY(0)}}
.ac-item { padding:10px 15px; cursor:pointer; border-bottom:1px solid var(--ac-border); transition:background .12s; }
.ac-item:last-child { border-bottom:none; }
.ac-item:hover,.ac-item.active-ac { background:var(--ac-hover); }
.ac-email   { font-weight:600; font-size:13px; color:var(--text-main); display:block; margin-bottom:1px; }
.ac-details { font-size:11px; color:var(--text-muted); }
.ac-empty   { padding:14px; text-align:center; color:var(--text-muted); font-size:13px; }
#searchEmail { background:var(--bg-card); color:var(--text-main); border-color:var(--border-soft); }

/* Modal dark */
[data-theme="dark"] .modal-content { background:var(--bg-card)!important; color:var(--text-main)!important; border-color:var(--border-soft)!important; }
[data-theme="dark"] .modal-body    { background:var(--bg-card)!important; }
[data-theme="dark"] .modal-footer  { background:var(--modal-footer-bg)!important; border-color:var(--border-soft)!important; }
[data-theme="dark"] .form-control,
[data-theme="dark"] .form-select   { background:var(--bg-card)!important; color:var(--text-main)!important; border-color:var(--border-soft)!important; }
[data-theme="dark"] .form-control::placeholder { color:var(--text-muted); }
[data-theme="dark"] label { color:var(--text-muted)!important; }

.tmpl-btn {
    border:2px solid var(--border-soft); border-radius:10px; padding:11px 6px;
    cursor:pointer; text-align:center; transition:all .2s;
    background:var(--tmpl-btn-bg); width:100%; color:var(--text-main);
}
.tmpl-btn:hover { border-color:var(--primary); background:var(--tmpl-btn-hover); transform:translateY(-2px); }
.tmpl-btn.active { border-color:var(--primary); background:var(--tmpl-btn-hover); box-shadow:0 0 0 3px rgba(59,130,246,.15); }
.tmpl-btn .t-ico { font-size:24px; display:block; margin-bottom:3px; }
.tmpl-btn .t-lbl { font-size:10px; font-weight:700; color:var(--text-muted); }

.sec-div { display:flex; align-items:center; gap:9px; color:var(--text-muted); font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; margin:14px 0 9px; }
.sec-div::before,.sec-div::after { content:''; flex:1; height:1px; background:var(--border-soft); }

.st-btn { border:2px solid var(--border-soft); border-radius:7px; padding:6px 10px; cursor:pointer; background:var(--st-btn-bg); color:var(--text-muted); font-size:11px; font-weight:700; transition:all .2s; width:100%; }
.st-btn.ok  { border-color:#10b981; background:#ecfdf5; color:#059669; }
.st-btn.wip { border-color:var(--primary); background:#eff6ff; color:#2563eb; }
.st-btn.pend{ border-color:var(--warning); background:#fffbeb; color:#d97706; }

.wpi { border:2px solid var(--border-soft); border-radius:20px; padding:4px 11px; cursor:pointer; background:var(--wpi-bg); color:var(--text-muted); font-size:11px; font-weight:600; transition:all .2s; }
.wpi.sel { border-color:#6366f1; background:#eef2ff; color:#4f46e5; }

@keyframes toastIn{from{opacity:0;transform:translateX(14px)}to{opacity:1;transform:translateX(0)}}
    </style>
</head>
<body>

