<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Workplace- Integratel</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">

<style>
/* ══════════════════════════════════════════
   VARIABLES — LIGHT & DARK
══════════════════════════════════════════ */
:root,
[data-theme="light"] {
  --bg-main:        #f0f4f9;
  --bg-card:        #ffffff;
  --bg-header:      #fafbfc;
  --bg-grid:        rgba(59,130,246,.04);
  --border-soft:    #e2e8f0;
  --text-main:      #1e293b;
  --text-muted:     #64748b;
  --primary:        #3b82f6;
  --success:        #10b981;
  --warning:        #f59e0b;
  --info:           #06b6d4;
  --danger:         #ef4444;
  --purple:         #8b5cf6;
  --pink:           #ec4899;
  --shadow-card:    0 2px 8px rgba(0,0,0,.06);
  --shadow-hover:   0 12px 32px rgba(59,130,246,.18);
  --toggle-bg:      #e2e8f0;
  --toggle-knob:    #ffffff;
  --toggle-icon:    #64748b;
  --shine:          rgba(255,255,255,.55);
  --grid-line:      rgba(59,130,246,.07);
  --hero-text:      #1e293b;
  --hero-sub:       #64748b;
  --chip-bg:        rgba(59,130,246,.08);
  --chip-color:     #3b82f6;
}

[data-theme="dark"] {
  --bg-main:        #0b1120;
  --bg-card:        #131f35;
  --bg-header:      #0f1929;
  --bg-grid:        rgba(96,165,250,.03);
  --border-soft:    #1e3050;
  --text-main:      #e2e8f0;
  --text-muted:     #94a3b8;
  --primary:        #60a5fa;
  --success:        #34d399;
  --warning:        #fbbf24;
  --info:           #22d3ee;
  --danger:         #f87171;
  --purple:         #a78bfa;
  --pink:           #f472b6;
  --shadow-card:    0 2px 12px rgba(0,0,0,.4);
  --shadow-hover:   0 14px 40px rgba(96,165,250,.22);
  --toggle-bg:      #3b82f6;
  --toggle-knob:    #ffffff;
  --toggle-icon:    #ffffff;
  --shine:          rgba(255,255,255,.04);
  --grid-line:      rgba(96,165,250,.06);
  --hero-text:      #e2e8f0;
  --hero-sub:       #94a3b8;
  --chip-bg:        rgba(96,165,250,.12);
  --chip-color:     #60a5fa;
}

/* ══════════════════════════════════════════
   BASE
══════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Sora', sans-serif;
  background: var(--bg-main);
  color: var(--text-main);
  min-height: 100vh;
  overflow-x: hidden;
  transition: background .35s ease, color .35s ease;
}

/* Grid decorativo de fondo */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
  z-index: 0;
}

/* ══════════════════════════════════════════
   DARK MODE TOGGLE (igual al dashboard)
══════════════════════════════════════════ */
.theme-toggle {
  position: fixed;
  top: 14px; right: 16px;
  z-index: 9999;
  display: flex; align-items: center; gap: 8px;
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  border-radius: 30px;
  padding: 6px 14px 6px 10px;
  box-shadow: var(--shadow-card);
  cursor: pointer;
  transition: all .25s ease;
  user-select: none;
}
.theme-toggle:hover { box-shadow: 0 6px 20px rgba(0,0,0,.15); }
.toggle-track {
  width: 40px; height: 22px;
  background: var(--toggle-bg);
  border-radius: 11px; position: relative;
  transition: background .3s; flex-shrink: 0;
}
.toggle-knob {
  width: 16px; height: 16px;
  background: var(--toggle-knob);
  border-radius: 50%; position: absolute;
  top: 3px; left: 3px;
  transition: transform .3s cubic-bezier(.4,0,.2,1);
  box-shadow: 0 1px 4px rgba(0,0,0,.3);
}
[data-theme="dark"] .toggle-knob { transform: translateX(18px); }
.toggle-icon  { font-size: 14px; color: var(--toggle-icon); line-height: 1; transition: color .3s; }
.toggle-label { font-size: 12px; font-weight: 600; color: var(--text-muted); transition: color .3s; white-space: nowrap; }

/* ══════════════════════════════════════════
   WRAPPER
══════════════════════════════════════════ */
.home-wrapper {
  position: relative; z-index: 1;
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 60px 24px 40px;
}

/* ══════════════════════════════════════════
   LOGO / HERO
══════════════════════════════════════════ */
.hero {
  text-align: center;
  margin-bottom: 52px;
  animation: fadeDown .7s ease both;
}

.hero-logo {
  display: inline-flex; align-items: center; gap: 12px;
  margin-bottom: 20px;
}
.hero-logo-icon {
  width: 52px; height: 52px;
  background: linear-gradient(135deg, var(--primary), var(--info));
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; color: #fff;
  box-shadow: 0 6px 20px rgba(59,130,246,.35);
  flex-shrink: 0;
}
.hero-logo-text {
  font-size: 26px; font-weight: 800; letter-spacing: -1px;
  color: var(--hero-text);
  transition: color .3s;
}
.hero-logo-text span {
  color: var(--primary);
}

.hero-title {
  font-size: clamp(15px, 2vw, 18px);
  font-weight: 400;
  color: var(--hero-sub);
  transition: color .3s;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: .5px;
}

.hero-chip {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--chip-bg);
  color: var(--chip-color);
  border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
  border-radius: 20px;
  padding: 4px 14px;
  font-size: 11px; font-weight: 600; letter-spacing: .8px;
  text-transform: uppercase;
  margin-top: 12px;
  transition: background .3s, color .3s;
}
.hero-chip i { font-size: 10px; }

/* ══════════════════════════════════════════
   MÓDULOS GRID
══════════════════════════════════════════ */
.modules-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  width: 100%;
  max-width: 1020px;
}

@media (max-width: 900px)  { .modules-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 540px)  { .modules-grid { grid-template-columns: 1fr; } }

/* ══════════════════════════════════════════
   MODULE CARD
══════════════════════════════════════════ */
.mod-card {
  position: relative;
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  border-radius: 18px;
  padding: 32px 28px 28px;
  text-decoration: none !important;
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 0;
  overflow: hidden;
  cursor: pointer;
  transition:
    transform .28s cubic-bezier(.4,0,.2,1),
    box-shadow .28s ease,
    border-color .28s ease,
    background .35s;
  animation: fadeUp .6s ease both;
}

/* stagger */
.mod-card:nth-child(1) { animation-delay: .05s; }
.mod-card:nth-child(2) { animation-delay: .10s; }
.mod-card:nth-child(3) { animation-delay: .15s; }
.mod-card:nth-child(4) { animation-delay: .20s; }
.mod-card:nth-child(5) { animation-delay: .25s; }
.mod-card:nth-child(6) { animation-delay: .30s; }

/* Shine sweep on hover */
.mod-card::after {
  content: '';
  position: absolute;
  top: -60%; left: -80%;
  width: 60%; height: 220%;
  background: var(--shine);
  transform: skewX(-18deg);
  transition: left .55s ease;
  pointer-events: none;
}
.mod-card:hover::after { left: 150%; }

/* Decorative blob */
.mod-card::before {
  content: '';
  position: absolute;
  top: -30px; right: -30px;
  width: 120px; height: 120px;
  border-radius: 50%;
  background: radial-gradient(circle, var(--mod-accent, var(--primary)) 0%, transparent 70%);
  opacity: .07;
  transition: opacity .3s, transform .3s;
}
.mod-card:hover::before { opacity: .14; transform: scale(1.25); }

.mod-card:hover {
  transform: translateY(-5px) scale(1.015);
  box-shadow: var(--shadow-hover);
  border-color: color-mix(in srgb, var(--mod-accent, var(--primary)) 40%, transparent);
}

/* Icon badge */
.mod-icon {
  width: 56px; height: 56px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px;
  margin-bottom: 20px;
  flex-shrink: 0;
  position: relative; z-index: 1;
  transition: transform .25s ease;
}
.mod-card:hover .mod-icon { transform: scale(1.1) rotate(-4deg); }

.mod-name {
  font-size: 18px; font-weight: 700;
  color: var(--text-main);
  margin-bottom: 6px;
  position: relative; z-index: 1;
  transition: color .3s;
}
.mod-card:hover .mod-name { color: var(--mod-accent, var(--primary)); }

.mod-desc {
  font-size: 12.5px; line-height: 1.55;
  color: var(--text-muted);
  position: relative; z-index: 1;
  transition: color .3s;
  flex: 1;
}

.mod-arrow {
  position: absolute;
  bottom: 22px; right: 24px;
  font-size: 16px;
  color: var(--text-muted);
  opacity: 0;
  transform: translateX(-6px);
  transition: opacity .25s, transform .25s, color .25s;
  z-index: 1;
}
.mod-card:hover .mod-arrow {
  opacity: 1; transform: translateX(0);
  color: var(--mod-accent, var(--primary));
}

/* ══════════════════════════════════════════
   PER-MODULE ACCENT COLORS
══════════════════════════════════════════ */
.mod-equipos  { --mod-accent: #3b82f6; }
.mod-usuarios { --mod-accent: #10b981; }
.mod-cmdb     { --mod-accent: #8b5cf6; }
.mod-soporte  { --mod-accent: #f59e0b; }
.mod-backlog  { --mod-accent: #ec4899; }
.mod-reportes { --mod-accent: #06b6d4; }

[data-theme="dark"] .mod-equipos  { --mod-accent: #60a5fa; }
[data-theme="dark"] .mod-usuarios { --mod-accent: #34d399; }
[data-theme="dark"] .mod-cmdb     { --mod-accent: #a78bfa; }
[data-theme="dark"] .mod-soporte  { --mod-accent: #fbbf24; }
[data-theme="dark"] .mod-backlog  { --mod-accent: #f472b6; }
[data-theme="dark"] .mod-reportes { --mod-accent: #22d3ee; }

/* icon bg */
.mod-equipos  .mod-icon { background: rgba(59,130,246,.12);  color: #3b82f6; }
.mod-usuarios .mod-icon { background: rgba(16,185,129,.12);  color: #10b981; }
.mod-cmdb     .mod-icon { background: rgba(139,92,246,.12);  color: #8b5cf6; }
.mod-soporte  .mod-icon { background: rgba(245,158,11,.12);  color: #f59e0b; }
.mod-backlog  .mod-icon { background: rgba(236,72,153,.12);  color: #ec4899; }
.mod-reportes .mod-icon { background: rgba(6,182,212,.12);   color: #06b6d4; }

[data-theme="dark"] .mod-equipos  .mod-icon { background: rgba(96,165,250,.15);  color: #60a5fa; }
[data-theme="dark"] .mod-usuarios .mod-icon { background: rgba(52,211,153,.15);  color: #34d399; }
[data-theme="dark"] .mod-cmdb     .mod-icon { background: rgba(167,139,250,.15); color: #a78bfa; }
[data-theme="dark"] .mod-soporte  .mod-icon { background: rgba(251,191,36,.15);  color: #fbbf24; }
[data-theme="dark"] .mod-backlog  .mod-icon { background: rgba(244,114,182,.15); color: #f472b6; }
[data-theme="dark"] .mod-reportes .mod-icon { background: rgba(34,211,238,.15);  color: #22d3ee; }

/* ══════════════════════════════════════════
   FOOTER
══════════════════════════════════════════ */
.home-footer {
  margin-top: 48px;
  text-align: center;
  font-size: 11.5px;
  color: var(--text-muted);
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: .3px;
  opacity: .7;
  animation: fadeUp .6s .4s ease both;
}

/* ══════════════════════════════════════════
   ANIMATIONS
══════════════════════════════════════════ */
@keyframes fadeDown {
  from { opacity: 0; transform: translateY(-22px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(22px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Scrollbar */
*::-webkit-scrollbar { width: 6px; height: 6px; }
*::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
[data-theme="dark"] *::-webkit-scrollbar-thumb { background: #334155; }
</style>
</head>
<body>

<!-- DARK MODE TOGGLE -->
<div class="theme-toggle" onclick="toggleTheme()" role="button" aria-label="Cambiar tema">
  <i id="toggleIcon" class="bi bi-moon-stars-fill toggle-icon"></i>
  <div class="toggle-track">
    <div class="toggle-knob"></div>
  </div>
  <span id="toggleLabel" class="toggle-label">Oscuro</span>
</div>

<div class="home-wrapper">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-logo">
      <div class="hero-logo-icon">
        <i class="bi bi-hexagon-fill"></i>
      </div>
      <div class="hero-logo-text">Gest -  <span>Integratel</span></div>
    </div>
    <div class="hero-title">Sistema de Gestión IT · v1.0</div>
    <div class="hero-chip">
      <i class="bi bi-circle-fill" style="color:var(--success);"></i>
      Plataforma activa
    </div>
  </div>

<div class="modules-grid">

    <a href="<%= APP_URL %>/almacen" class="mod-card mod-equipos">
      <div class="mod-icon"><i class="bi bi-hdd-stack-fill"></i></div>
      <div class="mod-name">Almacen</div>
      <div class="mod-desc">Gestión de hardware: laptops, desktops, ultraligeras y activos tecnológicos.</div>
      <i class="bi bi-arrow-right mod-arrow"></i>
    </a>

    <a href="<%= APP_URL %>/employees" class="mod-card mod-usuarios">
      <div class="mod-icon"><i class="bi bi-people-fill"></i></div>
      <div class="mod-name">Usuarios</div>
      <div class="mod-desc">Administración de cuentas, perfiles, roles y planilla de colaboradores.</div>
      <i class="bi bi-arrow-right mod-arrow"></i>
    </a>

    <a href="<%= APP_URL %>/equipment" class="mod-card mod-cmdb">
      <div class="mod-icon"><i class="bi bi-diagram-3-fill"></i></div>
      <div class="mod-name">CMDB</div>
      <div class="mod-desc">Base de datos de configuración: inventario, relaciones y atributos de CIs.</div>
      <i class="bi bi-arrow-right mod-arrow"></i>
    </a>

    <a href="<%= APP_URL %>/soporte" class="mod-card mod-soporte">
      <div class="mod-icon"><i class="bi bi-headset"></i></div>
      <div class="mod-name">Soporte</div>
      <div class="mod-desc">Gestión de tickets, incidentes, solicitudes y atención al usuario final.</div>
      <i class="bi bi-arrow-right mod-arrow"></i>
    </a>

    <a href="<%= APP_URL %>/print-queue" class="mod-card mod-backlog">
      <div class="mod-icon"><i class="bi bi-printer"></i></div>
      <div class="mod-name">Cola(Demo)</div>
      <div class="mod-desc">Tablero de tareas, pendientes y seguimiento de proyectos del equipo IT.</div>
      <i class="bi bi-arrow-right mod-arrow"></i>
    </a>

    <a href="<%= APP_URL %>/reports-distribution" class="mod-card mod-reportes">
      <div class="mod-icon"><i class="bi bi-bar-chart-line-fill"></i></div>
      <div class="mod-name">Reportes</div>
      <div class="mod-desc">Dashboards analíticos, métricas KPI, exportaciones y reportes ejecutivos.</div>
      <i class="bi bi-arrow-right mod-arrow"></i>
    </a>

  </div>

  <div class="home-footer">
    © 2025 Stefanini Group &nbsp;·&nbsp; IT Management Platform &nbsp;·&nbsp; v2.0.1
  </div>

</div>



</div><!-- /.home-wrapper -->

<script>
(function () {
  const saved = localStorage.getItem('dashboardTheme') || 'light';
  document.documentElement.setAttribute('data-theme', saved);
})();

function toggleTheme() {
  const html    = document.documentElement;
  const current = html.getAttribute('data-theme');
  const next    = current === 'dark' ? 'light' : 'dark';
  html.setAttribute('data-theme', next);
  localStorage.setItem('dashboardTheme', next);
  updateToggleUI(next);
}

function updateToggleUI(theme) {
  const icon  = document.getElementById('toggleIcon');
  const label = document.getElementById('toggleLabel');
  if (theme === 'dark') {
    icon.className    = 'bi bi-sun-fill toggle-icon';
    label.textContent = 'Claro';
  } else {
    icon.className    = 'bi bi-moon-stars-fill toggle-icon';
    label.textContent = 'Oscuro';
  }
}

document.addEventListener('DOMContentLoaded', () => {
  const saved = localStorage.getItem('dashboardTheme') || 'light';
  updateToggleUI(saved);
});
</script>

</body>
</html>
