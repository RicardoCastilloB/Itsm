<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solicitudes de Servicio</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<style>
:root,[data-theme="light"]{
    --bg:#f0f4f8;--card:#fff;--hdr:#f8fafc;--border:#e2e8f0;
    --text:#1e293b;--muted:#64748b;--primary:#3b82f6;--success:#10b981;
    --warning:#f59e0b;--info:#06b6d4;--danger:#ef4444;--purple:#8b5cf6;
    --hover:#f1f5f9;--sh-sm:0 1px 3px rgba(0,0,0,.06);--sh-md:0 4px 12px rgba(0,0,0,.08);
}
[data-theme="dark"]{
    --bg:#0f172a;--card:#1e293b;--hdr:#162032;--border:#2d3f55;
    --text:#e2e8f0;--muted:#94a3b8;--primary:#60a5fa;--success:#34d399;
    --warning:#fbbf24;--info:#22d3ee;--danger:#f87171;--purple:#a78bfa;
    --hover:#243348;--sh-sm:0 1px 3px rgba(0,0,0,.3);--sh-md:0 4px 12px rgba(0,0,0,.4);
}
*{box-sizing:border-box;}
body{margin:0;background:var(--bg);color:var(--text);font-family:'DM Sans',-apple-system,sans-serif;}
.pg{max-width:1700px;margin:0 auto;padding:24px 20px;}
.page-hdr{display:flex;align-items:center;gap:16px;margin-bottom:28px;}
.page-hdr-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;box-shadow:var(--sh-md);}
.page-hdr h1{font-size:22px;font-weight:800;margin:0;}
.page-hdr p{margin:3px 0 0;font-size:13px;color:var(--muted);}
.page-hdr-right{margin-left:auto;display:flex;gap:8px;align-items:center;}
.kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px;}
@media(max-width:1100px){.kpi-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:600px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 18px;display:flex;justify-content:space-between;align-items:center;box-shadow:var(--sh-sm);cursor:pointer;position:relative;overflow:hidden;transition:all .2s;}
.kpi::before{content:'';position:absolute;inset:0;background:var(--kc);opacity:0;transition:opacity .2s;}
.kpi:hover::before,.kpi.active::before{opacity:.06;}
.kpi.active{border-color:var(--kc)!important;box-shadow:0 0 0 2px var(--kc)!important;}
.kpi-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin-bottom:5px;}
.kpi-val{font-size:28px;font-weight:800;line-height:1;color:var(--kc);}
.kpi-icon{font-size:32px;opacity:.18;color:var(--kc);}
.card-ui{background:var(--card);border:1px solid var(--border);border-radius:14px;box-shadow:var(--sh-sm);overflow:hidden;margin-bottom:20px;}
.card-head{padding:13px 18px;background:var(--hdr);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.card-head .title{font-size:13px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px;}
.tbl-wrap{overflow:auto;max-height:520px;}
.tbl{width:100%;border-collapse:collapse;font-size:13px;}
.tbl thead th{background:var(--hdr);color:var(--muted);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;padding:11px 14px;border-bottom:1px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;}
.tbl tbody tr{border-bottom:1px solid var(--border);transition:background .15s;cursor:pointer;}
.tbl tbody tr:hover{background:var(--hover);}
.tbl td{padding:11px 14px;vertical-align:middle;}
.badge-status,.badge-priority{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.bs-borrador{background:#f1f5f9;color:#64748b;}
.bs-pendiente{background:#fef3c7;color:#d97706;}
.bs-aprobado{background:#d1fae5;color:#059669;}
.bs-en_proceso{background:#dbeafe;color:#2563eb;}
.bs-completado{background:#d1fae5;color:#059669;}
.bs-rechazado{background:#fee2e2;color:#dc2626;}
.bs-cancelado{background:#f1f5f9;color:#94a3b8;}
.bp-baja{background:#d1fae5;color:#059669;}
.bp-media{background:#fef3c7;color:#d97706;}
.bp-alta{background:#fee2e2;color:#dc2626;}
.bp-critica{background:#fce7f3;color:#be185d;}
.btn-sm{padding:6px 14px;font-size:12px;font-weight:600;border-radius:8px;border:none;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary-sm{background:var(--primary);color:#fff;}
.btn-primary-sm:hover{opacity:.88;}
.btn-outline-sm{background:transparent;border:1px solid var(--border);color:var(--muted);}
.btn-outline-sm:hover{background:var(--hover);}
.search-bar{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.search-bar input,.search-bar select{height:36px;border:1px solid var(--border);border-radius:8px;padding:0 12px;font-size:13px;background:var(--card);color:var(--text);outline:none;}
.empty-state{text-align:center;padding:60px 20px;color:var(--muted);}
.empty-state i{font-size:48px;opacity:.3;display:block;margin-bottom:12px;}
.pagination{display:flex;gap:4px;align-items:center;justify-content:flex-end;padding:12px 18px;border-top:1px solid var(--border);}
.page-btn{width:32px;height:32px;border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;background:var(--card);color:var(--text);transition:all .15s;}
.page-btn:hover,.page-btn.active{background:var(--primary);color:#fff;border-color:var(--primary);}
/* Modal */
.modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal-box{background:var(--card);border-radius:20px;width:560px;max-width:95vw;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 60px rgba(0,0,0,.25);transform:translateY(20px);transition:transform .2s;}
.modal-overlay.open .modal-box{transform:translateY(0);}
.modal-hdr{padding:20px 24px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.modal-hdr h3{margin:0;font-size:16px;font-weight:800;}
.modal-body{padding:20px 24px;overflow-y:auto;flex:1;}
.modal-ftr{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;}
.form-lbl{font-size:12px;font-weight:700;color:var(--muted);margin-bottom:5px;display:block;}
.form-ctrl{width:100%;border:1px solid var(--border);border-radius:8px;padding:9px 12px;font-size:13px;background:var(--card);color:var(--text);outline:none;transition:border .15s;}
.form-ctrl:focus{border-color:var(--primary);}
.form-group{margin-bottom:14px;}
.catalog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-bottom:16px;}
.cat-card{border:2px solid var(--border);border-radius:12px;padding:14px;cursor:pointer;transition:all .2s;background:var(--card);}
.cat-card:hover,.cat-card.selected{border-color:var(--primary);background:rgba(59,130,246,.04);}
.cat-card .cat-icon{font-size:28px;margin-bottom:8px;}
.cat-card .cat-name{font-size:13px;font-weight:700;}
.cat-card .cat-desc{font-size:11px;color:var(--muted);margin-top:3px;}
.theme-toggle{background:none;border:1px solid var(--border);border-radius:8px;padding:6px 10px;cursor:pointer;color:var(--text);font-size:16px;}
</style>
</head>
<body>
<div class="pg">
  <!-- HEADER -->
  <div class="page-hdr">
    <div class="page-hdr-icon" style="background:linear-gradient(135deg,#8b5cf6,#6d28d9);">
      <i class="bi bi-ticket-detailed" style="color:#fff;"></i>
    </div>
    <div>
      <h1>Solicitudes de Servicio</h1>
      <p>Portal de autoservicio — solicita recursos y accesos</p>
    </div>
    <div class="page-hdr-right">
      <button class="theme-toggle" onclick="toggleTheme()" title="Cambiar tema"><i class="bi bi-moon-stars-fill"></i></button>
      <button class="btn-sm btn-primary-sm" onclick="openModal('modalNueva')">
        <i class="bi bi-plus-lg"></i> Nueva Solicitud
      </button>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpi-grid" id="kpiGrid">
    <div class="kpi" style="--kc:var(--purple)" onclick="filterStatus('')">
      <div><div class="kpi-label">Total</div><div class="kpi-val" id="kpiTotal">—</div></div>
      <i class="bi bi-collection kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--warning)" onclick="filterStatus('pendiente_aprobacion')">
      <div><div class="kpi-label">Pendientes</div><div class="kpi-val" id="kpiPendiente">—</div></div>
      <i class="bi bi-hourglass-split kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--primary)" onclick="filterStatus('en_proceso')">
      <div><div class="kpi-label">En Proceso</div><div class="kpi-val" id="kpiProceso">—</div></div>
      <i class="bi bi-arrow-repeat kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--success)" onclick="filterStatus('completado')">
      <div><div class="kpi-label">Completadas</div><div class="kpi-val" id="kpiCompletado">—</div></div>
      <i class="bi bi-check-circle kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--danger)" onclick="filterStatus('rechazado')">
      <div><div class="kpi-label">Rechazadas</div><div class="kpi-val" id="kpiRechazado">—</div></div>
      <i class="bi bi-x-circle kpi-icon"></i>
    </div>
  </div>

  <!-- TABLE -->
  <div class="card-ui">
    <div class="card-head">
      <span class="title"><i class="bi bi-list-ul"></i> Mis Solicitudes</span>
      <div class="search-bar">
        <select id="fStatus" class="form-ctrl" style="width:160px;" onchange="loadSolicitudes()">
          <option value="">Todos los estados</option>
          <option value="borrador">Borrador</option>
          <option value="pendiente_aprobacion">Pendiente aprobación</option>
          <option value="aprobado">Aprobado</option>
          <option value="en_proceso">En proceso</option>
          <option value="completado">Completado</option>
          <option value="rechazado">Rechazado</option>
          <option value="cancelado">Cancelado</option>
        </select>
        <select id="fPriority" class="form-ctrl" style="width:130px;" onchange="loadSolicitudes()">
          <option value="">Prioridad</option>
          <option value="baja">Baja</option>
          <option value="media">Media</option>
          <option value="alta">Alta</option>
          <option value="critica">Crítica</option>
        </select>
      </div>
    </div>
    <div class="tbl-wrap">
      <table class="tbl">
        <thead>
          <tr>
            <th>ID</th><th>Título</th><th>Servicio</th><th>Prioridad</th>
            <th>Estado</th><th>Vence</th><th>Creado</th><th></th>
          </tr>
        </thead>
        <tbody id="srBody">
          <tr><td colspan="8"><div class="empty-state"><i class="bi bi-arrow-clockwise"></i>Cargando...</div></td></tr>
        </tbody>
      </table>
    </div>
    <div class="pagination" id="srPagination"></div>
  </div>
</div>

<!-- MODAL NUEVA SOLICITUD -->
<div class="modal-overlay" id="modalNueva">
  <div class="modal-box">
    <div class="modal-hdr">
      <h3><i class="bi bi-ticket-detailed" style="color:var(--purple)"></i> Nueva Solicitud</h3>
      <button class="btn-sm btn-outline-sm" onclick="closeModal('modalNueva')">✕</button>
    </div>
    <div class="modal-body">
      <!-- Step 1: Catalog -->
      <div id="step1">
        <p style="font-size:13px;color:var(--muted);margin-bottom:14px;">Selecciona la categoría de servicio:</p>
        <div class="catalog-grid" id="catalogGrid">
          <div style="text-align:center;padding:20px;color:var(--muted);grid-column:1/-1;">
            <i class="bi bi-arrow-clockwise"></i> Cargando catálogo...
          </div>
        </div>
      </div>
      <!-- Step 2: Form -->
      <div id="step2" style="display:none;">
        <button class="btn-sm btn-outline-sm" style="margin-bottom:14px;" onclick="backStep()">
          <i class="bi bi-arrow-left"></i> Volver
        </button>
        <div class="form-group">
          <label class="form-lbl">Servicio *</label>
          <select id="srServiceId" class="form-ctrl"><option value="">— Seleccionar —</option></select>
        </div>
        <div class="form-group">
          <label class="form-lbl">Título *</label>
          <input type="text" id="srTitle" class="form-ctrl" placeholder="Breve descripción de la solicitud">
        </div>
        <div class="form-group">
          <label class="form-lbl">Descripción</label>
          <textarea id="srDesc" class="form-ctrl" rows="3" placeholder="Detalla lo que necesitas..."></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div class="form-group">
            <label class="form-lbl">Prioridad</label>
            <select id="srPriority" class="form-ctrl">
              <option value="baja">Baja</option>
              <option value="media" selected>Media</option>
              <option value="alta">Alta</option>
              <option value="critica">Crítica</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-lbl">Fecha límite</label>
            <input type="date" id="srDue" class="form-ctrl">
          </div>
        </div>
      </div>
    </div>
    <div class="modal-ftr" id="modalFtr" style="display:none;">
      <button class="btn-sm btn-outline-sm" onclick="closeModal('modalNueva')">Cancelar</button>
      <button class="btn-sm btn-primary-sm" onclick="crearSolicitud()">
        <i class="bi bi-send"></i> Enviar Solicitud
      </button>
    </div>
  </div>
</div>

<script>
let srPage = 1;
let srCatalog = [];

async function loadKpis() {
    try {
        const res = await fetch('/api/service-requests?limit=500');
        const d = await res.json();
        const rows = d.data || [];
        document.getElementById('kpiTotal').textContent = d.total ?? rows.length;
        document.getElementById('kpiPendiente').textContent = rows.filter(r => r.status === 'pendiente_aprobacion').length;
        document.getElementById('kpiProceso').textContent   = rows.filter(r => r.status === 'en_proceso').length;
        document.getElementById('kpiCompletado').textContent = rows.filter(r => r.status === 'completado').length;
        document.getElementById('kpiRechazado').textContent  = rows.filter(r => r.status === 'rechazado').length;
    } catch {}
}

async function loadSolicitudes(page = 1) {
    srPage = page;
    const status   = document.getElementById('fStatus').value;
    const priority = document.getElementById('fPriority').value;
    const params   = new URLSearchParams({ page, limit: 20 });
    if (status)   params.set('status', status);
    if (priority) params.set('priority', priority);

    const res = await fetch(`/api/service-requests?${params}`);
    const d   = await res.json();
    const rows = d.data || [];
    const tbody = document.getElementById('srBody');

    if (!rows.length) {
        tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><i class="bi bi-inbox"></i>Sin solicitudes</div></td></tr>`;
        document.getElementById('srPagination').innerHTML = '';
        return;
    }

    tbody.innerHTML = rows.map(r => `
        <tr onclick="verSolicitud('${r.id}')">
          <td><span style="font-family:monospace;font-size:11px;color:var(--muted)">${r.id.substring(0,8)}…</span></td>
          <td><strong>${escHtml(r.title)}</strong></td>
          <td>${r.serviceId ? '<i class="bi bi-box"></i>' : '—'}</td>
          <td><span class="badge-priority bp-${r.priority}">${r.priority}</span></td>
          <td><span class="badge-status bs-${r.status}">${fmtStatus(r.status)}</span></td>
          <td>${r.dueDate ? fmtDate(r.dueDate) : '—'}</td>
          <td>${fmtDate(r.createdAt)}</td>
          <td>
            ${r.status === 'pendiente_aprobacion'
              ? `<button class="btn-sm btn-primary-sm" onclick="event.stopPropagation();aprobar('${r.id}','aprobado')">Aprobar</button>`
              : ''}
          </td>
        </tr>`).join('');

    const total = d.total || rows.length;
    const pages = Math.ceil(total / 20);
    renderPagination('srPagination', pages, page, p => loadSolicitudes(p));
}

async function loadCatalog() {
    const res = await fetch('/api/service-requests/catalog');
    const d   = await res.json();
    srCatalog = d.data || [];
    const grid = document.getElementById('catalogGrid');
    if (!srCatalog.length) {
        grid.innerHTML = '<p style="color:var(--muted);grid-column:1/-1;text-align:center;">Sin categorías disponibles</p>';
        return;
    }
    grid.innerHTML = srCatalog.map(cat => `
        <div class="cat-card" onclick="selectCategory('${cat.id}','${escAttr(cat.name)}')">
          <div class="cat-icon"><i class="bi bi-${cat.icon || 'folder'}"></i></div>
          <div class="cat-name">${escHtml(cat.name)}</div>
          <div class="cat-desc">${escHtml(cat.description || '')}</div>
        </div>`).join('');
}

function selectCategory(catId, catName) {
    document.querySelector('#catalogGrid .selected')?.classList.remove('selected');
    document.querySelector(`#catalogGrid [onclick*="${catId}"]`)?.classList.add('selected');

    const cat = srCatalog.find(c => c.id === catId);
    const svcs = cat?.servicios || [];
    const sel  = document.getElementById('srServiceId');
    sel.innerHTML = '<option value="">— Seleccionar servicio —</option>' +
        svcs.map(s => `<option value="${s.id}">${escHtml(s.name)}</option>`).join('');

    document.getElementById('step1').style.display = 'none';
    document.getElementById('step2').style.display = 'block';
    document.getElementById('modalFtr').style.display = 'flex';
}

function backStep() {
    document.getElementById('step1').style.display = 'block';
    document.getElementById('step2').style.display = 'none';
    document.getElementById('modalFtr').style.display = 'none';
}

async function crearSolicitud() {
    const title = document.getElementById('srTitle').value.trim();
    if (!title) return alert('El título es requerido');
    const body = {
        title,
        description: document.getElementById('srDesc').value,
        serviceId:   document.getElementById('srServiceId').value || null,
        priority:    document.getElementById('srPriority').value,
        dueDate:     document.getElementById('srDue').value || null,
    };
    const res = await fetch('/api/service-requests', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    const d = await res.json();
    if (!d.success) return alert(d.error);
    closeModal('modalNueva');
    loadSolicitudes();
    loadKpis();
}

async function aprobar(id, decision) {
    const res = await fetch(`/api/service-requests/${id}/approve`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ decision }),
    });
    const d = await res.json();
    if (!d.success) return alert(d.error);
    loadSolicitudes(srPage);
    loadKpis();
}

function verSolicitud(id) {
    window.open(`/api/service-requests/${id}`, '_blank');
}

function filterStatus(s) {
    document.getElementById('fStatus').value = s;
    loadSolicitudes();
}

function openModal(id) {
    document.getElementById(id).classList.add('open');
    if (id === 'modalNueva') {
        document.getElementById('step1').style.display = 'block';
        document.getElementById('step2').style.display = 'none';
        document.getElementById('modalFtr').style.display = 'none';
        loadCatalog();
    }
}
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function renderPagination(containerId, pages, current, cb) {
    const c = document.getElementById(containerId);
    if (pages <= 1) { c.innerHTML = ''; return; }
    let html = '';
    for (let i = 1; i <= Math.min(pages, 7); i++) {
        html += `<div class="page-btn ${i===current?'active':''}" onclick="(${cb})(${i})">${i}</div>`;
    }
    c.innerHTML = html;
}

function fmtStatus(s) {
    return { borrador:'Borrador', pendiente_aprobacion:'Pendiente aprobación',
             aprobado:'Aprobado', en_proceso:'En proceso', completado:'Completado',
             rechazado:'Rechazado', cancelado:'Cancelado' }[s] || s;
}
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('es', { day:'2-digit', month:'short', year:'numeric' }) : '—'; }
function escHtml(t) { return String(t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function escAttr(t) { return String(t||'').replace(/'/g,"\\'"); }

function toggleTheme() {
    const html = document.documentElement;
    html.setAttribute('data-theme', html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
}

loadSolicitudes();
loadKpis();
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
