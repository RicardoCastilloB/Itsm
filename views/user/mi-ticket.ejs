<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mi Ticket</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link rel="stylesheet" href="<%= APP_URL %>/css/base.css">
<link rel="stylesheet" href="<%= APP_URL %>/css/ticket.css">
<link rel="stylesheet" href="<%= APP_URL %>/css/forms.css">
<style>
body{background:var(--c-bg,#f0f4f8);color:var(--c-text,#1e293b);font-family:'DM Sans',sans-serif;}
.pg{max-width:900px;margin:0 auto;padding:80px 20px 40px;}
.ticket-header{background:var(--c-card,#fff);border:1px solid var(--c-border,#e2e8f0);border-radius:16px;padding:24px 28px;margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,.06);}
.ticket-id{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--c-muted,#64748b);margin-bottom:4px;}
.ticket-title{font-size:20px;font-weight:800;margin-bottom:12px;}
.ticket-badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
.meta-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;}
.meta-item{display:flex;flex-direction:column;gap:2px;}
.meta-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--c-muted,#64748b);}
.meta-value{font-size:13px;font-weight:600;}

/* Timeline */
.timeline{margin-bottom:20px;}
.timeline-item{display:flex;gap:12px;padding:12px 0;}
.timeline-item::before{content:'';position:absolute;left:17px;top:0;bottom:-12px;width:1px;background:var(--c-border,#e2e8f0);}
.timeline-wrap{position:relative;padding-left:40px;}
.tl-dot{position:absolute;left:0;width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;z-index:1;top:8px;}
.tl-dot--comment{background:#dbeafe;color:#1d4ed8;}
.tl-dot--system {background:var(--c-hover,#f1f5f9);color:var(--c-muted,#64748b);}
.tl-dot--status {background:#d1fae5;color:#065f46;}
.tl-body{background:var(--c-card,#fff);border:1px solid var(--c-border,#e2e8f0);border-radius:12px;padding:14px 16px;flex:1;}
.tl-meta{display:flex;gap:8px;align-items:center;margin-bottom:6px;flex-wrap:wrap;}
.tl-author{font-size:12px;font-weight:700;}
.tl-time{font-size:11px;color:var(--c-muted,#64748b);}
.tl-text{font-size:13px;white-space:pre-wrap;word-break:break-word;color:var(--c-text,#1e293b);}
.tl-system .tl-text{color:var(--c-muted,#64748b);font-style:italic;font-size:12px;}

/* Adjunto */
.attachment{display:inline-flex;align-items:center;gap:6px;padding:6px 12px;background:var(--c-hover,#f1f5f9);border:1px solid var(--c-border,#e2e8f0);border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;color:var(--c-text,#1e293b);transition:all .15s;}
.attachment:hover{background:var(--c-primary,#3b82f6);color:#fff;border-color:var(--c-primary,#3b82f6);}

/* Badge helpers */
.sb{display:inline-flex;align-items:center;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;gap:4px;}
.sb::before{content:'';width:6px;height:6px;border-radius:50%;background:currentColor;opacity:.8;}
.sb-open    {background:#dbeafe;color:#1d4ed8;}
.sb-prog    {background:#ede9fe;color:#5b21b6;}
.sb-pend    {background:#fef3c7;color:#92400e;}
.sb-done    {background:#d1fae5;color:#065f46;}
.sb-closed  {background:#f1f5f9;color:#475569;}
.pb{display:inline-flex;align-items:center;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;}
.pb-P1{background:#fee2e2;color:#991b1b;} .pb-P2{background:#ffedd5;color:#9a3412;}
.pb-P3{background:#fef3c7;color:#92400e;} .pb-P4{background:#f1f5f9;color:#475569;}

/* Panel comentario */
.comment-panel{background:var(--c-card,#fff);border:1px solid var(--c-border,#e2e8f0);border-radius:16px;padding:20px 24px;box-shadow:0 1px 4px rgba(0,0,0,.06);}
.comment-panel h3{font-size:14px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:6px;}

/* SLA banner */
.sla-banner{padding:12px 18px;border-radius:10px;font-size:13px;font-weight:600;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.sla-banner--risk  {background:#fef3c7;color:#92400e;border:1px solid #fcd34d;}
.sla-banner--breach{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;}

/* Encuesta */
.survey-inline{background:linear-gradient(135deg,#d1fae5,#a7f3d0);border:1px solid #6ee7b7;border-radius:14px;padding:20px;text-align:center;margin-bottom:20px;}
[data-theme="dark"] .survey-inline{background:linear-gradient(135deg,#064e3b,#065f46);border-color:#065f46;color:#d1fae5;}
.stars-inline{display:flex;justify-content:center;gap:8px;margin:12px 0;}
.star-inline{font-size:28px;cursor:pointer;transition:transform .1s;filter:grayscale(1) opacity(.4);background:none;border:none;user-select:none;}
.star-inline.active,.star-inline:hover{filter:none;transform:scale(1.15);}
</style>
</head>
<body>
<%- include('../partials/sidebar_top') %>
<%- include('../partials/styles_sidebar') %>

<div class="pg">
  <%- include('../partials/breadcrumb', { crumbs: [
    { label: 'Portal', href: APP_URL + '/portal', icon: 'bi bi-house' },
    { label: 'Mis tickets', href: APP_URL + '/portal/tickets' },
    { label: 'Ticket #' + ticketId.slice(-6) }
  ]}) %>

  <!-- Encuesta si el ticket está resuelto y no ha sido valorado -->
  <div id="surveySection" style="display:none"></div>

  <!-- Ticket header -->
  <div class="ticket-header" id="ticketHeader">
    <div style="text-align:center;padding:20px;color:var(--c-muted,#64748b)"><i class="bi bi-arrow-repeat" style="animation:spin .8s linear infinite;font-size:24px;display:block;margin-bottom:8px"></i>Cargando ticket...</div>
  </div>

  <!-- Timeline -->
  <div class="comment-panel" style="margin-bottom:20px;">
    <h3><i class="bi bi-chat-dots" style="opacity:.6"></i> Historial y comentarios</h3>
    <div id="timelineWrap" class="timeline-wrap">
      <div style="text-align:center;padding:20px;color:var(--c-muted,#64748b);font-size:13px">Cargando...</div>
    </div>
  </div>

  <!-- Añadir comentario -->
  <div class="comment-panel" id="commentPanel">
    <h3><i class="bi bi-reply" style="opacity:.6"></i> Agregar comentario</h3>
    <textarea id="commentText" class="form__textarea" rows="3" placeholder="Escribe un comentario o información adicional…"></textarea>
    <div style="margin-top:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <label style="font-size:12px;font-weight:600;color:var(--c-muted,#64748b);cursor:pointer;display:flex;align-items:center;gap:6px;">
        <input type="file" id="attachFile" style="display:none" accept="image/*,.pdf,.doc,.docx">
        <i class="bi bi-paperclip"></i> Adjuntar archivo
      </label>
      <span id="attachName" style="font-size:11px;color:var(--c-muted,#64748b)"></span>
      <button onclick="submitComment()" style="margin-left:auto;background:var(--c-primary,#3b82f6);color:#fff;border:none;border-radius:8px;padding:9px 18px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;">
        <i class="bi bi-send"></i> Enviar
      </button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
const APP_URL  = '<%= APP_URL %>';
const TICKET_ID = '<%= ticketId %>';
let surveyRating = 0;
let ticket = null;

document.addEventListener('DOMContentLoaded', () => {
  loadTicket();
  document.getElementById('attachFile').addEventListener('change', function() {
    document.getElementById('attachName').textContent = this.files[0]?.name || '';
  });
});

async function loadTicket() {
  try {
    const r = await fetch(APP_URL + '/api/itsm/tickets/' + TICKET_ID).then(r => r.json());
    if (!r.success) { document.getElementById('ticketHeader').innerHTML = '<p style="color:var(--c-danger,#ef4444);text-align:center;padding:20px">Ticket no encontrado</p>'; return; }
    ticket = r.data;
    renderHeader(ticket);
    renderTimeline(ticket.comentarios || [], ticket.adjuntos || []);
    checkSurvey(ticket);
    if (['resuelto','cerrado'].includes(ticket.status)) {
      document.getElementById('commentPanel').style.opacity = '.5';
      document.getElementById('commentPanel').title = 'Ticket cerrado — no se pueden añadir comentarios';
    }
  } catch(e) {
    document.getElementById('ticketHeader').innerHTML = '<p style="color:var(--c-danger,#ef4444);text-align:center;padding:20px">Error cargando ticket</p>';
  }
}

function statusClass(s) {
  const m = { abierto:'sb-open', en_progreso:'sb-prog', pendiente:'sb-pend', resuelto:'sb-done', cerrado:'sb-closed' };
  return m[s] || 'sb-closed';
}
function statusLabel(s) {
  const m = { abierto:'Abierto', en_progreso:'En progreso', pendiente:'Pendiente', resuelto:'Resuelto', cerrado:'Cerrado' };
  return m[s] || s;
}

function renderHeader(t) {
  let slaBanner = '';
  if (t.slaStatus === 'riesgo')  slaBanner = `<div class="sla-banner sla-banner--risk"><i class="bi bi-exclamation-triangle-fill"></i> Tu ticket está próximo a vencer el SLA. Un agente se pondrá en contacto pronto.</div>`;
  if (t.slaStatus === 'vencido') slaBanner = `<div class="sla-banner sla-banner--breach"><i class="bi bi-alarm-fill"></i> El plazo de atención de este ticket ha vencido. Estamos trabajando en ello.</div>`;
  document.getElementById('ticketHeader').innerHTML = `
    ${slaBanner}
    <div class="ticket-id">Ticket #${t.id}</div>
    <div class="ticket-title">${t.titulo}</div>
    <div class="ticket-badges">
      <span class="sb ${statusClass(t.status)}">${statusLabel(t.status)}</span>
      <span class="pb pb-${t.priority}">${t.priority}</span>
      ${t.categoria ? `<span style="background:var(--c-hover,#f1f5f9);border:1px solid var(--c-border,#e2e8f0);padding:3px 10px;border-radius:999px;font-size:11px;font-weight:600">${t.categoria.nombre}</span>` : ''}
    </div>
    ${t.descripcion ? `<div style="font-size:13px;color:var(--c-muted,#64748b);background:var(--c-hover,#f1f5f9);border-radius:10px;padding:12px 14px;margin-bottom:16px;white-space:pre-wrap">${t.descripcion}</div>` : ''}
    <div class="meta-grid">
      <div class="meta-item"><span class="meta-label">Creado</span><span class="meta-value">${new Date(t.createdAt).toLocaleDateString('es',{day:'numeric',month:'long',year:'numeric'})}</span></div>
      ${t.slaDueAt ? `<div class="meta-item"><span class="meta-label">Plazo SLA</span><span class="meta-value">${new Date(t.slaDueAt).toLocaleDateString('es',{day:'numeric',month:'long',hour:'2-digit',minute:'2-digit'})}</span></div>` : ''}
      ${t.resolvedAt ? `<div class="meta-item"><span class="meta-label">Resuelto</span><span class="meta-value">${new Date(t.resolvedAt).toLocaleDateString('es',{day:'numeric',month:'long',year:'numeric'})}</span></div>` : ''}
      <div class="meta-item"><span class="meta-label">Tipo</span><span class="meta-value" style="text-transform:capitalize">${t.tipo}</span></div>
    </div>`;
}

function renderTimeline(comments, attachments) {
  const wrap = document.getElementById('timelineWrap');
  if (!comments.length && !attachments.length) {
    wrap.innerHTML = '<p style="font-size:13px;color:var(--c-muted,#64748b);text-align:center;padding:16px">Sin actividad aún</p>';
    return;
  }
  const isSystem = t => ['cambio_estado','asignacion','sistema'].includes(t);
  wrap.innerHTML = comments.map(c => {
    const sys = isSystem(c.tipo);
    return `<div style="position:relative;padding-left:44px;margin-bottom:12px;">
      <div class="tl-dot ${sys ? 'tl-dot--system' : 'tl-dot--comment'}">
        ${sys ? '<i class="bi bi-info-circle"></i>' : '<i class="bi bi-chat-text"></i>'}
      </div>
      <div style="position:absolute;left:16px;top:42px;bottom:-12px;width:1px;background:var(--c-border,#e2e8f0)"></div>
      <div class="tl-body ${sys ? 'tl-system' : ''}">
        <div class="tl-meta">
          <span class="tl-author">${sys ? '⚙ Sistema' : '👤 ' + (c.userId || 'Agente')}</span>
          <span class="tl-time">${new Date(c.createdAt).toLocaleString('es',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}</span>
        </div>
        <div class="tl-text">${c.contenido}</div>
      </div>
    </div>`;
  }).join('') + (attachments.length ? `
    <div style="margin-top:12px;"><div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--c-muted,#64748b);margin-bottom:8px">Archivos adjuntos</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">${attachments.map(a => `<a href="${APP_URL}/uploads/tickets/${a.filename}" target="_blank" class="attachment"><i class="bi bi-paperclip"></i>${a.original}</a>`).join('')}</div></div>` : '');
}

async function submitComment() {
  if (['resuelto','cerrado'].includes(ticket?.status)) return;
  const text = document.getElementById('commentText').value.trim();
  if (!text) return;
  const fd = new FormData();
  fd.append('contenido', text);
  fd.append('tipo', 'comentario');
  const file = document.getElementById('attachFile').files[0];
  if (file) fd.append('file', file);
  try {
    const r = await fetch(APP_URL + '/api/itsm/tickets/' + TICKET_ID + '/comments', { method: 'POST', body: fd }).then(r => r.json());
    if (r.success) {
      document.getElementById('commentText').value = '';
      document.getElementById('attachName').textContent = '';
      document.getElementById('attachFile').value = '';
      loadTicket();
    }
  } catch(e) {}
}

function checkSurvey(t) {
  if (!['resuelto','cerrado'].includes(t.status)) return;
  if (t.survey) return; // ya respondida
  const sec = document.getElementById('surveySection');
  sec.style.display = 'block';
  sec.innerHTML = `<div class="survey-inline">
    <div style="font-size:22px;margin-bottom:6px">⭐</div>
    <div style="font-weight:800;font-size:15px;margin-bottom:4px">¿Cómo calificarías la atención?</div>
    <div style="font-size:12px;opacity:.8;margin-bottom:10px">Tu ticket fue resuelto. Tu opinión ayuda a mejorar el servicio.</div>
    <div class="stars-inline" id="inlinestars">
      ${[1,2,3,4,5].map(v => `<button class="star-inline" data-val="${v}" onclick="rateInline(${v})">${['😞','😕','😐','😊','🤩'][v-1]}</button>`).join('')}
    </div>
    <textarea id="inlineSurveyComment" class="survey-comment" style="background:rgba(255,255,255,.5);font-family:DM Sans,sans-serif;" placeholder="Comentario opcional…"></textarea>
    <button onclick="submitInlineSurvey()" style="background:#10b981;color:#fff;border:none;border-radius:10px;padding:9px 24px;font-weight:700;font-size:13px;cursor:pointer;">Enviar valoración</button>
    <button onclick="document.getElementById('surveySection').remove()" style="background:none;border:none;font-size:12px;color:rgba(0,0,0,.5);cursor:pointer;margin-left:8px;">Saltar</button>
  </div>`;
}

function rateInline(v) {
  surveyRating = v;
  document.querySelectorAll('.star-inline').forEach((b,i) => b.classList.toggle('active', i < v));
}

async function submitInlineSurvey() {
  if (!surveyRating) { alert('Selecciona una calificación'); return; }
  const comment = document.getElementById('inlineSurveyComment').value.trim();
  await fetch(APP_URL + '/api/portal/survey', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ticketId: TICKET_ID, rating: surveyRating, comment })
  });
  document.getElementById('surveySection').remove();
}

@keyframes spin { to { transform: rotate(360deg); } }
</script>
</body>
</html>
