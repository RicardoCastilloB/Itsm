<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gestión de Cambios</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<style>
:root,[data-theme="light"]{
    --bg:#f0f4f8;--card:#fff;--hdr:#f8fafc;--border:#e2e8f0;
    --text:#1e293b;--muted:#64748b;--primary:#3b82f6;--success:#10b981;
    --warning:#f59e0b;--info:#06b6d4;--danger:#ef4444;--purple:#8b5cf6;
    --hover:#f1f5f9;--sh-sm:0 1px 3px rgba(0,0,0,.06);--sh-md:0 4px 12px rgba(0,0,0,.08);
}
[data-theme="dark"]{
    --bg:#0f172a;--card:#1e293b;--hdr:#162032;--border:#2d3f55;
    --text:#e2e8f0;--muted:#94a3b8;--primary:#60a5fa;--success:#34d399;
    --warning:#fbbf24;--info:#22d3ee;--danger:#f87171;--purple:#a78bfa;
    --hover:#243348;
}
*{box-sizing:border-box;}
body{margin:0;background:var(--bg);color:var(--text);font-family:'DM Sans',-apple-system,sans-serif;}
.pg{max-width:1700px;margin:0 auto;padding:24px 20px;}
.page-hdr{display:flex;align-items:center;gap:16px;margin-bottom:28px;}
.page-hdr-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;box-shadow:0 4px 12px rgba(0,0,0,.08);}
.page-hdr h1{font-size:22px;font-weight:800;margin:0;}
.page-hdr p{margin:3px 0 0;font-size:13px;color:var(--muted);}
.page-hdr-right{margin-left:auto;display:flex;gap:8px;align-items:center;}
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px;}
@media(max-width:900px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 18px;display:flex;justify-content:space-between;align-items:center;box-shadow:0 1px 3px rgba(0,0,0,.06);cursor:pointer;position:relative;overflow:hidden;transition:all .2s;}
.kpi::before{content:'';position:absolute;inset:0;background:var(--kc);opacity:0;transition:opacity .2s;}
.kpi:hover::before,.kpi.active::before{opacity:.06;}
.kpi.active{border-color:var(--kc)!important;box-shadow:0 0 0 2px var(--kc)!important;}
.kpi-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin-bottom:5px;}
.kpi-val{font-size:28px;font-weight:800;line-height:1;color:var(--kc);}
.kpi-icon{font-size:32px;opacity:.18;color:var(--kc);}
.card-ui{background:var(--card);border:1px solid var(--border);border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);overflow:hidden;margin-bottom:20px;}
.card-head{padding:13px 18px;background:var(--hdr);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.card-head .title{font-size:13px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px;}
.tbl-wrap{overflow:auto;max-height:540px;}
.tbl{width:100%;border-collapse:collapse;font-size:13px;}
.tbl thead th{background:var(--hdr);color:var(--muted);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;padding:11px 14px;border-bottom:1px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;}
.tbl tbody tr{border-bottom:1px solid var(--border);transition:background .15s;cursor:pointer;}
.tbl tbody tr:hover{background:var(--hover);}
.tbl td{padding:11px 14px;vertical-align:middle;}
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.risk-bajo{background:#d1fae5;color:#059669;}
.risk-medio{background:#fef3c7;color:#d97706;}
.risk-alto{background:#fee2e2;color:#dc2626;}
.risk-critico{background:#fce7f3;color:#be185d;}
.type-normal{background:#dbeafe;color:#2563eb;}
.type-estandar{background:#d1fae5;color:#059669;}
.type-emergencia{background:#fee2e2;color:#dc2626;}
.s-borrador{background:#f1f5f9;color:#64748b;}
.s-pendiente_aprobacion{background:#fef3c7;color:#d97706;}
.s-aprobado{background:#d1fae5;color:#059669;}
.s-en_implementacion{background:#dbeafe;color:#2563eb;}
.s-implementado{background:#d1fae5;color:#059669;}
.s-fallido{background:#fee2e2;color:#dc2626;}
.s-cancelado{background:#f1f5f9;color:#94a3b8;}
.s-revisado{background:#ede9fe;color:#7c3aed;}
.btn-sm{padding:6px 14px;font-size:12px;font-weight:600;border-radius:8px;border:none;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--primary);color:#fff;}
.btn-primary:hover{opacity:.88;}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--muted);}
.btn-outline:hover{background:var(--hover);}
.form-ctrl{width:100%;border:1px solid var(--border);border-radius:8px;padding:9px 12px;font-size:13px;background:var(--card);color:var(--text);outline:none;transition:border .15s;}
.form-ctrl:focus{border-color:var(--primary);}
.form-group{margin-bottom:14px;}
.form-lbl{font-size:12px;font-weight:700;color:var(--muted);margin-bottom:5px;display:block;}
.modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal-box{background:var(--card);border-radius:20px;width:640px;max-width:95vw;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 60px rgba(0,0,0,.25);transform:translateY(20px);transition:transform .2s;}
.modal-overlay.open .modal-box{transform:translateY(0);}
.modal-hdr{padding:20px 24px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.modal-hdr h3{margin:0;font-size:16px;font-weight:800;}
.modal-body{padding:20px 24px;overflow-y:auto;flex:1;}
.modal-ftr{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;}
.pagination{display:flex;gap:4px;align-items:center;justify-content:flex-end;padding:12px 18px;border-top:1px solid var(--border);}
.page-btn{width:32px;height:32px;border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;background:var(--card);color:var(--text);transition:all .15s;}
.page-btn:hover,.page-btn.active{background:var(--primary);color:#fff;border-color:var(--primary);}
.empty-state{text-align:center;padding:60px 20px;color:var(--muted);}
.theme-toggle{background:none;border:1px solid var(--border);border-radius:8px;padding:6px 10px;cursor:pointer;color:var(--text);font-size:16px;}
.search-bar{display:flex;gap:8px;flex-wrap:wrap;}
</style>
</head>
<body>
<div class="pg">
  <div class="page-hdr">
    <div class="page-hdr-icon" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
      <i class="bi bi-arrow-left-right" style="color:#fff;"></i>
    </div>
    <div>
      <h1>Gestión de Cambios</h1>
      <p>Control de cambios en infraestructura y servicios TI (CAB)</p>
    </div>
    <div class="page-hdr-right">
      <button class="theme-toggle" onclick="toggleTheme()"><i class="bi bi-moon-stars-fill"></i></button>
      <button class="btn-sm btn-primary" onclick="openModal()">
        <i class="bi bi-plus-lg"></i> Nuevo Cambio
      </button>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpi-grid">
    <div class="kpi" style="--kc:var(--primary)">
      <div><div class="kpi-label">Activos</div><div class="kpi-val" id="kpiActivos">—</div></div>
      <i class="bi bi-arrow-repeat kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--warning)">
      <div><div class="kpi-label">Pendiente CAB</div><div class="kpi-val" id="kpiPendientes">—</div></div>
      <i class="bi bi-people kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--success)">
      <div><div class="kpi-label">Implementados</div><div class="kpi-val" id="kpiImpl">—</div></div>
      <i class="bi bi-check2-circle kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--danger)">
      <div><div class="kpi-label">Emergencias</div><div class="kpi-val" id="kpiEmerg">—</div></div>
      <i class="bi bi-lightning kpi-icon"></i>
    </div>
  </div>

  <!-- TABLE -->
  <div class="card-ui">
    <div class="card-head">
      <span class="title"><i class="bi bi-list-ul"></i> Registro de Cambios</span>
      <div class="search-bar">
        <select id="fStatus" class="form-ctrl" style="width:180px;" onchange="loadCambios()">
          <option value="">Todos los estados</option>
          <option value="borrador">Borrador</option>
          <option value="pendiente_aprobacion">Pendiente aprobación</option>
          <option value="aprobado">Aprobado</option>
          <option value="en_implementacion">En implementación</option>
          <option value="implementado">Implementado</option>
          <option value="fallido">Fallido</option>
          <option value="cancelado">Cancelado</option>
          <option value="revisado">Revisado</option>
        </select>
        <select id="fType" class="form-ctrl" style="width:130px;" onchange="loadCambios()">
          <option value="">Tipo</option>
          <option value="normal">Normal</option>
          <option value="estandar">Estándar</option>
          <option value="emergencia">Emergencia</option>
        </select>
        <select id="fRisk" class="form-ctrl" style="width:120px;" onchange="loadCambios()">
          <option value="">Riesgo</option>
          <option value="bajo">Bajo</option>
          <option value="medio">Medio</option>
          <option value="alto">Alto</option>
          <option value="critico">Crítico</option>
        </select>
      </div>
    </div>
    <div class="tbl-wrap">
      <table class="tbl">
        <thead>
          <tr>
            <th>N° Cambio</th><th>Título</th><th>Tipo</th><th>Riesgo</th>
            <th>Estado</th><th>Inicio planif.</th><th>Fin planif.</th><th>Acciones</th>
          </tr>
        </thead>
        <tbody id="chBody">
          <tr><td colspan="8"><div class="empty-state"><i class="bi bi-arrow-clockwise"></i> Cargando...</div></td></tr>
        </tbody>
      </table>
    </div>
    <div class="pagination" id="chPagination"></div>
  </div>
</div>

<!-- MODAL NUEVO CAMBIO -->
<div class="modal-overlay" id="modalCambio">
  <div class="modal-box">
    <div class="modal-hdr">
      <h3><i class="bi bi-arrow-left-right" style="color:var(--warning)"></i> Nuevo Cambio</h3>
      <button class="btn-sm btn-outline" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-lbl">Título *</label>
        <input type="text" id="chTitle" class="form-ctrl" placeholder="Ej: Actualización MySQL 8.0">
      </div>
      <div class="form-group">
        <label class="form-lbl">Descripción</label>
        <textarea id="chDesc" class="form-ctrl" rows="3" placeholder="Justificación y alcance del cambio..."></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-lbl">Tipo</label>
          <select id="chType" class="form-ctrl">
            <option value="normal">Normal</option>
            <option value="estandar">Estándar</option>
            <option value="emergencia">Emergencia</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-lbl">Prioridad</label>
          <select id="chPriority" class="form-ctrl">
            <option value="baja">Baja</option>
            <option value="media" selected>Media</option>
            <option value="alta">Alta</option>
            <option value="critica">Crítica</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-lbl">Riesgo</label>
          <select id="chRisk" class="form-ctrl">
            <option value="bajo">Bajo</option>
            <option value="medio" selected>Medio</option>
            <option value="alto">Alto</option>
            <option value="critico">Crítico</option>
          </select>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-lbl">Inicio planificado</label>
          <input type="datetime-local" id="chStart" class="form-ctrl">
        </div>
        <div class="form-group">
          <label class="form-lbl">Fin planificado</label>
          <input type="datetime-local" id="chEnd" class="form-ctrl">
        </div>
      </div>
      <div class="form-group">
        <label class="form-lbl">Plan de rollback</label>
        <textarea id="chRollback" class="form-ctrl" rows="2" placeholder="Pasos para revertir el cambio si falla..."></textarea>
      </div>
      <div class="form-group">
        <label class="form-lbl">Plan de pruebas</label>
        <textarea id="chTest" class="form-ctrl" rows="2" placeholder="Cómo se verificará el éxito del cambio..."></textarea>
      </div>
    </div>
    <div class="modal-ftr">
      <button class="btn-sm btn-outline" onclick="closeModal()">Cancelar</button>
      <button class="btn-sm btn-primary" onclick="crearCambio()">
        <i class="bi bi-send"></i> Crear Cambio
      </button>
    </div>
  </div>
</div>

<script>
let chPage = 1;

async function loadKpis() {
    try {
        const res = await fetch('/api/changes/kpis');
        const d = await res.json();
        if (!d.success) return;
        document.getElementById('kpiActivos').textContent   = d.data.activos    ?? '—';
        document.getElementById('kpiPendientes').textContent= d.data.pendientes  ?? '—';
        document.getElementById('kpiImpl').textContent      = d.data.implementados ?? '—';
        document.getElementById('kpiEmerg').textContent     = d.data.emergencias ?? '—';
    } catch {}
}

async function loadCambios(page = 1) {
    chPage = page;
    const params = new URLSearchParams({ page, limit: 20 });
    const s = document.getElementById('fStatus').value;
    const t = document.getElementById('fType').value;
    const r = document.getElementById('fRisk').value;
    if (s) params.set('status', s);
    if (t) params.set('type', t);
    if (r) params.set('risk', r);

    const res = await fetch(`/api/changes?${params}`);
    const d   = await res.json();
    const rows = d.data || [];
    const tbody = document.getElementById('chBody');

    if (!rows.length) {
        tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><i class="bi bi-inbox"></i> Sin cambios</div></td></tr>`;
        document.getElementById('chPagination').innerHTML = '';
        return;
    }

    tbody.innerHTML = rows.map(ch => `
        <tr>
          <td><span style="font-family:monospace;font-size:12px;font-weight:700;color:var(--primary)">${esc(ch.changeNumber)}</span></td>
          <td><strong>${esc(ch.title)}</strong></td>
          <td><span class="badge type-${ch.type}">${ch.type}</span></td>
          <td><span class="badge risk-${ch.riskLevel}">${ch.riskLevel}</span></td>
          <td><span class="badge s-${ch.status}">${fmtStatus(ch.status)}</span></td>
          <td>${fmtDate(ch.plannedStart)}</td>
          <td>${fmtDate(ch.plannedEnd)}</td>
          <td>
            <select class="form-ctrl" style="width:140px;padding:4px 8px;font-size:12px;"
              onchange="cambiarEstado('${ch.id}', this.value)">
              <option value="">— Estado —</option>
              <option value="aprobado">Aprobar (CAB)</option>
              <option value="en_implementacion">Iniciar</option>
              <option value="implementado">Implementado</option>
              <option value="fallido">Fallido</option>
              <option value="cancelado">Cancelar</option>
              <option value="revisado">Revisado</option>
            </select>
          </td>
        </tr>`).join('');

    const pages = Math.ceil((d.total || rows.length) / 20);
    renderPagination(pages, page);
}

async function crearCambio() {
    const title = document.getElementById('chTitle').value.trim();
    if (!title) return alert('Título requerido');
    const body = {
        title,
        description:  document.getElementById('chDesc').value,
        type:         document.getElementById('chType').value,
        priority:     document.getElementById('chPriority').value,
        riskLevel:    document.getElementById('chRisk').value,
        plannedStart: document.getElementById('chStart').value || null,
        plannedEnd:   document.getElementById('chEnd').value   || null,
        rollbackPlan: document.getElementById('chRollback').value,
        testPlan:     document.getElementById('chTest').value,
    };
    const res = await fetch('/api/changes', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    const d = await res.json();
    if (!d.success) return alert(d.error);
    closeModal();
    loadCambios();
    loadKpis();
}

async function cambiarEstado(id, status) {
    if (!status) return;
    const res = await fetch(`/api/changes/${id}`, {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status }),
    });
    const d = await res.json();
    if (!d.success) return alert(d.error);
    loadCambios(chPage);
    loadKpis();
}

function renderPagination(pages, current) {
    const c = document.getElementById('chPagination');
    if (pages <= 1) { c.innerHTML = ''; return; }
    c.innerHTML = Array.from({ length: Math.min(pages, 7) }, (_, i) => i + 1)
        .map(i => `<div class="page-btn ${i===current?'active':''}" onclick="loadCambios(${i})">${i}</div>`)
        .join('');
}

function fmtStatus(s) {
    const m = { borrador:'Borrador', pendiente_aprobacion:'Pend. Aprobación', aprobado:'Aprobado',
                en_implementacion:'En implementación', implementado:'Implementado',
                fallido:'Fallido', cancelado:'Cancelado', revisado:'Revisado' };
    return m[s] || s;
}
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('es', { day:'2-digit', month:'short', year:'numeric' }) : '—'; }
function esc(t) { return String(t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;'); }

function openModal()  { document.getElementById('modalCambio').classList.add('open'); }
function closeModal() { document.getElementById('modalCambio').classList.remove('open'); }
function toggleTheme() {
    const h = document.documentElement;
    h.setAttribute('data-theme', h.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
}

loadCambios();
loadKpis();
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
