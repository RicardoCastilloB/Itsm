<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mejora Continua (CSI)</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root,[data-theme="light"]{
  --bg:#f0f4f8;--card:#fff;--hdr:#f8fafc;--border:#e2e8f0;
  --text:#1e293b;--muted:#64748b;--primary:#3b82f6;--success:#10b981;
  --warning:#f59e0b;--danger:#ef4444;--purple:#8b5cf6;--info:#06b6d4;
  --hover:#f1f5f9;--sh-sm:0 1px 3px rgba(0,0,0,.06);--sh-md:0 4px 12px rgba(0,0,0,.08);
}
[data-theme="dark"]{
  --bg:#0f172a;--card:#1e293b;--hdr:#162032;--border:#2d3f55;
  --text:#e2e8f0;--muted:#94a3b8;--primary:#60a5fa;--success:#34d399;
  --warning:#fbbf24;--danger:#f87171;--purple:#a78bfa;--info:#22d3ee;--hover:#243348;
}
*{box-sizing:border-box;}
body{margin:0;background:var(--bg);color:var(--text);font-family:'DM Sans',-apple-system,sans-serif;}
.pg{max-width:1700px;margin:0 auto;padding:24px 20px;}
.page-hdr{display:flex;align-items:center;gap:16px;margin-bottom:28px;}
.page-hdr-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;box-shadow:var(--sh-md);}
.page-hdr h1{font-size:22px;font-weight:800;margin:0;}
.page-hdr p{margin:3px 0 0;font-size:13px;color:var(--muted);}
.page-hdr-right{margin-left:auto;display:flex;gap:8px;align-items:center;}
.kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px;}
@media(max-width:1000px){.kpi-grid{grid-template-columns:repeat(3,1fr);}}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;display:flex;justify-content:space-between;align-items:center;box-shadow:var(--sh-sm);position:relative;overflow:hidden;}
.kpi::before{content:'';position:absolute;inset:0;background:var(--kc);opacity:.04;}
.kpi-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin-bottom:4px;}
.kpi-val{font-size:24px;font-weight:800;line-height:1;color:var(--kc);}
.kpi-icon{font-size:28px;opacity:.18;color:var(--kc);}
.two-col{display:grid;grid-template-columns:1fr 380px;gap:16px;}
@media(max-width:1100px){.two-col{grid-template-columns:1fr;}}
.card-ui{background:var(--card);border:1px solid var(--border);border-radius:14px;box-shadow:var(--sh-sm);overflow:hidden;margin-bottom:16px;}
.card-head{padding:13px 18px;background:var(--hdr);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.card-head .title{font-size:13px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px;}
.csi-item{padding:16px 18px;border-bottom:1px solid var(--border);transition:background .15s;}
.csi-item:last-child{border-bottom:none;}
.csi-item:hover{background:var(--hover);}
.csi-title{font-weight:700;font-size:14px;margin-bottom:5px;}
.csi-meta{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:6px;}
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;}
.st-propuesta{background:#dbeafe;color:#2563eb;}
.st-en_progreso{background:#fef3c7;color:#d97706;}
.st-completada{background:#d1fae5;color:#059669;}
.st-cancelada{background:#f1f5f9;color:#94a3b8;}
.pri-baja{background:#d1fae5;color:#059669;}
.pri-media{background:#fef3c7;color:#d97706;}
.pri-alta{background:#fee2e2;color:#dc2626;}
.pri-critica{background:#fce7f3;color:#be185d;}
.progress-bar-wrap{height:8px;background:var(--border);border-radius:4px;overflow:hidden;margin-top:6px;}
.progress-bar-fill{height:100%;border-radius:4px;background:var(--primary);transition:width .5s;}
.btn-sm{padding:6px 14px;font-size:12px;font-weight:600;border-radius:8px;border:none;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--primary);color:#fff;}
.btn-primary:hover{opacity:.88;}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--muted);}
.btn-outline:hover{background:var(--hover);}
.form-ctrl{width:100%;border:1px solid var(--border);border-radius:8px;padding:9px 12px;font-size:13px;background:var(--card);color:var(--text);outline:none;}
.form-ctrl:focus{border-color:var(--primary);}
.form-group{margin-bottom:14px;}
.form-lbl{font-size:12px;font-weight:700;color:var(--muted);margin-bottom:5px;display:block;}
.modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal-box{background:var(--card);border-radius:20px;width:600px;max-width:95vw;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 60px rgba(0,0,0,.25);transform:translateY(20px);transition:transform .2s;}
.modal-overlay.open .modal-box{transform:translateY(0);}
.modal-hdr{padding:20px 24px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.modal-hdr h3{margin:0;font-size:16px;font-weight:800;}
.modal-body{padding:20px 24px;overflow-y:auto;flex:1;}
.modal-ftr{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;}
.filter-bar{display:flex;gap:8px;align-items:center;flex-wrap:wrap;padding:10px 18px;background:var(--hdr);border-bottom:1px solid var(--border);}
.empty-state{text-align:center;padding:40px 20px;color:var(--muted);}
.theme-toggle{background:none;border:1px solid var(--border);border-radius:8px;padding:6px 10px;cursor:pointer;color:var(--text);font-size:16px;}
</style>
</head>
<body>
<div class="pg">
  <div class="page-hdr">
    <div class="page-hdr-icon" style="background:linear-gradient(135deg,#8b5cf6,#6d28d9);">
      <i class="bi bi-arrow-up-right-circle" style="color:#fff;"></i>
    </div>
    <div>
      <h1>Mejora Continua — CSI</h1>
      <p>Registro de iniciativas de mejora de servicios TI (ITIL v4)</p>
    </div>
    <div class="page-hdr-right">
      <button class="theme-toggle" onclick="toggleTheme()"><i class="bi bi-moon-stars-fill"></i></button>
      <button class="btn-sm btn-primary" onclick="openModal()">
        <i class="bi bi-plus-lg"></i> Nueva Iniciativa
      </button>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpi-grid">
    <div class="kpi" style="--kc:var(--purple)">
      <div><div class="kpi-label">Total</div><div class="kpi-val" id="kpiTotal">—</div></div>
      <i class="bi bi-collection kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--primary)">
      <div><div class="kpi-label">Propuestas</div><div class="kpi-val" id="kpiProp">—</div></div>
      <i class="bi bi-lightbulb kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--warning)">
      <div><div class="kpi-label">En Progreso</div><div class="kpi-val" id="kpiProg">—</div></div>
      <i class="bi bi-arrow-repeat kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--success)">
      <div><div class="kpi-label">Completadas</div><div class="kpi-val" id="kpiComp">—</div></div>
      <i class="bi bi-check-circle kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--info)">
      <div><div class="kpi-label">Mejora Prom.</div><div class="kpi-val" id="kpiMejora">—</div></div>
      <i class="bi bi-graph-up-arrow kpi-icon"></i>
    </div>
  </div>

  <div class="two-col">
    <!-- Lista de iniciativas -->
    <div class="card-ui">
      <div class="filter-bar">
        <select id="fStatus" class="form-ctrl" style="width:150px;" onchange="load()">
          <option value="">Todos</option>
          <option value="propuesta">Propuesta</option>
          <option value="en_progreso">En Progreso</option>
          <option value="completada">Completada</option>
          <option value="cancelada">Cancelada</option>
        </select>
        <select id="fPriority" class="form-ctrl" style="width:130px;" onchange="load()">
          <option value="">Prioridad</option>
          <option value="baja">Baja</option>
          <option value="media">Media</option>
          <option value="alta">Alta</option>
          <option value="critica">Crítica</option>
        </select>
      </div>
      <div id="csiList">
        <div class="empty-state"><i class="bi bi-arrow-clockwise"></i> Cargando...</div>
      </div>
    </div>

    <!-- Panel gráfico -->
    <div>
      <div class="card-ui">
        <div class="card-head"><span class="title"><i class="bi bi-bar-chart"></i> Estado de Iniciativas</span></div>
        <div style="padding:16px;"><canvas id="chartCsi" height="200"></canvas></div>
      </div>
      <div class="card-ui">
        <div class="card-head"><span class="title"><i class="bi bi-info-circle"></i> ¿Qué es CSI?</span></div>
        <div style="padding:16px;font-size:13px;line-height:1.7;color:var(--muted);">
          <p>El <strong style="color:var(--text);">Continual Service Improvement (CSI)</strong> de ITIL v4 permite identificar y gestionar oportunidades de mejora en los servicios TI.</p>
          <p>Cada iniciativa debe tener:</p>
          <ul style="padding-left:18px;">
            <li><strong>Métrica base</strong> — valor actual</li>
            <li><strong>Meta</strong> — valor objetivo</li>
            <li><strong>% mejora esperada</strong></li>
          </ul>
          <p>Módulo diferenciador — pocas plataformas ITSM lo incluyen.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL NUEVA INICIATIVA -->
<div class="modal-overlay" id="modalCsi">
  <div class="modal-box">
    <div class="modal-hdr">
      <h3><i class="bi bi-lightbulb" style="color:var(--purple)"></i> Nueva Iniciativa CSI</h3>
      <button class="btn-sm btn-outline" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-lbl">Título *</label>
        <input type="text" id="cTitle" class="form-ctrl" placeholder="Ej: Reducir tiempo de resolución P2 en 20%">
      </div>
      <div class="form-group">
        <label class="form-lbl">Descripción</label>
        <textarea id="cDesc" class="form-ctrl" rows="2" placeholder="Contexto y justificación..."></textarea>
      </div>
      <div class="form-group">
        <label class="form-lbl">Objetivo</label>
        <textarea id="cObjective" class="form-ctrl" rows="2" placeholder="¿Qué se logrará al completar esta iniciativa?"></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-lbl">Prioridad</label>
          <select id="cPriority" class="form-ctrl">
            <option value="baja">Baja</option>
            <option value="media" selected>Media</option>
            <option value="alta">Alta</option>
            <option value="critica">Crítica</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-lbl">Fecha objetivo</label>
          <input type="date" id="cTarget" class="form-ctrl">
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-lbl">Métrica</label>
          <input type="text" id="cMetric" class="form-ctrl" placeholder="Ej: Tiempo resolución P2">
        </div>
        <div class="form-group">
          <label class="form-lbl">Valor base</label>
          <input type="number" id="cBaseline" class="form-ctrl" placeholder="48">
        </div>
        <div class="form-group">
          <label class="form-lbl">Valor objetivo</label>
          <input type="number" id="cTargetVal" class="form-ctrl" placeholder="24">
        </div>
      </div>
      <div class="form-group">
        <label class="form-lbl">% Mejora esperada</label>
        <input type="number" id="cPct" class="form-ctrl" placeholder="20" min="0" max="100">
      </div>
    </div>
    <div class="modal-ftr">
      <button class="btn-sm btn-outline" onclick="closeModal()">Cancelar</button>
      <button class="btn-sm btn-primary" onclick="crear()">
        <i class="bi bi-send"></i> Crear Iniciativa
      </button>
    </div>
  </div>
</div>

<script>
let chartCsi = null;

async function loadKpis() {
    try {
        const res = await fetch('/api/csi/kpis');
        const d   = await res.json();
        if (!d.success) return;
        document.getElementById('kpiTotal').textContent   = d.data.total      ?? '—';
        document.getElementById('kpiProp').textContent    = d.data.propuestas  ?? '—';
        document.getElementById('kpiProg').textContent    = d.data.en_progreso ?? '—';
        document.getElementById('kpiComp').textContent    = d.data.completadas ?? '—';
        document.getElementById('kpiMejora').textContent  = d.data.avg_mejora ? d.data.avg_mejora.toFixed(1) + '%' : '—';

        if (chartCsi) chartCsi.destroy();
        const ctx = document.getElementById('chartCsi').getContext('2d');
        chartCsi = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Propuesta','En Progreso','Completada','Cancelada'],
                datasets: [{ data: [d.data.propuestas||0, d.data.en_progreso||0, d.data.completadas||0, d.data.canceladas||0],
                    backgroundColor:['#3b82f6','#f59e0b','#10b981','#94a3b8'], borderWidth:0 }],
            },
            options: { cutout:'65%', plugins:{ legend:{ position:'bottom', labels:{ boxWidth:12 } } } },
        });
    } catch {}
}

async function load() {
    const status   = document.getElementById('fStatus').value;
    const priority = document.getElementById('fPriority').value;
    const params   = new URLSearchParams({ limit: 50 });
    if (status)   params.set('status', status);
    if (priority) params.set('priority', priority);

    const res  = await fetch(`/api/csi?${params}`);
    const d    = await res.json();
    const rows = d.data || [];
    const list = document.getElementById('csiList');

    if (!rows.length) {
        list.innerHTML = '<div class="empty-state"><i class="bi bi-inbox"></i> Sin iniciativas</div>';
        return;
    }

    list.innerHTML = rows.map(r => {
        const pct = r.baselineValue && r.targetValue && r.actualValue
            ? Math.min(100, Math.round(Math.abs(r.actualValue - r.baselineValue) / Math.abs(r.targetValue - r.baselineValue) * 100))
            : null;
        return `
        <div class="csi-item">
          <div class="csi-title">${esc(r.title)}</div>
          <div class="csi-meta">
            <span class="badge st-${r.status}">${fmtStatus(r.status)}</span>
            <span class="badge pri-${r.priority}">${r.priority}</span>
            ${r.targetDate ? `<span style="font-size:11px;color:var(--muted);"><i class="bi bi-calendar"></i> ${r.targetDate}</span>` : ''}
            ${r.improvementPct ? `<span style="font-size:11px;color:var(--info);font-weight:700;"><i class="bi bi-graph-up-arrow"></i> Meta: ${r.improvementPct}%</span>` : ''}
          </div>
          ${r.metric ? `<div style="font-size:12px;color:var(--muted);margin-bottom:4px;"><strong>Métrica:</strong> ${esc(r.metric)} | Base: ${r.baselineValue??'—'} → Objetivo: ${r.targetValue??'—'} ${r.actualValue!=null?`| Actual: <strong>${r.actualValue}</strong>`:''}` : ''}
          ${pct !== null ? `
            <div style="display:flex;align-items:center;gap:8px;margin-top:6px;">
              <div class="progress-bar-wrap" style="flex:1;"><div class="progress-bar-fill" style="width:${pct}%;"></div></div>
              <span style="font-size:12px;font-weight:700;color:var(--primary);">${pct}%</span>
            </div>` : ''}
          <div style="margin-top:8px;display:flex;gap:6px;">
            <select class="form-ctrl" style="padding:4px 8px;font-size:12px;width:140px;" onchange="cambiarEstado('${r.id}',this.value)">
              <option value="">— Estado —</option>
              <option value="propuesta">Propuesta</option>
              <option value="en_progreso">En Progreso</option>
              <option value="completada">Completada</option>
              <option value="cancelada">Cancelada</option>
            </select>
            ${r.status !== 'cancelada' && r.baselineValue ? `
              <input type="number" placeholder="Valor actual" style="border:1px solid var(--border);border-radius:8px;padding:4px 8px;font-size:12px;width:110px;background:var(--card);color:var(--text);"
                onblur="actualizarValor('${r.id}', this.value)">
            ` : ''}
          </div>
        </div>`;
    }).join('');
}

async function crear() {
    const title = document.getElementById('cTitle').value.trim();
    if (!title) return alert('Título requerido');
    const res = await fetch('/api/csi', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            title,
            description:    document.getElementById('cDesc').value,
            objective:      document.getElementById('cObjective').value,
            priority:       document.getElementById('cPriority').value,
            targetDate:     document.getElementById('cTarget').value || null,
            metric:         document.getElementById('cMetric').value || null,
            baselineValue:  parseFloat(document.getElementById('cBaseline').value) || null,
            targetValue:    parseFloat(document.getElementById('cTargetVal').value) || null,
            improvementPct: parseFloat(document.getElementById('cPct').value) || null,
        }),
    });
    const d = await res.json();
    if (!d.success) return alert(d.error);
    closeModal();
    load(); loadKpis();
}

async function cambiarEstado(id, status) {
    if (!status) return;
    const res = await fetch(`/api/csi/${id}`, {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status }),
    });
    if (!(await res.json()).success) return alert('Error');
    load(); loadKpis();
}

async function actualizarValor(id, val) {
    if (!val) return;
    await fetch(`/api/csi/${id}`, {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ actualValue: parseFloat(val) }),
    });
    load();
}

function fmtStatus(s) {
    return { propuesta:'Propuesta', en_progreso:'En Progreso', completada:'Completada', cancelada:'Cancelada' }[s] || s;
}
function esc(t) { return String(t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;'); }
function openModal()  { document.getElementById('modalCsi').classList.add('open'); }
function closeModal() { document.getElementById('modalCsi').classList.remove('open'); }
function toggleTheme() {
    const h = document.documentElement;
    h.setAttribute('data-theme', h.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
}

load(); loadKpis();
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
