<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CMDB — Inventario de Configuración</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<style>
:root,[data-theme="light"]{
    --bg:#f0f4f8;--card:#fff;--hdr:#f8fafc;--border:#e2e8f0;
    --text:#1e293b;--muted:#64748b;--primary:#3b82f6;--success:#10b981;
    --warning:#f59e0b;--info:#06b6d4;--danger:#ef4444;--purple:#8b5cf6;
    --hover:#f1f5f9;--sh-sm:0 1px 3px rgba(0,0,0,.06);--sh-md:0 4px 12px rgba(0,0,0,.08);
}
[data-theme="dark"]{
    --bg:#0f172a;--card:#1e293b;--hdr:#162032;--border:#2d3f55;
    --text:#e2e8f0;--muted:#94a3b8;--primary:#60a5fa;--success:#34d399;
    --warning:#fbbf24;--info:#22d3ee;--danger:#f87171;--purple:#a78bfa;
    --hover:#243348;
}
*{box-sizing:border-box;}
body{margin:0;background:var(--bg);color:var(--text);font-family:'DM Sans',-apple-system,sans-serif;}
.pg{max-width:1700px;margin:0 auto;padding:24px 20px;}
.page-hdr{display:flex;align-items:center;gap:16px;margin-bottom:28px;}
.page-hdr-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;box-shadow:var(--sh-md);}
.page-hdr h1{font-size:22px;font-weight:800;margin:0;}
.page-hdr p{margin:3px 0 0;font-size:13px;color:var(--muted);}
.page-hdr-right{margin-left:auto;display:flex;gap:8px;align-items:center;}
.kpi-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:24px;}
@media(max-width:1200px){.kpi-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:600px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;display:flex;justify-content:space-between;align-items:center;box-shadow:var(--sh-sm);cursor:pointer;position:relative;overflow:hidden;transition:all .2s;}
.kpi::before{content:'';position:absolute;inset:0;background:var(--kc);opacity:0;transition:opacity .2s;}
.kpi:hover::before,.kpi.active::before{opacity:.06;}
.kpi.active{border-color:var(--kc)!important;box-shadow:0 0 0 2px var(--kc)!important;}
.kpi-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin-bottom:4px;}
.kpi-val{font-size:24px;font-weight:800;line-height:1;color:var(--kc);}
.kpi-icon{font-size:28px;opacity:.18;color:var(--kc);}
.card-ui{background:var(--card);border:1px solid var(--border);border-radius:14px;box-shadow:var(--sh-sm);overflow:hidden;margin-bottom:20px;}
.card-head{padding:13px 18px;background:var(--hdr);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.card-head .title{font-size:13px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px;}
.tbl-wrap{overflow:auto;max-height:560px;}
.tbl{width:100%;border-collapse:collapse;font-size:13px;}
.tbl thead th{background:var(--hdr);color:var(--muted);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;padding:11px 14px;border-bottom:1px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;}
.tbl tbody tr{border-bottom:1px solid var(--border);transition:background .15s;cursor:pointer;}
.tbl tbody tr:hover{background:var(--hover);}
.tbl td{padding:10px 14px;vertical-align:middle;}
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.env-produccion{background:#d1fae5;color:#059669;}
.env-staging{background:#fef3c7;color:#d97706;}
.env-desarrollo{background:#dbeafe;color:#2563eb;}
.env-dr{background:#ede9fe;color:#7c3aed;}
.st-activo{background:#d1fae5;color:#059669;}
.st-inactivo{background:#f1f5f9;color:#94a3b8;}
.st-en_mantenimiento{background:#fef3c7;color:#d97706;}
.st-retirado{background:#fee2e2;color:#dc2626;}
.btn-sm{padding:6px 14px;font-size:12px;font-weight:600;border-radius:8px;border:none;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--primary);color:#fff;}
.btn-primary:hover{opacity:.88;}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--muted);}
.btn-outline:hover{background:var(--hover);}
.btn-danger{background:var(--danger);color:#fff;}
.form-ctrl{width:100%;border:1px solid var(--border);border-radius:8px;padding:9px 12px;font-size:13px;background:var(--card);color:var(--text);outline:none;transition:border .15s;}
.form-ctrl:focus{border-color:var(--primary);}
.form-group{margin-bottom:14px;}
.form-lbl{font-size:12px;font-weight:700;color:var(--muted);margin-bottom:5px;display:block;}
.modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal-box{background:var(--card);border-radius:20px;width:600px;max-width:95vw;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 60px rgba(0,0,0,.25);transform:translateY(20px);transition:transform .2s;}
.modal-overlay.open .modal-box{transform:translateY(0);}
.modal-hdr{padding:20px 24px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.modal-hdr h3{margin:0;font-size:16px;font-weight:800;}
.modal-body{padding:20px 24px;overflow-y:auto;flex:1;}
.modal-ftr{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;}
.detail-panel{background:var(--card);border:1px solid var(--border);border-radius:14px;box-shadow:var(--sh-sm);overflow:hidden;margin-bottom:20px;display:none;}
.detail-panel.open{display:block;}
.detail-head{padding:13px 18px;background:var(--hdr);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.detail-body{padding:16px 18px;}
.attr-row{display:grid;grid-template-columns:120px 1fr;gap:8px;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px;}
.attr-row:last-child{border-bottom:none;}
.attr-key{font-weight:700;color:var(--muted);}
.rel-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;background:var(--hover);margin-bottom:6px;font-size:13px;}
.rel-dir{color:var(--muted);font-size:11px;}
.pagination{display:flex;gap:4px;align-items:center;justify-content:flex-end;padding:12px 18px;border-top:1px solid var(--border);}
.page-btn{width:32px;height:32px;border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;background:var(--card);color:var(--text);transition:all .15s;}
.page-btn:hover,.page-btn.active{background:var(--primary);color:#fff;border-color:var(--primary);}
.empty-state{text-align:center;padding:60px 20px;color:var(--muted);}
.theme-toggle{background:none;border:1px solid var(--border);border-radius:8px;padding:6px 10px;cursor:pointer;color:var(--text);font-size:16px;}
.search-bar{display:flex;gap:8px;flex-wrap:wrap;}
</style>
</head>
<body>
<div class="pg">
  <div class="page-hdr">
    <div class="page-hdr-icon" style="background:linear-gradient(135deg,#10b981,#059669);">
      <i class="bi bi-diagram-3" style="color:#fff;"></i>
    </div>
    <div>
      <h1>CMDB</h1>
      <p>Base de datos de gestión de configuración — activos e infraestructura TI</p>
    </div>
    <div class="page-hdr-right">
      <button class="theme-toggle" onclick="toggleTheme()"><i class="bi bi-moon-stars-fill"></i></button>
      <button class="btn-sm btn-outline" onclick="openModalRel()">
        <i class="bi bi-diagram-2"></i> Agregar Relación
      </button>
      <button class="btn-sm btn-primary" onclick="openModalAdd()">
        <i class="bi bi-plus-lg"></i> Nuevo CI
      </button>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpi-grid">
    <div class="kpi" style="--kc:var(--primary)" onclick="filterStatus('')">
      <div><div class="kpi-label">Total CIs</div><div class="kpi-val" id="kpiTotal">—</div></div>
      <i class="bi bi-server kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--success)" onclick="filterStatus('activo')">
      <div><div class="kpi-label">Activos</div><div class="kpi-val" id="kpiActivo">—</div></div>
      <i class="bi bi-check-circle kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--warning)" onclick="filterStatus('en_mantenimiento')">
      <div><div class="kpi-label">Mantenimiento</div><div class="kpi-val" id="kpiManto">—</div></div>
      <i class="bi bi-tools kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--muted)" onclick="filterStatus('inactivo')">
      <div><div class="kpi-label">Inactivos</div><div class="kpi-val" id="kpiInactivo">—</div></div>
      <i class="bi bi-pause-circle kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--danger)" onclick="filterStatus('retirado')">
      <div><div class="kpi-label">Retirados</div><div class="kpi-val" id="kpiRetirado">—</div></div>
      <i class="bi bi-trash kpi-icon"></i>
    </div>
    <div class="kpi no-click" style="--kc:var(--info);cursor:default;">
      <div><div class="kpi-label">Relaciones</div><div class="kpi-val" id="kpiRels">—</div></div>
      <i class="bi bi-diagram-2 kpi-icon"></i>
    </div>
  </div>

  <!-- Detail panel (visible on row click) -->
  <div class="detail-panel" id="detailPanel">
    <div class="detail-head">
      <span style="font-size:13px;font-weight:700;" id="detailName">CI Detail</span>
      <button class="btn-sm btn-outline" onclick="closeDetail()">✕ Cerrar</button>
    </div>
    <div class="detail-body">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
        <div id="detailAttrs"></div>
        <div>
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:10px;">Relaciones</div>
          <div id="detailRels"><span style="color:var(--muted);font-size:13px;">Sin relaciones</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- TABLE -->
  <div class="card-ui">
    <div class="card-head">
      <span class="title"><i class="bi bi-table"></i> Inventario de CIs</span>
      <div class="search-bar">
        <select id="fType" class="form-ctrl" style="width:160px;" onchange="loadCmdb()">
          <option value="">Tipo de CI</option>
        </select>
        <select id="fStatus" class="form-ctrl" style="width:140px;" onchange="loadCmdb()">
          <option value="">Estado</option>
          <option value="activo">Activo</option>
          <option value="inactivo">Inactivo</option>
          <option value="en_mantenimiento">Mantenimiento</option>
          <option value="retirado">Retirado</option>
        </select>
        <select id="fEnv" class="form-ctrl" style="width:130px;" onchange="loadCmdb()">
          <option value="">Entorno</option>
          <option value="produccion">Producción</option>
          <option value="staging">Staging</option>
          <option value="desarrollo">Desarrollo</option>
          <option value="dr">DR</option>
        </select>
        <input type="text" id="fSearch" class="form-ctrl" style="width:200px;" placeholder="Buscar CI..." oninput="loadCmdb()">
      </div>
    </div>
    <div class="tbl-wrap">
      <table class="tbl">
        <thead>
          <tr>
            <th>Nombre</th><th>Tipo</th><th>Estado</th><th>Entorno</th>
            <th>IP / Host</th><th>Versión</th><th>Serial</th><th>Ubicación</th>
          </tr>
        </thead>
        <tbody id="ciBody">
          <tr><td colspan="8"><div class="empty-state"><i class="bi bi-arrow-clockwise"></i> Cargando...</div></td></tr>
        </tbody>
      </table>
    </div>
    <div class="pagination" id="ciPagination"></div>
  </div>
</div>

<!-- MODAL NUEVO CI -->
<div class="modal-overlay" id="modalAdd">
  <div class="modal-box">
    <div class="modal-hdr">
      <h3><i class="bi bi-plus-circle" style="color:var(--success)"></i> Nuevo CI</h3>
      <button class="btn-sm btn-outline" onclick="closeModal('modalAdd')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-lbl">Tipo de CI *</label>
        <select id="addTypeId" class="form-ctrl"><option value="">— Seleccionar —</option></select>
      </div>
      <div class="form-group">
        <label class="form-lbl">Nombre *</label>
        <input type="text" id="addName" class="form-ctrl" placeholder="Ej: srv-web-prod-01">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-lbl">Estado</label>
          <select id="addStatus" class="form-ctrl">
            <option value="activo" selected>Activo</option>
            <option value="inactivo">Inactivo</option>
            <option value="en_mantenimiento">En mantenimiento</option>
            <option value="retirado">Retirado</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-lbl">Entorno</label>
          <select id="addEnv" class="form-ctrl">
            <option value="produccion" selected>Producción</option>
            <option value="staging">Staging</option>
            <option value="desarrollo">Desarrollo</option>
            <option value="dr">DR</option>
          </select>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-lbl">IP / Hostname</label>
          <input type="text" id="addIp" class="form-ctrl" placeholder="192.168.1.10">
        </div>
        <div class="form-group">
          <label class="form-lbl">Número de serie</label>
          <input type="text" id="addSerial" class="form-ctrl">
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-lbl">Versión / OS</label>
          <input type="text" id="addVersion" class="form-ctrl" placeholder="Ubuntu 22.04">
        </div>
        <div class="form-group">
          <label class="form-lbl">Ubicación</label>
          <input type="text" id="addLocation" class="form-ctrl" placeholder="Rack A — DC1">
        </div>
      </div>
    </div>
    <div class="modal-ftr">
      <button class="btn-sm btn-outline" onclick="closeModal('modalAdd')">Cancelar</button>
      <button class="btn-sm btn-primary" onclick="crearCI()">
        <i class="bi bi-save"></i> Guardar
      </button>
    </div>
  </div>
</div>

<!-- MODAL RELACIÓN -->
<div class="modal-overlay" id="modalRel">
  <div class="modal-box">
    <div class="modal-hdr">
      <h3><i class="bi bi-diagram-2" style="color:var(--info)"></i> Agregar Relación entre CIs</h3>
      <button class="btn-sm btn-outline" onclick="closeModal('modalRel')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-lbl">CI Origen *</label>
        <select id="relSource" class="form-ctrl"><option value="">— Seleccionar —</option></select>
      </div>
      <div class="form-group">
        <label class="form-lbl">Tipo de relación</label>
        <select id="relType" class="form-ctrl">
          <option value="depende_de">depende_de</option>
          <option value="conectado_a">conectado_a</option>
          <option value="instalado_en">instalado_en</option>
          <option value="virtualizado_en">virtualizado_en</option>
          <option value="contiene">contiene</option>
          <option value="respaldado_por">respaldado_por</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-lbl">CI Destino *</label>
        <select id="relTarget" class="form-ctrl"><option value="">— Seleccionar —</option></select>
      </div>
    </div>
    <div class="modal-ftr">
      <button class="btn-sm btn-outline" onclick="closeModal('modalRel')">Cancelar</button>
      <button class="btn-sm btn-primary" onclick="crearRelacion()">
        <i class="bi bi-link-45deg"></i> Crear Relación
      </button>
    </div>
  </div>
</div>

<script>
let ciTypes = [];
let allCI   = [];
let ciPage  = 1;
let ciTotal = 0;

async function init() {
    const res = await fetch('/api/cmdb/types');
    const d   = await res.json();
    ciTypes   = d.data || [];
    const sel = document.getElementById('fType');
    sel.innerHTML = '<option value="">Tipo de CI</option>' +
        ciTypes.map(t => `<option value="${t.id}">${esc(t.name)}</option>`).join('');
    loadKpis();
    loadCmdb();
}

async function loadKpis() {
    try {
        const res = await fetch('/api/cmdb/kpis');
        const d   = await res.json();
        if (!d.success) return;
        document.getElementById('kpiTotal').textContent    = d.data.total       ?? '—';
        document.getElementById('kpiActivo').textContent   = d.data.activos     ?? '—';
        document.getElementById('kpiManto').textContent    = d.data.mantenimiento ?? '—';
        document.getElementById('kpiInactivo').textContent = d.data.inactivos   ?? '—';
        document.getElementById('kpiRetirado').textContent = d.data.retirados   ?? '—';
        document.getElementById('kpiRels').textContent     = d.data.relaciones  ?? '—';
    } catch {}
}

async function loadCmdb(page = 1) {
    ciPage = page;
    const params = new URLSearchParams({ page, limit: 25 });
    const t = document.getElementById('fType').value;
    const s = document.getElementById('fStatus').value;
    const e = document.getElementById('fEnv').value;
    const q = document.getElementById('fSearch').value;
    if (t) params.set('ciTypeId', t);
    if (s) params.set('status', s);
    if (e) params.set('environment', e);
    if (q) params.set('search', q);

    const res = await fetch(`/api/cmdb?${params}`);
    const d   = await res.json();
    allCI     = d.data || [];
    ciTotal   = d.total || allCI.length;
    const tbody = document.getElementById('ciBody');

    if (!allCI.length) {
        tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><i class="bi bi-inbox"></i> Sin CIs</div></td></tr>`;
        document.getElementById('ciPagination').innerHTML = '';
        return;
    }

    tbody.innerHTML = allCI.map(ci => `
        <tr onclick="showDetail('${ci.id}')">
          <td><strong>${esc(ci.name)}</strong></td>
          <td><span style="font-size:12px;color:var(--muted)">${esc(ci.tipo?.name || '—')}</span></td>
          <td><span class="badge st-${ci.status}">${ci.status}</span></td>
          <td><span class="badge env-${ci.environment}">${ci.environment}</span></td>
          <td><span style="font-family:monospace;font-size:12px">${esc(ci.ipAddress || '—')}</span></td>
          <td>${esc(ci.version || '—')}</td>
          <td><span style="font-family:monospace;font-size:11px;color:var(--muted)">${esc(ci.serialNumber || '—')}</span></td>
          <td>${esc(ci.location || '—')}</td>
        </tr>`).join('');

    const pages = Math.ceil(ciTotal / 25);
    const pag = document.getElementById('ciPagination');
    if (pages <= 1) { pag.innerHTML = ''; return; }
    pag.innerHTML = Array.from({ length: Math.min(pages, 7) }, (_, i) => i + 1)
        .map(i => `<div class="page-btn ${i===page?'active':''}" onclick="loadCmdb(${i})">${i}</div>`)
        .join('');
}

async function showDetail(id) {
    const res = await fetch(`/api/cmdb/${id}`);
    const d   = await res.json();
    if (!d.success) return;
    const ci  = d.data;
    const rels = d.relationships || [];
    document.getElementById('detailName').textContent = ci.name;
    document.getElementById('detailAttrs').innerHTML = `
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:10px;">Atributos</div>
        ${[
            ['Tipo',       ci.tipo?.name || '—'],
            ['Estado',     ci.status],
            ['Entorno',    ci.environment],
            ['IP/Host',    ci.ipAddress    || '—'],
            ['Versión',    ci.version      || '—'],
            ['Serial',     ci.serialNumber || '—'],
            ['Ubicación',  ci.location     || '—'],
        ].map(([k,v]) => `<div class="attr-row"><span class="attr-key">${k}</span><span>${esc(v)}</span></div>`).join('')}`;

    document.getElementById('detailRels').innerHTML = rels.length
        ? rels.map(r => {
            const isSource = r.source_id === id;
            return `<div class="rel-item">
              <i class="bi bi-diagram-2" style="color:var(--info)"></i>
              <span>${esc(isSource ? r.target_name : r.source_name)}</span>
              <span style="color:var(--muted);font-size:11px;margin-left:auto;font-family:monospace">${esc(r.relationship)}</span>
            </div>`;
          }).join('')
        : '<span style="color:var(--muted);font-size:13px;">Sin relaciones registradas</span>';

    document.getElementById('detailPanel').classList.add('open');
    document.getElementById('detailPanel').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function closeDetail() { document.getElementById('detailPanel').classList.remove('open'); }

async function crearCI() {
    const typeId = document.getElementById('addTypeId').value;
    const name   = document.getElementById('addName').value.trim();
    if (!typeId || !name) return alert('Tipo y nombre son requeridos');
    const res = await fetch('/api/cmdb', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            ciTypeId:     typeId,
            name,
            status:       document.getElementById('addStatus').value,
            environment:  document.getElementById('addEnv').value,
            ipAddress:    document.getElementById('addIp').value     || null,
            serialNumber: document.getElementById('addSerial').value || null,
            version:      document.getElementById('addVersion').value || null,
            location:     document.getElementById('addLocation').value || null,
        }),
    });
    const d = await res.json();
    if (!d.success) return alert(d.error);
    closeModal('modalAdd');
    loadCmdb(); loadKpis();
}

async function crearRelacion() {
    const sourceId     = document.getElementById('relSource').value;
    const targetId     = document.getElementById('relTarget').value;
    const relationship = document.getElementById('relType').value;
    if (!sourceId || !targetId) return alert('Selecciona origen y destino');
    if (sourceId === targetId)  return alert('El origen y destino no pueden ser el mismo CI');
    const res = await fetch(`/api/cmdb/${sourceId}/relationships`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targetId, relationship }),
    });
    const d = await res.json();
    if (!d.success) return alert(d.error);
    closeModal('modalRel');
    loadKpis();
}

function openModalAdd() {
    const sel = document.getElementById('addTypeId');
    sel.innerHTML = '<option value="">— Seleccionar —</option>' +
        ciTypes.map(t => `<option value="${t.id}">${esc(t.name)}</option>`).join('');
    document.getElementById('modalAdd').classList.add('open');
}

function openModalRel() {
    const opts = '<option value="">— Seleccionar —</option>' +
        allCI.map(ci => `<option value="${ci.id}">${esc(ci.name)}</option>`).join('');
    document.getElementById('relSource').innerHTML = opts;
    document.getElementById('relTarget').innerHTML = opts;
    document.getElementById('modalRel').classList.add('open');
}

function filterStatus(s) { document.getElementById('fStatus').value = s; loadCmdb(); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function esc(t) { return String(t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;'); }
function toggleTheme() {
    const h = document.documentElement;
    h.setAttribute('data-theme', h.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
}

init();
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
