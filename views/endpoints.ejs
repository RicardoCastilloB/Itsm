                },
                pageLength: 25,
                order: [[0, 'asc'], [1, 'asc']],
                dom: 'Bfrtip',
                buttons: [
                    'copy', 'excel', 'print'
                ],
                columnDefs: [
                    { width: '15%', targets: 0 },
                    { width: '10%', targets: 1 },
                    { width: '35%', targets: 2 },
                    { width: '40%', targets: 3 }
                ]
            });
        });
