<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Listas de Distribución - Equipment Management</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link rel="stylesheet" href="../css/style.css">

<script>(function(){const s=localStorage.getItem('dashboardTheme')||'light';document.documentElement.setAttribute('data-theme',s);})();</script>

<style>
/* ── Variables (igual al resto de la app) ── */
:root,[data-theme="light"]{
  --bg:#f0f4f8;--card:#ffffff;--header:#f8fafc;--border:#e2e8f0;
  --text:#1e293b;--muted:#64748b;--primary:#3b82f6;--success:#10b981;
  --warning:#f59e0b;--danger:#ef4444;--info:#06b6d4;
  --hover:#f1f5f9;--input-bg:#f8fafc;
  --shadow:0 1px 3px rgba(0,0,0,.07);--shadow-md:0 4px 16px rgba(0,0,0,.10);
}
[data-theme="dark"]{
  --bg:#0f172a;--card:#1e293b;--header:#162032;--border:#2d3f55;
  --text:#e2e8f0;--muted:#94a3b8;--primary:#60a5fa;--success:#34d399;
  --warning:#fbbf24;--danger:#f87171;--info:#22d3ee;
  --hover:#243348;--input-bg:#162032;
  --shadow:0 1px 3px rgba(0,0,0,.3);--shadow-md:0 4px 16px rgba(0,0,0,.4);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:"DM Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;font-size:13.5px;transition:background .3s,color .3s;}
.pg{margin-top:60px;padding:20px 24px;display:flex;flex-direction:column;gap:16px;max-width:1680px;margin-left:auto;margin-right:auto;}

/* ── Layout 2 columnas ── */
.rl-layout{display:grid;grid-template-columns:300px 1fr;gap:16px;align-items:start;}
@media(max-width:1000px){.rl-layout{grid-template-columns:1fr;}}

/* ── Card ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:var(--shadow);transition:background .3s,border-color .3s;}
.card-head{padding:12px 16px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;font-weight:700;font-size:13px;color:var(--text);transition:background .3s,border-color .3s;}
.card-head i{color:var(--primary);margin-right:6px;}
.card-body{padding:0;}

/* ── Sidebar de listas ── */
.list-sidebar{display:flex;flex-direction:column;}
.list-item{
  display:flex;align-items:center;gap:11px;padding:11px 14px;
  cursor:pointer;border-bottom:1px solid var(--border);transition:background .15s;
  position:relative;
}
.list-item:last-child{border-bottom:none;}
.list-item:hover{background:var(--hover);}
.list-item.active{background:rgba(59,130,246,.07);border-left:3px solid var(--primary);}
.list-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.list-name{font-weight:600;font-size:13px;flex:1;}
.list-count{font-size:11px;color:var(--muted);background:var(--input-bg);border:1px solid var(--border);padding:1px 8px;border-radius:20px;font-weight:600;}
.list-actions{display:none;gap:4px;}
.list-item:hover .list-actions{display:flex;}
.list-edit-btn,.list-del-btn{background:none;border:none;padding:3px 6px;border-radius:5px;cursor:pointer;font-size:13px;transition:all .15s;}
.list-edit-btn{color:var(--muted);}.list-edit-btn:hover{color:var(--primary);background:rgba(59,130,246,.08);}
.list-del-btn{color:var(--muted);}.list-del-btn:hover{color:var(--danger);background:rgba(239,68,68,.08);}

/* ── Toolbar ── */
.toolbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:12px 16px;border-bottom:1px solid var(--border);background:var(--header);transition:background .3s,border-color .3s;}
.search-wrap{position:relative;flex:1;min-width:180px;}
.search-wrap i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none;}
.search-inp{
  width:100%;padding:7px 12px 7px 32px;
  border:1px solid var(--border);border-radius:9px;font-size:12.5px;
  background:var(--input-bg);color:var(--text);outline:none;transition:border-color .2s;
}
.search-inp:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.search-inp::placeholder{color:var(--muted);}

/* ── Contacts table ── */
.tbl-scroll{overflow-x:auto;overflow-y:auto;max-height:580px;}
.tbl{width:100%;border-collapse:collapse;font-size:13px;}
.tbl thead th{font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);font-weight:700;padding:10px 14px;background:var(--header);border-bottom:1px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;transition:background .3s;}
.tbl tbody td{padding:10px 14px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;transition:background .1s,border-color .3s;}
.tbl tbody tr:hover td{background:var(--hover);}
.tbl tbody tr:last-child td{border-bottom:none;}

/* ── Pills / badges ── */
.pill{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;}
.p-active{background:rgba(16,185,129,.12);color:#10b981;}
.p-inactive{background:rgba(239,68,68,.1);color:#ef4444;}
.list-chip{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;margin:2px;border:1px solid;}

/* ── Buttons (mismos que el resto de la app) ── */
.btn-primary{background:var(--primary);color:#fff;border:none;border-radius:9px;padding:8px 18px;font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;white-space:nowrap;}
.btn-primary:hover{filter:brightness(1.1);transform:translateY(-1px);}
.btn-primary:disabled{opacity:.6;cursor:not-allowed;transform:none;}
.btn-ghost{background:transparent;color:var(--primary);border:1.5px solid var(--primary);border-radius:9px;padding:7px 14px;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;}
.btn-ghost:hover{background:var(--primary);color:#fff;}
.btn-sm{padding:5px 9px;font-size:11.5px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;display:inline-flex;align-items:center;gap:4px;transition:all .15s;white-space:nowrap;}
.btn-sm:hover{border-color:var(--primary);color:var(--primary);}
.btn-sm.danger:hover{border-color:var(--danger);color:var(--danger);}

/* ── Modal ── */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1050;align-items:center;justify-content:center;backdrop-filter:blur(2px);}
.modal-bg.open{display:flex;}
.modal-box{background:var(--card);border:1px solid var(--border);border-radius:16px;width:100%;max-width:500px;box-shadow:0 20px 60px rgba(0,0,0,.25);animation:mIn .2s ease;overflow:hidden;transition:background .3s,border-color .3s;}
.modal-box.wide{max-width:580px;}
@keyframes mIn{from{opacity:0;transform:scale(.95);}to{opacity:1;transform:scale(1);}}
.modal-head{padding:16px 20px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;font-weight:700;font-size:15px;transition:background .3s,border-color .3s;}
.modal-body{padding:20px 22px;}
.modal-foot{padding:13px 22px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;background:var(--header);transition:background .3s,border-color .3s;}
.btn-mcancel{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:9px;padding:7px 16px;font-size:13px;cursor:pointer;transition:all .2s;}
.btn-mcancel:hover{border-color:var(--text);color:var(--text);}
.btn-mclose{width:28px;height:28px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.btn-mclose:hover{background:rgba(239,68,68,.1);color:var(--danger);border-color:var(--danger);}

/* Form */
.fg{display:flex;flex-direction:column;gap:5px;margin-bottom:13px;}
.fg:last-child{margin-bottom:0;}
.fl{font-size:10.5px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);}
.req{color:var(--danger);}
.fc{padding:9px 12px;border:1.5px solid var(--border);border-radius:9px;font-size:13px;font-family:"DM Sans",sans-serif;background:var(--input-bg);color:var(--text);outline:none;width:100%;transition:border-color .2s,box-shadow .2s,background .3s;}
.fc::placeholder{color:var(--muted);}
.fc:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.fc.invalid{border-color:var(--danger);}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:13px;}
@media(max-width:480px){.grid2{grid-template-columns:1fr;}}

/* Checkboxes de listas */
.list-check-grid{display:flex;flex-direction:column;gap:7px;max-height:200px;overflow-y:auto;padding:2px;}
.list-chk-row{display:flex;align-items:center;gap:9px;padding:8px 11px;border:1.5px solid var(--border);border-radius:9px;cursor:pointer;transition:all .2s;}
.list-chk-row:hover{border-color:var(--primary);background:rgba(59,130,246,.04);}
.list-chk-row.checked{border-color:var(--primary);background:rgba(59,130,246,.07);}
.list-chk-row input{display:none;}
.list-chk-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.list-chk-name{flex:1;font-weight:600;font-size:13px;}
.list-chk-icon{width:18px;height:18px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;opacity:0;transition:opacity .15s;}
.list-chk-row.checked .list-chk-icon{opacity:1;}

/* Color picker inline */
.color-opts{display:flex;gap:7px;flex-wrap:wrap;}
.color-opt{width:24px;height:24px;border-radius:50%;cursor:pointer;border:2.5px solid transparent;transition:transform .15s;}
.color-opt:hover{transform:scale(1.15);}
.color-opt.sel{border-color:var(--text);transform:scale(1.15);}

/* Toast */
.toast-wrap{position:fixed;bottom:22px;right:22px;z-index:9999;display:flex;flex-direction:column;gap:7px;}
.toast-item{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:11px;padding:11px 16px;font-size:13px;font-weight:500;box-shadow:var(--shadow-md);display:flex;align-items:center;gap:9px;min-width:250px;animation:tIn .22s ease;}
.toast-item.ok{border-left:4px solid var(--success);}
.toast-item.err{border-left:4px solid var(--danger);}
.toast-item.inf{border-left:4px solid var(--info);}
@keyframes tIn{from{opacity:0;transform:translateX(22px);}to{opacity:1;transform:translateX(0);}}

/* Spinner */
@keyframes spin{to{transform:rotate(360deg);}}
.spin-anim{animation:spin .7s linear infinite;}
.mini-spin{display:inline-block;width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:spin .65s linear infinite;}

/* Empty state */
.empty-state{text-align:center;padding:48px 20px;color:var(--muted);}
.empty-state i{font-size:34px;display:block;margin-bottom:10px;opacity:.3;}

/* Count badge */
.count-badge{background:var(--input-bg);color:var(--muted);font-size:11px;font-weight:700;padding:2px 9px;border-radius:20px;border:1px solid var(--border);}

/* Scrollbar */
*::-webkit-scrollbar{width:5px;height:5px;}
*::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
*::-webkit-scrollbar-track{background:transparent;}

[data-theme="dark"] .modal-content,[data-theme="dark"] .modal-header,[data-theme="dark"] .modal-body,[data-theme="dark"] .modal-footer{background:var(--card)!important;border-color:var(--border)!important;}
</style>
</head>
<body>

<%- include("partials/sidebar_top") %>
<div class="toast-wrap" id="toastWrap"></div>

<div class="pg">

  <!-- Header -->
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <div style="font-size:20px;font-weight:800;letter-spacing:-.3px;display:flex;align-items:center;gap:9px;">
        <i class="bi bi-envelope-paper-fill" style="color:var(--primary);"></i> Listas de Distribución
      </div>
      <div style="font-size:12px;color:var(--muted);margin-top:3px;">
        Gestiona destinatarios para el envío de reportes · autocompletado en el módulo de envíos
      </div>
    </div>
    <div style="display:flex;gap:8px;">
      <button class="btn-ghost" onclick="openModalNewList()">
        <i class="bi bi-plus-circle"></i> Nueva lista
      </button>
      <button class="btn-primary" onclick="openModalNewContact()">
        <i class="bi bi-person-plus-fill"></i> Añadir destinatario
      </button>
    </div>
  </div>

  <!-- Layout 2 columnas -->
  <div class="rl-layout">

    <!-- ── SIDEBAR: LISTAS ── -->
    <div class="card list-sidebar">
      <div class="card-head">
        <span><i class="bi bi-collection-fill"></i>Listas</span>
        <button class="btn-sm" onclick="openModalNewList()" title="Nueva lista">
          <i class="bi bi-plus"></i>
        </button>
      </div>
      <div class="card-body">
        <div id="listsSidebar">
          <div style="text-align:center;padding:28px;color:var(--muted);">
            <span class="mini-spin"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- ── PANEL: CONTACTOS ── -->
    <div class="card">
      <div class="card-head">
        <span>
          <i class="bi bi-people-fill"></i>
          <span id="panelTitle">Todos los destinatarios</span>
          <span class="count-badge ms-2" id="contactCount">0</span>
        </span>
      </div>

      <!-- Toolbar -->
      <div class="toolbar">
        <div class="search-wrap">
          <i class="bi bi-search"></i>
          <input type="text" class="search-inp" id="searchContacts"
                 placeholder="Buscar por nombre o email…" oninput="filterContacts()">
        </div>
        <button class="btn-sm" onclick="loadContacts()" title="Recargar">
          <i class="bi bi-arrow-clockwise"></i>
        </button>
        <button class="btn-sm" onclick="exportContacts()" title="Exportar CSV">
          <i class="bi bi-download"></i> CSV
        </button>
      </div>

      <!-- Tabla -->
      <div class="tbl-scroll">
        <table class="tbl">
          <thead>
            <tr>
              <th style="text-align:left;">Nombre</th>
              <th>Email</th>
              <th>Listas</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="contactsTbody">
            <tr><td colspan="5" class="empty-state">
              <span class="mini-spin"></span>
              <p style="margin:8px 0 0;font-size:12px;">Cargando destinatarios…</p>
            </td></tr>
          </tbody>
        </table>
      </div>

      <!-- Footer -->
      <div style="padding:10px 16px;border-top:1px solid var(--border);background:var(--header);font-size:12px;color:var(--muted);">
        <span id="contactsFooter">—</span>
      </div>
    </div>

  </div><!-- /.rl-layout -->
</div><!-- /.pg -->

<!-- ══ MODAL: Nueva / Editar LISTA ══ -->
<div class="modal-bg" id="modalList">
  <div class="modal-box">
    <div class="modal-head">
      <span id="modalListTitle" style="display:flex;align-items:center;gap:8px;">
        <i class="bi bi-collection-fill" style="color:var(--primary);"></i> Nueva lista
      </span>
      <button class="btn-mclose" onclick="closeModal('modalList')"><i class="bi bi-x"></i></button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="listId">
      <div class="fg">
        <label class="fl">Nombre <span class="req">*</span></label>
        <input class="fc" id="listName" placeholder="Ej: Técnicos de campo">
      </div>
      <div class="fg">
        <label class="fl">Descripción</label>
        <input class="fc" id="listDesc" placeholder="Opcional…">
      </div>
      <div class="fg">
        <label class="fl">Color de identificación</label>
        <div class="color-opts" id="colorOpts"></div>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn-mcancel" onclick="closeModal('modalList')">Cancelar</button>
      <button class="btn-primary" id="btnSaveList" onclick="saveList()">
        <i class="bi bi-check-lg"></i> Guardar lista
      </button>
    </div>
  </div>
</div>

<!-- ══ MODAL: Nuevo / Editar CONTACTO ══ -->
<div class="modal-bg" id="modalContact">
  <div class="modal-box wide">
    <div class="modal-head">
      <span id="modalContactTitle" style="display:flex;align-items:center;gap:8px;">
        <i class="bi bi-person-plus-fill" style="color:var(--success);"></i> Añadir destinatario
      </span>
      <button class="btn-mclose" onclick="closeModal('modalContact')"><i class="bi bi-x"></i></button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="contactId">
      <div class="grid2" style="margin-bottom:13px;">
        <div class="fg" style="margin-bottom:0;">
          <label class="fl">Nombre completo <span class="req">*</span></label>
          <input class="fc" id="contactName" placeholder="Ej: Juan García">
        </div>
        <div class="fg" style="margin-bottom:0;">
          <label class="fl">Email <span class="req">*</span></label>
          <input class="fc" id="contactEmail" type="email" placeholder="correo@empresa.com">
        </div>
      </div>
      <div class="fg">
        <label class="fl">Asignar a listas <span style="font-weight:400;text-transform:none;letter-spacing:0;">(opcional)</span></label>
        <div class="list-check-grid" id="listCheckGrid">
          <div style="color:var(--muted);font-size:12px;padding:8px;">Cargando listas…</div>
        </div>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn-mcancel" onclick="closeModal('modalContact')">Cancelar</button>
      <button class="btn-primary" id="btnSaveContact" onclick="saveContact()">
        <i class="bi bi-check-lg"></i> Guardar destinatario
      </button>
    </div>
  </div>
</div>

<!-- ══ MODAL: Confirmar eliminar ══ -->
<div class="modal-bg" id="modalConfirm">
  <div class="modal-box" style="max-width:380px;">
    <div class="modal-head">
      <span style="display:flex;align-items:center;gap:8px;color:var(--danger);">
        <i class="bi bi-trash-fill"></i> Confirmar eliminación
      </span>
      <button class="btn-mclose" onclick="closeModal('modalConfirm')"><i class="bi bi-x"></i></button>
    </div>
    <div class="modal-body">
      <p style="font-size:13.5px;color:var(--text);" id="confirmMsg">¿Estás seguro?</p>
    </div>
    <div class="modal-foot">
      <button class="btn-mcancel" onclick="closeModal('modalConfirm')">Cancelar</button>
      <button class="btn-primary" style="background:var(--danger);border-color:var(--danger);" id="confirmOkBtn">
        <i class="bi bi-trash"></i> Eliminar
      </button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/sidebar.js"></script>

<script>
/* ════════════════════════════════════════
   STATE
════════════════════════════════════════ */
let allLists    = [];
let allContacts = [];
let currentListId = null;   // null = todos
let selectedColors = '#3b82f6';
let confirmCb   = null;

const COLORS = ['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#f97316','#ec4899','#64748b'];
const esc = s => (s||'').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

/* ════════════════════════════════════════
   TOAST
════════════════════════════════════════ */
function toast(msg, type='inf', dur=4500){
  const icons={ok:'bi-check-circle-fill',err:'bi-x-circle-fill',inf:'bi-info-circle-fill'};
  const clrs ={ok:'var(--success)',err:'var(--danger)',inf:'var(--info)'};
  const el=document.createElement('div');
  el.className=`toast-item ${type}`;
  el.innerHTML=`<i class="bi ${icons[type]}" style="color:${clrs[type]};font-size:17px;flex-shrink:0;"></i><span>${msg}</span>`;
  document.getElementById('toastWrap').appendChild(el);
  setTimeout(()=>{el.style.cssText='opacity:0;transform:translateX(20px);transition:.3s;';setTimeout(()=>el.remove(),300);},dur);
}

/* ════════════════════════════════════════
   MODAL HELPERS
════════════════════════════════════════ */
const openModal  = id => document.getElementById(id).classList.add('open');
const closeModal = id => document.getElementById(id).classList.remove('open');
document.querySelectorAll('.modal-bg').forEach(o => {
  o.addEventListener('click', e => { if(e.target===o) o.classList.remove('open'); });
});

/* ════════════════════════════════════════
   LOAD LISTS (sidebar)
════════════════════════════════════════ */
async function loadLists(){
  try{
    const j = await fetch('/api/report-lists', {credentials:'include'}).then(r=>r.json());
    if(!j.success) throw new Error(j.error);
    allLists = j.data || [];
    renderSidebar();
  }catch(e){ toast('Error cargando listas: '+e.message,'err'); }
}

function renderSidebar(){
  const el = document.getElementById('listsSidebar');
  const allRow = `
    <div class="list-item ${currentListId===null?'active':''}" onclick="selectList(null)">
      <div class="list-dot" style="background:var(--primary);"></div>
      <span class="list-name">Todos los contactos</span>
      <span class="list-count">${allContacts.length}</span>
    </div>`;

  const rows = allLists.map(l => `
    <div class="list-item ${currentListId===l.id?'active':''}" onclick="selectList(${l.id})" id="litem_${l.id}">
      <div class="list-dot" style="background:${esc(l.color||'#3b82f6')};"></div>
      <span class="list-name">${esc(l.name)}</span>
      <span class="list-count">${l.member_count||0}</span>
      <div class="list-actions">
        <button class="list-edit-btn" onclick="event.stopPropagation();openModalEditList(${l.id})" title="Editar">
          <i class="bi bi-pencil"></i>
        </button>
        <button class="list-del-btn" onclick="event.stopPropagation();confirmDeleteList(${l.id},'${esc(l.name)}')" title="Eliminar">
          <i class="bi bi-trash3"></i>
        </button>
      </div>
    </div>`).join('');

  el.innerHTML = allRow + rows;
}

function selectList(id){
  currentListId = id;
  renderSidebar();
  loadContacts();
}

/* ════════════════════════════════════════
   LOAD CONTACTS
════════════════════════════════════════ */
async function loadContacts(){
  const tbody = document.getElementById('contactsTbody');
  tbody.innerHTML = `<tr><td colspan="5" class="empty-state"><span class="mini-spin"></span></td></tr>`;

  const title = currentListId === null
    ? 'Todos los destinatarios'
    : (allLists.find(l=>l.id===currentListId)?.name || '—');
  document.getElementById('panelTitle').textContent = title;

  try{
    let url = '/api/report-lists/contacts/all';
    if(currentListId) url += `?list_id=${currentListId}`;
    const j = await fetch(url, {credentials:'include'}).then(r=>r.json());
    if(!j.success) throw new Error(j.error);
    allContacts = j.data || [];
    renderContacts(allContacts);
  }catch(e){
    tbody.innerHTML = `<tr><td colspan="5" class="empty-state"><i class="bi bi-exclamation-triangle" style="color:var(--danger);"></i><p>${e.message}</p></td></tr>`;
  }
}

function renderContacts(list){
  const tbody = document.getElementById('contactsTbody');
  document.getElementById('contactCount').textContent = list.length;
  document.getElementById('contactsFooter').textContent = `${list.length} destinatario${list.length!==1?'s':''}`;

  if(!list.length){
    tbody.innerHTML = `<tr><td colspan="5" class="empty-state"><i class="bi bi-inbox"></i><p>Sin destinatarios${currentListId?' en esta lista':''}</p></td></tr>`;
    return;
  }

  tbody.innerHTML = list.map(c => {
    const listChips = c.lists
      ? c.lists.split(', ').map((ln, i) => {
          const lid = (c.list_ids||'').split(',')[i];
          const color = allLists.find(l=>String(l.id)===String(lid))?.color || '#64748b';
          return `<span class="list-chip" style="background:${hexA(color,.1)};color:${color};border-color:${hexA(color,.3)};">${esc(ln)}</span>`;
        }).join('')
      : '<span style="color:var(--muted);font-size:11px;">Sin lista</span>';

    return `<tr>
      <td style="font-weight:600;">${esc(c.name)}</td>
      <td style="font-size:12px;"><a href="mailto:${esc(c.email)}" style="color:var(--primary);">${esc(c.email)}</a></td>
      <td>${listChips}</td>
      <td><span class="pill ${c.is_active?'p-active':'p-inactive'}">${c.is_active?'✅ Activo':'⛔ Inactivo'}</span></td>
      <td style="white-space:nowrap;">
        <div style="display:flex;gap:5px;">
          <button class="btn-sm" onclick="openModalEditContact(${c.id})" title="Editar">
            <i class="bi bi-pencil"></i>
          </button>
          <button class="btn-sm danger" onclick="confirmDeleteContact(${c.id},'${esc(c.name)}')" title="Eliminar">
            <i class="bi bi-trash3"></i>
          </button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function filterContacts(){
  const q = document.getElementById('searchContacts').value.toLowerCase();
  if(!q){ renderContacts(allContacts); return; }
  const filtered = allContacts.filter(c =>
    c.name.toLowerCase().includes(q) || c.email.toLowerCase().includes(q)
  );
  renderContacts(filtered);
}

/* ════════════════════════════════════════
   MODAL: NUEVA / EDITAR LISTA
════════════════════════════════════════ */
function buildColorPicker(selected){
  document.getElementById('colorOpts').innerHTML = COLORS.map(c =>
    `<div class="color-opt${c===selected?' sel':''}" style="background:${c};" onclick="pickColor('${c}')" title="${c}"></div>`
  ).join('');
  selectedColors = selected || COLORS[0];
}

function pickColor(c){
  selectedColors = c;
  document.querySelectorAll('.color-opt').forEach(el => el.classList.toggle('sel', el.style.background===c));
}

function openModalNewList(){
  document.getElementById('listId').value = '';
  document.getElementById('listName').value = '';
  document.getElementById('listDesc').value = '';
  document.getElementById('modalListTitle').innerHTML = `<i class="bi bi-collection-fill" style="color:var(--primary);"></i> Nueva lista`;
  buildColorPicker(COLORS[0]);
  openModal('modalList');
  setTimeout(()=>document.getElementById('listName').focus(), 150);
}

async function openModalEditList(id){
  const l = allLists.find(x=>x.id===id);
  if(!l) return;
  document.getElementById('listId').value   = l.id;
  document.getElementById('listName').value = l.name;
  document.getElementById('listDesc').value = l.description||'';
  document.getElementById('modalListTitle').innerHTML = `<i class="bi bi-pencil-square" style="color:var(--primary);"></i> Editar lista`;
  buildColorPicker(l.color||COLORS[0]);
  openModal('modalList');
}

async function saveList(){
  const id   = document.getElementById('listId').value;
  const name = document.getElementById('listName').value.trim();
  const desc = document.getElementById('listDesc').value.trim();
  if(!name){ document.getElementById('listName').classList.add('invalid'); return; }
  document.getElementById('listName').classList.remove('invalid');
  document.getElementById('btnSaveList').disabled = true;

  try{
    const method = id ? 'PUT' : 'POST';
    const url    = id ? `/api/report-lists/${id}` : '/api/report-lists';
    const j = await fetch(url,{method,credentials:'include',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({name, description:desc||null, color:selectedColors, icon:'bi-people'})
    }).then(r=>r.json());
    if(!j.success) throw new Error(j.error);
    toast(id ? 'Lista actualizada' : 'Lista creada','ok');
    closeModal('modalList');
    await loadLists();
    await loadContacts();
  }catch(e){ toast('Error: '+e.message,'err'); }
  finally{ document.getElementById('btnSaveList').disabled=false; }
}

/* ════════════════════════════════════════
   MODAL: NUEVO / EDITAR CONTACTO
════════════════════════════════════════ */
function buildListCheckGrid(selectedIds=[]){
  const grid = document.getElementById('listCheckGrid');
  if(!allLists.length){
    grid.innerHTML = `<div style="color:var(--muted);font-size:12px;padding:8px;">Sin listas disponibles — crea una primero</div>`;
    return;
  }
  grid.innerHTML = allLists.map(l => {
    const checked = selectedIds.includes(l.id) || selectedIds.includes(String(l.id));
    return `<label class="list-chk-row${checked?' checked':''}" id="chk_row_${l.id}">
      <input type="checkbox" value="${l.id}" ${checked?'checked':''}
             onchange="toggleChkRow(this,${l.id})">
      <div class="list-chk-dot" style="background:${esc(l.color||'#3b82f6')};"></div>
      <span class="list-chk-name">${esc(l.name)}</span>
      <span style="font-size:11px;color:var(--muted);">${l.member_count||0} miembros</span>
      <div class="list-chk-icon"><i class="bi bi-check"></i></div>
    </label>`;
  }).join('');
}

function toggleChkRow(inp, id){
  document.getElementById('chk_row_'+id).classList.toggle('checked', inp.checked);
}

function getCheckedLists(){
  return [...document.querySelectorAll('#listCheckGrid input:checked')].map(i => +i.value);
}

function openModalNewContact(){
  document.getElementById('contactId').value    = '';
  document.getElementById('contactName').value  = '';
  document.getElementById('contactEmail').value = '';
  document.getElementById('contactName').classList.remove('invalid');
  document.getElementById('contactEmail').classList.remove('invalid');
  document.getElementById('modalContactTitle').innerHTML = `<i class="bi bi-person-plus-fill" style="color:var(--success);"></i> Añadir destinatario`;
  // Pre-seleccionar lista actual si hay una activa
  buildListCheckGrid(currentListId ? [currentListId] : []);
  openModal('modalContact');
  setTimeout(()=>document.getElementById('contactName').focus(), 150);
}

async function openModalEditContact(id){
  const c = allContacts.find(x=>x.id===id);
  if(!c) return;
  document.getElementById('contactId').value    = c.id;
  document.getElementById('contactName').value  = c.name;
  document.getElementById('contactEmail').value = c.email;
  document.getElementById('contactName').classList.remove('invalid');
  document.getElementById('contactEmail').classList.remove('invalid');
  document.getElementById('modalContactTitle').innerHTML = `<i class="bi bi-pencil-square" style="color:var(--primary);"></i> Editar destinatario`;
  const selectedIds = (c.list_ids||'').split(',').filter(Boolean);
  buildListCheckGrid(selectedIds);
  openModal('modalContact');
}

async function saveContact(){
  const id    = document.getElementById('contactId').value;
  const name  = document.getElementById('contactName').value.trim();
  const email = document.getElementById('contactEmail').value.trim();
  let valid   = true;

  if(!name)  { document.getElementById('contactName').classList.add('invalid');  valid=false; }
  else         document.getElementById('contactName').classList.remove('invalid');
  if(!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){
    document.getElementById('contactEmail').classList.add('invalid'); valid=false;
  } else {
    document.getElementById('contactEmail').classList.remove('invalid');
  }
  if(!valid) return;

  const list_ids = getCheckedLists();
  document.getElementById('btnSaveContact').disabled = true;

  try{
    const method = id ? 'PUT' : 'POST';
    const url    = id ? `/api/report-lists/contacts/${id}` : '/api/report-lists/contacts';
    const j = await fetch(url,{method,credentials:'include',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({name, email, list_ids})
    }).then(r=>r.json());
    if(!j.success) throw new Error(j.error);
    toast(id ? 'Destinatario actualizado' : `✅ ${name} añadido correctamente`,'ok');
    closeModal('modalContact');
    await loadLists();
    await loadContacts();
  }catch(e){ toast('Error: '+e.message,'err'); }
  finally{ document.getElementById('btnSaveContact').disabled=false; }
}

/* ════════════════════════════════════════
   ELIMINAR
════════════════════════════════════════ */
function confirmDeleteList(id, name){
  document.getElementById('confirmMsg').innerHTML =
    `¿Eliminar la lista <strong>"${esc(name)}"</strong>? Los contactos no se borrarán, solo se desvinculan de la lista.`;
  document.getElementById('confirmOkBtn').onclick = async () => {
    try{
      const j = await fetch(`/api/report-lists/${id}`,{method:'DELETE',credentials:'include'}).then(r=>r.json());
      if(!j.success) throw new Error(j.error);
      toast('Lista eliminada','ok');
      closeModal('modalConfirm');
      if(currentListId===id) currentListId=null;
      await loadLists();
      await loadContacts();
    }catch(e){ toast('Error: '+e.message,'err'); }
  };
  openModal('modalConfirm');
}

function confirmDeleteContact(id, name){
  document.getElementById('confirmMsg').innerHTML =
    `¿Eliminar a <strong>"${esc(name)}"</strong> de todos los destinatarios? Esta acción no se puede deshacer.`;
  document.getElementById('confirmOkBtn').onclick = async () => {
    try{
      const j = await fetch(`/api/report-lists/contacts/${id}`,{method:'DELETE',credentials:'include'}).then(r=>r.json());
      if(!j.success) throw new Error(j.error);
      toast('Destinatario eliminado','ok');
      closeModal('modalConfirm');
      await loadLists();
      await loadContacts();
    }catch(e){ toast('Error: '+e.message,'err'); }
  };
  openModal('modalConfirm');
}

/* ════════════════════════════════════════
   EXPORT CSV
════════════════════════════════════════ */
function exportContacts(){
  if(!allContacts.length){ toast('Sin datos para exportar','inf'); return; }
  const rows = [
    ['Nombre','Email','Listas','Estado'],
    ...allContacts.map(c => [c.name, c.email, c.lists||'', c.is_active?'Activo':'Inactivo'])
  ].map(r => r.map(v=>`"${(v||'').toString().replace(/"/g,'""')}"`).join(','));
  const a = Object.assign(document.createElement('a'),{
    href: URL.createObjectURL(new Blob([rows.join('\n')],{type:'text/csv;charset=utf-8;'})),
    download: `destinatarios_${new Date().toISOString().split('T')[0]}.csv`
  });
  a.click();
  toast(`Exportados: ${allContacts.length} contactos`,'ok');
}

/* ════════════════════════════════════════
   COLOR HELPER
════════════════════════════════════════ */
function hexA(hex, alpha){
  const r=parseInt((hex||'#3b82f6').slice(1,3),16);
  const g=parseInt((hex||'#3b82f6').slice(3,5),16);
  const b=parseInt((hex||'#3b82f6').slice(5,7),16);
  return `rgba(${r},${g},${b},${alpha})`;
}

/* ════════════════════════════════════════
   INIT
════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', async () => {
  await loadLists();
  await loadContacts();
});
</script>
</body>
</html>
