// ── Open edit modal ─────────────────────────────────────────────
function openEditAsg(a){
  document.getElementById('editAsgId').value=a.assignment_id;
  document.getElementById('editAsgEmployee').value=a.employee_name||'';
  document.getElementById('editAsgCip').value=a.employee_cip||'';
  document.getElementById('editAsgEquipment').value=a.equipment_code||'';
  document.getElementById('editAsgModel').value=a.equipment_model||'';
  document.getElementById('editAsgDept').value=a.department_name||'';
  document.getElementById('editAsgDeptId').value=a.department_id||'';
  document.getElementById('editAsgLoc').value=a.location_name||'';
  document.getElementById('editAsgLocId').value=a.location_id||'';
  document.getElementById('editAsgDate').value=a.assignment_date?a.assignment_date.substring(0,10):'';
  new bootstrap.Modal(document.getElementById('editAssignmentModal')).show();
}

// ── Save new ────────────────────────────────────────────────────
document.getElementById('btnSaveNewAsg').addEventListener('click',async()=>{
  const spinner=document.getElementById('spinnerNewAsg');spinner.classList.remove('d-none');
  try{
    const body={
      employee_id:document.getElementById('addEmployeeId').value||null,
      employee_cip:document.getElementById('addEmployeeCip').value||null,
      equipment_code:document.getElementById('addEquipmentCode').value,
      department_id:document.getElementById('addDepartmentId').value||null,
      location_id:document.getElementById('addLocationId').value||null,
      assignment_date:document.getElementById('addAssignmentDate').value
    };
    if(!body.employee_id&&!body.employee_cip){toast('Selecciona un empleado de la lista','err');return;}
    if(!body.equipment_code||!body.assignment_date){toast('Completa los campos obligatorios','err');return;}
    const res=await fetch('/api/assignments',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const json=await res.json();if(!json.success)throw new Error(json.message||'Error');
    bootstrap.Modal.getInstance(document.getElementById('addAssignmentModal'))?.hide();
    toast('Asignación creada','ok');loadAsgData();
  }catch(e){toast('Error: '+e.message,'err');}
  finally{spinner.classList.add('d-none');}
});

// ── Save edit ───────────────────────────────────────────────────
document.getElementById('btnSaveEditAsg').addEventListener('click',async()=>{
  const spinner=document.getElementById('spinnerEditAsg');spinner.classList.remove('d-none');
  try{
    const body={
      assignment_id:document.getElementById('editAsgId').value,
      employee_cip:document.getElementById('editAsgCip').value,
      employee_name:document.getElementById('editAsgEmployee').value,
      equipment_code:document.getElementById('editAsgEquipment').value,
      department_id:document.getElementById('editAsgDeptId').value||null,
      location_id:document.getElementById('editAsgLocId').value||null,
      assignment_date:document.getElementById('editAsgDate').value
    };
    const res=await fetch('/api/assignments/update',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const json=await res.json();if(!json.success)throw new Error(json.message||'Error');
    bootstrap.Modal.getInstance(document.getElementById('editAssignmentModal'))?.hide();
    toast('Actualizado','ok');loadAsgData();
  }catch(e){toast('Error: '+e.message,'err');}
  finally{spinner.classList.add('d-none');}
});

// ── Search ──────────────────────────────────────────────────────
let asgSearchTimer=null;
document.getElementById('asgSearch').addEventListener('input',e=>{
  clearTimeout(asgSearchTimer);
  asgSearchTimer=setTimeout(()=>{asgSearchTerm=e.target.value.trim();ASG_PAGE=1;applyAsgFilters();},350);
});

// ── Nueva button ────────────────────────────────────────────────
document.getElementById('btnNuevaAsg').addEventListener('click',()=>{
  // Limpiar todos los campos para evitar valores viejos
  ['addEmployeeName','addEmployeeCip','addEquipmentCode','addEquipmentModel','addDepartmentName','addLocationName'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.value='';
  });
  ['addEmployeeId','addDepartmentId','addLocationId'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.value='';
  });
  document.getElementById('addAssignmentDate').value=new Date().toISOString().split('T')[0];
  new bootstrap.Modal(document.getElementById('addAssignmentModal')).show();
});

// ── Theme sync (charts rerender) ────────────────────────────────
window.addEventListener('themeChanged',()=>{if(ASG_DATA.length)setTimeout(renderAsgChart,80);});

// ── Init ────────────────────────────────────────────────────────
loadAsgData();
initAddModalAC();
initEditModalAC();
</script>
</body>
</html>
