<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gestión de Asignaciones</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
/* ── Variables ─────────────────────────────────────────────────── */
:root,[data-theme="light"]{
  --bg:#f0f4f8; --card:#ffffff; --header:#f8fafc;
  --border:#e2e8f0; --text:#1e293b; --muted:#64748b;
  --primary:#3b82f6; --success:#10b981; --warning:#f59e0b;
  --danger:#ef4444; --info:#06b6d4; --purple:#8b5cf6;
  --row-hover:#f1f5f9; --shadow:0 1px 3px rgba(0,0,0,.07);
  --shadow-md:0 4px 16px rgba(0,0,0,.10); --input-bg:#f8fafc;
  --row-recent-bg:#f0fdf4; --row-recent-border:#10b981;
  --eq-laptop-bg:#dbeafe;  --eq-laptop-color:#2563eb;
  --eq-desktop-bg:#d1fae5; --eq-desktop-color:#059669;
  --eq-monitor-bg:#fef3c7; --eq-monitor-color:#d97706;
  --eq-tablet-bg:#ede9fe;  --eq-tablet-color:#7c3aed;
}
[data-theme="dark"]{
  --bg:#0f172a; --card:#1e293b; --header:#162032;
  --border:#2d3f55; --text:#e2e8f0; --muted:#94a3b8;
  --primary:#60a5fa; --success:#34d399; --warning:#fbbf24;
  --danger:#f87171; --info:#22d3ee; --purple:#a78bfa;
  --row-hover:#243348; --shadow:0 1px 3px rgba(0,0,0,.3);
  --shadow-md:0 4px 16px rgba(0,0,0,.4); --input-bg:#162032;
  --row-recent-bg:#0a2a1a; --row-recent-border:#34d399;
  --eq-laptop-bg:#1e3a5f;  --eq-laptop-color:#93c5fd;
  --eq-desktop-bg:#064e3b; --eq-desktop-color:#6ee7b7;
  --eq-monitor-bg:#422006; --eq-monitor-color:#fde68a;
  --eq-tablet-bg:#2e1065;  --eq-tablet-color:#c4b5fd;
}

*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);
  font-family:"DM Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
  transition:background .3s,color .3s;font-size:13.5px;}

/* ── Layout ───────────────────────────────────────────────────── */
.pg{margin-top:60px;padding:20px 24px;display:flex;flex-direction:column;gap:16px;}

/* ── KPI grid ─────────────────────────────────────────────────── */
.kpi-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;}
@media(max-width:1200px){.kpi-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:640px) {.kpi-grid{grid-template-columns:repeat(2,1fr);}}
.kpi{
  background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:16px 18px;box-shadow:var(--shadow);
  transition:transform .2s,background .3s,border-color .3s;
  cursor:default;position:relative;overflow:hidden;
}
.kpi:hover{transform:translateY(-2px);box-shadow:var(--shadow-md);}
.kpi-label{font-size:10px;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:700;margin-bottom:8px;}
.kpi-val  {font-size:30px;font-weight:900;line-height:1;letter-spacing:-1px;}
.kpi-sub  {font-size:10px;color:var(--muted);margin-top:4px;}
.kpi-val.sm{font-size:14px;letter-spacing:0;margin-top:4px;}
.kpi-icon {font-size:28px;opacity:.14;position:absolute;right:16px;top:50%;transform:translateY(-50%);}
.c-primary{color:var(--primary);} .c-success{color:var(--success);} .c-warning{color:var(--warning);}
.c-danger {color:var(--danger);}  .c-info   {color:var(--info);}    .c-purple {color:var(--purple);}
.c-muted  {color:var(--muted);}

/* ── Charts row ───────────────────────────────────────────────── */
.charts-row{display:grid;grid-template-columns:1.7fr 1fr;gap:14px;}
@media(max-width:1100px){.charts-row{grid-template-columns:1fr;}}
.chart-card{
  background:var(--card);border:1px solid var(--border);border-radius:14px;
  overflow:hidden;box-shadow:var(--shadow);transition:background .3s,border-color .3s;
}
.chart-head{
  padding:13px 18px;background:var(--header);border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);
  transition:background .3s,border-color .3s;
}
.chart-head i{font-size:15px;margin-right:7px;}
.chart-body{padding:16px;position:relative;}
.chart-body canvas{max-height:225px;}

/* ── Top list ─────────────────────────────────────────────────── */
.top-list{padding:0;margin:0;list-style:none;}
.top-list-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 16px;border-bottom:1px solid var(--border);font-size:12px;
  transition:background .1s;
}
.top-list-item:last-child{border-bottom:none;}
.top-list-item:hover{background:var(--row-hover);}
.rank-badge{
  width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:10px;font-weight:800;flex-shrink:0;background:var(--border);color:var(--muted);
}
.rank-1{background:#ffd700;color:#000;} .rank-2{background:#c0c0c0;color:#000;} .rank-3{background:#cd7f32;color:#fff;}
.top-name{flex:1;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.top-bar-wrap{width:76px;background:var(--border);border-radius:4px;height:5px;}
.top-bar{height:5px;border-radius:4px;background:var(--primary);}
.top-count{font-weight:700;font-size:12px;color:var(--text);min-width:28px;text-align:right;}

/* ── Main table card ──────────────────────────────────────────── */
.main-panel{
  background:var(--card);border:1px solid var(--border);border-radius:14px;
  overflow:hidden;box-shadow:var(--shadow);transition:background .3s,border-color .3s;
}
.tbl-head{
  padding:14px 18px;background:var(--header);border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;
  transition:background .3s,border-color .3s;
}
.tbl-head-title{font-size:14px;font-weight:800;color:var(--text);display:flex;align-items:center;gap:8px;letter-spacing:-.2px;}
.toolbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}

/* Search bar */
.search-wrap{position:relative;}
.search-wrap i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none;}
.search-input{
  background:var(--input-bg);border:1px solid var(--border);color:var(--text);
  border-radius:9px;padding:7px 12px 7px 32px;font-size:12.5px;width:300px;outline:none;
  transition:background .3s,border-color .2s,color .3s;
}
.search-input:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.12);}
.search-input::placeholder{color:var(--muted);}

/* Filter pills */
.filter-bar{
  padding:10px 18px;border-bottom:1px solid var(--border);background:var(--card);
  display:flex;align-items:center;gap:8px;flex-wrap:wrap;
  transition:background .3s,border-color .3s;
}
.filter-label{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.4px;}
.fpill{
  padding:4px 14px;border-radius:20px;font-size:12px;font-weight:600;
  border:1px solid var(--border);background:var(--input-bg);color:var(--muted);
  cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:5px;
}
.fpill:hover{border-color:var(--primary);color:var(--primary);}
.fpill.active{background:var(--primary);color:#fff;border-color:var(--primary);}
.fpill-warn.active{background:var(--warning);border-color:var(--warning);color:#000;}

/* Buttons */
.btn-primary-sm{
  background:var(--primary);color:#fff;border:none;border-radius:9px;
  padding:7px 16px;font-size:12.5px;font-weight:700;cursor:pointer;
  display:inline-flex;align-items:center;gap:6px;transition:all .2s;white-space:nowrap;
}
.btn-primary-sm:hover{filter:brightness(1.1);transform:translateY(-1px);}
.btn-ghost-sm{
  background:transparent;border:1px solid var(--border);color:var(--muted);
  border-radius:9px;padding:7px 12px;font-size:12px;cursor:pointer;
  display:inline-flex;align-items:center;gap:5px;transition:all .15s;
}
.btn-ghost-sm:hover{border-color:var(--primary);color:var(--primary);}
.btn-success-sm{
  background:var(--success);color:#fff;border:none;border-radius:9px;
  padding:7px 14px;font-size:12.5px;font-weight:700;cursor:pointer;
  display:inline-flex;align-items:center;gap:6px;transition:all .2s;
}
.btn-success-sm:hover{filter:brightness(1.1);}
.badge-count{
  background:var(--info);color:#fff;border-radius:20px;
  padding:2px 9px;font-size:11px;font-weight:700;
}

/* Table */
.tbl-scroll{overflow-x:auto;overflow-y:auto;max-height:520px;}
.tbl{width:100%;border-collapse:collapse;font-size:12.5px;}
.tbl thead th{
  font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);
  font-weight:700;padding:10px 14px;background:var(--header);
  border-bottom:1px solid var(--border);white-space:nowrap;
  position:sticky;top:0;z-index:5;text-align:center;
  transition:background .3s,color .3s,border-color .3s;
}
.tbl thead th:first-child{text-align:left;}
.tbl tbody td{
  padding:11px 14px;border-bottom:1px solid var(--border);
  color:var(--text);vertical-align:middle;text-align:center;
  transition:border-color .3s,color .3s,background .1s;
}
.tbl tbody td:first-child{text-align:left;}
.tbl tbody tr:last-child td{border-bottom:none;}
.tbl tbody tr{transition:background .1s;}
.tbl tbody tr:hover td{background:var(--row-hover);}
.tbl tbody tr.row-recent td{background:var(--row-recent-bg);}
.tbl tbody tr.row-recent td:first-child{border-left:3px solid var(--success);}

/* Pagination */
.tbl-foot{padding:10px 18px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.tbl-info{font-size:11.5px;color:var(--muted);}
.pagination{display:flex;gap:4px;}
.pg-btn{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:7px;padding:4px 10px;font-size:12px;cursor:pointer;transition:.15s;}
.pg-btn:hover,.pg-btn.active{background:var(--primary);color:#fff;border-color:var(--primary);}
.pg-btn:disabled{opacity:.4;cursor:not-allowed;}

/* Pills / Badges */
.pill{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;line-height:1.6;}
.p-blue  {background:rgba(59,130,246,.13);color:var(--primary);}
.p-green {background:rgba(16,185,129,.13);color:var(--success);}
.p-yellow{background:rgba(245,158,11,.13);color:var(--warning);}
.p-red   {background:rgba(239,68,68,.13); color:var(--danger);}
.p-gray  {background:rgba(100,116,139,.1);color:var(--muted);}
.p-purple{background:rgba(139,92,246,.13);color:var(--purple);}
[data-theme="dark"] .p-purple{background:rgba(167,139,250,.2);}

/* Eq type icon */
.eq-icon{
  width:26px;height:26px;border-radius:6px;
  display:inline-flex;align-items:center;justify-content:center;
  font-size:13px;margin-right:5px;flex-shrink:0;vertical-align:middle;
}
.eq-laptop {background:var(--eq-laptop-bg);color:var(--eq-laptop-color);}
.eq-desktop{background:var(--eq-desktop-bg);color:var(--eq-desktop-color);}
.eq-monitor{background:var(--eq-monitor-bg);color:var(--eq-monitor-color);}
.eq-tablet {background:var(--eq-tablet-bg);color:var(--eq-tablet-color);}
.eq-other  {background:var(--border);color:var(--muted);}

/* Empty state */
.empty-state{text-align:center;padding:56px 20px;color:var(--muted);}
.empty-state i{font-size:36px;display:block;margin-bottom:12px;opacity:.3;}
.empty-state p{font-size:13px;}

/* Toast */
.toast-wrap{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;}
.toast-item{
  background:var(--card);border:1px solid var(--border);color:var(--text);
  border-radius:12px;padding:12px 18px;font-size:13px;font-weight:500;
  box-shadow:var(--shadow-md);display:flex;align-items:center;gap:10px;min-width:260px;
  animation:toastIn .25s ease;
}
.toast-item.ok {border-left:4px solid var(--success);}
.toast-item.err{border-left:4px solid var(--danger);}
.toast-item.inf{border-left:4px solid var(--info);}
@keyframes toastIn{from{opacity:0;transform:translateX(24px);}to{opacity:1;transform:translateX(0);}}

/* Modal */
.modal-content{border-radius:16px;border:none;background:var(--card);box-shadow:0 24px 64px rgba(0,0,0,.25);}
.modal-header{
  border-bottom:1px solid var(--border);padding:20px 24px;
  border-radius:16px 16px 0 0;background:var(--header);
  display:flex;align-items:center;justify-content:space-between;
}
.modal-title-text{font-size:15px;font-weight:800;color:var(--text);display:flex;align-items:center;gap:8px;}
.modal-title-text i{color:var(--primary);}
.modal-title-text.success i{color:var(--success);}
.modal-body{padding:24px;background:var(--card);}
.modal-footer{border-top:1px solid var(--border);padding:16px 24px;background:var(--card);border-radius:0 0 16px 16px;}
.form-label{font-weight:700;font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px;display:block;}
.form-control,.form-select{
  border:1px solid var(--border);border-radius:9px;
  padding:9px 13px;font-size:13px;background:var(--input-bg);
  color:var(--text);outline:none;width:100%;transition:all .2s;
}
.form-control:focus,.form-select:focus{
  border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.12);
}
.form-control::placeholder{color:var(--muted);}
.form-control[readonly]{opacity:.65;cursor:not-allowed;}

/* Autocomplete */
.autocomplete-results{
  display:none;max-height:200px;overflow-y:auto;
  border:1px solid var(--border);border-radius:9px;margin-top:4px;
  box-shadow:var(--shadow-md);background:var(--card);z-index:9999;position:relative;
}
.autocomplete-item{padding:10px 13px;cursor:pointer;border-bottom:1px solid var(--border);transition:background .12s;font-size:13px;}
.autocomplete-item:hover{background:var(--row-hover);}
.autocomplete-item:last-child{border-bottom:none;}
.ac-name{font-weight:700;display:block;color:var(--text);}
.ac-sub {font-size:11px;color:var(--muted);}

/* Btn modal */
.btn-modal{
  border:none;border-radius:9px;padding:9px 20px;font-size:13px;font-weight:700;
  cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;
}
.btn-modal.primary{background:var(--primary);color:#fff;}
.btn-modal.primary:hover{filter:brightness(1.1);}
.btn-modal.success{background:var(--success);color:#fff;}
.btn-modal.success:hover{filter:brightness(1.1);}
.btn-modal.cancel{background:transparent;border:1px solid var(--border);color:var(--muted);}
.btn-modal.cancel:hover{border-color:var(--text);color:var(--text);}

/* Spinner */
@keyframes spin{to{transform:rotate(360deg);}}
.spin-anim{animation:spin .7s linear infinite;}
.d-none{display:none!important;}

/* Scrollbar */
*::-webkit-scrollbar{width:5px;height:5px;}
*::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
*::-webkit-scrollbar-track{background:transparent;}
</style>
</head>
<body>

<%- include("partials/sidebar_top") %>

<div class="toast-wrap" id="toastWrap"></div>

<div class="pg">

  <!-- ── KPIs ──────────────────────────────────────────────────── -->
  <div class="kpi-grid">
    <div class="kpi">
      <div class="kpi-label">Total Activas</div>
      <div class="kpi-val c-info" id="asgTotal">—</div>
      <div class="kpi-sub">activas</div>
      <i class="bi bi-clipboard-check kpi-icon c-info"></i>
    </div>
    <div class="kpi">
      <div class="kpi-label">Este Mes</div>
      <div class="kpi-val c-primary" id="asgEsteMes">—</div>
      <div class="kpi-sub">asignaciones</div>
      <i class="bi bi-calendar-check kpi-icon c-primary"></i>
    </div>
    <div class="kpi">
      <div class="kpi-label">Multi-Equipo</div>
      <div class="kpi-val c-warning" id="asgMulti">—</div>
      <div class="kpi-sub">empleados</div>
      <i class="bi bi-layers kpi-icon c-warning"></i>
    </div>
    <div class="kpi">
      <div class="kpi-label">Última Asignación</div>
      <div class="kpi-val sm c-success" id="asgUltima">—</div>
      <i class="bi bi-clock-history kpi-icon c-success"></i>
    </div>
    <div class="kpi">
      <div class="kpi-label">Modelo Top</div>
      <div class="kpi-val sm c-purple" id="asgModeloTop">—</div>
      <i class="bi bi-trophy kpi-icon c-purple"></i>
    </div>
    <div class="kpi">
      <div class="kpi-label">Depto Top</div>
      <div class="kpi-val sm c-danger" id="asgDeptoTop">—</div>
      <i class="bi bi-building kpi-icon c-danger"></i>
    </div>
  </div>

  <!-- ── Charts ────────────────────────────────────────────────── -->
  <div class="charts-row">
    <div class="chart-card">
      <div class="chart-head">
        <span><i class="bi bi-bar-chart-fill c-primary"></i>Asignaciones por Mes (últimos 12 meses)</span>
        <button class="btn-ghost-sm" onclick="dlAsgChart()" title="Descargar">
          <i class="bi bi-download"></i>
        </button>
      </div>
      <div class="chart-body">
        <canvas id="asgChartBar"></canvas>
      </div>
    </div>
    <div class="chart-card">
      <div class="chart-head">
        <span><i class="bi bi-trophy-fill c-warning"></i>Top Modelos Asignados</span>
      </div>
      <div style="max-height:268px;overflow-y:auto;">
        <ul class="top-list" id="asgTopModelos"></ul>
      </div>
    </div>
  </div>

  <!-- ── Table card ─────────────────────────────────────────────── -->
  <div class="main-panel">

    <!-- Header -->
    <div class="tbl-head">
      <div class="tbl-head-title">
        <i class="bi bi-table"></i>
        Lista de Asignaciones
        <span class="badge-count" id="asgTableCount">0</span>
      </div>
      <div class="toolbar">
        <div class="search-wrap">
          <i class="bi bi-search"></i>
          <input type="text" class="search-input" id="asgSearch"
                 placeholder="Buscar por empleado, CIP, equipo, modelo, departamento o ubicación...">
        </div>
        <button class="btn-success-sm" id="btnNuevaAsg">
          <i class="bi bi-plus-circle"></i> Nueva
        </button>
        <button class="btn-ghost-sm" onclick="loadAsgData()" title="Recargar">
          <i class="bi bi-arrow-clockwise"></i>
        </button>
        <button class="btn-ghost-sm" onclick="exportAsg('excel')" title="Excel">
          <i class="bi bi-file-earmark-excel c-success"></i>
        </button>
        <button class="btn-ghost-sm" onclick="exportAsg('csv')" title="CSV">
          <i class="bi bi-file-earmark-text c-info"></i>
        </button>
      </div>
    </div>

    <!-- Filter pills -->
    <div class="filter-bar">
      <span class="filter-label">Filtrar:</span>
      <div class="fpill active" id="pill-all"   onclick="setPill('all')">Todos</div>
      <div class="fpill"       id="pill-month"  onclick="setPill('month')">
        <i class="bi bi-calendar3"></i> Último mes
      </div>
      <div class="fpill fpill-warn" id="pill-multi" onclick="setPill('multi')">
        <i class="bi bi-layers"></i> Multi-equipo
      </div>
    </div>

    <!-- Table -->
    <div class="tbl-scroll">
      <table class="tbl">
        <thead>
          <tr>
            <th>ID</th><th>Empleado</th><th>CIP</th><th>Equipo</th>
            <th>Modelo</th><th>Tipo</th><th>Fecha</th>
            <th>Departamento</th><th>Ubicación</th><th>Acciones</th>
          </tr>
        </thead>
        <tbody id="asgTableBody">
          <tr><td colspan="10" class="empty-state">
            <i class="bi bi-arrow-repeat spin-anim"></i>
            <p>Cargando asignaciones...</p>
          </td></tr>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="tbl-foot">
      <span class="tbl-info" id="asgPagInfo"></span>
      <div class="pagination" id="asgPagBtns"></div>
    </div>

  </div><!-- /.main-panel -->

</div><!-- /.pg -->


<!-- ── Modal Nueva Asignación ──────────────────────────────────── -->
<div class="modal fade" id="addAssignmentModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <div class="modal-title-text success">
          <i class="bi bi-plus-circle"></i> Nueva Asignación
        </div>
        <button type="button" class="btn-ghost-sm" data-bs-dismiss="modal" style="padding:4px 8px;">
          <i class="bi bi-x-lg"></i>
        </button>
