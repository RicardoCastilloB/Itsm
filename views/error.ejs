<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/sidebar.js"></script>
<script>
// ── State ───────────────────────────────────────────────────────
let ASG_DATA=[], ASG_FILTERED=[], ASG_PAGE=1;
const ASG_PER_PAGE=25;
let asgChart=null, asgActivePill='all', asgSearchTerm='';

// ── Toast ───────────────────────────────────────────────────────
function toast(msg, type='inf', dur=4000){
  const icons={ok:'bi-check-circle-fill',err:'bi-x-circle-fill',inf:'bi-info-circle-fill'};
  const clrs ={ok:'var(--success)',err:'var(--danger)',inf:'var(--info)'};
  const wrap=document.getElementById('toastWrap');
  const el=document.createElement('div');
  el.className=`toast-item ${type}`;
  el.innerHTML=`<i class="bi ${icons[type]||icons.inf}" style="color:${clrs[type]||clrs.inf};font-size:17px;flex-shrink:0;"></i><span>${msg}</span>`;
  wrap.appendChild(el);
  setTimeout(()=>{el.style.cssText='opacity:0;transform:translateX(20px);transition:.3s;';setTimeout(()=>el.remove(),300);},dur);
}

// ── Helpers ─────────────────────────────────────────────────────
function fmtDate(d){if(!d)return '—';const dt=new Date(d);return isNaN(dt)?d:dt.toLocaleDateString('es-PE');}

function eqIcon(type){
  const map={
    'Laptop':'eq-laptop bi-laptop',
    'Desktop':'eq-desktop bi-pc-display',
    'Monitor':'eq-monitor bi-display',
    'Tablet':'eq-tablet bi-tablet'
  };
  const cls=map[type]||'eq-other bi-device-hdd';
  const[bg,ic]=cls.split(' ');
  return `<span class="eq-icon ${bg}"><i class="bi ${ic}"></i></span>`;
}

function typePill(type){
  const map={
    'Laptop':'p-blue','Desktop':'p-green',
    'Monitor':'p-yellow','Tablet':'p-purple'
  };
  return `<span class="pill ${map[type]||'p-gray'}">${type||'—'}</span>`;
}

// ── Load data ───────────────────────────────────────────────────
async function loadAsgData(){
  document.getElementById('asgTableBody').innerHTML=
    '<tr><td colspan="10" class="empty-state"><i class="bi bi-arrow-repeat spin-anim"></i><p>Cargando asignaciones...</p></td></tr>';
  try{
    const res=await fetch('/api/assignments');
    const json=await res.json();
    if(!json.success)throw new Error(json.message||'Error API');
    ASG_DATA=json.data||[];
    renderAsgKPIs();
    renderAsgChart();
    renderAsgTopModels();
    applyAsgFilters();
  }catch(e){
    document.getElementById('asgTableBody').innerHTML=
      `<tr><td colspan="10" class="empty-state"><i class="bi bi-exclamation-triangle-fill"></i><p>Error: ${e.message}</p></td></tr>`;
    toast('Error al cargar: '+e.message,'err');
  }
}

// ── KPIs ────────────────────────────────────────────────────────
function renderAsgKPIs(){
  const now=new Date(),y=now.getFullYear(),m=now.getMonth();
  const esteMes=ASG_DATA.filter(a=>{const d=new Date(a.assignment_date);return d.getFullYear()===y&&d.getMonth()===m;}).length;
  const byEmp={};ASG_DATA.forEach(a=>{byEmp[a.employee_cip]=(byEmp[a.employee_cip]||0)+1;});
  const multi=Object.values(byEmp).filter(v=>v>1).length;
  const sorted=[...ASG_DATA].sort((a,b)=>new Date(b.assignment_date)-new Date(a.assignment_date));
  const ultima=sorted[0]?fmtDate(sorted[0].assignment_date):'—';
  const byModel={};ASG_DATA.forEach(a=>{byModel[a.equipment_model]=(byModel[a.equipment_model]||0)+1;});
  const modelTop=Object.entries(byModel).sort((a,b)=>b[1]-a[1])[0];
  const byDept={};ASG_DATA.forEach(a=>{const d=a.department_name||'Sin depto';if(d!=='Sin departamento')byDept[d]=(byDept[d]||0)+1;});
  const deptTop=Object.entries(byDept).sort((a,b)=>b[1]-a[1])[0];
  document.getElementById('asgTotal').textContent=ASG_DATA.length;
  document.getElementById('asgEsteMes').textContent=esteMes;
  document.getElementById('asgMulti').textContent=multi;
  document.getElementById('asgUltima').textContent=ultima;
  document.getElementById('asgModeloTop').textContent=modelTop?modelTop[0]:'—';
  document.getElementById('asgDeptoTop').textContent=deptTop?deptTop[0].substring(0,18)+(deptTop[0].length>18?'…':''):'—';
}

// ── Chart ───────────────────────────────────────────────────────
function isDark(){return document.documentElement.getAttribute('data-theme')==='dark';}
function tText() {return isDark()?'#94a3b8':'#64748b';}
function tGrid() {return isDark()?'rgba(255,255,255,.04)':'rgba(0,0,0,.04)';}

function renderAsgChart(){
  const months=[],counts={};
  for(let i=11;i>=0;i--){
    const d=new Date();d.setMonth(d.getMonth()-i);
    const key=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
    const label=d.toLocaleDateString('es-PE',{month:'short',year:'2-digit'});
    months.push({key,label});counts[key]=0;
  }
  ASG_DATA.forEach(a=>{if(!a.assignment_date)return;const k=a.assignment_date.substring(0,7);if(counts[k]!==undefined)counts[k]++;});
  const labels=months.map(m=>m.label);
  const data=months.map(m=>counts[m.key]);
  const maxVal=Math.max(...data);
  const primaryColor=isDark()?'#60a5fa':'#3b82f6';
  const dimColor=isDark()?'rgba(96,165,250,.25)':'rgba(59,130,246,.2)';
  const colors=data.map(v=>v===maxVal&&v>0?primaryColor:dimColor);
  const ctx=document.getElementById('asgChartBar').getContext('2d');
  if(asgChart)asgChart.destroy();
  asgChart=new Chart(ctx,{
    type:'bar',
    data:{labels,datasets:[{data,backgroundColor:colors,borderRadius:6,borderSkipped:false}]},
    options:{
      responsive:true,maintainAspectRatio:true,
      plugins:{
        legend:{display:false},
        tooltip:{
          backgroundColor:isDark()?'#1e293b':'#fff',
          borderColor:isDark()?'#2d3f55':'#e2e8f0',borderWidth:1,
          titleColor:isDark()?'#e2e8f0':'#1e293b',bodyColor:tText(),
          callbacks:{label:c=>` ${c.parsed.y} asignaciones`}
        }
      },
      scales:{
        y:{beginAtZero:true,grid:{color:tGrid()},ticks:{color:tText(),font:{size:11},precision:0}},
        x:{grid:{display:false},ticks:{color:tText(),font:{size:11}}}
      }
    }
  });
}

function dlAsgChart(){if(!asgChart)return;const a=document.createElement('a');a.download=`asignaciones_chart_${new Date().toISOString().split('T')[0]}.png`;a.href=asgChart.toBase64Image();a.click();}

// ── Top Models ──────────────────────────────────────────────────
function renderAsgTopModels(){
  const byModel={};ASG_DATA.forEach(a=>{const k=a.equipment_model||'Sin modelo';byModel[k]=(byModel[k]||0)+1;});
  const top=Object.entries(byModel).sort((a,b)=>b[1]-a[1]).slice(0,8);
  const maxCount=top[0]?top[0][1]:1;
  document.getElementById('asgTopModelos').innerHTML=top.map(([name,count],i)=>
    `<li class="top-list-item">
      <span class="rank-badge rank-${i+1}">${i+1}</span>
      <span class="top-name" title="${name}">${name}</span>
      <div class="top-bar-wrap"><div class="top-bar" style="width:${Math.round(count/maxCount*100)}%"></div></div>
      <span class="top-count">${count}</span>
    </li>`).join('');
}

// ── Filters ─────────────────────────────────────────────────────
function setPill(pill){
  asgActivePill=pill;
  ['all','month','multi'].forEach(p=>document.getElementById(`pill-${p}`).classList.toggle('active',p===pill));
  ASG_PAGE=1;applyAsgFilters();
}

function applyAsgFilters(){
  const term=asgSearchTerm.toLowerCase();
  const now=new Date(),monthAgo=new Date(now.getFullYear(),now.getMonth()-1,now.getDate());
  const byEmp={};ASG_DATA.forEach(a=>{byEmp[a.employee_cip]=(byEmp[a.employee_cip]||0)+1;});
  ASG_FILTERED=ASG_DATA.filter(a=>{
    if(asgActivePill==='month'&&new Date(a.assignment_date)<monthAgo)return false;
    if(asgActivePill==='multi'&&(byEmp[a.employee_cip]||0)<=1)return false;
    if(term){
      const hay=[a.employee_name,a.employee_cip,a.equipment_code,a.equipment_model,a.department_name,a.location_name,a.assignment_id].join(' ').toLowerCase();
      if(!hay.includes(term))return false;
    }
    return true;
  });
  document.getElementById('asgTableCount').textContent=ASG_FILTERED.length;
  renderAsgTable();renderAsgPagination();
}

// ── Table ───────────────────────────────────────────────────────
function renderAsgTable(){
  const start=(ASG_PAGE-1)*ASG_PER_PAGE;
  const page=ASG_FILTERED.slice(start,start+ASG_PER_PAGE);
  const sevenDaysAgo=new Date(Date.now()-7*24*60*60*1000);
  if(!page.length){
    document.getElementById('asgTableBody').innerHTML='<tr><td colspan="10" class="empty-state"><i class="bi bi-inbox"></i><p>No se encontraron asignaciones</p></td></tr>';
    return;
  }
  document.getElementById('asgTableBody').innerHTML=page.map(a=>{
    const isRecent=a.assignment_date&&new Date(a.assignment_date)>=sevenDaysAgo;
    return`<tr class="${isRecent?'row-recent':''}">
      <td><span style="font-family:monospace;font-size:11px;color:var(--muted)">#${a.assignment_id}</span></td>
      <td style="text-align:left;"><strong style="font-size:13px">${a.employee_name||'—'}</strong></td>
      <td><span style="font-family:monospace;font-size:12px">${a.employee_cip||'—'}</span></td>
      <td style="text-align:left;">${eqIcon(a.equipment_type)}<strong>${a.equipment_code||'—'}</strong></td>
      <td>${a.equipment_model||'—'}</td>
      <td>${typePill(a.equipment_type)}</td>
      <td style="font-size:12px;color:var(--muted)">${fmtDate(a.assignment_date)}</td>
      <td style="font-size:12px">${a.department_name||'—'}</td>
      <td style="font-size:12px">${a.location_name||'—'}</td>
      <td>
        <button class="btn-primary-sm" style="padding:4px 10px;font-size:11px;" onclick='openEditAsg(${JSON.stringify(a)})'>
          <i class="bi bi-pencil-fill"></i>
        </button>
      </td>
    </tr>`;
  }).join('');
}

// ── Pagination ──────────────────────────────────────────────────
function renderAsgPagination(){
  const total=ASG_FILTERED.length,pages=Math.ceil(total/ASG_PER_PAGE);
  const start=Math.min((ASG_PAGE-1)*ASG_PER_PAGE+1,total),end=Math.min(ASG_PAGE*ASG_PER_PAGE,total);
  document.getElementById('asgPagInfo').textContent=total>0?`${start.toLocaleString()}–${end.toLocaleString()} de ${total.toLocaleString()} asignaciones`:'Sin resultados';
  const btns=document.getElementById('asgPagBtns');
  if(pages<=1){btns.innerHTML='';return;}
  let h=`<button class="pg-btn" onclick="goAsgPage(${ASG_PAGE-1})" ${ASG_PAGE===1?'disabled':''}>‹</button>`;
  const s=Math.max(1,ASG_PAGE-2),e2=Math.min(pages,ASG_PAGE+2);
  if(s>1)h+=`<button class="pg-btn" onclick="goAsgPage(1)">1</button>${s>2?'<span style="padding:0 4px;color:var(--muted)">…</span>':''}`;
  for(let p=s;p<=e2;p++)h+=`<button class="pg-btn ${p===ASG_PAGE?'active':''}" onclick="goAsgPage(${p})">${p}</button>`;
  if(e2<pages)h+=`${e2<pages-1?'<span style="padding:0 4px;color:var(--muted)">…</span>':''}<button class="pg-btn" onclick="goAsgPage(${pages})">${pages}</button>`;
  h+=`<button class="pg-btn" onclick="goAsgPage(${ASG_PAGE+1})" ${ASG_PAGE>=pages?'disabled':''}>›</button>`;
  btns.innerHTML=h;
}

function goAsgPage(p){ASG_PAGE=p;renderAsgTable();renderAsgPagination();}

// ── Export ──────────────────────────────────────────────────────
function exportAsg(fmt){
  if(!ASG_FILTERED.length){toast('No hay datos','inf');return;}
  const rows=ASG_FILTERED.map(a=>({ID:a.assignment_id,Empleado:a.employee_name,CIP:a.employee_cip,Equipo:a.equipment_code,Modelo:a.equipment_model,Tipo:a.equipment_type,Fecha:a.assignment_date,Departamento:a.department_name,Ubicacion:a.location_name}));
  const ws=XLSX.utils.json_to_sheet(rows);const wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,'Asignaciones');
  XLSX.writeFile(wb,`asignaciones_${new Date().toISOString().split('T')[0]}.${fmt==='excel'?'xlsx':'csv'}`);
  toast('Exportación completada','ok');
}

// ── Autocomplete ────────────────────────────────────────────────
let asgDebounceTimer=null;
function setupAC(inputId,resultsId,url,handlers,minLen=2){
  const input=document.getElementById(inputId),results=document.getElementById(resultsId);
  if(!input||!results)return;
  let items=[];
  input.addEventListener('input',()=>{
    clearTimeout(asgDebounceTimer);
    const val=input.value.trim();
    if(val.length<minLen){results.style.display='none';return;}
    asgDebounceTimer=setTimeout(async()=>{
      try{
        const res=await fetch(url+encodeURIComponent(val));
        const json=await res.json();
        items=json.data||[];
        results.innerHTML=items.length
          ?items.slice(0,8).map((item,i)=>handlers.render(item,i)).join('')
          :'<div class="autocomplete-item" style="color:var(--muted);cursor:default">Sin resultados</div>';
        results.querySelectorAll('[data-idx]').forEach(el=>el.addEventListener('click',()=>{handlers.pick(items[parseInt(el.dataset.idx)]);results.style.display='none';}));
        results.style.display='block';
      }catch(e){results.style.display='none';}
    },300);
  });
  document.addEventListener('click',e=>{if(!input.contains(e.target)&&!results.contains(e.target))results.style.display='none';});
}

function initAddModalAC(){
  setupAC('addEmployeeName','addEmployeeResults','/api/employees/search?include_baja=true&q=',{
    render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.full_name}${e.is_active===0||e.is_active===false?'<span style="font-size:9px;background:var(--danger);color:#fff;border-radius:3px;padding:1px 5px;margin-left:6px;font-weight:700;">BAJA</span>':''}</span><span class="ac-sub">CIP: ${e.cip||'—'}</span></div>`,
    pick:e=>{document.getElementById('addEmployeeName').value=e.full_name;document.getElementById('addEmployeeCip').value=e.cip||'';document.getElementById('addEmployeeId').value=e.id||'';}
  },3);
  setupAC('addEquipmentCode','addEquipmentResults','/api/equipment/search?term=',{
    render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.device_code}</span><span class="ac-sub">${e.model||''} · ${e.brand||''} · ${e.status||''}</span></div>`,
    pick:e=>{document.getElementById('addEquipmentCode').value=e.device_code;document.getElementById('addEquipmentModel').value=e.model||'';}
  },2);
  setupAC('addDepartmentName','addDepartmentResults','/api/departments/search?term=',{
    render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.department_name}</span><span class="ac-sub">${e.division||''}</span></div>`,
    pick:e=>{document.getElementById('addDepartmentName').value=e.department_name;document.getElementById('addDepartmentId').value=e.id;}
  },3);
  setupAC('addLocationName','addLocationResults','/api/locations/search?term=',{
    render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.location_name}</span><span class="ac-sub">${e.city||''}</span></div>`,
    pick:e=>{document.getElementById('addLocationName').value=e.location_name;document.getElementById('addLocationId').value=e.id;}
  },3);
}

function initEditModalAC(){
  setupAC('editAsgEmployee','editEmployeeResults','/api/employees/search?include_baja=true&q=',{
    render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.full_name}${e.is_active===0||e.is_active===false?'<span style="font-size:9px;background:var(--danger);color:#fff;border-radius:3px;padding:1px 5px;margin-left:6px;font-weight:700;">BAJA</span>':''}</span><span class="ac-sub">CIP: ${e.cip||'—'}</span></div>`,
    pick:e=>{document.getElementById('editAsgEmployee').value=e.full_name;document.getElementById('editAsgCip').value=e.cip||'';}
  },3);
  setupAC('editAsgEquipment','editEquipmentResults','/api/equipment/search?term=',{
    render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.device_code}</span><span class="ac-sub">${e.model||''} · ${e.brand||''}</span></div>`,
    pick:e=>{document.getElementById('editAsgEquipment').value=e.device_code;document.getElementById('editAsgModel').value=e.model||'';}
  },2);
  setupAC('editAsgDept','editDepartmentResults','/api/departments/search?term=',{
    render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.department_name}</span><span class="ac-sub">${e.division||''}</span></div>`,
    pick:e=>{document.getElementById('editAsgDept').value=e.department_name;document.getElementById('editAsgDeptId').value=e.id;}
  },3);
  setupAC('editAsgLoc','editLocationResults','/api/locations/search?term=',{
    render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.location_name}</span><span class="ac-sub">${e.city||''}</span></div>`,
    pick:e=>{document.getElementById('editAsgLoc').value=e.location_name;document.getElementById('editAsgLocId').value=e.id;}
