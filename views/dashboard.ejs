<script>
/* ══════════════════════════════════════════════════
   DARK MODE LOGIC
══════════════════════════════════════════════════ */
(function () {
    // Apply saved theme immediately to avoid flash
    const saved = localStorage.getItem('dashboardTheme') || 'light';
    document.documentElement.setAttribute('data-theme', saved);
})();

function toggleTheme() {
    const html    = document.documentElement;
    const current = html.getAttribute('data-theme');
    const next    = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('dashboardTheme', next);
    updateToggleUI(next);

    // Update Chart.js charts if they exist
    if (typeof updateChartsTheme === 'function') updateChartsTheme(next);
}

function updateToggleUI(theme) {
    const icon  = document.getElementById('toggleIcon');
    const label = document.getElementById('toggleLabel');
    if (theme === 'dark') {
        icon.className  = 'bi bi-sun-fill toggle-icon';
        label.textContent = 'Claro';
    } else {
        icon.className  = 'bi bi-moon-stars-fill toggle-icon';
        label.textContent = 'Oscuro';
    }
}

// Run on DOMContentLoaded to sync UI with saved preference
document.addEventListener('DOMContentLoaded', function () {
    const saved = localStorage.getItem('dashboardTheme') || 'light';
    updateToggleUI(saved);
});

/* ══════════════════════════════════════════════════
   DASHBOARD FUNCTIONS
══════════════════════════════════════════════════ */
async function cargarEquiposPorTipo() {
    try {
        const res  = await fetch('/api/dashboard/equipos-por-tipo');
        const data = await res.json();
        if (!data.success || !data.data.length) return;
        const tbody = $('#equiposPorTipo tbody');
        tbody.empty();
        data.data.forEach(item => {
            const pct = parseFloat(item.porcentaje_asignados) || 0;
            let cls = 'bg-success', txt = 'Normal';
            if (pct > 80) { cls = 'bg-danger';  txt = 'Alto Uso'; }
            else if (pct > 60) { cls = 'bg-warning'; txt = 'Medio'; }
            tbody.append(`<tr>
                <td><strong>${item.tipo}</strong></td>
                <td><span class="badge bg-secondary">${item.total}</span></td>
                <td><span class="badge bg-success">${item.asignados}</span></td>
                <td><span class="badge bg-info">${item.disponibles}</span></td>
                <td>
                    <div class="progress mb-1">
                        <div class="progress-bar ${cls}" style="width:${pct}%"></div>
                    </div>
                    <small class="text-muted">${pct.toFixed(1)}%</small>
                </td>
                <td><span class="badge ${cls}">${txt}</span></td>
            </tr>`);
        });
    } catch (e) { console.error(e); }
}

async function cargarEquiposPorUbicacion() {
    try {
        const res  = await fetch('/api/dashboard/equipos-por-ubicacion');
        const data = await res.json();
        if (!data.success || !data.data.length) return;
        const tbody = $('#equiposPorUbicacion tbody');
        tbody.empty();
        data.data.forEach(item => {
            tbody.append(`<tr>
                <td><strong>${item.ubicacion}</strong></td>
                <td>${item.ciudad||'-'}</td>
                <td><span class="badge bg-primary">${item.total_equipos}</span></td>
                <td>${item.laptops||0}</td>
                <td>${item.desktops||0}</td>
                <td>${item.monitores||0}</td>
                <td>${item.tablets||0}</td>
                <td>${item.otros||0}</td>
            </tr>`);
        });
    } catch (e) { console.error(e); }
}

async function cargarEstadisticasGenerales() {
    try {
        const res  = await fetch('/api/dashboard/stats-completo');
        const data = await res.json();
        if (!data.success) return;
        $('#kpiTotalEquipos').text(data.data.totalEquipos    || 0);
        $('#equiposAsignados').text(data.data.equiposAsignados || 0);
        $('#equiposDisponibles').text(data.data.equiposDisponibles || 0);
        $('#equiposGarantia').text(data.data.equiposGarantia  || 0);
    } catch (e) { console.error(e); }
}

async function cargarTopModelosAsignados() {
    const contenedor = document.getElementById('topMarcas');
    try {
        const res    = await fetch('/api/dashboard/top-modelos-asignados?limite=10');
        const result = await res.json();
        if (!result.success || !result.data?.length) {
            contenedor.innerHTML = '<div class="p-4 text-center text-muted">No hay modelos asignados</div>';
            return;
        }
        const modelos = result.data;
        let html = '<div class="list-group list-group-flush">';
        modelos.forEach((m, i) => {
            const pos   = i + 1;
            const badge = pos === 1 ? 'bg-warning text-dark' : pos === 2 ? 'bg-secondary' : pos === 3 ? 'bg-danger' : 'bg-secondary';
            const iconos = { 'Laptop':'bi-laptop','Desktop':'bi-pc-display','Monitor':'bi-display','Tablet':'bi-tablet' };
            const icono  = `bi ${iconos[m.tipo_equipo] || 'bi-box'}`;
            html += `
            <div class="list-group-item px-3 py-3 border-0 border-bottom">
                <div class="d-flex align-items-start">
                    <div class="me-3">
                        <span class="badge ${badge} rounded-pill" style="min-width:28px;font-size:.8rem;">${pos}</span>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <div>
                                <h6 class="mb-0 fw-bold" style="font-size:13px;">
                                    <i class="${icono} text-muted me-1"></i>${m.marca} ${m.modelo}
                                </h6>
                                <small class="text-muted">${m.tipo_equipo}</small>
                            </div>
                            <span class="badge bg-primary rounded-pill">${m.cantidad_asignada}</span>
                        </div>
                        <div class="progress mb-1" style="height:4px;">
                            <div class="progress-bar bg-primary" style="width:${m.porcentaje_total}%"></div>
                        </div>
                        <div class="d-flex justify-content-between">
                            <small class="text-muted">${m.porcentaje_total}% del total</small>
                            <small class="text-muted"><i class="bi bi-clock-history"></i> ${m.antiguedad_promedio_anos} años</small>
                        </div>
                    </div>
                </div>
            </div>`;
        });
        html += '</div>';
        contenedor.innerHTML = html;
    } catch (e) {
        contenedor.innerHTML = '<div class="p-4 text-center text-danger"><i class="bi bi-exclamation-triangle"></i> Error al cargar</div>';
    }
}

function filtrarTablaUbicacion() {
    const filter = document.getElementById('searchUbicacion').value.toLowerCase().trim();
    const rows   = document.querySelectorAll('#equiposPorUbicacion tbody tr');
    rows.forEach(row => {
        if (row.cells.length === 1) return;
        const ubic = (row.cells[0]?.textContent || '').toLowerCase();
        const ciud = (row.cells[1]?.textContent || '').toLowerCase();
        row.style.display = ubic.includes(filter) || ciud.includes(filter) ? '' : 'none';
    });
}

function limpiarBusquedaUbicacion() {
    document.getElementById('searchUbicacion').value = '';
    filtrarTablaUbicacion();
}

$(document).ready(function () {
    cargarEstadisticasGenerales();
    cargarEquiposPorTipo();
    cargarEquiposPorUbicacion();
    cargarTopModelosAsignados();

    setInterval(() => {
        cargarEstadisticasGenerales();
        cargarEquiposPorTipo();
        cargarEquiposPorUbicacion();
    }, 300000);
});
</script>

