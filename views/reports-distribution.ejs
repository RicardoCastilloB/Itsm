<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reportes & Distribución</title>
<script>(function(){const s=localStorage.getItem('dashboardTheme')||'light';document.documentElement.setAttribute('data-theme',s);})();</script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<link rel="stylesheet" href="../css/style.css">
<style>
/* ══ VARIABLES ══════════════════════════════════════════════ */
:root,[data-theme="light"]{
  --bg:#f0f4f8;--card:#ffffff;--header:#f8fafc;--border:#e2e8f0;
  --text:#1e293b;--muted:#64748b;--primary:#3b82f6;--success:#10b981;
  --warning:#f59e0b;--danger:#ef4444;--info:#06b6d4;--purple:#8b5cf6;
  --hover:#f1f5f9;--input-bg:#f8fafc;--input-ro:#f8fafc;
  --shadow:0 1px 3px rgba(0,0,0,.07);--shadow-md:0 4px 16px rgba(0,0,0,.10);
  --alert-ok-bg:#f0fdf4;--alert-ok-color:#166534;--alert-ok-border:#86efac;
}
[data-theme="dark"]{
  --bg:#0f172a;--card:#1e293b;--header:#162032;--border:#2d3f55;
  --text:#e2e8f0;--muted:#94a3b8;--primary:#60a5fa;--success:#34d399;
  --warning:#fbbf24;--danger:#f87171;--info:#22d3ee;--purple:#a78bfa;
  --hover:#243348;--input-bg:#162032;--input-ro:#162032;
  --shadow:0 1px 3px rgba(0,0,0,.3);--shadow-md:0 4px 16px rgba(0,0,0,.4);
  --alert-ok-bg:#064e3b;--alert-ok-color:#a7f3d0;--alert-ok-border:#34d399;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:13.5px;transition:background .3s,color .3s;}

/* ══ LAYOUT PRINCIPAL ═══════════════════════════════════════ */
.pg{margin-top:60px;padding:20px 24px;display:flex;flex-direction:column;gap:0;max-width:1680px;margin-left:auto;margin-right:auto;}
.pg-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;padding-bottom:18px;}
.pg-title{font-size:21px;font-weight:800;letter-spacing:-.3px;display:flex;align-items:center;gap:10px;}
.pg-title i{color:var(--primary);}
.pg-sub{font-size:12px;color:var(--muted);margin-top:3px;}

/* ══ PESTAÑAS DE MÓDULO ══════════════════════════════════════ */
.mod-nav{display:flex;background:var(--card);border:1px solid var(--border);border-radius:14px 14px 0 0;border-bottom:none;overflow:hidden;box-shadow:var(--shadow);}
.mod-tab{flex:1;padding:14px 20px;border:none;background:transparent;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13.5px;font-weight:700;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;border-bottom:3px solid transparent;letter-spacing:-.1px;}
.mod-tab:not(:last-child){border-right:1px solid var(--border);}
.mod-tab:hover{background:var(--hover);color:var(--text);}
.mod-tab.active{background:var(--header);color:var(--primary);border-bottom-color:var(--primary);}
.mod-tab .tb{font-size:16px;}
.mod-tab .badge{display:inline-flex;align-items:center;justify-content:center;min-width:20px;height:20px;border-radius:10px;font-size:10px;font-weight:800;padding:0 5px;background:var(--border);color:var(--muted);}
.mod-tab.active .badge{background:rgba(59,130,246,.15);color:var(--primary);}

.mod-shell{background:var(--card);border:1px solid var(--border);border-top:none;border-radius:0 0 14px 14px;box-shadow:var(--shadow);overflow:hidden;}
.mod-panel{display:none;}
.mod-panel.active{display:block;}

/* ══ BOTONES COMPARTIDOS ════════════════════════════════════ */
.btn-primary{background:var(--primary);color:#fff;border:none;border-radius:9px;padding:8px 18px;font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;white-space:nowrap;font-family:'DM Sans',sans-serif;}
.btn-primary:hover{filter:brightness(1.1);transform:translateY(-1px);}
.btn-primary:disabled{opacity:.55;cursor:not-allowed;transform:none;}
.btn-primary.green{background:var(--success);}
.btn-ghost{background:transparent;color:var(--primary);border:1.5px solid var(--primary);border-radius:9px;padding:7px 14px;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;font-family:'DM Sans',sans-serif;}
.btn-ghost:hover{background:var(--primary);color:#fff;}
.btn-sm{padding:5px 9px;font-size:11.5px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;display:inline-flex;align-items:center;gap:4px;transition:all .15s;white-space:nowrap;font-family:'DM Sans',sans-serif;}
.btn-sm:hover{border-color:var(--primary);color:var(--primary);}
.btn-sm.danger:hover{border-color:var(--danger);color:var(--danger);}
.btn-preview{padding:5px 12px;border-radius:7px;font-size:12px;font-weight:600;border:1.5px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:6px;}
.btn-preview:hover,.btn-preview.on{border-color:var(--info);color:var(--info);background:rgba(6,182,212,.08);}

/* ══ FORMULARIO ═════════════════════════════════════════════ */
.fc{padding:9px 12px;border:1.5px solid var(--border);border-radius:9px;font-size:13px;font-family:'DM Sans',sans-serif;background:var(--input-bg);color:var(--text);outline:none;width:100%;transition:border-color .2s,box-shadow .2s,background .3s,color .3s;}
.fc::placeholder{color:var(--muted);}
.fc:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.fc[readonly]{background:var(--input-ro);color:var(--muted);cursor:default;}
.fc.invalid{border-color:var(--danger);}
textarea.fc{resize:vertical;min-height:88px;line-height:1.65;}
.fl{font-size:10.5px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);}
.fg{display:flex;flex-direction:column;gap:5px;margin-bottom:13px;}
.fg:last-child{margin-bottom:0;}
.req{color:var(--danger);}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:13px;}
@media(max-width:600px){.grid2{grid-template-columns:1fr;}}

/* ══ TARJETA INTERNA ════════════════════════════════════════ */
.icard{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px;box-shadow:var(--shadow);}
.icard:last-child{margin-bottom:0;}
.icard-head{padding:12px 18px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;font-weight:700;font-size:13px;color:var(--text);}
.icard-head i{color:var(--primary);margin-right:6px;}
.icard-body{padding:16px 18px;}
.cbadge{display:inline-flex;align-items:center;justify-content:center;min-width:17px;height:17px;border-radius:9px;background:var(--primary);color:#fff;font-size:10px;font-weight:800;padding:0 4px;}
.count-badge{background:var(--input-bg);color:var(--muted);font-size:11px;font-weight:700;padding:2px 9px;border-radius:20px;border:1px solid var(--border);}

/* ══ TAGS (para / cc / bcc) ═════════════════════════════════ */
.tags-wrap{min-height:42px;padding:5px 8px;display:flex;flex-wrap:wrap;gap:5px;align-items:center;cursor:text;border:1.5px solid var(--border);border-radius:9px;background:var(--input-bg);transition:border-color .2s,box-shadow .2s,background .3s;}
.tags-wrap:focus-within{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.tag{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:20px;font-size:11.5px;font-weight:600;background:rgba(59,130,246,.1);color:var(--primary);animation:tagPop .15s ease;max-width:220px;}
.tag.ext{background:rgba(6,182,212,.1);color:var(--info);}
.tag.dist{background:rgba(245,158,11,.1);color:var(--warning);}
.tag span{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.tag-x{background:none;border:none;cursor:pointer;color:inherit;opacity:.6;padding:0;font-size:14px;line-height:1;transition:opacity .15s;flex-shrink:0;}
.tag-x:hover{opacity:1;}
@keyframes tagPop{from{opacity:0;transform:scale(.82);}to{opacity:1;transform:scale(1);}}
.tags-input{border:none;outline:none;background:transparent;font-size:13px;font-family:'DM Sans',sans-serif;color:var(--text);min-width:130px;flex:1;padding:2px 4px;}
.tags-input::placeholder{color:var(--muted);}

/* Autocomplete */
.ac-wrap{position:relative;}
.ac-drop{display:none;position:absolute;top:calc(100% + 4px);left:0;right:0;z-index:300;background:var(--card);border:1px solid var(--border);border-radius:10px;box-shadow:var(--shadow-md);max-height:190px;overflow-y:auto;}
.ac-item{padding:8px 12px;cursor:pointer;font-size:12.5px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:9px;transition:background .1s;}
.ac-item:last-child{border-bottom:none;}
.ac-item:hover{background:var(--hover);}
.ac-av{width:28px;height:28px;border-radius:50%;flex-shrink:0;background:rgba(59,130,246,.1);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;}
.ac-name{font-weight:600;font-size:12.5px;}
.ac-email{font-size:11px;color:var(--muted);font-family:'DM Mono',monospace;}
.ac-dept{font-size:10px;color:var(--muted);margin-left:auto;white-space:nowrap;}

/* CC / BCC */
.cc-row{display:flex;gap:7px;margin-bottom:13px;}
.btn-cc{padding:4px 11px;border-radius:7px;font-size:12px;font-weight:600;border:1.5px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;}
.btn-cc:hover{border-color:var(--primary);color:var(--primary);}
.btn-cc.on{border-color:var(--primary);color:var(--primary);background:rgba(59,130,246,.08);}

/* Chips distribución */
.dc-row{display:flex;flex-wrap:wrap;gap:7px;}
.dc{padding:4px 11px;border-radius:20px;font-size:12px;font-weight:600;border:1.5px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:5px;}
.dc:hover,.dc.active{border-color:var(--warning);color:var(--warning);background:rgba(245,158,11,.08);}

/* Templates */
.tpl-row{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;}
.tpl-btn{padding:4px 11px;border-radius:7px;font-size:11.5px;font-weight:500;border:1.5px solid var(--border);background:var(--header);color:var(--text);cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;}
.tpl-btn:hover{border-color:var(--primary);color:var(--primary);}

/* File tabs */
.file-tabs{display:flex;border-bottom:2px solid var(--border);margin-bottom:14px;}
.ft-tab{padding:8px 17px;font-size:13px;font-weight:600;border:none;background:transparent;color:var(--muted);cursor:pointer;border-bottom:2.5px solid transparent;margin-bottom:-2px;transition:all .2s;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:7px;}
.ft-tab:hover{color:var(--text);}
.ft-tab.active{color:var(--primary);border-bottom-color:var(--primary);}

/* Drop zone */
.drop-zone{border:2px dashed var(--border);border-radius:10px;padding:28px 18px;text-align:center;cursor:pointer;background:var(--header);position:relative;transition:all .25s;}
.drop-zone:hover,.drop-zone.drag-over{border-color:var(--primary);background:rgba(59,130,246,.04);}
.drop-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.dz-icon{font-size:30px;color:var(--primary);opacity:.4;margin-bottom:7px;display:block;transition:transform .2s;}
.drop-zone:hover .dz-icon{transform:translateY(-4px);opacity:.65;}
.dz-title{font-weight:700;font-size:13.5px;margin-bottom:3px;}
.dz-sub{font-size:11.5px;color:var(--muted);}
.dz-types{display:flex;gap:5px;justify-content:center;flex-wrap:wrap;margin-top:8px;}
.dz-type{padding:2px 7px;border-radius:5px;font-size:10px;font-weight:700;background:var(--card);border:1px solid var(--border);color:var(--muted);}

/* Reportes app */
.rep-list{display:flex;flex-direction:column;gap:7px;}
.rep-item{display:flex;align-items:center;gap:10px;padding:10px 13px;border-radius:9px;border:1.5px solid var(--border);background:var(--header);cursor:pointer;transition:all .2s;position:relative;overflow:hidden;}
.rep-item:hover{border-color:var(--primary);background:rgba(59,130,246,.04);}
.rep-item.sel{border-color:var(--primary);background:rgba(59,130,246,.07);}
.rep-check{width:17px;height:17px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;opacity:0;transition:opacity .15s;}
.rep-item.sel .rep-check{opacity:1;}
.rep-name{font-size:13px;font-weight:600;}
.rep-meta{font-size:11px;color:var(--muted);}
.rep-badge{margin-left:auto;padding:2px 7px;border-radius:5px;font-size:10px;font-weight:700;white-space:nowrap;flex-shrink:0;}
.rb-pdf{background:rgba(239,68,68,.1);color:#ef4444;}
.rb-xls{background:rgba(16,185,129,.1);color:#10b981;}
.rep-gen-overlay{display:none;position:absolute;inset:0;border-radius:9px;background:rgba(59,130,246,.07);align-items:center;justify-content:center;gap:7px;font-size:12px;font-weight:700;color:var(--primary);}
.rep-item.generating .rep-gen-overlay{display:flex;}
.rep-item.generating{pointer-events:none;}

/* Adjuntos */
.att-list{display:flex;flex-direction:column;gap:7px;margin-top:11px;}
.att-item{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:9px;border:1px solid var(--border);background:var(--header);animation:tagPop .2s ease;}
.att-icon{font-size:19px;flex-shrink:0;}
.att-pdf{color:#ef4444;}.att-word{color:#3b82f6;}.att-excel{color:#10b981;}.att-ppt{color:#f97316;}.att-img{color:#8b5cf6;}.att-other{color:var(--muted);}
.att-info{flex:1;min-width:0;}
.att-name{font-size:12.5px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.att-size{font-size:11px;color:var(--muted);}
.att-src{font-size:10px;font-weight:700;padding:1px 6px;border-radius:4px;margin-left:4px;}
.att-src.app{background:rgba(59,130,246,.1);color:var(--primary);}
.att-src.upload{background:var(--header);border:1px solid var(--border);color:var(--muted);}
.att-rm{background:none;border:none;color:var(--muted);cursor:pointer;padding:4px;border-radius:6px;display:flex;align-items:center;transition:all .15s;}
.att-rm:hover{background:rgba(239,68,68,.1);color:var(--danger);}

/* Preview correo */
.ep-wrap{border:1.5px solid var(--border);border-radius:11px;overflow:hidden;margin-bottom:14px;animation:slideD .22s ease;}
@keyframes slideD{from{opacity:0;transform:translateY(-8px);}to{opacity:1;transform:translateY(0);}}
.ep-bar{padding:8px 12px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:5px;}
.ep-dot{width:11px;height:11px;border-radius:50%;}
.ep-lbl{font-size:11px;color:var(--muted);margin-left:7px;font-family:'DM Mono',monospace;}
.ep-body{padding:14px 16px;background:var(--card);}
.ep-row{display:flex;gap:8px;padding:5px 0;border-bottom:1px solid var(--border);font-size:12.5px;}
.ep-row:last-of-type{border-bottom:none;}
.ep-k{font-weight:700;color:var(--muted);min-width:58px;font-size:10.5px;text-transform:uppercase;letter-spacing:.4px;padding-top:1px;}
.ep-v{color:var(--text);flex:1;word-break:break-word;}
.ep-content{margin-top:10px;padding:11px;border-radius:8px;background:var(--header);border:1px solid var(--border);white-space:pre-wrap;line-height:1.65;font-size:12.5px;color:var(--muted);}
.ep-atts{margin-top:9px;display:flex;flex-wrap:wrap;gap:6px;}
.ep-att-chip{display:flex;align-items:center;gap:5px;padding:3px 9px;border-radius:7px;background:var(--header);border:1px solid var(--border);font-size:11.5px;font-weight:600;}

/* Status envío */
.sr-status{display:none;padding:11px 14px;border-radius:9px;margin-top:10px;align-items:center;gap:10px;font-size:13px;font-weight:600;}
.sr-status.show{display:flex;}
.sr-status.sending{background:rgba(6,182,212,.1);color:var(--info);}
.sr-status.ok{background:var(--alert-ok-bg);color:var(--alert-ok-color);border:1px solid var(--alert-ok-border);}
.sr-status.err{background:rgba(239,68,68,.1);color:var(--danger);}
.mini-prog{height:3px;background:var(--border);border-radius:2px;margin-top:7px;overflow:hidden;}
.mini-prog-fill{height:100%;border-radius:2px;background:var(--primary);width:0%;transition:width .3s;}
@keyframes prog-ind{0%{transform:translateX(-100%);}100%{transform:translateX(300%);}}
.mini-prog-fill.ind{width:30%;animation:prog-ind 1.1s infinite;}

/* Historial */
.hist-search{position:relative;margin-bottom:10px;}
.hist-search i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:12px;pointer-events:none;}
.hist-search input{width:100%;padding:7px 10px 7px 30px;border:1.5px solid var(--border);border-radius:9px;font-size:12.5px;background:var(--input-bg);color:var(--text);outline:none;font-family:'DM Sans',sans-serif;transition:border-color .2s;}
.hist-search input:focus{border-color:var(--primary);}
.hist-search input::placeholder{color:var(--muted);}
.hi{padding:10px 12px;border-radius:10px;border:1px solid var(--border);background:var(--header);cursor:pointer;transition:all .2s;margin-bottom:7px;}
.hi:hover{border-color:var(--primary);transform:translateX(2px);}
.hi-top{display:flex;justify-content:space-between;gap:6px;margin-bottom:3px;}
.hi-subj{font-size:12.5px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;}
.hi-time{font-size:10px;color:var(--muted);white-space:nowrap;font-family:'DM Mono',monospace;}
.hi-to{font-size:11px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.hi-badges{display:flex;gap:5px;margin-top:5px;flex-wrap:wrap;}
.hb{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700;}
.hb-ok{background:var(--alert-ok-bg);color:var(--alert-ok-color);border:1px solid var(--alert-ok-border);}
.hb-err{background:rgba(239,68,68,.1);color:var(--danger);}
.hb-att{background:var(--header);border:1px solid var(--border);color:var(--muted);}
.hist-empty{text-align:center;padding:28px 16px;color:var(--muted);font-size:12.5px;}
.hist-empty i{font-size:26px;display:block;margin-bottom:7px;opacity:.3;}

/* Confirm rows (modal envío) */
.confirm-row{padding:10px 13px;background:var(--header);border-radius:9px;border:1px solid var(--border);margin-bottom:9px;}
.confirm-key{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);margin-bottom:3px;}
.confirm-val{font-size:13px;font-weight:600;color:var(--text);white-space:pre-wrap;word-break:break-all;}

/* ══ LISTAS — layout 2 col ══════════════════════════════════ */
.rl-layout{display:grid;grid-template-columns:290px 1fr;min-height:580px;}
@media(max-width:900px){.rl-layout{grid-template-columns:1fr;}}
.ls-panel{border-right:1px solid var(--border);display:flex;flex-direction:column;}
.ls-head{padding:12px 16px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;font-weight:700;font-size:13px;}
.ls-head i{color:var(--primary);margin-right:6px;}
.ls-body{flex:1;overflow-y:auto;max-height:640px;}
.list-item{display:flex;align-items:center;gap:11px;padding:11px 14px;cursor:pointer;border-bottom:1px solid var(--border);transition:background .15s;position:relative;}
.list-item:last-child{border-bottom:none;}
.list-item:hover{background:var(--hover);}
.list-item.active{background:rgba(59,130,246,.07);border-left:3px solid var(--primary);}
.list-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.list-name{font-weight:600;font-size:13px;flex:1;}
.list-count{font-size:11px;color:var(--muted);background:var(--input-bg);border:1px solid var(--border);padding:1px 8px;border-radius:20px;font-weight:600;}
.list-actions{display:none;gap:4px;}
.list-item:hover .list-actions{display:flex;}
.list-edit-btn,.list-del-btn{background:none;border:none;padding:3px 6px;border-radius:5px;cursor:pointer;font-size:13px;transition:all .15s;}
.list-edit-btn{color:var(--muted);}.list-edit-btn:hover{color:var(--primary);background:rgba(59,130,246,.08);}
.list-del-btn{color:var(--muted);}.list-del-btn:hover{color:var(--danger);background:rgba(239,68,68,.08);}
.cp-panel{display:flex;flex-direction:column;}
.cp-head{padding:12px 16px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;font-weight:700;font-size:13px;}
.cp-toolbar{padding:10px 14px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.search-wrap{position:relative;flex:1;min-width:160px;}
.search-wrap i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none;}
.search-inp{width:100%;padding:7px 12px 7px 32px;border:1px solid var(--border);border-radius:9px;font-size:12.5px;background:var(--input-bg);color:var(--text);outline:none;transition:border-color .2s,background .3s;}
.search-inp:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.search-inp::placeholder{color:var(--muted);}

/* Tabla contactos */
.tbl-scroll{overflow-x:auto;overflow-y:auto;max-height:560px;}
.tbl{width:100%;border-collapse:collapse;font-size:13px;}
.tbl thead th{font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);font-weight:700;padding:10px 14px;background:var(--header);border-bottom:1px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;}
.tbl tbody td{padding:10px 14px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;}
.tbl tbody tr:hover td{background:var(--hover);}
.tbl tbody tr:last-child td{border-bottom:none;}
.pill{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;}
.p-active{background:rgba(16,185,129,.12);color:#10b981;}
.p-inactive{background:rgba(239,68,68,.1);color:#ef4444;}
.list-chip{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;margin:2px;border:1px solid;}

/* Color picker listas */
.color-opts{display:flex;gap:7px;flex-wrap:wrap;}
.color-opt{width:24px;height:24px;border-radius:50%;cursor:pointer;border:2.5px solid transparent;transition:transform .15px;}
.color-opt:hover{transform:scale(1.15);}
.color-opt.sel{border-color:var(--text);transform:scale(1.15);}
.list-chk-grid{display:flex;flex-direction:column;gap:7px;max-height:200px;overflow-y:auto;padding:2px;}
.list-chk-row{display:flex;align-items:center;gap:9px;padding:8px 11px;border:1.5px solid var(--border);border-radius:9px;cursor:pointer;transition:all .2s;}
.list-chk-row:hover{border-color:var(--primary);background:rgba(59,130,246,.04);}
.list-chk-row.checked{border-color:var(--primary);background:rgba(59,130,246,.07);}
.list-chk-row input{display:none;}
.list-chk-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.list-chk-name{flex:1;font-weight:600;font-size:13px;}
.list-chk-icon{width:18px;height:18px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;opacity:0;transition:opacity .15s;}
.list-chk-row.checked .list-chk-icon{opacity:1;}

/* Modal */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1050;align-items:center;justify-content:center;backdrop-filter:blur(2px);}
.modal-bg.open{display:flex;}
.modal-box{background:var(--card);border:1px solid var(--border);border-radius:16px;width:100%;max-width:500px;box-shadow:0 20px 60px rgba(0,0,0,.25);animation:mIn .2s ease;overflow:hidden;}
.modal-box.wide{max-width:580px;}
@keyframes mIn{from{opacity:0;transform:scale(.95);}to{opacity:1;transform:scale(1);}}
.modal-head{padding:16px 20px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;font-weight:700;font-size:15px;}
.modal-body-p{padding:20px 22px;}
.modal-foot{padding:13px 22px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;background:var(--header);}
.btn-mcancel{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:9px;padding:7px 16px;font-size:13px;cursor:pointer;transition:all .2s;}
.btn-mcancel:hover{border-color:var(--text);color:var(--text);}
.btn-mclose{width:28px;height:28px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.btn-mclose:hover{background:rgba(239,68,68,.1);color:var(--danger);border-color:var(--danger);}

/* Bootstrap modal dark */
[data-theme="dark"] .modal-content{background:var(--card)!important;border-color:var(--border)!important;color:var(--text)!important;}
[data-theme="dark"] .modal-body,[data-theme="dark"] .modal-footer,[data-theme="dark"] .modal-header{background:var(--card)!important;border-color:var(--border)!important;}

/* Toast */
.toast-wrap{position:fixed;bottom:22px;right:22px;z-index:9999;display:flex;flex-direction:column;gap:7px;}
.toast-item{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:11px;padding:11px 16px;font-size:13px;font-weight:500;box-shadow:var(--shadow-md);display:flex;align-items:center;gap:9px;min-width:260px;animation:tIn .22s ease;}
.toast-item.ok{border-left:4px solid var(--success);}
.toast-item.err{border-left:4px solid var(--danger);}
.toast-item.inf{border-left:4px solid var(--info);}
@keyframes tIn{from{opacity:0;transform:translateX(22px);}to{opacity:1;transform:translateX(0);}}

/* Misc */
@keyframes spin{to{transform:rotate(360deg);}}
.spin-anim{animation:spin .7s linear infinite;}
.mini-spin{display:inline-block;width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:spin .65s linear infinite;}
.empty-state{text-align:center;padding:42px 20px;color:var(--muted);}
.empty-state i{font-size:32px;display:block;margin-bottom:10px;opacity:.3;}
*::-webkit-scrollbar{width:5px;height:5px;}
*::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
*::-webkit-scrollbar-track{background:transparent;}
</style>
</head>
