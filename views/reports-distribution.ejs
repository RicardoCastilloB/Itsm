document.addEventListener('DOMContentLoaded', async () => {
  renderGlobalActions('envio');
  // Cargar listas (necesario para chips de distribución en envío)
  await loadLists();
  // Inicializar módulo envío
  await loadEmployees();
  renderTemplates();
  renderAppReports();
  setDefaultBody();
  updateRcCount();
  renderHist();
  initDrop();
  document.getElementById('mBadgeEnvio').textContent = histItems.length;
});
</script>

