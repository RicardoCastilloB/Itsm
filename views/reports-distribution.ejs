        <div class="fg" style="margin-bottom:0;"><label class="fl">Email <span class="req">*</span></label><input class="fc" id="contactEmail" type="email" placeholder="correo@empresa.com"></div>
      </div>
      <div class="fg"><label class="fl">Asignar a listas <span style="font-weight:400;text-transform:none;letter-spacing:0;">(opcional)</span></label><div class="list-chk-grid" id="listCheckGrid"><div style="color:var(--muted);font-size:12px;padding:8px;">Cargando listas…</div></div></div>
