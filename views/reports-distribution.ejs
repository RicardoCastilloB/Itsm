<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/sidebar.js"></script>
<script>
/* ════════════════════════════════════════════════════════════
   NAVEGACIÓN MÓDULOS
════════════════════════════════════════════════════════════ */
let activeModule = 'envio', listasLoaded = false;

function switchMod(mod) {
  activeModule = mod;
  document.querySelectorAll('.mod-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.mod-panel').forEach(p => p.classList.remove('active'));
  const cap = s => s.charAt(0).toUpperCase()+s.slice(1);
  document.getElementById('mTab'+cap(mod)).classList.add('active');
  document.getElementById('panel'+cap(mod)).classList.add('active');
  renderGlobalActions(mod);
  if (mod === 'listas' && !listasLoaded) { listasLoaded = true; loadLists(); loadContacts(); }
}

function renderGlobalActions(mod) {
  const el = document.getElementById('pgActions');
  if (mod === 'envio') {
    el.innerHTML = `<button class="btn-preview" onclick="togglePreview()"><i class="bi bi-eye"></i> Vista previa</button>
      <button class="btn-primary green" onclick="sendEmail()"><i class="bi bi-send-fill"></i> Enviar reporte</button>`;
  } else {
    el.innerHTML = `<button class="btn-ghost" onclick="openModalNewList()"><i class="bi bi-plus-circle"></i> Nueva lista</button>
      <button class="btn-primary" onclick="openModalNewContact()"><i class="bi bi-person-plus-fill"></i> Añadir destinatario</button>`;
  }
}

/* ════════════════════════════════════════════════════════════
   SHARED UTILS
════════════════════════════════════════════════════════════ */
const esc = s => (s||'').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const openModal  = id => document.getElementById(id).classList.add('open');
const closeModal = id => document.getElementById(id).classList.remove('open');
document.querySelectorAll('.modal-bg').forEach(o => o.addEventListener('click', e => { if(e.target===o) o.classList.remove('open'); }));

function toast(msg, type='inf', dur=4500) {
  const icons={ok:'bi-check-circle-fill',err:'bi-x-circle-fill',inf:'bi-info-circle-fill'};
  const clrs ={ok:'var(--success)',err:'var(--danger)',inf:'var(--info)'};
  const el = document.createElement('div');
  el.className = `toast-item ${type}`;
  el.innerHTML = `<i class="bi ${icons[type]}" style="color:${clrs[type]};font-size:17px;flex-shrink:0;"></i><span>${msg}</span>`;
  document.getElementById('toastWrap').appendChild(el);
  setTimeout(()=>{el.style.cssText='opacity:0;transform:translateX(20px);transition:.3s;';setTimeout(()=>el.remove(),300);}, dur);
}
const showToast = toast; // alias para compatibilidad con envío original

/* ════════════════════════════════════════════════════════════
   MÓDULO LISTAS DE DISTRIBUCIÓN — código original intacto
════════════════════════════════════════════════════════════ */
let allLists=[], allContacts=[], currentListId=null, selectedColors='#3b82f6';
const COLORS=['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#f97316','#ec4899','#64748b'];

function hexA(hex,alpha){const r=parseInt((hex||'#3b82f6').slice(1,3),16),g=parseInt((hex||'#3b82f6').slice(3,5),16),b=parseInt((hex||'#3b82f6').slice(5,7),16);return`rgba(${r},${g},${b},${alpha})`;}

async function loadLists(){
  try{
    const j=await fetch('/api/report-lists',{credentials:'include'}).then(r=>r.json());
    if(!j.success)throw new Error(j.error);
    allLists=j.data||[];
    renderSidebar();
    document.getElementById('mBadgeListas').textContent=allLists.length;
    renderDistrib(); // ← reconstruye chips con listas reales
  }catch(e){toast('Error cargando listas: '+e.message,'err');}
}

function renderSidebar(){
  const el=document.getElementById('listsSidebar');
  const allRow=`<div class="list-item ${currentListId===null?'active':''}" onclick="selectList(null)"><div class="list-dot" style="background:var(--primary);"></div><span class="list-name">Todos los contactos</span><span class="list-count">${allContacts.length}</span></div>`;
  const rows=allLists.map(l=>`<div class="list-item ${currentListId===l.id?'active':''}" onclick="selectList(${l.id})" id="litem_${l.id}"><div class="list-dot" style="background:${esc(l.color||'#3b82f6')};"></div><span class="list-name">${esc(l.name)}</span><span class="list-count">${l.member_count||0}</span><div class="list-actions"><button class="list-edit-btn" onclick="event.stopPropagation();openModalEditList(${l.id})" title="Editar"><i class="bi bi-pencil"></i></button><button class="list-del-btn" onclick="event.stopPropagation();confirmDeleteList(${l.id},'${esc(l.name)}')" title="Eliminar"><i class="bi bi-trash3"></i></button></div></div>`).join('');
  el.innerHTML=allRow+rows;
}

function selectList(id){currentListId=id;renderSidebar();loadContacts();}

async function loadContacts(){
  const tbody=document.getElementById('contactsTbody');
  tbody.innerHTML=`<tr><td colspan="5" class="empty-state"><span class="mini-spin"></span></td></tr>`;
  const title=currentListId===null?'Todos los destinatarios':(allLists.find(l=>l.id===currentListId)?.name||'—');
  document.getElementById('panelTitle').textContent=title;
  try{
    let url='/api/report-lists/contacts/all';
    if(currentListId)url+=`?list_id=${currentListId}`;
    const j=await fetch(url,{credentials:'include'}).then(r=>r.json());
    if(!j.success)throw new Error(j.error);
    allContacts=j.data||[];
    renderContacts(allContacts);
  }catch(e){tbody.innerHTML=`<tr><td colspan="5" class="empty-state"><i class="bi bi-exclamation-triangle" style="color:var(--danger);"></i><p>${e.message}</p></td></tr>`;}
}

function renderContacts(list){
  const tbody=document.getElementById('contactsTbody');
  document.getElementById('contactCount').textContent=list.length;
  document.getElementById('contactsFooter').textContent=`${list.length} destinatario${list.length!==1?'s':''}`;
  if(!list.length){tbody.innerHTML=`<tr><td colspan="5" class="empty-state"><i class="bi bi-inbox"></i><p>Sin destinatarios${currentListId?' en esta lista':''}</p></td></tr>`;return;}
  tbody.innerHTML=list.map(c=>{
    const listChips=c.lists?c.lists.split(', ').map((ln,i)=>{const lid=(c.list_ids||'').split(',')[i];const color=allLists.find(l=>String(l.id)===String(lid))?.color||'#64748b';return`<span class="list-chip" style="background:${hexA(color,.1)};color:${color};border-color:${hexA(color,.3)};">${esc(ln)}</span>`;}).join(''):'<span style="color:var(--muted);font-size:11px;">Sin lista</span>';
    return`<tr><td style="font-weight:600;">${esc(c.name)}</td><td style="font-size:12px;"><a href="mailto:${esc(c.email)}" style="color:var(--primary);">${esc(c.email)}</a></td><td>${listChips}</td><td><span class="pill ${c.is_active?'p-active':'p-inactive'}">${c.is_active?'✅ Activo':'⛔ Inactivo'}</span></td><td style="white-space:nowrap;"><div style="display:flex;gap:5px;"><button class="btn-sm" onclick="openModalEditContact(${c.id})"><i class="bi bi-pencil"></i></button><button class="btn-sm danger" onclick="confirmDeleteContact(${c.id},'${esc(c.name)}')"><i class="bi bi-trash3"></i></button></div></td></tr>`;
  }).join('');
}

function filterContacts(){const q=document.getElementById('searchContacts').value.toLowerCase();renderContacts(q?allContacts.filter(c=>c.name.toLowerCase().includes(q)||c.email.toLowerCase().includes(q)):allContacts);}

function buildColorPicker(selected){document.getElementById('colorOpts').innerHTML=COLORS.map(c=>`<div class="color-opt${c===selected?' sel':''}" style="background:${c};" onclick="pickColor('${c}')" title="${c}"></div>`).join('');selectedColors=selected||COLORS[0];}
function pickColor(c){selectedColors=c;document.querySelectorAll('.color-opt').forEach(el=>el.classList.toggle('sel',el.style.background===c));}

function openModalNewList(){document.getElementById('listId').value='';document.getElementById('listName').value='';document.getElementById('listDesc').value='';document.getElementById('modalListTitle').innerHTML=`<i class="bi bi-collection-fill" style="color:var(--primary);"></i> Nueva lista`;buildColorPicker(COLORS[0]);openModal('modalList');setTimeout(()=>document.getElementById('listName').focus(),150);}
async function openModalEditList(id){const l=allLists.find(x=>x.id===id);if(!l)return;document.getElementById('listId').value=l.id;document.getElementById('listName').value=l.name;document.getElementById('listDesc').value=l.description||'';document.getElementById('modalListTitle').innerHTML=`<i class="bi bi-pencil-square" style="color:var(--primary);"></i> Editar lista`;buildColorPicker(l.color||COLORS[0]);openModal('modalList');}
async function saveList(){const id=document.getElementById('listId').value;const name=document.getElementById('listName').value.trim();const desc=document.getElementById('listDesc').value.trim();if(!name){document.getElementById('listName').classList.add('invalid');return;}document.getElementById('listName').classList.remove('invalid');document.getElementById('btnSaveList').disabled=true;try{const method=id?'PUT':'POST';const url=id?`/api/report-lists/${id}`:'/api/report-lists';const j=await fetch(url,{method,credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,description:desc||null,color:selectedColors,icon:'bi-people'})}).then(r=>r.json());if(!j.success)throw new Error(j.error);toast(id?'Lista actualizada':'Lista creada','ok');closeModal('modalList');await loadLists();await loadContacts();}catch(e){toast('Error: '+e.message,'err');}finally{document.getElementById('btnSaveList').disabled=false;}}

function buildListCheckGrid(selectedIds=[]){const grid=document.getElementById('listCheckGrid');if(!allLists.length){grid.innerHTML=`<div style="color:var(--muted);font-size:12px;padding:8px;">Sin listas disponibles — crea una primero</div>`;return;}grid.innerHTML=allLists.map(l=>{const checked=selectedIds.includes(l.id)||selectedIds.includes(String(l.id));return`<label class="list-chk-row${checked?' checked':''}" id="chk_row_${l.id}"><input type="checkbox" value="${l.id}" ${checked?'checked':''} onchange="toggleChkRow(this,${l.id})"><div class="list-chk-dot" style="background:${esc(l.color||'#3b82f6')};"></div><span class="list-chk-name">${esc(l.name)}</span><span style="font-size:11px;color:var(--muted);">${l.member_count||0} miembros</span><div class="list-chk-icon"><i class="bi bi-check"></i></div></label>`;}).join('');}
const toggleChkRow=(inp,id)=>document.getElementById('chk_row_'+id).classList.toggle('checked',inp.checked);
const getCheckedLists=()=>[...document.querySelectorAll('#listCheckGrid input:checked')].map(i=>+i.value);

function openModalNewContact(){document.getElementById('contactId').value='';document.getElementById('contactName').value='';document.getElementById('contactEmail').value='';document.getElementById('contactName').classList.remove('invalid');document.getElementById('contactEmail').classList.remove('invalid');document.getElementById('modalContactTitle').innerHTML=`<i class="bi bi-person-plus-fill" style="color:var(--success);"></i> Añadir destinatario`;buildListCheckGrid(currentListId?[currentListId]:[]);openModal('modalContact');setTimeout(()=>document.getElementById('contactName').focus(),150);}
async function openModalEditContact(id){const c=allContacts.find(x=>x.id===id);if(!c)return;document.getElementById('contactId').value=c.id;document.getElementById('contactName').value=c.name;document.getElementById('contactEmail').value=c.email;document.getElementById('contactName').classList.remove('invalid');document.getElementById('contactEmail').classList.remove('invalid');document.getElementById('modalContactTitle').innerHTML=`<i class="bi bi-pencil-square" style="color:var(--primary);"></i> Editar destinatario`;buildListCheckGrid((c.list_ids||'').split(',').filter(Boolean));openModal('modalContact');}
async function saveContact(){const id=document.getElementById('contactId').value;const name=document.getElementById('contactName').value.trim();const email=document.getElementById('contactEmail').value.trim();let valid=true;if(!name){document.getElementById('contactName').classList.add('invalid');valid=false;}else document.getElementById('contactName').classList.remove('invalid');if(!email||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){document.getElementById('contactEmail').classList.add('invalid');valid=false;}else document.getElementById('contactEmail').classList.remove('invalid');if(!valid)return;const list_ids=getCheckedLists();document.getElementById('btnSaveContact').disabled=true;try{const method=id?'PUT':'POST';const url=id?`/api/report-lists/contacts/${id}`:'/api/report-lists/contacts';const j=await fetch(url,{method,credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,email,list_ids})}).then(r=>r.json());if(!j.success)throw new Error(j.error);toast(id?'Destinatario actualizado':`✅ ${name} añadido correctamente`,'ok');closeModal('modalContact');await loadLists();await loadContacts();}catch(e){toast('Error: '+e.message,'err');}finally{document.getElementById('btnSaveContact').disabled=false;}}

function confirmDeleteList(id,name){document.getElementById('confirmMsg').innerHTML=`¿Eliminar la lista <strong>"${esc(name)}"</strong>? Los contactos no se borrarán, solo se desvinculan de la lista.`;document.getElementById('confirmOkBtn').onclick=async()=>{try{const j=await fetch(`/api/report-lists/${id}`,{method:'DELETE',credentials:'include'}).then(r=>r.json());if(!j.success)throw new Error(j.error);toast('Lista eliminada','ok');closeModal('modalConfirm');if(currentListId===id)currentListId=null;await loadLists();await loadContacts();}catch(e){toast('Error: '+e.message,'err');}};openModal('modalConfirm');}
function confirmDeleteContact(id,name){document.getElementById('confirmMsg').innerHTML=`¿Eliminar a <strong>"${esc(name)}"</strong> de todos los destinatarios? Esta acción no se puede deshacer.`;document.getElementById('confirmOkBtn').onclick=async()=>{try{const j=await fetch(`/api/report-lists/contacts/${id}`,{method:'DELETE',credentials:'include'}).then(r=>r.json());if(!j.success)throw new Error(j.error);toast('Destinatario eliminado','ok');closeModal('modalConfirm');await loadLists();await loadContacts();}catch(e){toast('Error: '+e.message,'err');}};openModal('modalConfirm');}

function exportContacts(){if(!allContacts.length){toast('Sin datos para exportar','inf');return;}const rows=[['Nombre','Email','Listas','Estado'],...allContacts.map(c=>[c.name,c.email,c.lists||'',c.is_active?'Activo':'Inactivo'])].map(r=>r.map(v=>`"${(v||'').toString().replace(/"/g,'""')}"`).join(','));const a=Object.assign(document.createElement('a'),{href:URL.createObjectURL(new Blob([rows.join('\n')],{type:'text/csv;charset=utf-8;'})),download:`destinatarios_${new Date().toISOString().split('T')[0]}.csv`});a.click();toast(`Exportados: ${allContacts.length} contactos`,'ok');}

/* ════════════════════════════════════════════════════════════
   MÓDULO ENVÍO DE REPORTES — código original intacto
   INTEGRACIÓN: renderDistrib() ahora usa listas reales de BD
════════════════════════════════════════════════════════════ */
const REPORT_DEFS=[
  {id:'empleados',    name:'Reporte de Empleados',        icon:'bi-people-fill',         color:'#3b82f6',type:'PDF',  size:'~280 KB'},
  {id:'asignaciones', name:'Asignaciones Activas',        icon:'bi-clipboard-check-fill', color:'#10b981',type:'Excel',size:'~195 KB'},
  {id:'print-queue',  name:'Cola de Impresión',           icon:'bi-printer-fill',         color:'#f97316',type:'PDF',  size:'~110 KB'},
  {id:'kpis',         name:'KPIs del Mes',                icon:'bi-bar-chart-fill',       color:'#8b5cf6',type:'PDF',  size:'~450 KB'},
  {id:'inventario',   name:'Inventario de Equipos',       icon:'bi-laptop-fill',          color:'#10b981',type:'Excel',size:'~320 KB'},
  {id:'mantenimiento',name:'Historial de Mantenimientos', icon:'bi-tools',                color:'#f59e0b',type:'PDF',  size:'~175 KB'},
];

// Listas estáticas de respaldo (igual que el original)
const STATIC_DISTRIB=[
  {id:'gerencia',   label:'Gerencia',   icon:'bi-building',  emails:['gerencia@empresa.com']},
  {id:'rrhh',       label:'RRHH',       icon:'bi-people',    emails:['rrhh@empresa.com']},
  {id:'ti',         label:'TI',         icon:'bi-cpu',       emails:['ti@empresa.com']},
  {id:'finanzas',   label:'Finanzas',   icon:'bi-cash-stack',emails:['finanzas@empresa.com']},
  {id:'operaciones',label:'Operaciones',icon:'bi-gear',      emails:['operaciones@empresa.com']},
];

const TEMPLATES=[
  {label:'📊 KPIs del mes',  fn:()=>`[Reporte] KPIs – ${mesActual()} ${anio()}`},
  {label:'👥 Personal',      fn:()=>`[RRHH] Reporte de Personal – ${hoy()}`},
  {label:'💻 Inventario TI', fn:()=>`[TI] Inventario de Equipos – ${hoy()}`},
  {label:'🖨️ Cola impresión',fn:()=>`[Impresión] Resumen cola – ${hoy()}`},
  {label:'📋 Asignaciones',  fn:()=>`[Asignaciones] Estado actual – ${hoy()}`},
];

let tags={to:[],cc:[],bcc:[]},attachments=[],selectedReps=new Set(),repBlobs={};
let histItems=loadHist(),currentHistItem=null,acTimers={},employees=[];

const pad=n=>String(n).padStart(2,'0');
const hoy=()=>{const d=new Date();return`${pad(d.getDate())}/${pad(d.getMonth()+1)}/${d.getFullYear()}`;};
const MESES=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
const mesActual=()=>MESES[new Date().getMonth()];
const anio=()=>new Date().getFullYear();
const fmtSize=b=>{if(!b||typeof b==='string')return b||'—';if(b<1024)return b+'B';if(b<1048576)return(b/1024).toFixed(1)+'KB';return(b/1048576).toFixed(1)+'MB';};
const isToday=d=>{const n=new Date();return d.getDate()===n.getDate()&&d.getMonth()===n.getMonth()&&d.getFullYear()===n.getFullYear();};

function setDefaultBody(){
  const b=document.getElementById('body');
  if(b&&!b.value)b.value=`Estimado equipo,\n\nAdjunto el reporte solicitado generado el ${hoy()}.\n\nSaludos,\nSistema EquipManager`;
  updatePreview();
}

async function loadEmployees(){
  try{const j=await fetch('/api/employees?limit=500&page=1',{credentials:'include'}).then(r=>r.json());if(j.success&&j.data)employees=j.data;}
  catch(e){console.warn('Autocomplete empleados no disponible:',e.message);}
}

/* renderDistrib: usa listas reales de la BD si están cargadas,
   si no usa las estáticas de respaldo (igual que el original) */
function renderDistrib(){
  const el=document.getElementById('dcRow');
  if(!el)return;
  // Preferir listas reales de la BD
  const source = allLists.length ? allLists : STATIC_DISTRIB;
  el.innerHTML=source.map(l=>{
    const isReal=!!l.member_count!==undefined&&allLists.length>0;
    const id=isReal?`real_${l.id}`:l.id;
    const icon=l.icon||'bi-collection';
    const label=l.name||l.label;
    const count=isReal?(l.member_count||0):((l.emails||[]).length);
    return`<button class="dc" id="dc_${id}" onclick="toggleDistrib('${id}','${esc(label)}',${isReal?l.id:'null'})">
      <i class="bi ${icon}"></i> ${esc(label)}
      <span style="font-size:10px;opacity:.7;">(${count})</span>
    </button>`;
  }).join('');
}

/* toggleDistrib para listas reales: añade TODOS los emails de esa lista
   cargándolos del API (si es lista real) o usando el array estático */
async function toggleDistrib(chipId, label, realListId){
  const btn=document.getElementById('dc_'+chipId);
  if(!btn)return;

  if(realListId){
    // Lista real: cargar emails desde la BD
    try{
      const url=`/api/report-lists/contacts/all?list_id=${realListId}`;
      const j=await fetch(url,{credentials:'include'}).then(r=>r.json());
      if(!j.success)throw new Error(j.error);
      const emails=(j.data||[]).filter(c=>c.is_active&&c.email).map(c=>c.email);
      if(!emails.length){toast(`La lista "${label}" no tiene contactos activos`,'inf');return;}
      const allIn=emails.every(e=>tags.to.some(t=>t.email===e));
      if(allIn){emails.forEach(e=>{const i=tags.to.findIndex(t=>t.email===e);if(i>-1)tags.to.splice(i,1);});btn.classList.remove('active');}
      else{emails.forEach(e=>{if(!tags.to.some(t=>t.email===e))tags.to.push({email:e,name:e,internal:false,distrib:true});});btn.classList.add('active');}
    }catch(e){toast('Error cargando lista: '+e.message,'err');return;}
  }else{
    // Lista estática
    const list=STATIC_DISTRIB.find(d=>d.id===chipId);
    if(!list)return;
    const allIn=list.emails.every(e=>tags.to.some(t=>t.email===e));
    if(allIn){list.emails.forEach(e=>{const i=tags.to.findIndex(t=>t.email===e);if(i>-1)tags.to.splice(i,1);});btn.classList.remove('active');}
    else{list.emails.forEach(e=>{if(!tags.to.some(t=>t.email===e))tags.to.push({email:e,name:e,internal:false,distrib:true});});btn.classList.add('active');}
  }
  renderTags('to');updatePreview();updateRcCount();
}

/* ── TAGS (original intacto) ── */
const focusTI=id=>document.getElementById(id)?.focus();
function tagKD(e,field){const inp=e.target;if((e.key==='Enter'||e.key===',')&&inp.value.trim()){e.preventDefault();addTag(field,inp.value.trim());inp.value='';closeAc(field+'Ac');}else if(e.key==='Backspace'&&!inp.value&&tags[field].length)removeTag(field,tags[field].length-1);}
function addTag(field,email,name){const clean=email.replace(/,/g,'').trim();if(!clean||tags[field].some(t=>t.email===clean))return;const internal=employees.some(e=>e.email===clean);const distrib=STATIC_DISTRIB.some(d=>d.emails.includes(clean));tags[field].push({email:clean,name:name||clean,internal,distrib});renderTags(field);updatePreview();updateRcCount();}
function removeTag(field,idx){tags[field].splice(idx,1);renderTags(field);updatePreview();updateRcCount();}
function renderTags(field){const wrap=document.getElementById(field+'Wrap');const inp=document.getElementById(field+'Input');wrap.querySelectorAll('.tag').forEach(t=>t.remove());tags[field].forEach((t,i)=>{const cls=t.distrib?'dist':t.internal?'':'ext';const d=document.createElement('div');d.className=`tag ${cls}`;const short=t.name!==t.email?t.name:(t.email.length>22?t.email.split('@')[0]+'@…':t.email);d.innerHTML=`<span title="${esc(t.email)}">${esc(short)}</span><button class="tag-x" onclick="removeTag('${field}',${i});event.stopPropagation()">×</button>`;wrap.insertBefore(d,inp);});}
const updateRcCount=()=>{const el=document.getElementById('rcCount');if(el)el.textContent=tags.to.length+tags.cc.length+tags.bcc.length;};

/* ── AUTOCOMPLETE (original intacto) ── */
function acSearch(inp,dropId,field){const q=inp.value.toLowerCase().trim();clearTimeout(acTimers[field]);if(q.length<2){closeAc(dropId);return;}acTimers[field]=setTimeout(()=>{const matches=employees.filter(e=>(e.full_name||'').toLowerCase().includes(q)||(e.email||'').toLowerCase().includes(q)).slice(0,8);const drop=document.getElementById(dropId);if(!matches.length){closeAc(dropId);return;}drop.innerHTML=matches.map(e=>{const init=(e.full_name||e.email||'?').split(' ').map(w=>w[0]).slice(0,2).join('').toUpperCase();return`<div class="ac-item" onclick="pickAc('${field}','${esc(e.email)}','${esc(e.full_name||e.email)}')"><div class="ac-av">${init}</div><div><div class="ac-name">${esc(e.full_name||e.email)}</div><div class="ac-email">${esc(e.email)}</div></div><span class="ac-dept">${esc(e.department||e.position_name||'')}</span></div>`;}).join('');drop.style.display='block';},200);}
const pickAc=(field,email,name)=>{addTag(field,email,name);document.getElementById(field+'Input').value='';closeAc(field+'Ac');};
const closeAc=id=>{const d=document.getElementById(id);if(d)d.style.display='none';};
document.addEventListener('click',e=>{['toAc','ccAc','bccAc'].forEach(id=>{if(!document.getElementById(id)?.contains(e.target)&&!e.target.closest('.tags-wrap'))closeAc(id);});});

function toggleCC(field){const row=document.getElementById(field+'Row');const btn=document.getElementById(field+'Toggle');const vis=row.style.display!=='none';row.style.display=vis?'none':'';btn.classList.toggle('on',!vis);btn.textContent=vis?`+ ${field.toUpperCase()}`:`− ${field.toUpperCase()}`;updatePreview();}

function renderTemplates(){const el=document.getElementById('tplRow');if(!el)return;el.innerHTML=TEMPLATES.map(t=>`<button class="tpl-btn" onclick="applyTpl('${esc(t.fn())}')">${t.label}</button>`).join('');}
const applyTpl=text=>{document.getElementById('subject').value=text;updatePreview();};

function switchFT(tab){document.getElementById('panelUpload').style.display=tab==='upload'?'':'none';document.getElementById('panelApp').style.display=tab==='app'?'':'none';document.getElementById('ftUpload').classList.toggle('active',tab==='upload');document.getElementById('ftApp').classList.toggle('active',tab==='app');if(tab==='app')renderAppReports();}

function initDrop(){const zone=document.getElementById('dropZone');if(!zone)return;zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('drag-over');});zone.addEventListener('dragleave',()=>zone.classList.remove('drag-over'));zone.addEventListener('drop',e=>{e.preventDefault();zone.classList.remove('drag-over');handleFiles(e.dataTransfer.files);});}
function handleFiles(files){Array.from(files).forEach(f=>{if(attachments.some(a=>a.name===f.name&&a.type==='upload'))return;if(f.size>25*1024*1024){showToast(`${f.name} excede 25 MB`,'err');return;}attachments.push({id:`up_${Date.now()}_${Math.random().toString(36).slice(2)}`,name:f.name,size:f.size,file:f,type:'upload'});});renderAtts();updatePreview();}

function renderAppReports(){const wrap=document.getElementById('repListWrap');if(!wrap)return;wrap.innerHTML=`<div class="rep-list">`+REPORT_DEFS.map(r=>`<div class="rep-item" id="repI_${r.id}" onclick="toggleRep('${r.id}')"><div class="rep-check" id="repCk_${r.id}"><i class="bi bi-check"></i></div><i class="bi ${r.icon}" style="font-size:20px;color:${r.color};flex-shrink:0;"></i><div><div class="rep-name">${r.name}</div><div class="rep-meta">${r.size} · Generado al vuelo</div></div><span class="rep-badge ${r.type==='PDF'?'rb-pdf':'rb-xls'}">${r.type}</span><div class="rep-gen-overlay"><span class="mini-spin" style="border-color:rgba(59,130,246,.3);border-top-color:var(--primary);"></span> Generando…</div></div>`).join('')+`</div>`;}

async function toggleRep(id){const def=REPORT_DEFS.find(r=>r.id===id);const item=document.getElementById('repI_'+id);if(!def||!item)return;if(selectedReps.has(id)){selectedReps.delete(id);item.classList.remove('sel');attachments=attachments.filter(a=>a.id!==id);delete repBlobs[id];renderAtts();updatePreview();return;}item.classList.add('generating');showToast(`Generando ${def.name}…`,'inf',6000);try{const resp=await fetch(`/api/reports/${def.id}`,{method:'GET',credentials:'include'});if(!resp.ok)throw new Error(`HTTP ${resp.status}`);const cd=resp.headers.get('Content-Disposition')||'';const fnM=cd.match(/filename[^;=\n]*=['"]?([^'";\n]+)/i);const filename=fnM?fnM[1].trim():`${def.id}.${def.type==='PDF'?'pdf':'xlsx'}`;const blob=await resp.blob();repBlobs[id]={blob,filename};selectedReps.add(id);item.classList.add('sel');attachments.push({id,name:filename,size:blob.size,type:'app',def});showToast(`✅ ${def.name} listo`,'ok',3000);renderAtts();updatePreview();}catch(e){showToast(`❌ Error generando ${def.name}: ${e.message}`,'err',6000);}finally{item.classList.remove('generating');}}

function fileIcon(name){const ext=('.'+(name.split('.').pop()||'')).toLowerCase();if(['.pdf'].includes(ext))return{cls:'att-pdf',icon:'bi-file-earmark-pdf'};if(['.doc','.docx'].includes(ext))return{cls:'att-word',icon:'bi-file-earmark-word'};if(['.xls','.xlsx','.csv'].includes(ext))return{cls:'att-excel',icon:'bi-file-earmark-excel'};if(['.ppt','.pptx'].includes(ext))return{cls:'att-ppt',icon:'bi-file-earmark-ppt'};if(['.png','.jpg','.jpeg'].includes(ext))return{cls:'att-img',icon:'bi-file-image'};return{cls:'att-other',icon:'bi-file-earmark'};}

function renderAtts(){const list=document.getElementById('attList');const cnt=document.getElementById('attCount');if(cnt)cnt.textContent=attachments.length;if(!attachments.length){list.innerHTML='';return;}list.innerHTML=attachments.map((a,i)=>{const fi=fileIcon(a.name);const src=a.type==='app'?`<span class="att-src app">APP</span>`:`<span class="att-src upload">SUBIDO</span>`;return`<div class="att-item"><i class="bi ${fi.icon} att-icon ${fi.cls}"></i><div class="att-info"><div class="att-name">${esc(a.name)}</div><div class="att-size">${fmtSize(a.size)} ${src}</div></div><button class="att-rm" onclick="removeAtt(${i})" title="Quitar adjunto"><i class="bi bi-x-lg" style="font-size:12px;"></i></button></div>`;}).join('');}
function removeAtt(idx){const a=attachments[idx];if(a.type==='app'){selectedReps.delete(a.id);document.getElementById('repI_'+a.id)?.classList.remove('sel');delete repBlobs[a.id];}attachments.splice(idx,1);renderAtts();updatePreview();}

function togglePreview(){const panel=document.getElementById('previewPanel');const btn=document.getElementById('btnPreview');const vis=panel.style.display!=='none';panel.style.display=vis?'none':'';if(btn)btn.classList.toggle('on',!vis);if(!vis)updatePreview();}
function updatePreview(){const toStr=tags.to.map(t=>t.name!==t.email?`${t.name} <${t.email}>`:t.email).join(', ')||'—';const ccStr=tags.cc.map(t=>t.email).join(', ');const bccStr=tags.bcc.map(t=>t.email).join(', ');const s=id=>{const el=document.getElementById(id);return el};if(s('pvTo'))document.getElementById('pvTo').textContent=toStr;if(s('pvSubject'))document.getElementById('pvSubject').textContent=document.getElementById('subject')?.value||'(sin asunto)';if(s('pvBody'))document.getElementById('pvBody').textContent=document.getElementById('body')?.value||'';const ccRow=document.getElementById('pvCcRow'),bccRow=document.getElementById('pvBccRow');if(ccRow){if(ccStr){ccRow.style.display='';document.getElementById('pvCc').textContent=ccStr;}else ccRow.style.display='none';}if(bccRow){if(bccStr){bccRow.style.display='';document.getElementById('pvBcc').textContent=bccStr;}else bccRow.style.display='none';}const pvAtts=document.getElementById('pvAtts');if(pvAtts)pvAtts.innerHTML=attachments.map(a=>{const fi=fileIcon(a.name);return`<div class="ep-att-chip"><i class="bi ${fi.icon} ${fi.cls}"></i> ${esc(a.name)}</div>`;}).join('');}

function shakeEl(id){const el=document.getElementById(id);if(!el)return;el.style.animation='shk .4s ease';el.style.borderColor='var(--danger)';el.style.boxShadow='0 0 0 3px rgba(239,68,68,.12)';setTimeout(()=>{el.style.animation='';el.style.borderColor='';el.style.boxShadow='';},500);}
const shkStyle=document.createElement('style');shkStyle.textContent='@keyframes shk{0%,100%{transform:translateX(0);}20%,60%{transform:translateX(-5px);}40%,80%{transform:translateX(5px);}}';document.head.appendChild(shkStyle);

function sendEmail(){if(!tags.to.length){shakeEl('toWrap');showToast('Añade al menos un destinatario','inf');return;}if(!document.getElementById('subject').value.trim()){shakeEl('subject');showToast('Escribe el asunto','inf');return;}const toStr=tags.to.map(t=>t.name!==t.email?`${t.name} <${t.email}>`:t.email).join('\n');const ccStr=tags.cc.map(t=>t.email).join(', ');const bccStr=tags.bcc.map(t=>t.email).join(', ');let html=`<div class="confirm-row"><div class="confirm-key">Para</div><div class="confirm-val">${esc(toStr)}</div></div>${ccStr?`<div class="confirm-row"><div class="confirm-key">CC</div><div class="confirm-val">${esc(ccStr)}</div></div>`:''}${bccStr?`<div class="confirm-row"><div class="confirm-key">CCO</div><div class="confirm-val">${esc(bccStr)}</div></div>`:''}<div class="confirm-row"><div class="confirm-key">Asunto</div><div class="confirm-val" style="font-weight:700;">${esc(document.getElementById('subject').value)}</div></div>`;if(attachments.length)html+=`<div class="confirm-row"><div class="confirm-key">Adjuntos (${attachments.length})</div><div class="confirm-val">${attachments.map(a=>`📎 ${esc(a.name)} (${fmtSize(a.size)})`).join('\n')}</div></div>`;document.getElementById('confirmBody').innerHTML=html;new bootstrap.Modal(document.getElementById('confirmModal')).show();}

async function doSend(){bootstrap.Modal.getInstance(document.getElementById('confirmModal'))?.hide();const btnSend=document.getElementById('btnSend');btnSend.disabled=true;showSrStatus('Enviando correo…','sending');document.getElementById('miniProg').style.display='';try{const fd=new FormData();fd.append('to',JSON.stringify(tags.to.map(t=>t.email)));fd.append('cc',JSON.stringify(tags.cc.map(t=>t.email)));fd.append('bcc',JSON.stringify(tags.bcc.map(t=>t.email)));fd.append('subject',document.getElementById('subject').value);fd.append('body',document.getElementById('body').value);attachments.filter(a=>a.type==='upload').forEach(a=>fd.append('files',a.file,a.name));Object.entries(repBlobs).forEach(([,{blob,filename}])=>fd.append('files',blob,filename));const resp=await fetch('/api/mailer/send',{method:'POST',body:fd,credentials:'include'});const result=await resp.json();if(!result.success)throw new Error(result.error||'Error desconocido');saveHistEntry('ok');showSrStatus(`✅ Correo enviado correctamente a ${tags.to.length} destinatario(s)`,'ok');showToast('✅ Correo enviado','ok');setTimeout(()=>{clearForm(true);document.getElementById('srStatus').classList.remove('show');},3500);}catch(e){saveHistEntry('err');showSrStatus(`❌ Error al enviar: ${e.message}`,'err');showToast('Error: '+e.message,'err',7000);}finally{document.getElementById('miniProg').style.display='none';btnSend.disabled=false;}}

function saveHistEntry(status){histItems.unshift({id:Date.now(),to:tags.to.map(t=>t.email),cc:tags.cc.map(t=>t.email),bcc:tags.bcc.map(t=>t.email),subject:document.getElementById('subject').value,body:document.getElementById('body').value,atts:attachments.map(a=>({name:a.name,size:fmtSize(a.size),type:a.type})),sentAt:new Date().toISOString(),status});saveHist();renderHist();document.getElementById('mBadgeEnvio').textContent=histItems.length;}

function showSrStatus(msg,type){const el=document.getElementById('srStatus');el.className=`sr-status show ${type}`;el.innerHTML=type==='sending'?`<span class="mini-spin" style="border-color:rgba(6,182,212,.3);border-top-color:var(--info);"></span><span>${msg}</span>`:`<span>${msg}</span>`;if(type!=='sending')setTimeout(()=>el.classList.remove('show'),6000);}

function loadHist(){try{return JSON.parse(localStorage.getItem('srMailHist')||'[]');}catch{return[];}}
function saveHist(){try{localStorage.setItem('srMailHist',JSON.stringify(histItems.slice(0,60)));}catch{}}
function renderHist(q=''){const list=document.getElementById('histList');if(!list)return;const items=q?histItems.filter(h=>h.subject.toLowerCase().includes(q)||h.to.join(',').toLowerCase().includes(q)):histItems;if(!items.length){list.innerHTML=`<div class="hist-empty"><i class="bi bi-inbox"></i>Sin envíos recientes</div>`;return;}list.innerHTML=items.map(h=>{const d=new Date(h.sentAt);const ts=isToday(d)?d.toLocaleTimeString('es-PE',{hour:'2-digit',minute:'2-digit'}):d.toLocaleDateString('es-PE',{day:'2-digit',month:'short'});return`<div class="hi" onclick="openHistDetail(${h.id})"><div class="hi-top"><div class="hi-subj">${esc(h.subject)}</div><div class="hi-time">${ts}</div></div><div class="hi-to">Para: ${h.to.slice(0,2).join(', ')}${h.to.length>2?` +${h.to.length-2}`:''}</div><div class="hi-badges"><span class="hb ${h.status==='ok'?'hb-ok':'hb-err'}">${h.status==='ok'?'✅ Enviado':'❌ Error'}</span>${h.atts.length?`<span class="hb hb-att">📎 ${h.atts.length}</span>`:''}</div></div>`;}).join('');}
const filterHist=()=>renderHist(document.getElementById('histSearch').value.toLowerCase());
function openHistDetail(id){const h=histItems.find(x=>x.id===id);if(!h)return;currentHistItem=h;const d=new Date(h.sentAt);document.getElementById('histModalBody').innerHTML=`<div style="display:flex;flex-direction:column;gap:9px;"><div class="confirm-row"><div class="confirm-key">Para</div><div class="confirm-val">${esc(h.to.join(', '))}</div></div>${h.cc.length?`<div class="confirm-row"><div class="confirm-key">CC</div><div class="confirm-val">${esc(h.cc.join(', '))}</div></div>`:''}${h.bcc.length?`<div class="confirm-row"><div class="confirm-key">CCO</div><div class="confirm-val">${esc(h.bcc.join(', '))}</div></div>`:''}<div class="confirm-row"><div class="confirm-key">Asunto</div><div class="confirm-val" style="font-weight:700;">${esc(h.subject)}</div></div><div class="confirm-row"><div class="confirm-key">Enviado</div><div class="confirm-val" style="font-family:'DM Mono',monospace;font-size:12px;">${d.toLocaleString('es-PE')}</div></div>${h.body?`<div class="confirm-row"><div class="confirm-key">Mensaje</div><div class="confirm-val" style="font-weight:400;white-space:pre-wrap;">${esc(h.body)}</div></div>`:''}${h.atts.length?`<div class="confirm-row"><div class="confirm-key">Adjuntos</div><div class="confirm-val">${h.atts.map(a=>`📎 ${esc(a.name)} (${a.size})`).join('\n')}</div></div>`:''}</div>`;new bootstrap.Modal(document.getElementById('histModal')).show();}
function reuseEmail(){if(!currentHistItem)return;bootstrap.Modal.getInstance(document.getElementById('histModal'))?.hide();const h=currentHistItem;tags.to=h.to.map(e=>({email:e,name:e,internal:false}));tags.cc=h.cc.map(e=>({email:e,name:e,internal:false}));tags.bcc=h.bcc.map(e=>({email:e,name:e,internal:false}));['to','cc','bcc'].forEach(f=>renderTags(f));if(h.cc.length){document.getElementById('ccRow').style.display='';document.getElementById('ccToggle').textContent='− CC';document.getElementById('ccToggle').classList.add('on');}if(h.bcc.length){document.getElementById('bccRow').style.display='';document.getElementById('bccToggle').textContent='− CCO';document.getElementById('bccToggle').classList.add('on');}document.getElementById('subject').value=h.subject;document.getElementById('body').value=h.body||'';updatePreview();updateRcCount();showToast('Formulario rellenado desde historial','ok',3000);}

function clearForm(keepBody=false){tags={to:[],cc:[],bcc:[]};['to','cc','bcc'].forEach(f=>renderTags(f));attachments=[];selectedReps.clear();repBlobs={};renderAtts();renderAppReports();document.getElementById('subject').value='';if(!keepBody)setDefaultBody();document.getElementById('ccRow').style.display='none';document.getElementById('bccRow').style.display='none';document.getElementById('ccToggle').textContent='+ CC';document.getElementById('bccToggle').textContent='+ CCO';document.getElementById('ccToggle').classList.remove('on');document.getElementById('bccToggle').classList.remove('on');document.querySelectorAll('.dc').forEach(c=>c.classList.remove('active'));updatePreview();updateRcCount();}

