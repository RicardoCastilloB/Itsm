    <div class="modal-header" style="background:var(--header);border-color:var(--border);"><h5 class="modal-title" style="display:flex;align-items:center;gap:8px;"><i class="bi bi-envelope-open" style="color:var(--primary);"></i> Detalle de envío</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body" id="histModalBody" style="background:var(--card);"></div>
    <div class="modal-footer" style="background:var(--header);border-color:var(--border);"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button><button type="button" class="btn btn-primary" onclick="reuseEmail()"><i class="bi bi-arrow-repeat"></i> Reutilizar</button></div>
  </div></div>
