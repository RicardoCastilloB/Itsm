<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soporte Técnico — Active Directory</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,600;0,700&family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="../css/style.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>(function(){const s=localStorage.getItem('dashboardTheme')||'light';document.documentElement.setAttribute('data-theme',s);})();</script>

<style>
/* ═══════════════════════════════════════════════
   VARIABLES  (mismo sistema que el resto del app)
═══════════════════════════════════════════════ */
:root,[data-theme="light"]{
  --bg:#f0f4f8; --card:#ffffff; --hdr:#f8fafc; --border:#e2e8f0;
  --text:#1e293b; --muted:#64748b;
  --primary:#3b82f6; --success:#10b981; --warning:#f59e0b;
  --danger:#ef4444; --info:#06b6d4; --purple:#8b5cf6;
  --hover:#f1f5f9; --input-bg:#f8fafc;
  --sh:0 1px 3px rgba(0,0,0,.07); --sh-md:0 4px 16px rgba(0,0,0,.1);
  --mono:'JetBrains Mono',monospace;
}
[data-theme="dark"]{
  --bg:#0f172a; --card:#1e293b; --hdr:#162032; --border:#2d3f55;
  --text:#e2e8f0; --muted:#94a3b8;
  --primary:#60a5fa; --success:#34d399; --warning:#fbbf24;
  --danger:#f87171; --info:#22d3ee; --purple:#a78bfa;
  --hover:#243348; --input-bg:#162032;
  --sh:0 1px 3px rgba(0,0,0,.3); --sh-md:0 4px 16px rgba(0,0,0,.4);
}

/* ═══════════════════════════════════════════════ BASE */
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;transition:background .3s,color .3s;}

.pg{margin-top:60px;padding:18px 22px;display:flex;flex-direction:column;gap:14px;
    max-width:1700px;margin-left:auto;margin-right:auto;}

/* ═══════════════════════════════════════════════ KPI ROW */
.kpi-row{display:grid;grid-template-columns:repeat(9,1fr);gap:10px;}
@media(max-width:1400px){.kpi-row{grid-template-columns:repeat(5,1fr);}}
@media(max-width:900px) {.kpi-row{grid-template-columns:repeat(3,1fr);}}
@media(max-width:540px) {.kpi-row{grid-template-columns:repeat(2,1fr);}}

.kpi{background:var(--card);border:1px solid var(--border);border-radius:14px;
    padding:14px 16px;position:relative;overflow:hidden;
    box-shadow:var(--sh);transition:transform .2s,box-shadow .2s,background .3s,border-color .3s;}
.kpi:hover{transform:translateY(-2px);box-shadow:var(--sh-md);}
.kpi-lbl{font-size:9px;letter-spacing:.6px;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:5px;}
.kpi-val{font-size:26px;font-weight:900;line-height:1;letter-spacing:-1px;font-family:var(--mono);}
.kpi-sub{font-size:10px;color:var(--muted);margin-top:3px;}
.kpi-ico{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:30px;opacity:.1;}
.cg{color:var(--success);} .cr{color:var(--danger);} .ca{color:var(--warning);}
.cb{color:var(--primary);} .cp{color:var(--purple);} .ci{color:var(--info);} .cm{color:var(--muted);}

/* ═══════════════════════════════════════════════ SHARED CARD */
.card-ui{background:var(--card);border:1px solid var(--border);border-radius:14px;
    overflow:hidden;box-shadow:var(--sh);transition:background .3s,border-color .3s;}
.card-head{padding:13px 18px;background:var(--hdr);border-bottom:1px solid var(--border);
    display:flex;align-items:center;justify-content:space-between;
    font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;
    color:var(--muted);transition:background .3s,border-color .3s;}
.card-head .title{display:flex;align-items:center;gap:8px;color:var(--text);font-size:13px;text-transform:none;letter-spacing:0;}
.card-body{padding:20px;}

/* ═══════════════════════════════════════════════ SEARCH PANEL */
.search-panel{background:var(--card);border:1px solid var(--border);border-radius:16px;
    padding:20px 24px;box-shadow:var(--sh);}
.search-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:6px;}
.search-row{display:flex;gap:10px;}
.inp-wrap{position:relative;flex:1;}
.ico-inp{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:17px;pointer-events:none;}
.search-inp{width:100%;padding:13px 16px 13px 46px;border:2px solid var(--border);border-radius:12px;
    font-size:14px;font-family:var(--mono);background:var(--input-bg);color:var(--text);
    outline:none;transition:border-color .2s,box-shadow .2s,background .3s,color .3s;}
.search-inp:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.12);}
.search-inp::placeholder{font-family:'DM Sans',sans-serif;color:var(--muted);}
.btn-consult{padding:13px 30px;border-radius:12px;background:var(--primary);color:#fff;
    border:none;font-weight:700;font-size:14px;cursor:pointer;white-space:nowrap;
    transition:background .2s,transform .15s;}
.btn-consult:hover{background:#2563eb;transform:translateY(-1px);}
.btn-consult:disabled{opacity:.6;cursor:not-allowed;transform:none;}
.search-hint{margin-top:10px;font-size:11px;color:var(--muted);display:flex;align-items:center;gap:6px;}

/* ═══════════════════════════════════════════════ USER CARD */
.u-header{display:flex;align-items:flex-start;gap:20px;flex-wrap:wrap;}
.u-avatar{width:68px;height:68px;border-radius:16px;flex-shrink:0;
    display:flex;align-items:center;justify-content:center;
    font-size:24px;font-weight:900;color:#fff;
    background:linear-gradient(135deg,var(--primary),var(--purple));}
.u-name{font-size:20px;font-weight:800;line-height:1.15;}
.u-account{font-family:var(--mono);font-size:12px;color:var(--muted);margin-top:2px;}
.badges{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;}
.badge-pill{display:inline-flex;align-items:center;gap:5px;padding:5px 11px;
    border-radius:20px;font-size:11px;font-weight:700;border:1px solid transparent;}
.bp-ok   {background:rgba(16,185,129,.1); color:#059669;border-color:rgba(16,185,129,.25);}
.bp-bad  {background:rgba(239,68,68,.1);  color:#dc2626;border-color:rgba(239,68,68,.25);}
.bp-warn {background:rgba(245,158,11,.1); color:#b45309;border-color:rgba(245,158,11,.25);}
.bp-lock {background:rgba(139,92,246,.1); color:#6d28d9;border-color:rgba(139,92,246,.25);}
.bp-prov {background:rgba(14,165,233,.1); color:#0369a1;border-color:rgba(14,165,233,.25);}
.bp-info {background:rgba(6,182,212,.1);  color:#0891b2;border-color:rgba(6,182,212,.2);}

/* ═══════════════════════════════════════════════ INFO GRID */
.info-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:10px;margin-top:16px;}
.info-cell{background:var(--hover);border:1px solid var(--border);border-radius:10px;padding:12px 14px;}
.info-cell.span2{grid-column:span 2;}
@media(max-width:600px){.info-cell.span2{grid-column:span 1;}}
.ic-lbl{font-size:9.5px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-weight:700;margin-bottom:4px;display:flex;align-items:center;gap:5px;}
.ic-val{font-size:13px;color:var(--text);font-weight:600;word-break:break-all;}
.ic-val.mono{font-family:var(--mono);font-size:12px;}
.ic-val.ok  {color:var(--success);}
.ic-val.warn{color:var(--warning);}
.ic-val.bad {color:var(--danger);}
.ic-val.muted{color:var(--muted);}

/* ═══════════════════════════════════════════════ COMPUTER STRIP */
.comp-strip{margin-top:14px;background:linear-gradient(135deg,rgba(59,130,246,.05),rgba(139,92,246,.05));
    border:1px solid rgba(59,130,246,.18);border-radius:12px;padding:14px 18px;
    display:flex;align-items:center;gap:14px;}
.comp-ico{font-size:26px;color:var(--primary);flex-shrink:0;}
.comp-name{font-family:var(--mono);font-size:14px;font-weight:700;}
.comp-meta{font-size:11px;color:var(--muted);margin-top:2px;}

/* ═══════════════════════════════════════════════ GROUPS */
.grp-wrap{margin-top:14px;}
.grp-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-weight:700;margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.grp-tag{display:inline-block;padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;
    background:rgba(59,130,246,.08);color:var(--primary);border:1px solid rgba(59,130,246,.18);
    margin:2px 3px 2px 0;font-family:var(--mono);}

/* ═══════════════════════════════════════════════ ACTION ROW */
.act-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:16px;padding-top:14px;border-top:1px solid var(--border);}
.btn-act{display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border-radius:10px;
    font-size:12px;font-weight:700;border:1px solid transparent;cursor:pointer;transition:all .18s;}
.btn-unlock{background:rgba(245,158,11,.1);color:#b45309;border-color:rgba(245,158,11,.3);}
.btn-unlock:hover:not(:disabled){background:#f59e0b;color:#fff;border-color:#f59e0b;}
.btn-act:disabled{opacity:.35;cursor:not-allowed;}
.pill-prov{background:rgba(14,165,233,.12);color:#0369a1;border-color:rgba(14,165,233,.3);}
.btn-pwd{background:rgba(139,92,246,.1);color:#6d28d9;border-color:rgba(139,92,246,.25);}
.btn-pwd:hover{background:var(--purple);color:#fff;border-color:var(--purple);}
.btn-copy{background:rgba(6,182,212,.1);color:#0891b2;border-color:rgba(6,182,212,.2);}
.btn-copy:hover{background:var(--info);color:#fff;border-color:var(--info);}

/* ═══════════════════════════════════════════════ TABLES */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
@media(max-width:1100px){.two-col{grid-template-columns:1fr;}}

.tbl{width:100%;border-collapse:collapse;font-size:13px;}
.tbl thead th{font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);font-weight:700;
    padding:10px 14px;background:var(--hdr);border-bottom:1px solid var(--border);white-space:nowrap;}
.tbl tbody td{padding:11px 14px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;}
.tbl tbody tr:last-child td{border-bottom:none;}
.tbl tbody tr:hover td{background:var(--hover);}
.mono-cell{font-family:var(--mono);font-size:12px;}
.link-cell{font-family:var(--mono);font-size:12px;color:var(--primary);cursor:pointer;font-weight:600;}
.link-cell:hover{text-decoration:underline;}
.days-badge{display:inline-block;padding:3px 9px;border-radius:6px;font-size:11px;font-weight:700;font-family:var(--mono);}
.days-ok  {background:rgba(16,185,129,.1); color:#059669;}
.days-warn{background:rgba(245,158,11,.1); color:#b45309;}
.days-bad {background:rgba(239,68,68,.1);  color:#dc2626;}
.days-never{background:rgba(100,116,139,.1);color:var(--muted);}

/* ═══════════════════════════════════════════════ SKELETON */
.skel{background:linear-gradient(90deg,var(--border) 25%,var(--hover) 50%,var(--border) 75%);
    background-size:200%;animation:shim 1.3s infinite;border-radius:8px;}
@keyframes shim{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* ═══════════════════════════════════════════════ EMPTY */
.empty-state{text-align:center;padding:40px 16px;color:var(--muted);}
.empty-state i{font-size:40px;opacity:.2;display:block;margin-bottom:10px;}

/* ═══════════════════════════════════════════════ TOAST */
#toastBox{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;}
.t-item{background:var(--card);border:1px solid var(--border);color:var(--text);
    border-radius:12px;padding:11px 16px;font-size:13px;font-weight:500;
    box-shadow:var(--sh-md);display:flex;align-items:center;gap:10px;min-width:250px;
    pointer-events:auto;animation:tin .2s ease;}
.t-ok {border-left:4px solid var(--success);}
.t-err{border-left:4px solid var(--danger);}
.t-inf{border-left:4px solid var(--info);}
.t-wrn{border-left:4px solid var(--warning);}
@keyframes tin{from{opacity:0;transform:translateX(18px)}to{opacity:1;transform:none}}

/* ═══════════════════════════════════════════════ AUTOCOMPLETE */
.ac-wrap{position:relative;}
.ac-drop{position:absolute;top:calc(100% + 6px);left:0;right:0;
    background:var(--card);border:1px solid var(--border);border-radius:12px;
    box-shadow:var(--sh-md);z-index:200;overflow:hidden;
    animation:acIn .12s ease;}
@keyframes acIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:none}}
.ac-item{display:flex;align-items:center;gap:12px;padding:10px 14px;cursor:pointer;
    transition:background .12s;border-bottom:1px solid var(--border);}
.ac-item:last-child{border-bottom:none;}
.ac-item:hover,.ac-item.active{background:var(--hover);}
.ac-account{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--primary);min-width:110px;}
.ac-account mark{background:rgba(59,130,246,.18);color:var(--primary);border-radius:3px;padding:0 2px;}
.ac-name{font-size:12px;color:var(--text);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.ac-dept{font-size:11px;color:var(--muted);white-space:nowrap;}
.ac-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.ac-dot.on{background:var(--success);} .ac-dot.off{background:var(--muted);}
.ac-empty{padding:12px 14px;font-size:12px;color:var(--muted);text-align:center;}
*::-webkit-scrollbar{width:5px;height:5px;}
*::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
*::-webkit-scrollbar-track{background:transparent;}

/* ═══════════════════════════════════════════════ DT DARK MODE */
[data-theme="dark"] .modal-content{background:var(--card);border-color:var(--border);color:var(--text);}
[data-theme="dark"] .btn-close{filter:invert(1);}
</style>
</head>
<body>

<%- include("partials/sidebar_top") %>
<div id="toastBox"></div>
 
<div class="pg">

  <!-- ══════════════════════ KPI ROW ══════════════════════ -->
  <div class="kpi-row" id="kpiRow">
    <!-- filled by JS -->
    <% for(let i=0;i<9;i++){ %>
    <div class="kpi"><div><div class="kpi-lbl skel" style="width:60px;height:10px;margin-bottom:8px;"></div><div class="kpi-val skel" style="width:50px;height:28px;"></div></div></div>
    <% } %>
  </div>

  <!-- ══════════════════════ SEARCH ══════════════════════ -->
  <div class="search-panel">
    <div class="search-lbl"><i class="bi bi-shield-lock-fill"></i>Consultar cuenta de red — Active Directory</div>
    <div class="search-row">
      <div class="inp-wrap ac-wrap">
        <i class="bi bi-person-badge ico-inp"></i>
        <input type="text" id="searchInp" class="search-inp"
          placeholder="Cuenta de red (jperez, maria.garcia, juan.quispe)..."
          autocomplete="off" spellcheck="false">
        <div id="acDrop" class="ac-drop" style="display:none;"></div>
      </div>
      <button class="btn-consult" id="btnSearch">
        <i class="bi bi-search me-1"></i>Consultar AD
      </button>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:10px;flex-wrap:wrap;gap:8px;">
      <div class="search-hint">
        <i class="bi bi-info-circle"></i>
        Consulta en tiempo real al AD. Presiona <kbd style="background:var(--hover);border:1px solid var(--border);border-radius:4px;padding:0 4px;font-size:11px;">Enter</kbd> para buscar.
      </div>
      <div style="display:flex;align-items:center;gap:10px;font-size:11px;color:var(--muted);">
        <span style="display:flex;align-items:center;gap:5px;">
          <span id="cacheDot" style="width:7px;height:7px;border-radius:50%;background:var(--muted);flex-shrink:0;transition:background .3s;display:inline-block;"></span>
          <span id="cacheLabel">KPIs: cargando...</span>
        </span>
        <button onclick="forceRefresh()" id="btnRefresh"
          style="background:none;border:1px solid var(--border);border-radius:8px;padding:3px 10px;font-size:11px;color:var(--muted);cursor:pointer;display:flex;align-items:center;gap:5px;transition:all .2s;"
          onmouseover="this.style.borderColor='var(--primary)';this.style.color='var(--primary)'"
          onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">
          <i class="bi bi-arrow-clockwise"></i>Actualizar cache
        </button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ USER RESULT ══════════════════════ -->
  <div class="card-ui" id="userCard" style="display:none;">
    <div class="card-head">
      <span class="title"><i class="bi bi-person-circle cb"></i>Información de cuenta</span>
      <span id="queryTime" style="font-size:11px;font-weight:400;"></span>
    </div>
    <div class="card-body" id="userCardBody"></div>
  </div>

  <!-- ══════════════════════ BOTTOM TABLES ══════════════════════ -->
  <div class="two-col">

    <!-- Sin login >90d -->
    <div class="card-ui">
      <div class="card-head">
        <span class="title"><i class="bi bi-clock-history ca"></i>Usuarios activos — sin login +90 días</span>
        <button class="btn btn-sm btn-outline-secondary" onclick="loadStale()" style="font-size:11px;padding:3px 10px;"><i class="bi bi-arrow-clockwise"></i></button>
      </div>
      <!-- Filtro stale -->
      <div style="padding:0 0 10px;position:relative;">
        <div style="position:relative;">
          <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none;"></i>
          <input type="text" id="staleFilter" placeholder="Filtrar por cuenta, nombre, área..."
            autocomplete="off" spellcheck="false"
            style="width:100%;padding:8px 10px 8px 32px;border:1px solid var(--border);border-radius:8px;
                   font-size:12px;background:var(--input-bg);color:var(--text);outline:none;
                   transition:border-color .2s;"
            onfocus="this.style.borderColor='var(--primary)'"
            onblur="this.style.borderColor='var(--border)'">
          <div id="staleAcDrop" class="ac-drop" style="display:none;"></div>
        </div>
      </div>
      <div style="overflow:auto;max-height:380px;">
        <table class="tbl">
          <thead><tr><th>Cuenta</th><th>Nombre</th><th>Departamento</th><th>Cargo</th><th>Días</th></tr></thead>
          <tbody id="staleBody">
            <tr><td colspan="5" class="empty-state"><i class="bi bi-hourglass-split"></i>Consultando AD...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Equipos offline >30d -->
    <div class="card-ui">
      <div class="card-head">
        <span class="title"><i class="bi bi-pc-display cr"></i>Equipos — sin conectarse +30 días</span>
        <button class="btn btn-sm btn-outline-secondary" onclick="loadOffline()" style="font-size:11px;padding:3px 10px;"><i class="bi bi-arrow-clockwise"></i></button>
      </div>
      <!-- Filtro offline -->
      <div style="padding:0 0 10px;position:relative;">
        <div style="position:relative;">
          <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none;"></i>
          <input type="text" id="offlineFilter" placeholder="Filtrar por nombre, SO, descripción..."
            autocomplete="off" spellcheck="false"
            style="width:100%;padding:8px 10px 8px 32px;border:1px solid var(--border);border-radius:8px;
                   font-size:12px;background:var(--input-bg);color:var(--text);outline:none;
                   transition:border-color .2s;"
            onfocus="this.style.borderColor='var(--primary)'"
            onblur="this.style.borderColor='var(--border)'">
          <div id="offlineAcDrop" class="ac-drop" style="display:none;"></div>
        </div>
      </div>
      <div style="overflow:auto;max-height:380px;">
        <table class="tbl">
          <thead><tr><th>Equipo</th><th>Sistema Operativo</th><th>Descripción</th><th>Días</th></tr></thead>
          <tbody id="offlineBody">
            <tr><td colspan="4" class="empty-state"><i class="bi bi-hourglass-split"></i>Consultando AD...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div><!-- /.pg -->

<!-- ══════════════════════ MODAL: RESET CONTRASEÑA ══════════════════════ -->
<div id="resetModal" style="display:none;position:fixed;inset:0;z-index:1050;
    background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;">
  <div style="background:var(--card);border:1px solid var(--border);border-radius:18px;
      width:100%;max-width:460px;margin:20px;box-shadow:var(--sh-md);overflow:hidden;">

    <!-- Header -->
    <div style="padding:16px 22px;background:var(--hdr);border-bottom:1px solid var(--border);
        display:flex;align-items:center;justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="width:34px;height:34px;border-radius:10px;background:rgba(139,92,246,.12);
            border:1px solid rgba(139,92,246,.25);display:flex;align-items:center;justify-content:center;">
          <i class="bi bi-key-fill" style="color:var(--purple);font-size:16px;"></i>
        </span>
        <div>
          <div style="font-size:14px;font-weight:700;color:var(--text);">Restablecer contraseña</div>
          <div id="resetModalAccount" style="font-family:var(--mono);font-size:11px;color:var(--muted);"></div>
        </div>
      </div>
      <button onclick="closeResetModal()"
        style="background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer;
            padding:4px 8px;border-radius:6px;line-height:1;transition:background .15s;"
        onmouseover="this.style.background='var(--hover)'"
        onmouseout="this.style.background='none'">&times;</button>
    </div>

    <!-- Body -->
    <div style="padding:22px;">
      <!-- Aviso -->
      <div style="background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);
          border-radius:10px;padding:12px 14px;margin-bottom:18px;font-size:12px;
          display:flex;gap:10px;align-items:flex-start;">
        <i class="bi bi-exclamation-triangle-fill" style="color:var(--warning);font-size:15px;flex-shrink:0;margin-top:1px;"></i>
        <span style="color:var(--text);line-height:1.5;">
          Se establecerá una nueva contraseña temporal. El usuario
          <strong>deberá cambiarla al próximo inicio de sesión.</strong>
          Comunica la contraseña temporal al usuario de forma segura.
        </span>
      </div>

      <!-- Input contraseña -->
      <div style="margin-bottom:14px;">
        <label style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;
            color:var(--muted);font-weight:700;display:block;margin-bottom:6px;">
          <i class="bi bi-lock me-1"></i>Contraseña temporal
        </label>
        <div style="position:relative;">
          <input type="password" id="resetPwdInput"
            placeholder="Ej: Peru2025!"
            style="width:100%;padding:11px 44px 11px 14px;border:2px solid var(--border);
                border-radius:10px;font-size:14px;font-family:var(--mono);
                background:var(--input-bg);color:var(--text);outline:none;
                transition:border-color .2s,box-shadow .2s;"
            oninput="validatePwd(this.value)"
            onfocus="this.style.borderColor='var(--primary)';this.style.boxShadow='0 0 0 3px rgba(59,130,246,.12)'"
            onblur="this.style.borderColor='var(--border)';this.style.boxShadow='none'">
          <button onclick="togglePwdVisibility()" id="pwdToggleBtn"
            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);
                background:none;border:none;color:var(--muted);cursor:pointer;font-size:15px;padding:2px;">
            <i class="bi bi-eye" id="pwdToggleIco"></i>
          </button>
        </div>
      </div>

      <!-- Confirmar contraseña -->
      <div style="margin-bottom:16px;">
        <label style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;
            color:var(--muted);font-weight:700;display:block;margin-bottom:6px;">
          <i class="bi bi-lock-fill me-1"></i>Confirmar contraseña
        </label>
        <input type="password" id="resetPwdConfirm"
          placeholder="Repetir contraseña"
          style="width:100%;padding:11px 14px;border:2px solid var(--border);
              border-radius:10px;font-size:14px;font-family:var(--mono);
              background:var(--input-bg);color:var(--text);outline:none;
              transition:border-color .2s,box-shadow .2s;"
          oninput="validatePwd(document.getElementById('resetPwdInput').value)"
          onfocus="this.style.borderColor='var(--primary)';this.style.boxShadow='0 0 0 3px rgba(59,130,246,.12)'"
          onblur="this.style.borderColor='var(--border)';this.style.boxShadow='none'">
      </div>

      <!-- Indicadores de validación -->
      <div id="pwdRules" style="display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:18px;">
        <div class="pwd-rule" id="rule-len"> <i class="bi bi-circle"></i> Mínimo 8 caracteres</div>
        <div class="pwd-rule" id="rule-upper"><i class="bi bi-circle"></i> Una mayúscula</div>
        <div class="pwd-rule" id="rule-num">  <i class="bi bi-circle"></i> Un número</div>
        <div class="pwd-rule" id="rule-spec"> <i class="bi bi-circle"></i> Un carácter especial</div>
        <div class="pwd-rule" id="rule-match"><i class="bi bi-circle"></i> Las contraseñas coinciden</div>
      </div>

      <!-- Error -->
      <div id="resetError" style="display:none;background:rgba(239,68,68,.08);
          border:1px solid rgba(239,68,68,.2);border-radius:8px;padding:10px 14px;
          font-size:12px;color:var(--danger);margin-bottom:14px;">
      </div>
    </div>

    <!-- Footer -->
    <div style="padding:14px 22px;background:var(--hdr);border-top:1px solid var(--border);
        display:flex;gap:10px;justify-content:flex-end;">
      <button onclick="closeResetModal()"
        style="padding:9px 20px;border-radius:10px;border:1px solid var(--border);
            background:none;color:var(--muted);font-size:13px;font-weight:600;cursor:pointer;
            transition:all .15s;"
        onmouseover="this.style.background='var(--hover)'"
        onmouseout="this.style.background='none'">Cancelar</button>
      <button id="btnConfirmReset" onclick="confirmReset()" disabled
        style="padding:9px 24px;border-radius:10px;border:none;
            background:var(--purple);color:#fff;font-size:13px;font-weight:700;
            cursor:pointer;transition:all .15s;opacity:.5;display:flex;align-items:center;gap:7px;">
        <i class="bi bi-key-fill"></i>Restablecer contraseña
      </button>
    </div>
  </div>
</div>

<style>
.pwd-rule{font-size:11px;color:var(--muted);display:flex;align-items:center;gap:5px;transition:color .2s;}
.pwd-rule.ok{color:var(--success);}
.pwd-rule.ok .bi{font-size:12px;}
.pwd-rule.ok .bi::before{content:"\F26B";} /* bi-check-circle-fill */
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/sidebar.js"></script>
<script src="/js/ad-dashboard.js"></script>

<script>
function toggleTheme(){
  const h=document.documentElement,c=h.getAttribute('data-theme'),n=c==='dark'?'light':'dark';
  h.setAttribute('data-theme',n);localStorage.setItem('dashboardTheme',n);
}
</script>
</body>
</html>
