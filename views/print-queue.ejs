<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cola de Impresión</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link rel="stylesheet" href="../css/style.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700&family=Barlow+Condensed:wght@600;700;800;900&family=JetBrains+Mono:wght@400;600&display=swap');

:root,[data-theme="light"]{
  --bg:#eef2f7;--card:#ffffff;--header:#f4f7fb;
  --border:#dce4ef;--text:#0d1b2e;--muted:#5a7194;
  --primary:#0a3d8f;--primary-light:#1254c4;--primary-glow:rgba(10,61,143,.15);
  --success:#0a8a5c;--warning:#c97700;--danger:#c0392b;
  --info:#0077b6;--gold:#c9860a;--gold-bg:rgba(201,134,10,.07);
  --Workplace:#cc0000;--Workplace-dark:#990000;
  --row-hover:#f0f5ff;--shadow:0 1px 4px rgba(10,30,70,.08);
  --shadow-md:0 6px 24px rgba(10,30,70,.13);--shadow-lg:0 16px 48px rgba(10,30,70,.18);
  --input-bg:#f4f7fb;--radius:12px;
  --font:'Barlow',system-ui,sans-serif;--font-mono:'JetBrains Mono',monospace;
  --font-display:'Barlow Condensed',sans-serif;
}
[data-theme="dark"]{
  --bg:#070f1e;--card:#0d1a2e;--header:#0a1525;--border:#1a2d4a;--text:#e2eaf5;--muted:#6b8ab0;
  --primary:#1a6aff;--primary-light:#4d8fff;--primary-glow:rgba(26,106,255,.18);
  --success:#0fbf7f;--warning:#f0a500;--danger:#e05252;
  --info:#00adef;--gold:#f0a500;--gold-bg:rgba(240,165,0,.08);
  --Workplace:#ff2222;--Workplace-dark:#cc0000;
  --row-hover:#0f2040;--shadow:0 1px 4px rgba(0,0,0,.4);
  --shadow-md:0 6px 24px rgba(0,0,0,.5);--shadow-lg:0 16px 48px rgba(0,0,0,.6);
  --input-bg:#0a1525;
}

*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--font);transition:background .3s,color .3s;font-size:13.5px;line-height:1.5;}
.pg{margin-top:60px;padding:0;display:flex;flex-direction:column;gap:0;}

/* ── HERO BANNER ── */
.hero-banner{position:relative;overflow:hidden;background:linear-gradient(135deg,#051530 0%,#0a2560 45%,#0d3380 70%,#0a1e4a 100%);padding:0 32px;min-height:110px;display:flex;align-items:center;border-bottom:3px solid var(--Workplace);}
.hero-banner::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(90deg,transparent,transparent 60px,rgba(255,255,255,.018) 60px,rgba(255,255,255,.018) 61px),repeating-linear-gradient(0deg,transparent,transparent 40px,rgba(255,255,255,.015) 40px,rgba(255,255,255,.015) 41px);pointer-events:none;}
.hero-banner::after{content:'';position:absolute;right:0;top:0;bottom:0;width:420px;background:linear-gradient(90deg,transparent,rgba(204,0,0,.12) 60%,rgba(204,0,0,.22));pointer-events:none;}
.hero-stripe{position:absolute;right:160px;top:0;bottom:0;width:6px;background:var(--Workplace);opacity:.7;clip-path:polygon(8px 0,100% 0,calc(100% - 8px) 100%,0 100%);transform:skewX(-2deg);}
.hero-stripe+.hero-stripe{right:148px;opacity:.35;width:3px;}
.hero-left{position:relative;z-index:2;display:flex;flex-direction:column;gap:4px;flex:1;}
.hero-logo-row{display:flex;align-items:center;gap:16px;margin-bottom:2px;}
.integratel-logo{display:flex;align-items:center;gap:10px;}
.integratel-mark{width:40px;height:40px;background:var(--Workplace);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 2px 12px rgba(204,0,0,.4);}
.integratel-mark svg{width:24px;height:24px;}
.integratel-name{display:flex;flex-direction:column;line-height:1;}
.integratel-name span:first-child{font-family:var(--font-display);font-size:22px;font-weight:900;color:#fff;letter-spacing:1px;text-transform:uppercase;}
.integratel-name span:last-child{font-family:var(--font-display);font-size:10px;font-weight:600;color:rgba(255,255,255,.55);letter-spacing:3px;text-transform:uppercase;}
.hero-divider{width:1px;height:36px;background:rgba(255,255,255,.2);margin:0 4px;}
.Workplace-badge{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:6px 12px;}
.Workplace-badge-text{font-family:var(--font-display);font-size:18px;font-weight:900;color:#fff;letter-spacing:2px;text-transform:uppercase;}
.Workplace-badge-sub{font-size:9px;color:rgba(255,255,255,.45);letter-spacing:2px;text-transform:uppercase;margin-top:1px;}
.hero-title-row{display:flex;align-items:baseline;gap:12px;}
.hero-title{font-family:var(--font-display);font-size:28px;font-weight:900;color:#fff;letter-spacing:.5px;text-transform:uppercase;}
.hero-title span{color:var(--Workplace);}
.hero-sub{font-size:11.5px;color:rgba(255,255,255,.5);letter-spacing:.3px;}
.hero-right{position:relative;z-index:2;display:flex;align-items:center;gap:10px;flex-shrink:0;}
.printer-illustration{width:90px;height:70px;opacity:.85;filter:drop-shadow(0 4px 12px rgba(0,0,0,.4));}

/* ── Action bar ── */
.action-bar{background:var(--card);border-bottom:1px solid var(--border);padding:12px 32px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;box-shadow:var(--shadow);}
.action-bar-left{display:flex;align-items:center;gap:8px;}
.action-bar-right{display:flex;align-items:center;gap:8px;}
.status-dot{width:8px;height:8px;border-radius:50%;background:var(--success);box-shadow:0 0 0 3px rgba(10,138,92,.2);animation:pulse-dot 2s infinite;}
@keyframes pulse-dot{0%,100%{box-shadow:0 0 0 3px rgba(10,138,92,.2);}50%{box-shadow:0 0 0 6px rgba(10,138,92,.05);}}
.status-label{font-size:11.5px;font-weight:700;color:var(--muted);letter-spacing:.3px;}
.sync-badge{font-size:11px;color:var(--muted);font-weight:600;white-space:nowrap;padding:5px 10px;background:var(--header);border:1px solid var(--border);border-radius:8px;font-family:var(--font-mono);}

/* ── Buttons ── */
.btn-primary{background:linear-gradient(135deg,var(--primary),var(--primary-light));color:#fff;border:none;border-radius:9px;padding:9px 20px;font-size:13px;font-weight:700;font-family:var(--font);cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;white-space:nowrap;box-shadow:0 2px 8px rgba(10,61,143,.3);}
.btn-primary:hover{filter:brightness(1.1);transform:translateY(-1px);box-shadow:0 4px 16px rgba(10,61,143,.4);}
.btn-primary:disabled{opacity:.6;cursor:not-allowed;transform:none;box-shadow:none;}
.btn-ghost{background:transparent;color:var(--primary);border:1.5px solid var(--primary);border-radius:9px;padding:8px 16px;font-size:13px;font-weight:700;font-family:var(--font);cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;}
.btn-ghost:hover{background:var(--primary);color:#fff;}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:7px 12px;font-size:12px;font-family:var(--font);cursor:pointer;display:inline-flex;align-items:center;gap:5px;transition:all .15s;}
.btn-outline:hover{border-color:var(--primary);color:var(--primary);}
.btn-sm{padding:5px 9px;font-size:11.5px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;display:inline-flex;align-items:center;gap:4px;transition:all .15s;white-space:nowrap;font-family:var(--font);}
.btn-sm:hover{border-color:var(--primary);color:var(--primary);}
.btn-sm.danger:hover{border-color:var(--danger);color:var(--danger);}
.btn-sm.success-h:hover{border-color:var(--success);color:var(--success);}
.btn-sm.warn-h:hover{border-color:var(--warning);color:var(--warning);}
@keyframes spin{to{transform:rotate(360deg);}}
.spin-anim{animation:spin .7s linear infinite;}

/* ── Tabs ── */
.tab-container{background:var(--card);border-bottom:1px solid var(--border);padding:0 32px;}
.tab-strip{display:flex;gap:0;border-bottom:none;margin-bottom:0;}
.tab-btn{padding:13px 24px;font-size:13px;font-weight:700;font-family:var(--font);border:none;background:transparent;color:var(--muted);cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-1px;transition:all .2s;display:inline-flex;align-items:center;gap:8px;border-radius:0;letter-spacing:.2px;}
.tab-btn:hover{color:var(--text);background:var(--row-hover);}
.tab-btn.active{color:var(--primary);border-bottom-color:var(--primary);}
.tab-btn.vip-tab.active{color:var(--gold);border-bottom-color:var(--gold);}
.tab-badge{display:inline-flex;align-items:center;justify-content:center;min-width:22px;height:20px;border-radius:10px;font-size:10px;font-weight:800;padding:0 6px;background:var(--border);color:var(--muted);font-family:var(--font-mono);}
.tab-btn.active .tab-badge{background:var(--primary-glow);color:var(--primary);}
.tab-btn.vip-tab.active .tab-badge{background:rgba(201,134,10,.15);color:var(--gold);}
.tab-btn.vip-tab .tab-badge{background:rgba(201,134,10,.1);color:var(--gold);}

/* ── FILTER BAR ── */
.filter-bar{
  background:var(--header);border-bottom:1px solid var(--border);
  padding:10px 32px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;
}
.search-box{position:relative;flex:1;min-width:220px;max-width:380px;}
.search-box i{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none;}
.search-input{
  width:100%;padding:8px 12px 8px 34px;border:1.5px solid var(--border);border-radius:9px;
  font-size:12.5px;font-family:var(--font);background:var(--card);color:var(--text);
  outline:none;transition:border-color .2s,box-shadow .2s;
}
.search-input:focus{border-color:var(--primary);box-shadow:0 0 0 3px var(--primary-glow);}
.search-input::placeholder{color:var(--muted);}
.filter-select{
  background:var(--card);border:1.5px solid var(--border);color:var(--text);
  border-radius:9px;padding:8px 11px;font-size:12px;font-family:var(--font);
  outline:none;cursor:pointer;transition:border-color .2s;
}
.filter-select:focus{border-color:var(--primary);}
.filter-clear{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:7px 12px;font-size:12px;font-family:var(--font);cursor:pointer;display:inline-flex;align-items:center;gap:5px;transition:all .15s;white-space:nowrap;}
.filter-clear:hover{border-color:var(--danger);color:var(--danger);}
.filter-results{font-size:12px;color:var(--muted);font-family:var(--font-mono);white-space:nowrap;margin-left:auto;}

/* ── Table ── */
.table-container{background:var(--card);border-bottom:1px solid var(--border);}
.main-panel{display:flex;overflow:hidden;}
.tbl-side{flex:1;min-width:0;display:flex;flex-direction:column;}
.tbl-scroll{overflow-x:auto;overflow-y:auto;max-height:calc(100vh - 380px);}
.tbl{width:100%;border-collapse:collapse;font-size:12.5px;}
.tbl thead th{font-size:10px;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:800;font-family:var(--font-display);padding:11px 14px;background:var(--header);border-bottom:2px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;cursor:pointer;user-select:none;}
.tbl thead th:hover{color:var(--text);}
.tbl thead th.sorted{color:var(--primary);}
.tbl tbody td{padding:11px 14px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;}
.tbl tbody tr:last-child td{border-bottom:none;}
.tbl tbody tr{cursor:pointer;transition:background .1s;}
.tbl tbody tr:hover td{background:var(--row-hover);}
.tbl tbody tr.row-active td{background:var(--primary-glow);border-left:3px solid var(--primary);}
.tr-vip td{background:var(--gold-bg)!important;}
.tr-vip:hover td{background:rgba(201,134,10,.12)!important;}
.tr-vip.row-active td{background:rgba(201,134,10,.16)!important;border-left:3px solid var(--gold)!important;}
.tr-vip td:first-child::before{content:'⭐ ';font-size:11px;}
.tr-urgente:not(.tr-vip) td:first-child{border-left:3px solid var(--danger)!important;}
.tbl-foot{padding:12px 20px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;background:var(--header);}
.tbl-info{font-size:11.5px;color:var(--muted);font-family:var(--font-mono);}
.pagination{display:flex;gap:4px;}
.pg-btn{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:7px;padding:4px 11px;font-size:12px;cursor:pointer;transition:.15s;font-family:var(--font-mono);}
.pg-btn:hover,.pg-btn.active{background:var(--primary);color:#fff;border-color:var(--primary);}
.pg-btn:disabled{opacity:.35;cursor:not-allowed;}

/* ── Table action buttons ── */
.btn-print{display:inline-flex;align-items:center;gap:5px;border-radius:8px;padding:5px 10px;font-size:11px;font-weight:800;font-family:var(--font);background:linear-gradient(135deg,var(--primary),var(--primary-light));color:#fff;border:none;cursor:pointer;transition:all .2s;white-space:nowrap;box-shadow:0 2px 6px rgba(10,61,143,.25);letter-spacing:.3px;}
.btn-print:hover{filter:brightness(1.1);box-shadow:0 3px 10px rgba(10,61,143,.35);}
.btn-print:disabled{opacity:.5;cursor:not-allowed;}
.btn-mailbox{display:inline-flex;align-items:center;gap:4px;border-radius:7px;padding:4px 9px;font-size:11px;font-weight:700;font-family:var(--font);border:none;cursor:pointer;transition:all .2s;white-space:nowrap;}
.btn-mailbox.pendiente{background:rgba(192,57,43,.1);color:var(--danger);border:1px solid rgba(192,57,43,.25);}
.btn-mailbox.pendiente:hover{background:var(--danger);color:#fff;}
.btn-mailbox.eliminado{background:rgba(10,138,92,.1);color:var(--success);border:1px solid rgba(10,138,92,.25);cursor:default;}

/* ── Pills ── */
.pill{display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap;line-height:1.6;font-family:var(--font);}
.p-blue{background:rgba(10,61,143,.1);color:var(--primary);}
.p-green{background:rgba(10,138,92,.12);color:var(--success);}
.p-yellow{background:rgba(201,135,0,.12);color:var(--warning);}
.p-red{background:rgba(192,57,43,.12);color:var(--danger);}
.p-gray{background:rgba(90,113,148,.1);color:var(--muted);}
.p-orange{background:rgba(214,90,0,.12);color:#d45a00;}
.p-gold{background:rgba(201,134,10,.15);color:var(--gold);}
.pages-badge{display:inline-flex;align-items:center;gap:4px;background:linear-gradient(135deg,rgba(10,138,92,.12),rgba(10,138,92,.07));color:var(--success);border-radius:8px;padding:4px 10px;font-size:12px;font-weight:800;font-family:var(--font-mono);border:1px solid rgba(10,138,92,.2);}
.ft-icon{font-size:20px;}
.ft-pdf{color:#c0392b;}.ft-word{color:#0a3d8f;}.ft-excel{color:#0a8a5c;}.ft-ppt{color:#d45a00;}.ft-image{color:#6c3db5;}.ft-text,.ft-other{color:var(--muted);}

/* ── Toasts ── */
.toast-wrap{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;}
.toast-item{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:12px;padding:13px 18px;font-size:13px;font-weight:500;box-shadow:var(--shadow-md);display:flex;align-items:center;gap:10px;min-width:300px;animation:toastIn .25s ease;font-family:var(--font);}
.toast-item.ok{border-left:4px solid var(--success);}
.toast-item.err{border-left:4px solid var(--danger);}
.toast-item.inf{border-left:4px solid var(--primary);}
@keyframes toastIn{from{opacity:0;transform:translateX(24px);}to{opacity:1;transform:translateX(0);}}

/* ── Modals ── */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(5,15,35,.65);z-index:1050;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal-bg.open{display:flex;}
.modal-box{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:30px;width:100%;max-width:480px;box-shadow:var(--shadow-lg);animation:mIn .2s ease;}
.modal-box.wide{max-width:620px;}
@keyframes mIn{from{opacity:0;transform:scale(.95);}to{opacity:1;transform:scale(1);}}
.modal-box h5{font-size:17px;font-weight:800;font-family:var(--font-display);color:var(--text);margin-bottom:18px;display:flex;align-items:center;gap:9px;letter-spacing:.3px;}
.modal-box p{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.6;}
.m-actions{margin-top:20px;display:flex;gap:10px;justify-content:flex-end;}
.btn-mcancel{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:9px;padding:8px 18px;font-size:13px;cursor:pointer;font-family:var(--font);}
.btn-mcancel:hover{border-color:var(--text);color:var(--text);}
.btn-mclose{width:28px;height:28px;border-radius:7px;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.1);color:rgba(255,255,255,.7);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.btn-mclose:hover{background:rgba(255,255,255,.2);color:#fff;}
.btn-mconfirm{background:var(--Workplace);color:#fff;border:none;border-radius:9px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--font);}
.btn-mconfirm:hover{background:var(--Workplace-dark);}

/* ── Code modal ── */
.code-modal-bg{display:none;position:fixed;inset:0;background:rgba(5,15,35,.7);z-index:2000;align-items:center;justify-content:center;backdrop-filter:blur(5px);}
.code-modal-bg.open{display:flex;}
.code-modal-box{background:var(--card);border:1px solid var(--border);border-radius:20px;width:100%;max-width:400px;box-shadow:var(--shadow-lg);animation:mIn .2s ease;overflow:hidden;}
.code-modal-head{padding:18px 24px;background:linear-gradient(135deg,#051530,#0a2560);border-bottom:2px solid var(--Workplace);display:flex;align-items:center;justify-content:space-between;font-weight:800;font-size:15px;color:#fff;font-family:var(--font-display);letter-spacing:.5px;}
.code-modal-body{padding:24px;}
.code-input{width:100%;text-align:center;font-size:36px;font-weight:900;letter-spacing:12px;padding:16px;border:2px solid var(--border);border-radius:12px;background:var(--input-bg);color:var(--text);outline:none;transition:border-color .2s;font-family:var(--font-mono);}
.code-input:focus{border-color:var(--primary);box-shadow:0 0 0 3px var(--primary-glow);}
.code-input.shake{animation:shk .4s ease;border-color:var(--danger);}
.code-hint{font-size:12px;color:var(--muted);text-align:center;margin-top:10px;line-height:1.6;}
.code-actions{display:flex;gap:8px;margin-top:18px;}
.btn-code-cancel{flex:1;background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:9px;padding:10px;font-size:13px;cursor:pointer;font-family:var(--font);}
.btn-code-cancel:hover{border-color:var(--text);color:var(--text);}
.btn-code-ok{flex:2;background:linear-gradient(135deg,var(--primary),var(--primary-light));color:#fff;border:none;border-radius:9px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--font);box-shadow:0 2px 8px rgba(10,61,143,.3);}
.btn-code-ok:hover{filter:brightness(1.1);}
.btn-code-ok:disabled{opacity:.55;cursor:not-allowed;}

/* ── Drawer ── */
.drawer{width:0;overflow:hidden;border-left:1px solid transparent;transition:width .3s cubic-bezier(.4,0,.2,1),border-color .3s;flex-shrink:0;display:flex;flex-direction:column;}
.drawer.open{width:360px;border-left-color:var(--border);}
.drawer-header{padding:14px 18px;background:linear-gradient(135deg,#051530,#0a2560);border-bottom:2px solid var(--Workplace);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.drawer-header h6{font-size:11.5px;font-weight:700;color:rgba(255,255,255,.9);margin:0;font-family:var(--font-mono);max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.drawer-body{flex:1;overflow-y:auto;padding:0;}
.drawer-section{padding:14px 16px;border-bottom:1px solid var(--border);}
.drawer-section:last-child{border-bottom:none;}
.ds-title{font-size:9.5px;text-transform:uppercase;letter-spacing:.8px;font-weight:800;font-family:var(--font-display);margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.ds-title.hw{color:var(--success);}.ds-title.sec{color:var(--primary);}.ds-title.gen{color:var(--muted);}
.ds-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.ds-item{background:var(--input-bg);border-radius:8px;padding:9px 11px;border:1px solid var(--border);}
.ds-item.full{grid-column:1/-1;}
.ds-key{font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-weight:800;font-family:var(--font-display);margin-bottom:4px;}
.ds-val{font-size:12px;font-weight:600;color:var(--text);word-break:break-all;line-height:1.4;}
.ds-val.mono{font-family:var(--font-mono);font-size:11px;}
.ds-val.dim{color:var(--muted);font-weight:400;}
.drawer-close{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.7);cursor:pointer;padding:5px 8px;border-radius:7px;display:flex;align-items:center;transition:.15s;}
.drawer-close:hover{background:rgba(255,255,255,.2);color:#fff;}
.drawer-actions{display:flex;flex-direction:column;gap:6px;padding:14px 16px;border-bottom:1px solid var(--border);}
.drawer-actions .d-row{display:flex;gap:6px;}

/* ── VIP ── */
.vip-list{display:flex;flex-direction:column;gap:6px;max-height:280px;overflow-y:auto;margin-bottom:16px;}
.vip-row{display:flex;align-items:center;gap:10px;background:var(--input-bg);border:1px solid var(--border);border-radius:10px;padding:10px 14px;}
.vip-row-info{flex:1;}
.vip-row-name{font-size:13px;font-weight:700;color:var(--text);}
.vip-row-email{font-size:11.5px;color:var(--muted);font-family:var(--font-mono);}
.vip-add-form{display:flex;gap:8px;flex-wrap:wrap;}
.vip-input{background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:9px;padding:8px 13px;font-size:12.5px;flex:1;min-width:160px;outline:none;font-family:var(--font);}
.vip-input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,134,10,.12);}

/* ── Misc ── */
*::-webkit-scrollbar{width:5px;height:5px;}
*::-webkit-scrollbar-track{background:transparent;}
*::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
*::-webkit-scrollbar-thumb:hover{background:var(--muted);}
@keyframes shk{0%,100%{transform:translateX(0);}20%,60%{transform:translateX(-6px);}40%,80%{transform:translateX(6px);}}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.pg>*{animation:fadeUp .35s ease both;}
.pg>*:nth-child(1){animation-delay:.05s;}
.pg>*:nth-child(2){animation-delay:.1s;}
.pg>*:nth-child(3){animation-delay:.15s;}
.empty-state{text-align:center;padding:70px 20px;color:var(--muted);}
.empty-state i{font-size:40px;display:block;margin-bottom:14px;opacity:.3;}
.empty-state p{font-size:13px;font-weight:600;}
.Workplace-ribbon{background:linear-gradient(90deg,#0a0a0a,#1a0000,#0a0a0a);border-top:2px solid var(--Workplace);padding:8px 32px;display:flex;align-items:center;justify-content:space-between;}
.Workplace-ribbon-text{font-family:var(--font-display);font-size:10px;font-weight:700;color:rgba(255,255,255,.35);letter-spacing:2px;text-transform:uppercase;}
.Workplace-ribbon-logo{font-family:var(--font-display);font-size:14px;font-weight:900;color:var(--Workplace);letter-spacing:3px;text-transform:uppercase;}
#printFrame{display:none;}
</style>
</head>
