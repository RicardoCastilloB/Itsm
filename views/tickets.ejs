<!-- MODAL: ASIGNAR A AGENTE (dropdown flotante) -->
<!-- Se renderiza dinámicamente en JS -->

<div class="toast-container-custom" id="toastContainer"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/sidebar.js"></script>
<script>
// ═══════════════════════════════════════════════════════════
// Estado global
// ═══════════════════════════════════════════════════════════
let allTickets=[], filteredData=[], currentPage=1;
const PAGE_SIZE=20;
let activePill='all', closeTicketKey=null, closeTicketUrl=null;
let agentsCache = null;  // Cache de agentes para no recargar cada vez
let activeDropdown = null;  // Para cerrar dropdown abierto al hacer click afuera

document.addEventListener('DOMContentLoaded', () => {
    loadTickets();
    setupDragDrop();
    // Cerrar dropdowns al hacer click fuera
    document.addEventListener('click', (e) => {
        if (activeDropdown && !activeDropdown.contains(e.target)) {
            activeDropdown.remove();
            activeDropdown = null;
        }
    });
});

// ═══════════════════════════════════════════════════════════
// Carga principal de tickets (MySQL local)
// ═══════════════════════════════════════════════════════════
async function loadTickets(){
    document.getElementById('tableWrap').innerHTML=`<div class="spinner-wrap"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Cargando tickets...</div>`;
    try{
        const res=await fetch('/api/jira/tickets');
        const json=await res.json();
        if(!json.success)throw new Error(json.message);
        allTickets=json.data||[];
        updateKPIs(); applyFilters();
    }catch(err){
        document.getElementById('tableWrap').innerHTML=`<div class="empty-state"><i class="bi bi-exclamation-triangle"></i><p>No se pudieron cargar los tickets.<br><small>${err.message}</small></p><button class="btn-outline-sm mt-3" onclick="loadTickets()"><i class="bi bi-arrow-clockwise"></i> Reintentar</button></div>`;
    }
}

function updateKPIs(){
    const now=new Date(), month=now.getMonth(), year=now.getFullYear();
    const open=allTickets.filter(t=>isOpen(t.status)).length;
    const progress=allTickets.filter(t=>isProgress(t.status)).length;
    const closed=allTickets.filter(t=>isClosed(t.status)).length;
    const critical=allTickets.filter(t=>t.urgency_level===3).length;
    const thisMonth=allTickets.filter(t=>{const d=new Date(t.created);return d.getMonth()===month&&d.getFullYear()===year;}).length;
    document.getElementById('kpiTotal').textContent=allTickets.length;
    document.getElementById('kpiOpen').textContent=open;
    document.getElementById('kpiProgress').textContent=progress;
    document.getElementById('kpiClosed').textContent=closed;
    document.getElementById('kpiCritical').textContent=critical;
    document.getElementById('kpiMonth').textContent=thisMonth;
}

function isOpen(s)     { return ['open','abierto','waiting for support','por hacer','to do'].includes((s||'').toLowerCase()); }
function isProgress(s) { return ['in progress','en curso','en progreso','working'].includes((s||'').toLowerCase()); }
function isClosed(s)   { return ['done','closed','cerrado','resolved','resuelto','completado'].includes((s||'').toLowerCase()); }

function setPill(el,val){ document.querySelectorAll('.pill').forEach(p=>p.classList.remove('active')); el.classList.add('active'); activePill=val; currentPage=1; applyFilters(); }
function filterTickets(){ currentPage=1; applyFilters(); }

function applyFilters(){
    const q=(document.getElementById('searchInput').value||'').toLowerCase().trim();
    filteredData=allTickets.filter(t=>{
        if(activePill==='open'&&!isOpen(t.status))return false;
        if(activePill==='progress'&&!isProgress(t.status))return false;
        if(activePill==='closed'&&!isClosed(t.status))return false;
        if(activePill==='high'&&t.urgency_level<3)return false;
        if(q){const h=[t.key,t.summary,t.reporter,t.status,t.tipologia].join(' ').toLowerCase();if(!h.includes(q))return false;}
        return true;
    });
    renderTable(); renderPagination();
}

function renderTable(){
    if(!filteredData.length){
        document.getElementById('tableWrap').innerHTML=`<div class="empty-state"><i class="bi bi-inbox"></i><p>No se encontraron tickets con los filtros aplicados.</p></div>`;
        document.getElementById('paginationWrap').style.display='none'; return;
    }
    document.getElementById('paginationWrap').style.display='flex';
    const start=(currentPage-1)*PAGE_SIZE;
    const page=filteredData.slice(start,start+PAGE_SIZE);
    const rows=page.map(t=>{
        const statusBadge=isClosed(t.status)?`<span class="badge-status badge-closed"><i class="bi bi-check-circle"></i>${t.status}</span>`:isProgress(t.status)?`<span class="badge-status badge-progress"><i class="bi bi-gear"></i>${t.status}</span>`:`<span class="badge-status badge-open"><i class="bi bi-circle"></i>${t.status}</span>`;
        const urgDot=t.urgency_level===3?`<span class="prio-dot prio-high"></span>Alta`:t.urgency_level===2?`<span class="prio-dot prio-medium"></span>Media`:`<span class="prio-dot prio-low"></span>Baja`;
        const closeBtn=!isClosed(t.status)?`<button class="btn-outline-sm btn-close-ticket" onclick="openCloseModal('${t.key}','${t.url}')"><i class="bi bi-x-circle"></i> Cerrar</button>`:`<span style="color:var(--text-muted);font-size:11px;">Cerrado</span>`;
        const created=t.created?new Date(t.created).toLocaleDateString('es-PE',{day:'2-digit',month:'short',year:'numeric'}):'—';
        return`<tr><td><span class="ticket-key"><a href="${t.url}" target="_blank">${t.key}</a></span></td><td style="max-width:280px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${t.summary}">${t.summary}</td><td>${statusBadge}</td><td style="font-size:12px;">${urgDot}</td><td style="font-size:12px;color:var(--text-muted);">${t.reporter||'—'}</td><td style="font-size:12px;color:var(--text-muted);">${created}</td><td>${closeBtn}</td></tr>`;
    }).join('');
    document.getElementById('tableWrap').innerHTML=`<div style="overflow-x:auto;"><table class="table-tickets w-100"><thead><tr><th>Clave</th><th>Resumen</th><th>Estado</th><th>Urgencia</th><th>Reporter</th><th>Creado</th><th>Acción</th></tr></thead><tbody>${rows}</tbody></table></div>`;
}

function renderPagination(){
    const total=filteredData.length, pages=Math.ceil(total/PAGE_SIZE);
    const start=(currentPage-1)*PAGE_SIZE+1, end=Math.min(currentPage*PAGE_SIZE,total);
    document.getElementById('paginationInfo').textContent=total?`Mostrando ${start}–${end} de ${total} tickets`:'';
    const btns=document.getElementById('paginationBtns');
    if(pages<=1){btns.innerHTML='';return;}
    let html=`<button class="btn-outline-sm" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}><i class="bi bi-chevron-left"></i></button>`;
    for(let i=1;i<=pages;i++){
        if(i===1||i===pages||(i>=currentPage-1&&i<=currentPage+1)){html+=`<button class="btn-outline-sm ${i===currentPage?'active':''}" style="${i===currentPage?'background:var(--jira-blue);color:white;border-color:var(--jira-blue);':''}" onclick="goPage(${i})">${i}</button>`;}
        else if(i===currentPage-2||i===currentPage+2){html+=`<span style="padding:4px 6px;font-size:12px;color:var(--text-muted);">…</span>`;}
    }
    html+=`<button class="btn-outline-sm" onclick="goPage(${currentPage+1})" ${currentPage===pages?'disabled':''}><i class="bi bi-chevron-right"></i></button>`;
    btns.innerHTML=html;
}

function goPage(p){const pages=Math.ceil(filteredData.length/PAGE_SIZE);if(p<1||p>pages)return;currentPage=p;renderTable();renderPagination();}

// ═══════════════════════════════════════════════════════════
// Crear ticket
// ═══════════════════════════════════════════════════════════
function openCreateModal(){
    document.getElementById('createResult').style.display='none';
    document.getElementById('f_summary').value='';
    document.getElementById('f_reporter').value='@integratel.com.pe';
    document.getElementById('f_phone').value='';
    document.getElementById('f_description').value='';
    document.getElementById('f_component').value='ae0390c7-daf0-4efd-8181-99c3b55f1d1c:11277';
    document.getElementById('f_app').value='ae0390c7-daf0-4efd-8181-99c3b55f1d1c:11280';
    document.getElementById('f_tipologia').value='';
    document.getElementById('f_impact').value='618437';
    document.getElementById('f_urgency').value='618440';
    clearFile();
    new bootstrap.Modal(document.getElementById('modalCreate')).show();
}

function handleFileSelect(input){if(input.files&&input.files[0]){const f=input.files[0];document.getElementById('uploadFileName').textContent=f.name+` (${(f.size/1024).toFixed(1)} KB)`;document.getElementById('uploadPreview').style.display='flex';document.getElementById('uploadZone').style.borderColor='var(--success)';}}
function clearFile(){document.getElementById('f_attachment').value='';document.getElementById('uploadPreview').style.display='none';document.getElementById('uploadZone').style.borderColor='var(--border-soft)';}

function setupDragDrop(){
    const zone=document.getElementById('uploadZone');if(!zone)return;
    zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('dragover');});
    zone.addEventListener('dragleave',()=>zone.classList.remove('dragover'));
    zone.addEventListener('drop',e=>{e.preventDefault();zone.classList.remove('dragover');const dt=e.dataTransfer;if(dt.files.length){document.getElementById('f_attachment').files=dt.files;handleFileSelect(document.getElementById('f_attachment'));}});
}

async function submitTicket(){
    const summary=document.getElementById('f_summary').value.trim();
    const reporter=document.getElementById('f_reporter').value.trim();
    const phone=document.getElementById('f_phone').value.trim();
    const description=document.getElementById('f_description').value.trim();
    const component=document.getElementById('f_component').value;
    const app=document.getElementById('f_app').value;
    const tipologia=document.getElementById('f_tipologia').value;
    const impact=document.getElementById('f_impact').value;
    const urgency=document.getElementById('f_urgency').value;
    const fileInput=document.getElementById('f_attachment');
    if(!summary){showToast('El resumen es obligatorio','error');return;}
    if(!reporter){showToast('El correo del reporter es obligatorio','error');return;}
    if(!phone){showToast('El teléfono es obligatorio','error');return;}
    if(!component){showToast('Selecciona el tipo de componente','error');return;}
    if(!app){showToast('Selecciona el ítem afectado','error');return;}
    if(!tipologia){showToast('Selecciona la tipología del problema','error');return;}
    if(!description){showToast('La descripción es obligatoria','error');return;}
    if(!fileInput.files.length){showToast('Adjunta una evidencia (imagen o PDF)','error');return;}
    const btn=document.getElementById('btnSubmit');
    btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm me-2"></span>Creando...';
    try{
        const attachmentId=await uploadAttachment(fileInput.files[0]);
        const res=await fetch('/api/jira/ticket',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({summary,reporter,phone,description,component,app,tipologia,impact,urgency,attachmentId})});
        const json=await res.json();
        if(!json.success)throw new Error(json.message||json.details);
        document.getElementById('createdKey').textContent=json.data.key;
        document.getElementById('createdUrl').href=json.data.url;
        document.getElementById('createResult').style.display='block';
        document.getElementById('createResult').classList.add('flash-new');
        showToast(`✅ Ticket ${json.data.key} creado exitosamente`,'success');
        loadTickets();
    }catch(err){showToast('Error: '+err.message,'error');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-send-fill"></i> Crear Incidencia';}
}

async function uploadAttachment(file){const fd=new FormData();fd.append('file',file);const res=await fetch('/api/jira/attachment',{method:'POST',body:fd});const json=await res.json();if(!json.success)throw new Error('Error subiendo adjunto: '+json.message);return json.attachmentId;}

// ═══════════════════════════════════════════════════════════
// Cerrar ticket
// ═══════════════════════════════════════════════════════════
function openCloseModal(key,url){
    closeTicketKey=key; closeTicketUrl=url||`https://integratelperu.atlassian.net/browse/${key}`;
    document.getElementById('closeKeyLabel').textContent=key;
    document.getElementById('closeComment').value='';
    document.getElementById('jiraDirectLink').href=closeTicketUrl;
    document.getElementById('jiraDirectLink').onclick=(e)=>{e.preventDefault();e.stopPropagation();window.open(closeTicketUrl,'_blank');};
    new bootstrap.Modal(document.getElementById('modalClose')).show();
}

async function submitClose(){
    const comment=document.getElementById('closeComment').value.trim();
    const btn=document.getElementById('btnCloseSubmit');
    btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm me-2"></span>Cerrando...';
    try{
        const res=await fetch(`/api/jira/ticket/${closeTicketKey}/close`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({comment})});
        const json=await res.json();
        if(!json.success)throw new Error(json.message);
        bootstrap.Modal.getInstance(document.getElementById('modalClose')).hide();
        showToast(json.message,json.jiraClosed?'success':'info');
        loadTickets();
    }catch(err){showToast('Error: '+err.message,'error');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-check2-circle"></i> Confirmar cierre local';}
}

// ═══════════════════════════════════════════════════════════
// Modal de Búsqueda / Cola — NUEVO
// ═══════════════════════════════════════════════════════════
function openSearchModal(){
    // Reset
    document.getElementById('searchTicketKey').value='';
    document.getElementById('searchResult').style.display='none';
    document.getElementById('searchEmpty').style.display='none';
    document.getElementById('searchLoading').style.display='none';
    document.getElementById('searchIdle').style.display='block';
    // Mostrar tab inicial
    switchTab('tabSearch', document.querySelector('.search-tab-btn'));
    new bootstrap.Modal(document.getElementById('modalSearch')).show();
    setTimeout(()=>document.getElementById('searchTicketKey').focus(),300);
}

function switchTab(tabId, btn) {
    // Desactivar todos los tabs
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.search-tab-btn').forEach(b => b.classList.remove('active'));
    // Activar el seleccionado
    document.getElementById(tabId).classList.add('active');
    btn.classList.add('active');
    // Auto-cargar si es necesario
    if (tabId === 'tabUnassigned') {
        const list = document.getElementById('unassignedList');
        // Si aún tiene el placeholder inicial, cargar
        if (list.querySelector('.queue-empty')) loadUnassignedTickets();
    }
}

// ── Tab 1: Buscar ticket por clave ──────────────────────────
async function searchTicket(){
    const key=document.getElementById('searchTicketKey').value.trim().toUpperCase().replace(/\s+/g,'');
    if(!key){showToast('Ingresa un número de ticket','error');return;}
    document.getElementById('searchResult').style.display='none';
    document.getElementById('searchEmpty').style.display='none';
    document.getElementById('searchIdle').style.display='none';
    document.getElementById('searchLoading').style.display='flex';
    const btn=document.getElementById('btnSearch'); btn.disabled=true;
    try{
        // Primero buscar en DB local
        const localRes=await fetch(`/api/jira/ticket/${key}`);
        const localJson=await localRes.json();

        // También obtener detalle de Jira (assignee en vivo)
        let jiraDetail = null;
        try {
            const jiraRes = await fetch(`/api/jira/ticket/${key}/jira-detail`);
            const jiraJson = await jiraRes.json();
            if (jiraJson.success) jiraDetail = jiraJson.data;
        } catch(_) {}

        document.getElementById('searchLoading').style.display='none';

        if(!localJson.success||!localJson.data){
            // No está en DB local — mostrar con opción de ver en Jira
            document.getElementById('searchResult').innerHTML=`
                <div style="text-align:center;padding:24px;">
                    <i class="bi bi-ticket-detailed" style="font-size:36px;color:var(--text-muted);opacity:0.4;display:block;margin-bottom:12px;"></i>
                    <div style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">
                        <strong>${key}</strong> no está en el sistema local.<br>
                        ${jiraDetail ? `<span style="color:var(--success);">✓ Encontrado en Jira: ${jiraDetail.summary}</span>` : 'Puede que haya sido creado manualmente en Jira.'}
                    </div>
                    <button class="btn-create" onclick="window.open('https://integratelperu.atlassian.net/browse/${key}','_blank')" style="margin:0 auto;">
                        <i class="bi bi-box-arrow-up-right"></i> Abrir ${key} en Jira
                    </button>
                </div>`;
            document.getElementById('searchResult').style.display='block'; return;
        }

        const t=localJson.data;
        const assignee = jiraDetail?.assignee || null;  // Assignee en tiempo real de Jira
        const created=t.created_at?new Date(t.created_at).toLocaleString('es-PE',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}):'—';
        const closedAt=t.closed_at?new Date(t.closed_at).toLocaleString('es-PE',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}):null;
        const statusColor=isClosed(t.status)?'var(--success)':isProgress(t.status)?'var(--warning)':'var(--primary)';
        const statusBg=isClosed(t.status)?'rgba(52,211,153,.15)':isProgress(t.status)?'rgba(251,191,36,.15)':'rgba(96,165,250,.15)';
        const urgIcon=t.urgency_level===3?'🔴':t.urgency_level===2?'🟡':'🟢';

        // Sección de assignee
        const assigneeHtml = assignee
            ? `<div class="assignee-chip"><div class="avatar">${assignee.displayName.charAt(0).toUpperCase()}</div>${assignee.displayName}</div>
               <button class="btn-outline-sm" onclick="showAssignDropdown(event,'${t.ticket_key}',this)" title="Reasignar">
                   <i class="bi bi-arrow-repeat"></i> Reasignar
               </button>`
            : `<span style="font-size:12px;color:var(--text-muted);font-style:italic;">Sin asignar</span>
               <button class="btn-assign-me" onclick="assignSelf('${t.ticket_key}',this)">
                   <i class="bi bi-person-plus"></i> Asignarme
               </button>
               <button class="btn-outline-sm" onclick="showAssignDropdown(event,'${t.ticket_key}',this)" style="border-color:var(--warning);color:var(--warning);">
                   <i class="bi bi-person-gear"></i> Asignar a…
               </button>`;

        document.getElementById('searchResult').innerHTML=`
            <div style="border:1.5px solid var(--border-soft);border-radius:10px;overflow:hidden;">
                <div style="background:var(--bg-header);padding:14px 16px;border-bottom:1px solid var(--border-soft);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <span class="ticket-key" style="font-size:15px;"><a href="${t.jira_url}" target="_blank">${t.ticket_key}</a></span>
                        <span style="background:${statusBg};color:${statusColor};font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;">${t.status}</span>
                    </div>
                    <a href="${t.jira_url}" target="_blank" class="btn-outline-sm" style="border-color:var(--jira-blue);color:var(--jira-blue);"><i class="bi bi-box-arrow-up-right"></i> Ver en Jira</a>
                </div>
                <div style="padding:14px 16px;border-bottom:1px solid var(--border-soft);">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;color:var(--text-muted);margin-bottom:4px;">Resumen</div>
                    <div style="font-size:14px;font-weight:600;color:var(--text-main);">${t.summary}</div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;">
                    ${detailRow('Reporter',t.reporter,'bi-person')}
                    ${detailRow('Creado',created,'bi-calendar3')}
                    ${detailRow('Componente',t.component,'bi-cpu')}
                    ${detailRow('Ítem afectado',t.app_item,'bi-laptop')}
                    ${detailRow('Tipología',t.tipologia,'bi-tag')}
                    ${detailRow('Teléfono',t.phone,'bi-telephone')}
                    ${detailRow('Impacto',t.impact,'bi-people')}
                    ${detailRow('Urgencia',urgIcon+' '+(t.urgency||'—'),'bi-exclamation-circle')}
                    ${closedAt?detailRow('Cerrado',closedAt,'bi-check2-circle'):''}
                    ${t.closed_by?detailRow('Cerrado por',t.closed_by,'bi-person-check'):''}
                </div>
                <!-- SECCIÓN ASIGNACIÓN -->
                <div class="ticket-detail-assignee-section" id="assigneeSection_${t.ticket_key}">
                    <div>
                        <div class="ticket-detail-assignee-label"><i class="bi bi-person-badge me-1"></i> Asignado a (Jira en tiempo real)</div>
                        <div style="display:flex;align-items:center;gap:8px;margin-top:4px;" id="assigneeContent_${t.ticket_key}">
                            ${assigneeHtml}
                        </div>
                    </div>
                </div>
                ${t.description?`<div style="padding:14px 16px;border-top:1px solid var(--border-soft);"><div style="font-size:10px;font-weight:700;text-transform:uppercase;color:var(--text-muted);margin-bottom:6px;">Descripción</div><div style="font-size:13px;line-height:1.6;background:var(--bg-header);padding:10px;border-radius:6px;color:var(--text-main);">${t.description}</div></div>`:''}
                ${t.close_comment?`<div style="padding:14px 16px;border-top:1px solid var(--border-soft);"><div style="font-size:10px;font-weight:700;text-transform:uppercase;color:var(--text-muted);margin-bottom:6px;">Comentario de cierre</div><div style="font-size:13px;line-height:1.6;background:var(--step2-bg);padding:10px;border-radius:6px;border-left:3px solid var(--success);color:var(--text-main);">${t.close_comment}</div></div>`:''}
            </div>`;
        document.getElementById('searchResult').style.display='block';

    }catch(err){
        document.getElementById('searchLoading').style.display='none';
        document.getElementById('searchEmpty').style.display='block';
    }finally{
        btn.disabled=false;
    }
}

function detailRow(label,value,icon){
    return`<div style="padding:10px 16px;border-bottom:1px solid var(--border-soft);border-right:1px solid var(--border-soft);background:var(--bg-card);"><div style="font-size:10px;font-weight:700;text-transform:uppercase;color:var(--text-muted);margin-bottom:3px;"><i class="bi ${icon} me-1"></i>${label}</div><div style="font-size:12px;font-weight:600;color:var(--text-main);">${value||'—'}</div></div>`;
}

// ── Tab 2: Mis tickets asignados ────────────────────────────
async function loadAssignedTickets(){
    const email = document.getElementById('assignedEmail').value.trim();
    if(!email){showToast('Ingresa un correo','error');return;}

    document.getElementById('assignedLoading').style.display='flex';
    document.getElementById('assignedList').innerHTML='';

    try{
        const res = await fetch(`/api/jira/queue/assigned?email=${encodeURIComponent(email)}`);
        const json = await res.json();
        document.getElementById('assignedLoading').style.display='none';

        if(!json.success) throw new Error(json.message);

        const tickets = json.data || [];
        // Actualizar badge
        document.getElementById('badgeAssigned').textContent = tickets.length || '0';

        if(!tickets.length){
            document.getElementById('assignedList').innerHTML=`
                <div class="queue-empty">
                    <i class="bi bi-person-check"></i>
                    <p>No hay tickets activos asignados a <strong>${email}</strong></p>
                </div>`;
            return;
        }

        const html = `
            <div class="queue-header-info">
                <span class="queue-count-badge"><strong>${tickets.length}</strong> tickets asignados a ${email}</span>
            </div>
            <div class="queue-list-scroll">
                ${tickets.map(t => renderQueueRow(t, false)).join('')}
            </div>`;
        document.getElementById('assignedList').innerHTML = html;

    }catch(err){
        document.getElementById('assignedLoading').style.display='none';
        document.getElementById('assignedList').innerHTML=`<div class="queue-empty"><i class="bi bi-exclamation-triangle"></i><p>Error: ${err.message}</p></div>`;
    }
}

// ── Tab 3: Sin asignar ──────────────────────────────────────
async function loadUnassignedTickets(){
    document.getElementById('unassignedLoading').style.display='flex';
    document.getElementById('unassignedList').innerHTML='';

    try{
        const res = await fetch('/api/jira/queue/unassigned');
        const json = await res.json();
        document.getElementById('unassignedLoading').style.display='none';

        if(!json.success) throw new Error(json.message);

        const tickets = json.data || [];
        const total = json.total || tickets.length;
        // Actualizar badge
        document.getElementById('badgeUnassigned').textContent = total || '0';

        if(!tickets.length){
            document.getElementById('unassignedList').innerHTML=`
                <div class="queue-empty">
                    <i class="bi bi-inbox-fill" style="color:var(--success);opacity:1;"></i>
                    <p style="color:var(--success);font-weight:600;">¡Sin tickets pendientes! Todo asignado ✓</p>
                </div>`;
            document.getElementById('unassignedCountLabel').textContent = 'Sin tickets pendientes de asignación';
            return;
        }

        document.getElementById('unassignedCountLabel').innerHTML = `<strong>${total}</strong> tickets sin asignar en proyecto INC`;

        const html = `
            <div class="queue-list-scroll">
                ${tickets.map(t => renderQueueRow(t, true)).join('')}
            </div>`;
        document.getElementById('unassignedList').innerHTML = html;

    }catch(err){
        document.getElementById('unassignedLoading').style.display='none';
        document.getElementById('unassignedList').innerHTML=`<div class="queue-empty"><i class="bi bi-exclamation-triangle"></i><p>Error: ${err.message}</p></div>`;
    }
}

// ── Renderizar fila de ticket en cola ────────────────────────
function renderQueueRow(t, showAssignButtons) {
    const created = t.created ? new Date(t.created).toLocaleDateString('es-PE',{day:'2-digit',month:'short'}) : '—';
    const statusBadge = isProgress(t.status)
        ? `<span class="badge-status badge-progress" style="font-size:10px;padding:2px 7px;">${t.status||'—'}</span>`
        : `<span class="badge-status badge-open" style="font-size:10px;padding:2px 7px;">${t.status||'—'}</span>`;

    const assigneeInfo = t.assignee
        ? `<div class="assignee-chip" style="font-size:10px;">
               <div class="avatar" style="width:16px;height:16px;font-size:8px;">${t.assignee.charAt(0)}</div>
               ${t.assignee}
           </div>`
        : '';

    const actionBtns = showAssignButtons
        ? `<button class="btn-assign-me" onclick="assignSelf('${t.key}',this)" title="Asignarme este ticket">
               <i class="bi bi-person-plus"></i> Asignarme
           </button>
           <button class="btn-assign-other" onclick="showAssignDropdown(event,'${t.key}',this)" title="Asignar a alguien">
               <i class="bi bi-person-gear"></i>
           </button>`
        : `<a href="${t.url}" target="_blank" class="btn-outline-sm" style="font-size:10px;padding:3px 8px;">
               <i class="bi bi-box-arrow-up-right"></i> Jira
           </a>`;

    return `
        <div class="queue-ticket-row" id="qrow_${t.key}">
            <div class="queue-ticket-key"><a href="${t.url}" target="_blank">${t.key}</a></div>
            <div class="queue-ticket-summary" title="${t.summary}">${t.summary}</div>
            ${assigneeInfo}
            ${statusBadge}
            <div class="queue-ticket-meta">${created}</div>
            <div class="queue-ticket-actions">${actionBtns}</div>
        </div>`;
}

// ═══════════════════════════════════════════════════════════
// Asignación de tickets
// ═══════════════════════════════════════════════════════════

// Asignarme a mí mismo (usa el token del servidor)
async function assignSelf(ticketKey, btn) {
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    try {
        const res = await fetch(`/api/jira/ticket/${ticketKey}/assign`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ selfAssign: true })
        });
        const json = await res.json();
        if(!json.success) throw new Error(json.message);
        showToast(json.message, 'success');
        // Actualizar fila visualmente
        refreshQueueRow(ticketKey);
        // Si estamos en la vista de búsqueda de ticket, recargar
        if(document.getElementById('tabSearch').classList.contains('active')){
            searchTicket();
        }
    } catch(err){
        showToast('Error: '+err.message, 'error');
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-person-plus"></i> Asignarme';
    }
}

// Dropdown para asignar a cualquier agente
async function showAssignDropdown(event, ticketKey, anchorBtn) {
    event.stopPropagation();
    // Cerrar el anterior si existe
    if(activeDropdown) { activeDropdown.remove(); activeDropdown = null; }

    // Crear dropdown
    const dropdown = document.createElement('div');
    dropdown.className = 'assign-dropdown-menu';
    dropdown.innerHTML = `
        <div class="assign-dropdown-header"><i class="bi bi-person-gear me-1"></i> Asignar a agente</div>
        <div class="assign-dropdown-search">
            <input type="text" placeholder="Buscar agente..." id="agentSearchInput" oninput="filterAgents(this.value)">
        </div>
        <div class="assign-agent-list" id="agentListContainer">
            <div style="padding:12px;text-align:center;font-size:12px;color:var(--text-muted);">
                <div class="spinner-border spinner-border-sm text-primary"></div> Cargando...
            </div>
        </div>`;

    // Posicionar
    dropdown.style.cssText = `position:fixed; z-index:9999;`;
    document.body.appendChild(dropdown);
    activeDropdown = dropdown;

    // Calcular posición respecto al botón
    const rect = anchorBtn.getBoundingClientRect();
    const spaceBelow = window.innerHeight - rect.bottom;
    if(spaceBelow > 250) {
        dropdown.style.top = (rect.bottom + 4) + 'px';
    } else {
        dropdown.style.top = (rect.top - 250) + 'px';
    }
    dropdown.style.left = Math.min(rect.left, window.innerWidth - 240) + 'px';

    // Cargar agentes (con cache)
    await loadAgentsIntoDropdown(ticketKey);

    // Focus en búsqueda
    setTimeout(() => { const inp = document.getElementById('agentSearchInput'); if(inp) inp.focus(); }, 100);
}

let agentDropdownTicketKey = null;
async function loadAgentsIntoDropdown(ticketKey) {
    agentDropdownTicketKey = ticketKey;
    try {
        if(!agentsCache) {
            const res = await fetch('/api/jira/agents');
            const json = await res.json();
            if(!json.success) throw new Error(json.message);
            agentsCache = json.data || [];
        }
        renderAgentList(agentsCache);
    } catch(err) {
        const container = document.getElementById('agentListContainer');
        if(container) container.innerHTML = `<div style="padding:10px 12px;font-size:12px;color:var(--danger);">Error cargando agentes</div>`;
    }
}

function renderAgentList(agents) {
    const container = document.getElementById('agentListContainer');
    if(!container) return;
    if(!agents.length) {
        container.innerHTML = '<div style="padding:10px 12px;font-size:12px;color:var(--text-muted);">No se encontraron agentes</div>';
        return;
    }
    container.innerHTML = agents.map(a => `
        <div class="assign-agent-item" onclick="assignToAgent('${agentDropdownTicketKey}','${a.accountId}','${a.displayName}')">
            <div class="assign-agent-avatar">${(a.displayName||'?').charAt(0).toUpperCase()}</div>
            <div>
                <div style="font-weight:600;">${a.displayName}</div>
                <div class="assign-agent-email">${a.email||''}</div>
            </div>
        </div>`).join('');
}

function filterAgents(query) {
    if(!agentsCache) return;
    const q = query.toLowerCase();
    const filtered = agentsCache.filter(a =>
        (a.displayName||'').toLowerCase().includes(q) ||
        (a.email||'').toLowerCase().includes(q)
    );
    renderAgentList(filtered);
}

async function assignToAgent(ticketKey, accountId, displayName) {
    // Cerrar dropdown
    if(activeDropdown) { activeDropdown.remove(); activeDropdown = null; }

    try {
        const res = await fetch(`/api/jira/ticket/${ticketKey}/assign`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ accountId })
        });
        const json = await res.json();
        if(!json.success) throw new Error(json.message);
        showToast(`✅ ${ticketKey} asignado a ${displayName}`, 'success');
        refreshQueueRow(ticketKey);
        // Recargar detalle si estamos buscando ese ticket
        if(document.getElementById('tabSearch').classList.contains('active')) {
            const currentSearch = document.getElementById('searchTicketKey').value.trim().toUpperCase();
            if(currentSearch === ticketKey) searchTicket();
        }
    } catch(err) {
        showToast('Error: '+err.message, 'error');
    }
}

// Quitar fila de la lista de sin asignar después de asignar
function refreshQueueRow(ticketKey) {
    const row = document.getElementById(`qrow_${ticketKey}`);
    if(row) {
        row.style.opacity = '0.4';
        row.style.pointerEvents = 'none';
        setTimeout(() => {
            row.style.transition = 'all 0.3s';
            row.style.maxHeight = '0';
            row.style.overflow = 'hidden';
            row.style.marginBottom = '0';
            row.style.padding = '0';
            setTimeout(() => row.remove(), 300);
        }, 800);
    }
    // Actualizar contador badge
    const unassignedList = document.getElementById('unassignedList');
    const remaining = unassignedList ? unassignedList.querySelectorAll('.queue-ticket-row').length - 1 : 0;
    if(remaining >= 0) document.getElementById('badgeUnassigned').textContent = remaining;
}

// ═══════════════════════════════════════════════════════════
// Utilidades
// ═══════════════════════════════════════════════════════════
function copyTicketKey(){const key=document.getElementById('createdKey').textContent;navigator.clipboard.writeText(key).then(()=>showToast('Copiado: '+key));}

function showToast(msg,type='info'){
    const container=document.getElementById('toastContainer');
    const el=document.createElement('div');
    el.className=`toast-msg ${type}`;
    el.innerHTML=`<i class="bi bi-${type==='success'?'check-circle-fill':type==='error'?'x-circle-fill':'info-circle-fill'}"></i> ${msg}`;
    container.appendChild(el);
    setTimeout(()=>el.remove(),4000);
}
</script>
