                <div class="spinner-border spinner-border-sm text-primary"></div> Cargando cola...
            </div>
            <div id="unassignedList">
                <div class="queue-empty">
                    <i class="bi bi-inbox"></i>
                    <p>Presiona <strong>Actualizar</strong> para cargar los tickets sin asignar</p>
