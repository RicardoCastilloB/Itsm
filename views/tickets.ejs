<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Equipment Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="../css/style.css">

    <style>
/* ── Design System — Light & Dark ── */
:root, [data-theme="light"] {
    --bg-main:     #f5f7fa;
    --bg-card:     #ffffff;
    --bg-header:   #fafbfc;
    --border-soft: #e2e8f0;
    --border-row:  #f1f5f9;
    --text-main:   #1e293b;
    --text-muted:  #64748b;
    --primary:     #3b82f6;
    --success:     #10b981;
    --warning:     #f59e0b;
    --info:        #06b6d4;
    --danger:      #ef4444;
    --purple:      #8b5cf6;
    --jira-blue:   #0052cc;
    --jira-hover:  #003d99;
    --hover-row:   #f8fafc;
    --input-bg:    #ffffff;
    --pill-bg:     #ffffff;
    --upload-bg:   transparent;
    --detail-row-bg:  #f8fafc;
    --detail-desc-bg: #f8fafc;
    --detail-close-bg:#f0fdf4;
    --result-box-bg:  #eff6ff;
    --result-box-border: #bfdbfe;
    --result-box-color:  #1e40af;
    --step1-bg: #eff6ff; --step1-border: #bfdbfe; --step1-color: #1d4ed8; --step1-text: #1e40af;
    --step2-bg: #f0fdf4; --step2-border: #bbf7d0; --step2-color: #065f46;
    --detail-border: #e2e8f0;
    --queue-tab-active: #0052cc;
    --queue-unassigned-bg: #fff7ed;
    --queue-unassigned-border: #fed7aa;
    --queue-assigned-bg: #eff6ff;
    --queue-assigned-border: #bfdbfe;
}

[data-theme="dark"] {
    --bg-main:     #0f172a;
    --bg-card:     #1e293b;
    --bg-header:   #162032;
    --border-soft: #2d3f55;
    --border-row:  #2d3f55;
    --text-main:   #e2e8f0;
    --text-muted:  #94a3b8;
    --primary:     #60a5fa;
    --success:     #34d399;
    --warning:     #fbbf24;
    --info:        #22d3ee;
    --danger:      #f87171;
    --purple:      #a78bfa;
    --jira-blue:   #3b7dd8;
    --jira-hover:  #2563b0;
    --hover-row:   #243348;
    --input-bg:    #162032;
    --pill-bg:     #1e293b;
    --upload-bg:   #162032;
    --detail-row-bg:  #162032;
    --detail-desc-bg: #162032;
    --detail-close-bg:#0a2a1a;
    --result-box-bg:   #1e3a5f;
    --result-box-border:#2d5a9e;
    --result-box-color: #93c5fd;
    --step1-bg: #1e3a5f; --step1-border: #2d5a9e; --step1-color: #93c5fd; --step1-text: #bfdbfe;
    --step2-bg: #0a2a1a; --step2-border: #166534; --step2-color: #34d399;
    --detail-border: #2d3f55;
    --queue-tab-active: #3b7dd8;
    --queue-unassigned-bg: #2a1a00;
    --queue-unassigned-border: #78350f;
    --queue-assigned-bg: #1e3a5f;
    --queue-assigned-border: #2d5a9e;
}

body {
    margin: 0;
    background: var(--bg-main);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: var(--text-main);
    overflow-x: hidden;
    transition: background 0.3s, color 0.3s;
}

.dashboard-wrapper { width: 100%; padding: 16px; margin-top: 60px; }
.dashboard-content { width: 100%; max-width: 1680px; margin: 0 auto; }

.cards-6 { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; margin-bottom: 20px; }
@media (max-width: 1400px) { .cards-6 { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 992px)  { .cards-6 { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 576px)  { .cards-6 { grid-template-columns: 1fr; } }

.kpi-card {
    background: var(--bg-card); border-radius: 12px; height: 100px; padding: 16px;
    display: flex; justify-content: space-between; align-items: center;
    border: 1px solid var(--border-soft); box-shadow: 0 1px 3px rgba(0,0,0,.05);
    transition: all 0.2s; cursor: pointer;
}
.kpi-card:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,0,0,.08); }
.kpi-title { font-size: 10px; letter-spacing: 0.5px; text-transform: uppercase; color: var(--text-muted); font-weight: 600; margin-bottom: 6px; }
.kpi-value { font-size: 28px; font-weight: 700; line-height: 1; }
.kpi-icon  { font-size: 32px; opacity: .25; }

.primary { color: var(--primary); } .success { color: var(--success); }
.warning { color: var(--warning); } .info    { color: var(--info); }
.danger  { color: var(--danger);  } .purple  { color: var(--purple); }
.jira    { color: var(--jira-blue); }

.page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; flex-wrap: wrap; gap: 12px; }
.page-title  { font-size: 22px; font-weight: 700; color: var(--text-main); display: flex; align-items: center; gap: 10px; }
.page-title .jira-badge { background: var(--jira-blue); color: white; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 20px; letter-spacing: 0.5px; }

.card-panel {
    background: var(--bg-card); border-radius: 12px; border: 1px solid var(--border-soft);
    box-shadow: 0 1px 3px rgba(0,0,0,.05); padding: 20px; margin-bottom: 20px;
    transition: background 0.3s, border-color 0.3s;
}
.card-panel-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }

.badge-status { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; display: inline-flex; align-items: center; gap: 4px; }
.badge-open     { background: #dbeafe; color: #1d4ed8; }
.badge-progress { background: #fef3c7; color: #d97706; }
.badge-closed   { background: #d1fae5; color: #065f46; }

[data-theme="dark"] .badge-open     { background: #1e3a5f; color: #93c5fd; }
[data-theme="dark"] .badge-progress { background: #422006; color: #fde68a; }
[data-theme="dark"] .badge-closed   { background: #064e3b; color: #6ee7b7; }

.prio-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 4px; }
.prio-low    { background: #10b981; }
.prio-medium { background: #f59e0b; }
.prio-high   { background: #ef4444; }

.table-tickets thead th {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.4px; color: var(--text-muted);
    font-weight: 600; border-bottom: 2px solid var(--border-soft); padding: 10px 12px;
    white-space: nowrap; background: var(--bg-header);
    transition: background 0.3s, color 0.3s, border-color 0.3s;
}
.table-tickets td {
    padding: 10px 12px; vertical-align: middle; font-size: 13px;
    border-bottom: 1px solid var(--border-row);
    color: var(--text-main);
    transition: border-color 0.3s, color 0.3s;
}
.table-tickets tbody tr:hover { background: var(--hover-row); }
[data-theme="dark"] .table-tickets { --bs-table-bg: transparent; }
[data-theme="dark"] .table-tickets tbody tr:hover td { background: var(--hover-row) !important; }

.ticket-key { font-family: monospace; font-weight: 700; color: var(--jira-blue); font-size: 12px; }
.ticket-key a { color: inherit; text-decoration: none; }
.ticket-key a:hover { text-decoration: underline; }

.quick-form { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media (max-width: 768px) { .quick-form { grid-template-columns: 1fr; } }

.form-label-custom { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; color: var(--text-muted); margin-bottom: 6px; }
.form-control-custom, .form-select-custom {
    border: 1.5px solid var(--border-soft); border-radius: 8px; padding: 9px 12px; font-size: 13px;
    transition: border-color 0.2s, background 0.3s, color 0.3s; width: 100%;
    background: var(--input-bg);
    color: var(--text-main);
}
.form-control-custom:focus, .form-select-custom:focus {
    outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(59,130,246,.1);
}
.form-control-custom::placeholder { color: var(--text-muted); }
textarea.form-control-custom { resize: vertical; }

.btn-create {
    background: var(--jira-blue); color: white; border: none; border-radius: 8px;
    padding: 10px 24px; font-size: 13px; font-weight: 600; cursor: pointer;
    display: flex; align-items: center; gap: 8px; transition: all 0.2s;
}
.btn-create:hover { background: var(--jira-hover); transform: translateY(-1px); }
.btn-create:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

.btn-outline-sm {
    border: 1.5px solid var(--border-soft); background: transparent; border-radius: 6px;
    padding: 4px 10px; font-size: 11px; font-weight: 600; cursor: pointer;
    transition: all 0.15s; color: var(--text-muted);
    display: inline-flex; align-items: center; gap: 4px;
}
.btn-outline-sm:hover { border-color: var(--primary); color: var(--primary); background: var(--hover-row); }
.btn-close-ticket { border-color: #fca5a5; color: #dc2626; }
.btn-close-ticket:hover { background: #fee2e2; border-color: #dc2626; color: #dc2626; }
[data-theme="dark"] .btn-close-ticket { border-color: #7f1d1d; color: #f87171; }
[data-theme="dark"] .btn-close-ticket:hover { background: #450a0a; border-color: #f87171; color: #f87171; }

.search-bar { display: flex; gap: 10px; align-items: center; margin-bottom: 16px; flex-wrap: wrap; }
.search-input-wrap { position: relative; flex: 1; min-width: 200px; }
.search-input-wrap i { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 14px; }
.search-input-wrap input {
    padding-left: 34px; border: 1.5px solid var(--border-soft); border-radius: 8px;
    padding-top: 8px; padding-bottom: 8px; font-size: 13px; width: 100%;
    background: var(--input-bg); color: var(--text-main);
    transition: background 0.3s, color 0.3s, border-color 0.3s;
}
.search-input-wrap input::placeholder { color: var(--text-muted); }
.search-input-wrap input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(59,130,246,.1); }

.filter-pills { display: flex; gap: 6px; flex-wrap: wrap; }
.pill {
    border: 1.5px solid var(--border-soft);
    background: var(--pill-bg);
    border-radius: 20px; padding: 4px 14px; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: all 0.15s; color: var(--text-muted);
}
.pill.active { background: var(--jira-blue); border-color: var(--jira-blue); color: white; }
.pill:hover:not(.active) { border-color: var(--jira-blue); color: var(--jira-blue); }

.spinner-wrap { display: flex; align-items: center; justify-content: center; padding: 40px; color: var(--text-muted); gap: 10px; font-size: 13px; }

.toast-container-custom { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
.toast-msg { background: var(--text-main); color: white; padding: 12px 18px; border-radius: 10px; font-size: 13px; font-weight: 500; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 20px rgba(0,0,0,.2); animation: slideUp 0.3s ease; min-width: 280px; }
.toast-msg.success { background: #065f46; }
.toast-msg.error   { background: #991b1b; }
@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

.upload-zone {
    border: 2px dashed var(--border-soft); border-radius: 8px; padding: 20px; text-align: center;
    cursor: pointer; transition: all 0.2s; color: var(--text-muted); font-size: 13px; position: relative;
    background: var(--upload-bg);
}
.upload-zone:hover, .upload-zone.dragover { border-color: var(--primary); color: var(--primary); background: var(--hover-row); }
.upload-zone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
.upload-preview { display: flex; align-items: center; gap: 8px; margin-top: 8px; font-size: 12px; color: var(--success); }

.modal-header-custom {
    background: linear-gradient(135deg, var(--jira-blue), #0065ff);
    color: white; border-radius: 12px 12px 0 0; padding: 16px 20px;
}
.modal-content {
    border-radius: 12px; border: none; box-shadow: 0 20px 60px rgba(0,0,0,.15);
}

[data-theme="dark"] .modal-content { background: var(--bg-card) !important; color: var(--text-main) !important; }
[data-theme="dark"] .modal-body    { background: var(--bg-card) !important; }
[data-theme="dark"] .modal-footer  { background: var(--bg-header) !important; border-color: var(--border-soft) !important; }
[data-theme="dark"] .modal-header  { background: var(--bg-header) !important; border-color: var(--border-soft) !important; color: var(--text-main) !important; }
[data-theme="dark"] .modal-title   { color: var(--text-main) !important; }
[data-theme="dark"] .btn-close     { filter: invert(1); }

.empty-state { text-align: center; padding: 48px 20px; color: var(--text-muted); }
.empty-state i { font-size: 48px; opacity: 0.3; margin-bottom: 12px; display: block; }
.empty-state p { font-size: 14px; margin: 0; }

@keyframes flashPulse {
    0%   { box-shadow: 0 0 0 0 rgba(0,82,204,.4); }
    70%  { box-shadow: 0 0 0 10px rgba(0,82,204,0); }
    100% { box-shadow: 0 0 0 0 rgba(0,82,204,0); }
}
.flash-new { animation: flashPulse 1s ease 3; }

#paginationWrap { display:flex; justify-content:space-between; align-items:center; margin-top:12px; flex-wrap:wrap; gap:8px; }
#paginationInfo { font-size:12px; color:var(--text-muted); }

/* ═══════════════════════════════════════════════════════════
   NUEVOS ESTILOS — Modal de Búsqueda / Cola
═══════════════════════════════════════════════════════════ */

/* Tabs del modal de búsqueda */
.search-modal-tabs {
    display: flex;
    border-bottom: 2px solid var(--border-soft);
    margin-bottom: 20px;
    gap: 0;
}
.search-tab-btn {
    flex: 1;
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-bottom: -2px;
    white-space: nowrap;
}
.search-tab-btn:hover { color: var(--jira-blue); }
.search-tab-btn.active {
    color: var(--jira-blue);
    border-bottom-color: var(--jira-blue);
}
.tab-badge {
    background: var(--jira-blue);
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 1px 6px;
    border-radius: 10px;
    min-width: 18px;
    text-align: center;
}
.tab-badge.orange { background: #f59e0b; }

/* Panel de contenido de tabs */
.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* Fila de ticket en cola */
.queue-ticket-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid var(--border-soft);
    background: var(--bg-card);
    margin-bottom: 6px;
    transition: all 0.15s;
    flex-wrap: wrap;
}
.queue-ticket-row:hover { border-color: var(--jira-blue); background: var(--hover-row); }

.queue-ticket-key {
    font-family: monospace;
    font-weight: 700;
    color: var(--jira-blue);
    font-size: 12px;
    min-width: 80px;
    flex-shrink: 0;
}
.queue-ticket-key a { color: inherit; text-decoration: none; }
.queue-ticket-key a:hover { text-decoration: underline; }

.queue-ticket-summary {
    flex: 1;
    font-size: 13px;
    color: var(--text-main);
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.queue-ticket-meta {
    font-size: 11px;
    color: var(--text-muted);
    flex-shrink: 0;
}
.queue-ticket-actions { display: flex; gap: 6px; flex-shrink: 0; }

/* Botón asignarme */
.btn-assign-me {
    border: 1.5px solid var(--jira-blue);
    background: transparent;
    border-radius: 6px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    color: var(--jira-blue);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: all 0.15s;
    white-space: nowrap;
}
.btn-assign-me:hover { background: var(--jira-blue); color: white; }
.btn-assign-me:disabled { opacity: 0.5; cursor: not-allowed; }

/* Botón asignar a alguien */
.btn-assign-other {
    border: 1.5px solid var(--border-soft);
    background: transparent;
    border-radius: 6px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: all 0.15s;
}
.btn-assign-other:hover { border-color: var(--warning); color: var(--warning); }

/* Avatar asignado */
.assignee-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--queue-assigned-bg);
    border: 1px solid var(--queue-assigned-border);
    border-radius: 20px;
    padding: 2px 8px 2px 2px;
    font-size: 11px;
    font-weight: 600;
    color: var(--jira-blue);
}
.assignee-chip .avatar {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--jira-blue);
    color: white;
    font-size: 9px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

/* Filtro por correo */
.email-filter-wrap {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
}
.email-filter-wrap input {
    flex: 1;
}
.email-filter-suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg-card);
    border: 1.5px solid var(--border-soft);
    border-radius: 8px;
    box-shadow: 0 4px 12px rgba(0,0,0,.1);
    z-index: 100;
    max-height: 150px;
    overflow-y: auto;
}
.email-suggestion-item {
    padding: 8px 12px;
    font-size: 12px;
    cursor: pointer;
    color: var(--text-main);
    transition: background 0.1s;
}
.email-suggestion-item:hover { background: var(--hover-row); color: var(--jira-blue); }

/* Queue header info */
.queue-header-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    flex-wrap: wrap;
    gap: 8px;
}
.queue-count-badge {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
}
.queue-count-badge strong { color: var(--text-main); }

/* Dropdown de asignación */
.assign-dropdown {
    position: relative;
    display: inline-block;
}
.assign-dropdown-menu {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    background: var(--bg-card);
    border: 1.5px solid var(--border-soft);
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,.12);
    z-index: 200;
    min-width: 220px;
    overflow: hidden;
}
.assign-dropdown-header {
    padding: 8px 12px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border-soft);
}
.assign-dropdown-search {
    padding: 8px;
    border-bottom: 1px solid var(--border-soft);
}
.assign-dropdown-search input {
    width: 100%;
    border: 1.5px solid var(--border-soft);
    border-radius: 6px;
    padding: 5px 8px;
    font-size: 12px;
    background: var(--input-bg);
    color: var(--text-main);
}
.assign-dropdown-search input:focus { outline: none; border-color: var(--primary); }
.assign-agent-list { max-height: 180px; overflow-y: auto; }
.assign-agent-item {
    padding: 8px 12px;
    font-size: 12px;
    cursor: pointer;
    color: var(--text-main);
    transition: background 0.1s;
    display: flex;
    align-items: center;
    gap: 8px;
}
.assign-agent-item:hover { background: var(--hover-row); }
.assign-agent-avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--jira-blue), #0065ff);
    color: white;
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.assign-agent-email { font-size: 10px; color: var(--text-muted); }

/* Ticket detalle con asignación dentro del modal search */
.ticket-detail-assignee-section {
    padding: 12px 16px;
    border-top: 1px solid var(--border-soft);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    background: var(--bg-header);
}
.ticket-detail-assignee-label {
    font-size: 10px;
    font-weight: 700;
