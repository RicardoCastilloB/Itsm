<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gestión de Problemas</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<style>
:root,[data-theme="light"]{
    --bg:#f0f4f8;--card:#fff;--hdr:#f8fafc;--border:#e2e8f0;
    --text:#1e293b;--muted:#64748b;--primary:#3b82f6;--success:#10b981;
    --warning:#f59e0b;--info:#06b6d4;--danger:#ef4444;--purple:#8b5cf6;
    --hover:#f1f5f9;--sh-sm:0 1px 3px rgba(0,0,0,.06);--sh-md:0 4px 12px rgba(0,0,0,.08);
}
[data-theme="dark"]{
    --bg:#0f172a;--card:#1e293b;--hdr:#162032;--border:#2d3f55;
    --text:#e2e8f0;--muted:#94a3b8;--primary:#60a5fa;--success:#34d399;
    --warning:#fbbf24;--info:#22d3ee;--danger:#f87171;--purple:#a78bfa;
    --hover:#243348;
}
*{box-sizing:border-box;}
body{margin:0;background:var(--bg);color:var(--text);font-family:'DM Sans',-apple-system,sans-serif;}
.pg{max-width:1700px;margin:0 auto;padding:24px 20px;}
.page-hdr{display:flex;align-items:center;gap:16px;margin-bottom:28px;}
.page-hdr-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;box-shadow:var(--sh-md);}
.page-hdr h1{font-size:22px;font-weight:800;margin:0;}
.page-hdr p{margin:3px 0 0;font-size:13px;color:var(--muted);}
.page-hdr-right{margin-left:auto;display:flex;gap:8px;align-items:center;}
.kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px;}
@media(max-width:1000px){.kpi-grid{grid-template-columns:repeat(3,1fr);}}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 18px;display:flex;justify-content:space-between;align-items:center;box-shadow:var(--sh-sm);cursor:pointer;position:relative;overflow:hidden;transition:all .2s;}
.kpi::before{content:'';position:absolute;inset:0;background:var(--kc);opacity:0;transition:opacity .2s;}
.kpi:hover::before,.kpi.active::before{opacity:.06;}
.kpi.active{border-color:var(--kc)!important;box-shadow:0 0 0 2px var(--kc)!important;}
.kpi-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin-bottom:5px;}
.kpi-val{font-size:28px;font-weight:800;line-height:1;color:var(--kc);}
.kpi-icon{font-size:32px;opacity:.18;color:var(--kc);}
.two-col{display:grid;grid-template-columns:1fr 380px;gap:16px;align-items:start;}
@media(max-width:1100px){.two-col{grid-template-columns:1fr;}}
.card-ui{background:var(--card);border:1px solid var(--border);border-radius:14px;box-shadow:var(--sh-sm);overflow:hidden;margin-bottom:20px;}
.card-head{padding:13px 18px;background:var(--hdr);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.card-head .title{font-size:13px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px;}
.tbl-wrap{overflow:auto;max-height:480px;}
.tbl{width:100%;border-collapse:collapse;font-size:13px;}
.tbl thead th{background:var(--hdr);color:var(--muted);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;padding:11px 14px;border-bottom:1px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;}
.tbl tbody tr{border-bottom:1px solid var(--border);transition:background .15s;}
.tbl tbody tr:hover{background:var(--hover);}
.tbl td{padding:11px 14px;vertical-align:middle;}
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.s-abierto{background:#fee2e2;color:#dc2626;}
.s-en_investigacion{background:#fef3c7;color:#d97706;}
.s-conocido{background:#dbeafe;color:#2563eb;}
.s-resuelto{background:#d1fae5;color:#059669;}
.s-cerrado{background:#f1f5f9;color:#94a3b8;}
.p-baja{background:#d1fae5;color:#059669;}
.p-media{background:#fef3c7;color:#d97706;}
.p-alta{background:#fee2e2;color:#dc2626;}
.p-critica{background:#fce7f3;color:#be185d;}
.btn-sm{padding:6px 14px;font-size:12px;font-weight:600;border-radius:8px;border:none;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--primary);color:#fff;}
.btn-primary:hover{opacity:.88;}
.btn-danger{background:var(--danger);color:#fff;}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--muted);}
.btn-outline:hover{background:var(--hover);}
.form-ctrl{width:100%;border:1px solid var(--border);border-radius:8px;padding:9px 12px;font-size:13px;background:var(--card);color:var(--text);outline:none;transition:border .15s;}
.form-ctrl:focus{border-color:var(--primary);}
.form-group{margin-bottom:14px;}
.form-lbl{font-size:12px;font-weight:700;color:var(--muted);margin-bottom:5px;display:block;}
.ke-item{padding:12px 14px;border-bottom:1px solid var(--border);font-size:13px;}
.ke-item:last-child{border-bottom:none;}
.ke-title{font-weight:700;margin-bottom:4px;}
.ke-pub{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:12px;font-size:10px;font-weight:700;background:#d1fae5;color:#059669;}
.modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal-box{background:var(--card);border-radius:20px;width:600px;max-width:95vw;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 60px rgba(0,0,0,.25);transform:translateY(20px);transition:transform .2s;}
.modal-overlay.open .modal-box{transform:translateY(0);}
.modal-hdr{padding:20px 24px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.modal-hdr h3{margin:0;font-size:16px;font-weight:800;}
.modal-body{padding:20px 24px;overflow-y:auto;flex:1;}
.modal-ftr{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;}
.empty-state{text-align:center;padding:40px 20px;color:var(--muted);}
.theme-toggle{background:none;border:1px solid var(--border);border-radius:8px;padding:6px 10px;cursor:pointer;color:var(--text);font-size:16px;}
</style>
</head>
<body>
<div class="pg">
  <div class="page-hdr">
    <div class="page-hdr-icon" style="background:linear-gradient(135deg,#ef4444,#b91c1c);">
      <i class="bi bi-bug" style="color:#fff;"></i>
    </div>
    <div>
      <h1>Gestión de Problemas</h1>
      <p>Investigación de causa raíz y base de errores conocidos</p>
    </div>
    <div class="page-hdr-right">
      <button class="theme-toggle" onclick="toggleTheme()"><i class="bi bi-moon-stars-fill"></i></button>
      <button class="btn-sm btn-primary" onclick="openModalProb()">
        <i class="bi bi-plus-lg"></i> Nuevo Problema
      </button>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpi-grid">
    <div class="kpi" style="--kc:var(--danger)" onclick="filterStatus('abierto')">
      <div><div class="kpi-label">Abiertos</div><div class="kpi-val" id="kpiAbiertos">—</div></div>
      <i class="bi bi-exclamation-circle kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--warning)" onclick="filterStatus('en_investigacion')">
      <div><div class="kpi-label">Investigando</div><div class="kpi-val" id="kpiInvest">—</div></div>
      <i class="bi bi-search kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--primary)" onclick="filterStatus('conocido')">
      <div><div class="kpi-label">Conocidos</div><div class="kpi-val" id="kpiConocido">—</div></div>
      <i class="bi bi-book kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--success)" onclick="filterStatus('resuelto')">
      <div><div class="kpi-label">Resueltos</div><div class="kpi-val" id="kpiResuelto">—</div></div>
      <i class="bi bi-check-circle kpi-icon"></i>
    </div>
    <div class="kpi" style="--kc:var(--info)">
      <div><div class="kpi-label">Errores publ.</div><div class="kpi-val" id="kpiKE">—</div></div>
      <i class="bi bi-journal-text kpi-icon"></i>
    </div>
  </div>

  <div class="two-col">
    <!-- Tabla principal -->
    <div class="card-ui">
      <div class="card-head">
        <span class="title"><i class="bi bi-list-ul"></i> Problemas</span>
        <div style="display:flex;gap:8px;">
          <select id="fStatus" class="form-ctrl" style="width:150px;" onchange="loadProblemas()">
            <option value="">Todos</option>
            <option value="abierto">Abierto</option>
            <option value="en_investigacion">Investigando</option>
            <option value="conocido">Conocido</option>
            <option value="resuelto">Resuelto</option>
            <option value="cerrado">Cerrado</option>
          </select>
        </div>
      </div>
      <div class="tbl-wrap">
        <table class="tbl">
          <thead>
            <tr>
              <th>N° Problema</th><th>Título</th><th>Prioridad</th>
              <th>Estado</th><th>Creado</th><th>Acciones</th>
            </tr>
          </thead>
          <tbody id="probBody">
            <tr><td colspan="6"><div class="empty-state"><i class="bi bi-arrow-clockwise"></i> Cargando...</div></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Base de errores conocidos -->
    <div class="card-ui">
      <div class="card-head">
        <span class="title"><i class="bi bi-journal-bookmark"></i> Errores Conocidos</span>
        <button class="btn-sm btn-outline" onclick="openModalKE()" title="Agregar error conocido">
          <i class="bi bi-plus"></i>
        </button>
      </div>
      <div id="keList" style="min-height:120px;">
        <div class="empty-state"><i class="bi bi-journal-x"></i>Sin errores conocidos</div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL NUEVO PROBLEMA -->
<div class="modal-overlay" id="modalProb">
  <div class="modal-box">
    <div class="modal-hdr">
      <h3><i class="bi bi-bug" style="color:var(--danger)"></i> Nuevo Problema</h3>
      <button class="btn-sm btn-outline" onclick="closeModal('modalProb')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-lbl">Título *</label>
        <input type="text" id="probTitle" class="form-ctrl" placeholder="Ej: Intermitencia en servicio de autenticación">
      </div>
      <div class="form-group">
        <label class="form-lbl">Descripción</label>
        <textarea id="probDesc" class="form-ctrl" rows="3" placeholder="Síntomas observados, impacto..."></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-lbl">Prioridad</label>
          <select id="probPriority" class="form-ctrl">
            <option value="baja">Baja</option>
            <option value="media" selected>Media</option>
            <option value="alta">Alta</option>
            <option value="critica">Crítica</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-lbl">Workaround temporal</label>
          <input type="text" id="probWorkaround" class="form-ctrl" placeholder="Si existe solución temporal...">
        </div>
      </div>
    </div>
    <div class="modal-ftr">
      <button class="btn-sm btn-outline" onclick="closeModal('modalProb')">Cancelar</button>
      <button class="btn-sm btn-primary" onclick="crearProblema()">
        <i class="bi bi-send"></i> Crear
      </button>
    </div>
  </div>
</div>

<!-- MODAL ERROR CONOCIDO -->
<div class="modal-overlay" id="modalKE">
  <div class="modal-box">
    <div class="modal-hdr">
      <h3><i class="bi bi-journal-plus" style="color:var(--info)"></i> Registrar Error Conocido</h3>
      <button class="btn-sm btn-outline" onclick="closeModal('modalKE')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-lbl">Problema relacionado *</label>
        <select id="keProblema" class="form-ctrl"><option value="">— Seleccionar —</option></select>
      </div>
      <div class="form-group">
        <label class="form-lbl">Título *</label>
        <input type="text" id="keTitle" class="form-ctrl" placeholder="Nombre corto del error">
      </div>
      <div class="form-group">
        <label class="form-lbl">Síntomas</label>
        <textarea id="keSymptoms" class="form-ctrl" rows="2"></textarea>
      </div>
      <div class="form-group">
        <label class="form-lbl">Workaround</label>
        <textarea id="keWorkaround" class="form-ctrl" rows="2"></textarea>
      </div>
      <div class="form-group">
        <label class="form-lbl">Resolución definitiva</label>
        <textarea id="keResolution" class="form-ctrl" rows="2"></textarea>
      </div>
      <div class="form-group" style="display:flex;align-items:center;gap:8px;">
        <input type="checkbox" id="kePublish" style="width:16px;height:16px;">
        <label for="kePublish" class="form-lbl" style="margin:0;">Publicar en base de conocimiento</label>
      </div>
    </div>
    <div class="modal-ftr">
      <button class="btn-sm btn-outline" onclick="closeModal('modalKE')">Cancelar</button>
      <button class="btn-sm btn-primary" onclick="crearKE()">
        <i class="bi bi-save"></i> Guardar
      </button>
    </div>
  </div>
</div>

<script>
let probList = [];

async function loadKpis() {
    try {
        const res = await fetch('/api/problems/kpis');
        const d = await res.json();
        if (!d.success) return;
        document.getElementById('kpiAbiertos').textContent = d.data.abiertos    ?? '—';
        document.getElementById('kpiInvest').textContent   = d.data.investigacion ?? '—';
        document.getElementById('kpiConocido').textContent = d.data.conocidos    ?? '—';
        document.getElementById('kpiResuelto').textContent = d.data.resueltos    ?? '—';
        document.getElementById('kpiKE').textContent       = d.data.erroresPublicados ?? '—';
    } catch {}
}

async function loadProblemas() {
    const status = document.getElementById('fStatus').value;
    const params = new URLSearchParams({ limit: 50 });
    if (status) params.set('status', status);

    const res = await fetch(`/api/problems?${params}`);
    const d   = await res.json();
    probList  = d.data || [];
    const tbody = document.getElementById('probBody');

    if (!probList.length) {
        tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i>Sin problemas</div></td></tr>`;
        loadKE();
        return;
    }

    tbody.innerHTML = probList.map(p => `
        <tr>
          <td><span style="font-family:monospace;font-size:12px;font-weight:700;color:var(--danger)">${esc(p.problemNumber)}</span></td>
          <td><strong>${esc(p.title)}</strong>${p.workaround?`<div style="font-size:11px;color:var(--muted);margin-top:2px;">WA: ${esc(p.workaround)}</div>`:''}
          </td>
          <td><span class="badge p-${p.priority}">${p.priority}</span></td>
          <td><span class="badge s-${p.status}">${fmtStatus(p.status)}</span></td>
          <td>${fmtDate(p.createdAt)}</td>
          <td>
            <select class="form-ctrl" style="width:130px;padding:4px 8px;font-size:12px;"
              onchange="cambiarEstado('${p.id}', this.value)">
              <option value="">— Estado —</option>
              <option value="en_investigacion">Investigar</option>
              <option value="conocido">Conocido</option>
              <option value="resuelto">Resuelto</option>
              <option value="cerrado">Cerrar</option>
            </select>
          </td>
        </tr>`).join('');

    loadKE();
}

async function loadKE() {
    const res = await fetch('/api/problems?limit=200');
    const d   = await res.json();
    const all = d.data || [];
    const allKE = all.flatMap(p => (p.erroresConocidos || []).map(ke => ({ ...ke, probNum: p.problemNumber })));
    const list = document.getElementById('keList');
    if (!allKE.length) {
        list.innerHTML = '<div class="empty-state"><i class="bi bi-journal-x"></i>Sin errores conocidos</div>';
        return;
    }
    list.innerHTML = allKE.slice(0, 10).map(ke => `
        <div class="ke-item">
          <div class="ke-title">${esc(ke.title)} ${ke.isPublished ? '<span class="ke-pub"><i class="bi bi-check"></i>Publicado</span>' : ''}</div>
          <div style="font-size:11px;color:var(--muted)">PRB: ${esc(ke.probNum || '')}</div>
          ${ke.workaround ? `<div style="font-size:12px;color:var(--muted);margin-top:4px;">WA: ${esc(ke.workaround)}</div>` : ''}
        </div>`).join('');
}

async function crearProblema() {
    const title = document.getElementById('probTitle').value.trim();
    if (!title) return alert('Título requerido');
    const res = await fetch('/api/problems', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            title,
            description: document.getElementById('probDesc').value,
            priority:    document.getElementById('probPriority').value,
            workaround:  document.getElementById('probWorkaround').value,
        }),
    });
    const d = await res.json();
    if (!d.success) return alert(d.error);
    closeModal('modalProb');
    loadProblemas(); loadKpis();
}

async function crearKE() {
    const probId = document.getElementById('keProblema').value;
    const title  = document.getElementById('keTitle').value.trim();
    if (!probId || !title) return alert('Problema y título son requeridos');
    const res = await fetch(`/api/problems/${probId}/known-errors`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            title,
            symptoms:    document.getElementById('keSymptoms').value,
            workaround:  document.getElementById('keWorkaround').value,
            resolution:  document.getElementById('keResolution').value,
            isPublished: document.getElementById('kePublish').checked,
        }),
    });
    const d = await res.json();
    if (!d.success) return alert(d.error);
    closeModal('modalKE');
    loadKE(); loadKpis();
}

async function cambiarEstado(id, status) {
    if (!status) return;
    const res = await fetch(`/api/problems/${id}`, {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status }),
    });
    if (!(await res.json()).success) return alert('Error actualizando estado');
    loadProblemas(); loadKpis();
}

function filterStatus(s) { document.getElementById('fStatus').value = s; loadProblemas(); }

function openModalProb() { document.getElementById('modalProb').classList.add('open'); }
function openModalKE()   {
    const sel = document.getElementById('keProblema');
    sel.innerHTML = '<option value="">— Seleccionar —</option>' +
        probList.map(p => `<option value="${p.id}">${esc(p.problemNumber)} — ${esc(p.title.substring(0,40))}</option>`).join('');
    document.getElementById('modalKE').classList.add('open');
}
function closeModal(id)  { document.getElementById(id).classList.remove('open'); }

function fmtStatus(s) {
    return { abierto:'Abierto', en_investigacion:'Investigando', conocido:'Conocido',
             resuelto:'Resuelto', cerrado:'Cerrado' }[s] || s;
}
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('es', { day:'2-digit', month:'short', year:'numeric' }) : '—'; }
function esc(t) { return String(t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;'); }

function toggleTheme() {
    const h = document.documentElement;
    h.setAttribute('data-theme', h.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
}

loadProblemas(); loadKpis();
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
