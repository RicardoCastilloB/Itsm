<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Administrador</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="/socket.io/socket.io.js"></script>
<style>
:root,[data-theme="light"]{
  --bg:#f0f4f8;--card:#fff;--hdr:#f8fafc;--border:#e2e8f0;
  --text:#1e293b;--muted:#64748b;--primary:#3b82f6;--success:#10b981;
  --warning:#f59e0b;--danger:#ef4444;--purple:#8b5cf6;--info:#06b6d4;
  --hover:#f1f5f9;--sh-sm:0 1px 3px rgba(0,0,0,.06);--sh-md:0 4px 12px rgba(0,0,0,.08);
}
[data-theme="dark"]{
  --bg:#0f172a;--card:#1e293b;--hdr:#162032;--border:#2d3f55;
  --text:#e2e8f0;--muted:#94a3b8;--primary:#60a5fa;--success:#34d399;
  --warning:#fbbf24;--danger:#f87171;--purple:#a78bfa;--info:#22d3ee;
  --hover:#243348;
}
*{box-sizing:border-box;}
body{margin:0;background:var(--bg);color:var(--text);font-family:'DM Sans',-apple-system,sans-serif;}
.pg{max-width:1800px;margin:0 auto;padding:24px 20px;}
.page-hdr{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:28px;flex-wrap:wrap;}
.page-hdr-left{display:flex;align-items:center;gap:16px;}
.page-hdr-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;box-shadow:var(--sh-md);background:linear-gradient(135deg,#667eea,#764ba2);}
.page-hdr h1{font-size:22px;font-weight:800;margin:0;}
.page-hdr p{color:var(--muted);margin:2px 0 0;font-size:13px;}

/* KPI Cards */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;margin-bottom:28px;}
.kpi-card{background:var(--card);border-radius:16px;padding:20px;border:1px solid var(--border);box-shadow:var(--sh-sm);position:relative;overflow:hidden;transition:transform .15s,box-shadow .15s;}
.kpi-card:hover{transform:translateY(-2px);box-shadow:var(--sh-md);}
.kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.kpi-blue::before{background:var(--primary);}
.kpi-green::before{background:var(--success);}
.kpi-yellow::before{background:var(--warning);}
.kpi-red::before{background:var(--danger);}
.kpi-purple::before{background:var(--purple);}
.kpi-cyan::before{background:var(--info);}
.kpi-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin-bottom:8px;}
.kpi-val{font-size:32px;font-weight:800;line-height:1;margin-bottom:4px;font-family:'JetBrains Mono',monospace;}
.kpi-sub{font-size:11px;color:var(--muted);}
.kpi-icon{position:absolute;right:16px;top:50%;transform:translateY(-50%);font-size:36px;opacity:.07;}

/* Grid layouts */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;margin-bottom:20px;}
.grid-main-side{display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:20px;}
@media(max-width:1100px){.grid-2,.grid-3,.grid-main-side{grid-template-columns:1fr;}}

/* Cards */
.card{background:var(--card);border-radius:16px;padding:22px;border:1px solid var(--border);box-shadow:var(--sh-sm);}
.card-title{font-size:14px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:8px;color:var(--text);}
.card-title i{font-size:16px;opacity:.7;}

/* Table */
.data-table{width:100%;border-collapse:collapse;font-size:13px;}
.data-table th{background:var(--hdr);padding:10px 12px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);border-bottom:1px solid var(--border);}
.data-table td{padding:10px 12px;border-bottom:1px solid var(--border);vertical-align:middle;}
.data-table tbody tr:hover{background:var(--hover);}
.data-table tbody tr:last-child td{border-bottom:none;}
.tbl-wrap{overflow-x:auto;border-radius:10px;border:1px solid var(--border);}

/* Badges */
.badge-pill{display:inline-flex;align-items:center;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:600;gap:4px;}
.bp-blue{background:#dbeafe;color:#1d4ed8;}
.bp-green{background:#d1fae5;color:#065f46;}
.bp-yellow{background:#fef3c7;color:#92400e;}
.bp-red{background:#fee2e2;color:#991b1b;}
.bp-purple{background:#ede9fe;color:#5b21b6;}
.bp-gray{background:#f1f5f9;color:#475569;}
[data-theme="dark"] .bp-blue{background:#1e3a5f;color:#93c5fd;}
[data-theme="dark"] .bp-green{background:#064e3b;color:#6ee7b7;}
[data-theme="dark"] .bp-yellow{background:#451a03;color:#fcd34d;}
[data-theme="dark"] .bp-red{background:#450a0a;color:#fca5a5;}
[data-theme="dark"] .bp-purple{background:#2e1065;color:#c4b5fd;}
[data-theme="dark"] .bp-gray{background:#1e293b;color:#94a3b8;}

/* Progress */
.progress-bar-wrap{background:var(--border);border-radius:999px;height:8px;overflow:hidden;flex:1;}
.progress-bar-fill{height:100%;border-radius:999px;transition:width .4s ease;}
.progress-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.progress-label{font-size:12px;min-width:120px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.progress-val{font-size:12px;font-weight:700;min-width:36px;text-align:right;font-family:'JetBrains Mono',monospace;}

/* Agent load */
.agent-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.agent-row:last-child{border-bottom:none;}
.agent-avatar{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;flex-shrink:0;}
.agent-name{font-size:13px;font-weight:600;}
.agent-meta{font-size:11px;color:var(--muted);}
.agent-stats{margin-left:auto;display:flex;gap:8px;align-items:center;}
.stat-chip{background:var(--hdr);border:1px solid var(--border);border-radius:8px;padding:4px 8px;font-size:11px;font-weight:700;text-align:center;min-width:36px;}
.stat-chip.danger{background:#fee2e2;color:#991b1b;border-color:#fca5a5;}
.stat-chip.warn{background:#fef3c7;color:#92400e;border-color:#fcd34d;}
[data-theme="dark"] .stat-chip.danger{background:#450a0a;color:#fca5a5;border-color:#7f1d1d;}
[data-theme="dark"] .stat-chip.warn{background:#451a03;color:#fcd34d;border-color:#78350f;}

/* Chart containers */
.chart-wrap{position:relative;width:100%;}
.chart-wrap canvas{max-height:260px;}
.chart-wrap-tall canvas{max-height:320px;}

/* Refresh btn */
.refresh-btn{background:var(--primary);color:#fff;border:none;border-radius:10px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;transition:opacity .15s;}
.refresh-btn:hover{opacity:.85;}
.refresh-btn.spinning i{animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* Live dot */
.live-dot{width:8px;height:8px;border-radius:50%;background:var(--success);display:inline-block;margin-right:6px;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

/* Toast */
.toast-container{position:fixed;top:80px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;}
.toast{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px 18px;box-shadow:var(--sh-md);max-width:320px;pointer-events:all;animation:toastIn .3s ease;font-size:13px;}
@keyframes toastIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:none}}
.toast-title{font-weight:700;margin-bottom:4px;}
.toast-body{color:var(--muted);}
</style>
</head>
<body>
<%- include('partials/sidebar_top') %>
<%- include('partials/styles_sidebar') %>

<div class="pg" style="padding-top:80px;">

  <!-- Page Header -->
  <div class="page-hdr">
    <div class="page-hdr-left">
      <div class="page-hdr-icon">🛡️</div>
      <div>
        <h1>Dashboard Administrador</h1>
        <p><span class="live-dot"></span>Datos en tiempo real · Actualizado hace <span id="lastUpdated">—</span></p>
      </div>
    </div>
    <button class="refresh-btn" id="refreshBtn" onclick="loadAll()">
      <i class="bi bi-arrow-clockwise"></i> Actualizar
    </button>
  </div>

  <!-- KPI Grid -->
  <div class="kpi-grid" id="kpiGrid">
    <div class="kpi-card kpi-blue"><div class="kpi-label">Total Tickets</div><div class="kpi-val" id="k-total">—</div><div class="kpi-sub">Todos los estados</div><i class="bi bi-ticket-perforated kpi-icon"></i></div>
    <div class="kpi-card kpi-yellow"><div class="kpi-label">Abiertos</div><div class="kpi-val" id="k-open">—</div><div class="kpi-sub">Sin resolver</div><i class="bi bi-folder2-open kpi-icon"></i></div>
    <div class="kpi-card kpi-red"><div class="kpi-label">En Riesgo SLA</div><div class="kpi-val" id="k-risk">—</div><div class="kpi-sub">Próximos a vencer</div><i class="bi bi-exclamation-triangle kpi-icon"></i></div>
    <div class="kpi-card kpi-red" style="--danger:#dc2626"><div class="kpi-label">SLA Vencido</div><div class="kpi-val" id="k-breach">—</div><div class="kpi-sub">Superaron el plazo</div><i class="bi bi-alarm kpi-icon"></i></div>
    <div class="kpi-card kpi-green"><div class="kpi-label">Resueltos Hoy</div><div class="kpi-val" id="k-today">—</div><div class="kpi-sub">Últimas 24h</div><i class="bi bi-check-circle kpi-icon"></i></div>
    <div class="kpi-card kpi-cyan"><div class="kpi-label">% SLA Cumplido</div><div class="kpi-val" id="k-sla-pct">—</div><div class="kpi-sub">Últimos 30 días</div><i class="bi bi-graph-up kpi-icon"></i></div>
  </div>

  <!-- Trends + By Status / Priority -->
  <div class="grid-main-side">
    <div class="card">
      <div class="card-title"><i class="bi bi-bar-chart-line"></i> Tendencia Diaria (30 días)</div>
      <div class="chart-wrap"><canvas id="trendChart"></canvas></div>
    </div>
    <div class="card">
      <div class="card-title"><i class="bi bi-pie-chart"></i> Por Estado</div>
      <div class="chart-wrap"><canvas id="statusChart"></canvas></div>
    </div>
  </div>

  <div class="grid-3">
    <div class="card">
      <div class="card-title"><i class="bi bi-bar-chart"></i> Por Prioridad</div>
      <div class="chart-wrap"><canvas id="priorityChart"></canvas></div>
    </div>
    <div class="card">
      <div class="card-title"><i class="bi bi-tags"></i> Por Categoría (Top 8)</div>
      <div class="chart-wrap"><canvas id="catChart"></canvas></div>
    </div>
    <div class="card">
      <div class="card-title"><i class="bi bi-shield-check"></i> SLA por Prioridad</div>
      <div id="slaPriorityBars" class="mt-2"></div>
    </div>
  </div>

  <!-- Agent Load + SLA by Agent -->
  <div class="grid-2">
    <div class="card">
      <div class="card-title"><i class="bi bi-people"></i> Carga por Agente</div>
      <div id="agentLoadList"></div>
    </div>
    <div class="card">
      <div class="card-title"><i class="bi bi-person-check"></i> SLA por Agente</div>
      <div id="slaAgentBars" class="mt-2"></div>
    </div>
  </div>

  <!-- Recent Tickets Table -->
  <div class="card">
    <div class="card-title"><i class="bi bi-clock-history"></i> Tickets Recientes (últimos 20)</div>
    <div class="tbl-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Asunto</th>
            <th>Prioridad</th>
            <th>Estado</th>
            <th>Asignado a</th>
            <th>Categoría</th>
            <th>SLA</th>
            <th>Creado</th>
          </tr>
        </thead>
        <tbody id="recentTicketsTbody">
          <tr><td colspan="8" class="text-center text-muted py-4">Cargando...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

</div><!-- /pg -->

<!-- Toast container -->
<div class="toast-container" id="toastContainer"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
const APP_URL = '<%= APP_URL %>';
const CURRENT_USER_ID = '<%= user && user.id ? user.id : "" %>';

/* ── Theme ─────────────────────────────────────────── */
const saved = localStorage.getItem('theme') || 'light';
document.documentElement.setAttribute('data-theme', saved);

function toggleTheme() {
  const cur = document.documentElement.getAttribute('data-theme');
  const next = cur === 'dark' ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('theme', next);
  document.getElementById('toggleIcon').textContent = next === 'dark' ? '☀️' : '🌙';
  document.getElementById('toggleLabel').textContent = next === 'dark' ? 'Claro' : 'Oscuro';
  document.getElementById('switchKnob').style.transform = next === 'dark' ? 'translateX(22px)' : 'translateX(2px)';
}
if (saved === 'dark') {
  document.getElementById('toggleIcon').textContent = '☀️';
  document.getElementById('toggleLabel').textContent = 'Claro';
  document.getElementById('switchKnob').style.transform = 'translateX(22px)';
}

/* ── Socket.io ──────────────────────────────────────── */
const socket = io({ transports: ['websocket', 'polling'] });
socket.on('connect', () => {
  if (CURRENT_USER_ID) socket.emit('join', CURRENT_USER_ID);
});
socket.on('new-notification', (n) => showToast(n.title, n.body));

/* ── Chart refs ─────────────────────────────────────── */
let trendChart, statusChart, priorityChart, catChart;

function isDark() { return document.documentElement.getAttribute('data-theme') === 'dark'; }
function gridColor() { return isDark() ? 'rgba(255,255,255,.07)' : 'rgba(0,0,0,.06)'; }
function textColor() { return isDark() ? '#94a3b8' : '#64748b'; }

/* ── Load all data ──────────────────────────────────── */
async function loadAll() {
  const btn = document.getElementById('refreshBtn');
  btn.classList.add('spinning');
  try {
    await Promise.all([loadKpis(), loadTrends(), loadAgentLoad(), loadSla()]);
    document.getElementById('lastUpdated').textContent = new Date().toLocaleTimeString('es', { hour: '2-digit', minute: '2-digit' });
  } finally {
    btn.classList.remove('spinning');
  }
}

/* ── KPIs ───────────────────────────────────────────── */
async function loadKpis() {
  try {
    const [tRaw, sRaw] = await Promise.all([
      fetch(APP_URL + '/api/reports-itsm/trends').then(r => r.json()),
      fetch(APP_URL + '/api/reports-itsm/sla-compliance').then(r => r.json())
    ]);

    const tRes = tRaw.data || tRaw;
    const sRes = sRaw.data || sRaw;

    // totals from byStatus
    let total = 0, open = 0, risk = 0, breach = 0, today = 0;
    const byStatus = tRes.byStatus || [];
    byStatus.forEach(s => {
      total += s.count || 0;
      if (['abierto', 'en_progreso', 'pendiente'].includes(s.status)) open += s.count || 0;
    });

    const daily = tRes.daily || tRes.trends || [];
    const todayStr = new Date().toISOString().slice(0, 10);
    const todayRow = daily.find(r => r.day && r.day.slice(0,10) === todayStr);
    today = todayRow ? todayRow.count : 0;

    // SLA pct from compliance
    let slaOk = 0, slaTotal = 0;
    const byPrio = sRes.byPriority || [];
    byPrio.forEach(p => {
      slaTotal += p.total || 0;
      slaOk += p.within_sla || 0;
      risk += p.riesgo || 0;
      breach += p.vencido || 0;
    });
    const slaPct = slaTotal > 0 ? Math.round(slaOk / slaTotal * 100) : 0;

    document.getElementById('k-total').textContent = total || '—';
    document.getElementById('k-open').textContent = open || '—';
    document.getElementById('k-risk').textContent = risk || '—';
    document.getElementById('k-breach').textContent = breach || '—';
    document.getElementById('k-today').textContent = today !== undefined ? today : '—';
    document.getElementById('k-sla-pct').textContent = slaTotal ? slaPct + '%' : '—';

    renderStatusChart(byStatus);
    renderPriorityChart(tRes.byPriority || []);
    renderCatChart(tRes.byCat || tRes.byCategory || []);
    renderTrendChart(daily);
    renderRecentTickets([]);
    renderSlaPriorityBars(byPrio);
    renderSlaAgentBars(sRes.byAgent || []);
  } catch (e) { console.error(e); }
}

async function loadTrends() {} // merged into loadKpis
async function loadSla() {}    // merged into loadKpis

/* ── Agent load ─────────────────────────────────────── */
async function loadAgentLoad() {
  try {
    const raw = await fetch(APP_URL + '/api/reports-itsm/agent-load').then(r => r.json());
    const data = raw.data || raw;
    const agents = Array.isArray(data) ? data : (data.agents || data.rows || []);
    const container = document.getElementById('agentLoadList');
    if (!agents.length) { container.innerHTML = '<p class="text-muted text-center py-3" style="font-size:13px">Sin datos</p>'; return; }
    const colors = ['#3b82f6','#10b981','#8b5cf6','#f59e0b','#ef4444','#06b6d4','#f97316','#ec4899'];
    container.innerHTML = agents.slice(0,10).map((a, i) => {
      const initials = (a.agentName || a.nombre || 'A').split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
      const total = a.totalOpen || a.abiertos || 0;
      const riskCount = a.riesgo || 0;
      const breachCount = a.vencido || 0;
      return `<div class="agent-row">
        <div class="agent-avatar" style="background:${colors[i % colors.length]}">${initials}</div>
        <div>
          <div class="agent-name">${a.agentName || a.nombre || '—'}</div>
          <div class="agent-meta">${total} ticket${total !== 1 ? 's' : ''} abierto${total !== 1 ? 's' : ''}</div>
        </div>
        <div class="agent-stats">
          ${riskCount > 0 ? `<div class="stat-chip warn" title="En riesgo SLA">${riskCount}⚠</div>` : ''}
          ${breachCount > 0 ? `<div class="stat-chip danger" title="SLA vencido">${breachCount}🔴</div>` : ''}
          <div class="stat-chip">${total}</div>
        </div>
      </div>`;
    }).join('');
  } catch(e) { console.error(e); }
}

/* ── Render helpers ─────────────────────────────────── */
function renderTrendChart(trends) {
  const labels = trends.map(r => {
    const d = new Date(r.day || r.fecha || r.date);
    return d.toLocaleDateString('es', { month: 'short', day: 'numeric' });
  });
  const vals = trends.map(r => r.count || r.total || 0);
  if (trendChart) trendChart.destroy();
  trendChart = new Chart(document.getElementById('trendChart'), {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'Tickets',
        data: vals,
        borderColor: '#3b82f6',
        backgroundColor: 'rgba(59,130,246,.12)',
        fill: true,
        tension: 0.4,
        pointRadius: 3,
        pointHoverRadius: 6
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { color: gridColor() }, ticks: { color: textColor(), maxTicksLimit: 10 } },
        y: { grid: { color: gridColor() }, ticks: { color: textColor() }, beginAtZero: true }
      }
    }
  });
}

function renderStatusChart(data) {
  const labels = data.map(d => d.status || d.estado || '?');
  const vals = data.map(d => d.count || 0);
  const colors = ['#3b82f6','#f59e0b','#10b981','#8b5cf6','#ef4444','#06b6d4','#f97316'];
  if (statusChart) statusChart.destroy();
  statusChart = new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: { labels, datasets: [{ data: vals, backgroundColor: colors, borderWidth: 2, borderColor: 'var(--card)' }] },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: {
        legend: { position: 'bottom', labels: { color: textColor(), padding: 12, font: { size: 11 } } }
      }
    }
  });
}

function renderPriorityChart(data) {
  const labels = data.map(d => d.priority || d.prioridad || '?');
  const vals = data.map(d => d.count || 0);
  const bg = labels.map(l => l === 'critica' ? '#ef4444' : l === 'alta' ? '#f97316' : l === 'media' ? '#f59e0b' : '#10b981');
  if (priorityChart) priorityChart.destroy();
  priorityChart = new Chart(document.getElementById('priorityChart'), {
    type: 'bar',
    data: { labels, datasets: [{ label: 'Tickets', data: vals, backgroundColor: bg, borderRadius: 6 }] },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { color: textColor() } },
        y: { grid: { color: gridColor() }, ticks: { color: textColor() }, beginAtZero: true }
      }
    }
  });
}

function renderCatChart(data) {
  const sorted = [...data].sort((a,b) => (b.count||0)-(a.count||0)).slice(0,8);
  const labels = sorted.map(d => d.category || d.categoria || '?');
  const vals = sorted.map(d => d.count || 0);
  if (catChart) catChart.destroy();
  catChart = new Chart(document.getElementById('catChart'), {
    type: 'bar',
    data: { labels, datasets: [{ label: 'Tickets', data: vals, backgroundColor: '#8b5cf6', borderRadius: 6 }] },
    options: {
      indexAxis: 'y',
      responsive: true, maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { color: gridColor() }, ticks: { color: textColor() }, beginAtZero: true },
        y: { grid: { display: false }, ticks: { color: textColor(), font: { size: 11 } } }
      }
    }
  });
}

function renderSlaPriorityBars(data) {
  const el = document.getElementById('slaPriorityBars');
  if (!data.length) { el.innerHTML = '<p class="text-muted" style="font-size:13px">Sin datos SLA</p>'; return; }
  el.innerHTML = data.map(r => {
    const pct = r.total > 0 ? Math.round((r.within_sla || 0) / r.total * 100) : 0;
    const color = pct >= 90 ? '#10b981' : pct >= 70 ? '#f59e0b' : '#ef4444';
    const label = r.priority || r.prioridad || '?';
    return `<div class="progress-row">
      <span class="progress-label">${label}</span>
      <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${pct}%;background:${color}"></div></div>
      <span class="progress-val">${pct}%</span>
    </div><div style="font-size:10px;color:var(--muted);margin:-4px 0 10px 130px">${r.within_sla||0}/${r.total||0} dentro del SLA</div>`;
  }).join('');
}

function renderSlaAgentBars(data) {
  const el = document.getElementById('slaAgentBars');
  const agents = data.slice(0, 10);
  if (!agents.length) { el.innerHTML = '<p class="text-muted" style="font-size:13px">Sin datos</p>'; return; }
  el.innerHTML = agents.map(r => {
    const pct = r.total > 0 ? Math.round((r.within_sla || 0) / r.total * 100) : 0;
    const color = pct >= 90 ? '#10b981' : pct >= 70 ? '#f59e0b' : '#ef4444';
    const name = r.agentName || r.nombre || '—';
    return `<div class="progress-row">
      <span class="progress-label" title="${name}">${name}</span>
      <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${pct}%;background:${color}"></div></div>
      <span class="progress-val">${pct}%</span>
    </div>`;
  }).join('');
}

function renderRecentTickets(tickets) {
  const tbody = document.getElementById('recentTicketsTbody');
  if (!tickets.length) {
    tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">Sin tickets recientes</td></tr>';
    return;
  }
  const priorityBadge = p => {
    const m = { critica: 'bp-red', alta: 'bp-yellow', media: 'bp-blue', baja: 'bp-gray' };
    return `<span class="badge-pill ${m[p]||'bp-gray'}">${p||'—'}</span>`;
  };
  const statusBadge = s => {
    const m = { abierto: 'bp-blue', en_progreso: 'bp-purple', pendiente: 'bp-yellow', resuelto: 'bp-green', cerrado: 'bp-gray' };
    return `<span class="badge-pill ${m[s]||'bp-gray'}">${(s||'—').replace('_',' ')}</span>`;
  };
  const slaBadge = s => {
    if (!s || s === 'normal') return '';
    const m = { riesgo: 'bp-yellow', vencido: 'bp-red' };
    return `<span class="badge-pill ${m[s]||'bp-gray'}">${s}</span>`;
  };
  tbody.innerHTML = tickets.slice(0, 20).map(t => {
    const created = t.createdAt ? new Date(t.createdAt).toLocaleDateString('es', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';
    return `<tr>
      <td><span style="font-family:'JetBrains Mono';font-size:11px;color:var(--muted)">#${t.id||'?'}</span></td>
      <td style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${t.title||t.titulo||'—'}</td>
      <td>${priorityBadge(t.priority||t.prioridad)}</td>
      <td>${statusBadge(t.status||t.estado)}</td>
      <td style="font-size:12px">${t.assignedTo||t.agentName||'—'}</td>
      <td style="font-size:12px;color:var(--muted)">${t.category||t.categoria||'—'}</td>
      <td>${slaBadge(t.slaStatus||t.sla_status)}</td>
      <td style="font-size:11px;color:var(--muted);white-space:nowrap">${created}</td>
    </tr>`;
  }).join('');
}

/* ── Toast ──────────────────────────────────────────── */
function showToast(title, body) {
  const container = document.getElementById('toastContainer');
  const el = document.createElement('div');
  el.className = 'toast';
  el.innerHTML = `<div class="toast-title">${title}</div><div class="toast-body">${body||''}</div>`;
  container.appendChild(el);
  setTimeout(() => el.remove(), 5000);
}

/* ── Init ───────────────────────────────────────────── */
loadAll();
// auto-refresh every 5 minutes
setInterval(loadAll, 5 * 60 * 1000);
</script>
</body>
</html>
