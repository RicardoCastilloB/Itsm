        <button class="toggler-btn" id="mainToggleSidebar"><i class="fas fa-bars"></i></button>
        <div class="theme-toggle-wrap ms-auto" id="themeToggle" onclick="toggleTheme()" title="Cambiar tema" role="button">
            <i class="theme-toggle-icon" id="toggleIcon">🌙</i>
            <div class="theme-switch"><div class="theme-switch-knob" id="switchKnob"></div></div>
            <span class="theme-toggle-label" id="toggleLabel">Oscuro</span>
        </div>
