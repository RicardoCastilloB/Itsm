<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title || 'Dashboard RR.HH. & Asignaciones' %></title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<%# CSS global del proyecto — contiene sidebar, dark mode bridge, variables, etc. %>
<link rel="stylesheet" href="/css/style.css">

<%# Anti-flash: aplica el tema guardado antes de pintar %>
<script>
(function(){
  var t = localStorage.getItem('dashboardTheme') || 'light';
  document.documentElement.setAttribute('data-theme', t);
})();
</script>

<style>
/* ══════════════════════════════════════════════════════════════
   VARIABLES LOCALES
══════════════════════════════════════════════════════════════ */
:root, [data-theme="light"] {
  --pg-bg:      var(--bg-primary,  #f0f4f8);
  --card-bg:    var(--bg-card,     #ffffff);
  --hdr-bg:     var(--bg-primary,  #f8fafc);
  --bdr:        var(--border-color,#e2e8f0);
  --txt:        var(--text-primary,#1e293b);
  --mut:        var(--text-secondary,#64748b);
  --inp:        var(--input-bg,    #f8fafc);
  --hov:        var(--dt-row-hover,#f1f5f9);
  --sh:         0 1px 3px rgba(0,0,0,.07);
  --sh-md:      0 4px 16px rgba(0,0,0,.10);
  --clr-ok:     var(--accent-green,  #10b981);
  --clr-red:    var(--accent-red,    #ef4444);
  --clr-blue:   var(--accent-blue,   #3b82f6);
  --clr-warn:   var(--accent-yellow, #f59e0b);
  --clr-info:   #06b6d4;
  --clr-purple: #8b5cf6;
  --st-act-bg:  #dcfce7; --st-act-txt: #16a34a;
  --st-baj-bg:  #fee2e2; --st-baj-txt: #dc2626;
  --baj-row-bg: #fff5f5; --baj-row-txt:#9ca3af;
  --ac-bg:      #ffffff; --ac-hov:     #f8fafc;
  --eq-lap-bg:#dbeafe;  --eq-lap-c:#2563eb;
  --eq-dsk-bg:#d1fae5;  --eq-dsk-c:#059669;
  --eq-mon-bg:#fef3c7;  --eq-mon-c:#d97706;
  --eq-tab-bg:#ede9fe;  --eq-tab-c:#7c3aed;
  --row-rec-bg:#f0fdf4; --row-rec-bdr:#10b981;
  --mark-bg:#fef9c3;    --mark-c:#92400e;
}
[data-theme="dark"] {
  --pg-bg:      #0f172a;
  --card-bg:    #1e293b;
  --hdr-bg:     #162032;
  --bdr:        #2d3f55;
  --txt:        #e2e8f0;
  --mut:        #94a3b8;
  --inp:        #162032;
  --hov:        #243348;
  --sh:         0 1px 3px rgba(0,0,0,.3);
  --sh-md:      0 4px 16px rgba(0,0,0,.4);
  --clr-ok:     #34d399;
  --clr-red:    #f87171;
  --clr-blue:   #60a5fa;
  --clr-warn:   #fbbf24;
  --clr-info:   #22d3ee;
  --clr-purple: #a78bfa;
  --st-act-bg:  #064e3b; --st-act-txt: #6ee7b7;
  --st-baj-bg:  #450a0a; --st-baj-txt: #fca5a5;
  --baj-row-bg: #1f1010; --baj-row-txt:#64748b;
  --ac-bg:      #1e293b; --ac-hov:     #243348;
  --eq-lap-bg:#1e3a5f;  --eq-lap-c:#93c5fd;
  --eq-dsk-bg:#064e3b;  --eq-dsk-c:#6ee7b7;
  --eq-mon-bg:#422006;  --eq-mon-c:#fde68a;
  --eq-tab-bg:#2e1065;  --eq-tab-c:#c4b5fd;
  --row-rec-bg:#0a2a1a; --row-rec-bdr:#34d399;
  --mark-bg:#422006;    --mark-c:#fde68a;
}

/* ── Reset mínimo ─────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; }

/* ══════════════════════════════════════════════════════════════
   LAYOUT — idéntico a almacen.ejs
   .pg = max-width:1700px, padding:24px 20px, margin-top:64px
══════════════════════════════════════════════════════════════ */
.pg {
  max-width: 1700px;
  margin: 0 auto;
  padding: 24px 20px;
  margin-top: 64px;
}

/* ── Page Header — IDÉNTICO a almacen.ejs ─────────────────── */
.page-hdr { display:flex; align-items:center; gap:16px; margin-bottom:28px; }
.page-hdr-icon {
  width:52px; height:52px; border-radius:14px;
  display:flex; align-items:center; justify-content:center;
  font-size:24px; flex-shrink:0; box-shadow:var(--sh-md);
}
.page-hdr h1 { font-size:22px; font-weight:800; margin:0; color:var(--txt); }
.page-hdr p  { margin:3px 0 0; font-size:13px; color:var(--mut); }

/* ── Mini spinner ─────────────────────────────────────────── */
.mini-spin {
  display:inline-block; width:18px; height:18px;
  border:2px solid var(--bdr); border-top-color:var(--clr-blue);
  border-radius:50%; animation:_sp .7s linear infinite; vertical-align:middle;
}
@keyframes _sp { to { transform:rotate(360deg); } }

/* ── Tabs ─────────────────────────────────────────────────── */
.tab-bar {
  display:flex; gap:4px;
  background:var(--card-bg); border:1px solid var(--bdr);
  border-radius:14px; padding:6px; box-shadow:var(--sh); width:fit-content;
}
.tab-btn {
  padding:8px 20px; border-radius:10px; border:none;
  background:transparent; color:var(--mut); font-size:13px; font-weight:700;
  cursor:pointer; transition:all .2s; display:flex; align-items:center; gap:7px;
}
.tab-btn:hover  { color:var(--txt); background:var(--hov); }
.tab-btn.active { background:var(--clr-blue); color:#fff; box-shadow:0 2px 8px rgba(59,130,246,.3); }
.tab-panel      { display:none; flex-direction:column; gap:16px; }
.tab-panel.active { display:flex; }

/* ── KPI grids ────────────────────────────────────────────── */
.kpi-grid-6 {
  display:grid; grid-template-columns:repeat(6,1fr); gap:12px;
}
.kpi-grid-asg {
  display:grid; grid-template-columns:repeat(6,1fr); gap:12px;
}
@media(max-width:1400px) {
  .kpi-grid-6  { grid-template-columns:repeat(3,1fr); }
  .kpi-grid-asg{ grid-template-columns:repeat(3,1fr); }
}
@media(max-width:700px) {
  .kpi-grid-6,.kpi-grid-asg { grid-template-columns:repeat(2,1fr); }
}

.kpi {
  background:var(--card-bg); border:1px solid var(--bdr);
  border-radius:14px; padding:16px 18px; box-shadow:var(--sh);
  position:relative; overflow:hidden; transition:transform .2s,background .3s,border-color .3s;
  cursor:default;
}
.kpi:hover { transform:translateY(-2px); box-shadow:var(--sh-md); }
.kpi.kpi-ok     { border-left:4px solid var(--clr-ok); }
.kpi.kpi-red    { border-left:4px solid var(--clr-red); }
.kpi.kpi-blue   { border-left:4px solid var(--clr-blue); }
.kpi.kpi-warn   { border-left:4px solid var(--clr-warn); }
.kpi.kpi-info   { border-left:4px solid var(--clr-info); }
.kpi.kpi-purple { border-left:4px solid var(--clr-purple); }
.kpi-label { font-size:10px; text-transform:uppercase; letter-spacing:.6px; color:var(--mut); font-weight:700; margin-bottom:8px; }
.kpi-val   { font-size:28px; font-weight:900; line-height:1; letter-spacing:-1px; color:var(--txt); }
.kpi-val.sm{ font-size:15px; font-weight:700; letter-spacing:0; margin-top:4px; }
.kpi-sub   { font-size:10px; color:var(--mut); margin-top:5px; display:flex; align-items:center; gap:3px; }
.kpi-sub .up   { color:var(--clr-ok);  font-weight:700; }
.kpi-sub .down { color:var(--clr-red); font-weight:700; }
.kpi-icon  { font-size:28px; opacity:.12; position:absolute; right:14px; top:50%; transform:translateY(-50%); }
.c-ok     { color:var(--clr-ok); }
.c-red    { color:var(--clr-red); }
.c-blue   { color:var(--clr-blue); }
.c-warn   { color:var(--clr-warn); }
.c-info   { color:var(--clr-info); }
.c-purple { color:var(--clr-purple); }

/* ── Cards ────────────────────────────────────────────────── */
.card {
  background:var(--card-bg); border:1px solid var(--bdr);
  border-radius:14px; overflow:hidden; box-shadow:var(--sh);
  transition:background .3s,border-color .3s;
}
.card-head {
  padding:13px 18px; background:var(--hdr-bg); border-bottom:1px solid var(--bdr);
  display:flex; align-items:center; justify-content:space-between;
  font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.4px; color:var(--mut);
  transition:background .3s,border-color .3s;
}
.card-head .hl { display:flex; align-items:center; gap:7px; }
.card-body { padding:16px; }
.card-body canvas { max-height:225px; }

/* ── Chart rows ───────────────────────────────────────────── */
.charts-row-3 { display:grid; grid-template-columns:1.4fr 1fr 0.9fr; gap:14px; }
.charts-row-2 { display:grid; grid-template-columns:1.7fr 1fr; gap:14px; }
@media(max-width:1400px) { .charts-row-3 { grid-template-columns:1fr 1fr; } }
@media(max-width:1100px) { .charts-row-3,.charts-row-2 { grid-template-columns:1fr; } }

/* ── Donut ────────────────────────────────────────────────── */
.donut-wrap {
  display:flex; align-items:center; gap:20px; flex-wrap:wrap;
  justify-content:center; padding:20px;
}
.donut-canvas { width:160px; height:160px; flex-shrink:0; }
.legend-list  { flex:1; min-width:120px; }
.legend-row   {
  display:flex; align-items:center; gap:8px;
  padding:7px 0; border-bottom:1px solid var(--bdr);
  font-size:12px; transition:border-color .3s;
}
.legend-row:last-child { border-bottom:none; }
.legend-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.legend-lbl { flex:1; color:var(--mut); }
.legend-num { font-weight:700; font-size:14px; color:var(--txt); }
.legend-pct { font-size:10px; color:var(--mut); margin-left:3px; }

/* ── Top list ─────────────────────────────────────────────── */
.top-list { padding:0; margin:0; list-style:none; }
.top-list-item {
  display:flex; align-items:center; gap:10px;
  padding:9px 16px; border-bottom:1px solid var(--bdr);
  font-size:12px; transition:background .1s;
}
.top-list-item:last-child { border-bottom:none; }
.top-list-item:hover { background:var(--hov); }
.rank-badge {
  width:22px; height:22px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:10px; font-weight:800; flex-shrink:0;
  background:var(--bdr); color:var(--mut);
}
.rank-1 { background:#ffd700; color:#000; }
.rank-2 { background:#c0c0c0; color:#000; }
.rank-3 { background:#cd7f32; color:#fff; }
.top-name      { flex:1; font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.top-bar-wrap  { width:70px; background:var(--bdr); border-radius:4px; height:5px; }
.top-bar       { height:5px; border-radius:4px; background:var(--clr-blue); }
.top-count     { font-weight:700; font-size:12px; color:var(--txt); min-width:24px; text-align:right; }

/* ── Buscador autocomplete ────────────────────────────────── */
.search-box {
  padding:14px 18px; border-bottom:1px solid var(--bdr);
  background:var(--card-bg); transition:background .3s,border-color .3s;
}
.search-inner { position:relative; }
.search-field {
  width:100%; padding:11px 44px 11px 40px;
  border:1.5px solid var(--bdr); border-radius:12px;
  font-size:14px; outline:none;
  background:var(--inp); color:var(--txt); transition:all .2s;
}
.search-field::placeholder { color:var(--mut); }
.search-field:focus { border-color:var(--clr-blue); box-shadow:0 0 0 3px rgba(59,130,246,.10); }
.search-ico { position:absolute; left:13px; top:50%; transform:translateY(-50%); color:var(--mut); font-size:15px; pointer-events:none; }
.search-x   {
  position:absolute; right:10px; top:50%; transform:translateY(-50%);
  background:none; border:none; color:var(--mut); cursor:pointer;
  padding:4px 6px; border-radius:6px; font-size:13px; display:none; transition:all .15s;
}
.search-x:hover  { color:var(--txt); background:var(--hov); }
.search-x.show   { display:block; }
.search-hint     { margin-top:7px; font-size:12px; color:var(--mut); }
.search-hint a   { color:var(--clr-blue); font-weight:600; }

/* Dropdown autocomplete */
.ac-drop {
  position:absolute; top:calc(100% + 6px); left:0; right:0;
  background:var(--ac-bg); border:1px solid var(--bdr);
  border-radius:12px; box-shadow:var(--sh-md); z-index:1060;
  max-height:320px; overflow-y:auto; display:none;
}
.ac-drop.open { display:block; animation:acIn .14s ease; }
@keyframes acIn { from{opacity:0;transform:translateY(-5px)} to{opacity:1;transform:translateY(0)} }
.ac-header {
  padding:7px 13px; font-size:10px; color:var(--mut); font-weight:700;
  background:var(--hdr-bg); border-bottom:1px solid var(--bdr);
}
.ac-row {
  padding:10px 13px; cursor:pointer; border-bottom:1px solid var(--bdr);
  display:flex; align-items:center; gap:10px; transition:background .1s;
}
.ac-row:last-child { border-bottom:none; }
.ac-row:hover { background:var(--ac-hov); }
.ac-avatar {
  width:34px; height:34px; border-radius:50%; color:#fff;
  display:flex; align-items:center; justify-content:center;
  font-weight:700; font-size:11px; flex-shrink:0;
}
.ac-info   { flex:1; min-width:0; }
.ac-name   { font-weight:600; font-size:13px; color:var(--txt); }
.ac-meta   { font-size:11px; color:var(--mut); margin-top:1px; }
.ac-pill   { font-size:10px; font-weight:600; padding:2px 8px; border-radius:20px; flex-shrink:0; }
.ac-pill.on  { background:var(--st-act-bg); color:var(--st-act-txt); }
.ac-pill.off { background:var(--st-baj-bg); color:var(--st-baj-txt); }
.ac-footer {
  padding:9px 13px; font-size:12px; color:var(--clr-blue);
  border-top:1px solid var(--bdr); cursor:pointer; font-weight:700;
  display:flex; align-items:center; gap:6px;
  background:var(--hdr-bg); transition:background .1s;
}
.ac-footer:hover { background:var(--hov); }
.ac-empty { padding:22px; text-align:center; color:var(--mut); font-size:13px; }
mark.hl   { background:var(--mark-bg); color:var(--mark-c); border-radius:2px; padding:0 2px; font-weight:700; }

/* ── Filter pills ─────────────────────────────────────────── */
.pills-bar {
  padding:10px 18px; border-bottom:1px solid var(--bdr); background:var(--card-bg);
  display:flex; align-items:center; gap:8px; flex-wrap:wrap;
  transition:background .3s,border-color .3s;
}
.pills-label { font-size:10px; color:var(--mut); font-weight:700; text-transform:uppercase; letter-spacing:.4px; }
.fpill {
  padding:4px 13px; border-radius:20px; font-size:11px; font-weight:600; cursor:pointer;
  border:1.5px solid var(--bdr); background:var(--inp); color:var(--mut);
  transition:all .15s; display:flex; align-items:center; gap:5px; line-height:1.7;
}
.fpill:hover             { border-color:var(--clr-blue); color:var(--clr-blue); }
.fpill.f-all.on          { background:var(--clr-blue);   color:#fff; border-color:var(--clr-blue); }
.fpill.f-active.on       { background:var(--clr-ok);     color:#fff; border-color:var(--clr-ok); }
.fpill.f-baja.on         { background:var(--clr-red);    color:#fff; border-color:var(--clr-red); }
.fpill.fp-all.active     { background:var(--clr-blue);   color:#fff; border-color:var(--clr-blue); }
.fpill.fp-month.active   { background:var(--clr-info);   color:#fff; border-color:var(--clr-info); }
.fpill.fp-multi.active   { background:var(--clr-warn);   color:#000; border-color:var(--clr-warn); }

/* ── Tabla ────────────────────────────────────────────────── */
.tbl-scroll { overflow:auto; max-height:560px; }
.tbl { width:100%; border-collapse:collapse; font-size:12.5px; }
.tbl thead th {
  font-size:10px; text-transform:uppercase; color:var(--mut); font-weight:700;
  padding:10px 14px; background:var(--hdr-bg); border-bottom:1px solid var(--bdr);
  white-space:nowrap; position:sticky; top:0; z-index:10;
  text-align:center; transition:background .3s,border-color .3s;
}
.tbl thead th.left { text-align:left; }
.tbl tbody td {
  padding:11px 14px; border-bottom:1px solid var(--bdr); color:var(--txt);
  vertical-align:middle; text-align:center; transition:background .1s,border-color .3s;
}
.tbl tbody td.left { text-align:left; }
.tbl tbody tr:hover td { background:var(--hov); }
.tbl tbody tr:last-child td { border-bottom:none; }
.tbl tbody tr.row-recent td { background:var(--row-rec-bg); }
.tbl tbody tr.row-recent td:first-child { border-left:3px solid var(--row-rec-bdr); }
.emp-baja td {
  background:var(--baj-row-bg) !important; color:var(--baj-row-txt) !important;
  text-decoration:line-through; text-decoration-color:var(--clr-red);
}
.emp-baja td .emp-actions,
.emp-baja td .emp-actions * { text-decoration:none !important; color:inherit !important; }
.badge-baja {
  font-size:9px; font-weight:700; padding:2px 6px; border-radius:4px;
  background:var(--clr-red); color:#fff; letter-spacing:.4px; vertical-align:middle;
  margin-left:5px; text-decoration:none !important;
}

/* ── Status / Badges ──────────────────────────────────────── */
.status-pill {
  font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px;
  display:inline-flex; align-items:center; gap:4px;
}
.status-pill.activo { background:var(--st-act-bg); color:var(--st-act-txt); }
.status-pill.baja   { background:var(--st-baj-bg); color:var(--st-baj-txt); }
.count-badge { background:var(--inp); color:var(--mut); font-size:11px; font-weight:700; padding:2px 9px; border-radius:20px; border:1px solid var(--bdr); }
.badge-count { background:var(--clr-info); color:#fff; border-radius:20px; padding:2px 9px; font-size:11px; font-weight:700; }
.pill { display:inline-block; padding:2px 9px; border-radius:20px; font-size:11px; font-weight:600; white-space:nowrap; line-height:1.6; }
.p-blue   { background:rgba(59,130,246,.13);  color:var(--clr-blue); }
.p-green  { background:rgba(16,185,129,.13);  color:var(--clr-ok); }
.p-yellow { background:rgba(245,158,11,.13);  color:var(--clr-warn); }
.p-red    { background:rgba(239,68,68,.13);   color:var(--clr-red); }
.p-gray   { background:rgba(100,116,139,.10); color:var(--mut); }
.p-purple { background:rgba(139,92,246,.13);  color:var(--clr-purple); }
[data-theme="dark"] .p-purple { background:rgba(167,139,250,.2); }
.eq-icon  { width:26px; height:26px; border-radius:6px; display:inline-flex; align-items:center; justify-content:center; font-size:13px; margin-right:5px; flex-shrink:0; vertical-align:middle; }
.eq-laptop  { background:var(--eq-lap-bg); color:var(--eq-lap-c); }
.eq-desktop { background:var(--eq-dsk-bg); color:var(--eq-dsk-c); }
.eq-monitor { background:var(--eq-mon-bg); color:var(--eq-mon-c); }
.eq-tablet  { background:var(--eq-tab-bg); color:var(--eq-tab-c); }
.eq-other   { background:var(--bdr); color:var(--mut); }

/* ── Botones ──────────────────────────────────────────────── */
.btn-toggle { border:none; border-radius:8px; font-size:11px; font-weight:600; padding:5px 11px; cursor:pointer; transition:all .18s; white-space:nowrap; }
.btn-toggle.is-active   { background:var(--st-baj-bg); color:var(--st-baj-txt); border:1px solid var(--st-baj-txt); }
.btn-toggle.is-inactive { background:var(--st-act-bg); color:var(--st-act-txt); border:1px solid var(--st-act-txt); }
.btn-toggle:hover { opacity:.85; }
.btn-spin { display:inline-block; width:10px; height:10px; border:2px solid rgba(0,0,0,.12); border-top-color:currentColor; border-radius:50%; animation:_sp .6s linear infinite; vertical-align:middle; }
.btn-ghost { background:transparent; border:1px solid var(--bdr); color:var(--mut); border-radius:9px; padding:6px 12px; font-size:12px; cursor:pointer; display:inline-flex; align-items:center; gap:5px; transition:all .15s; }
.btn-ghost:hover { border-color:var(--clr-blue); color:var(--clr-blue); }
.btn-primary-sm { background:var(--clr-blue); color:#fff; border:none; border-radius:9px; padding:7px 14px; font-size:12.5px; font-weight:700; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:all .2s; white-space:nowrap; }
.btn-primary-sm:hover { filter:brightness(1.1); transform:translateY(-1px); }
.btn-success-sm { background:var(--clr-ok); color:#fff; border:none; border-radius:9px; padding:7px 14px; font-size:12.5px; font-weight:700; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:all .2s; white-space:nowrap; }
.btn-success-sm:hover { filter:brightness(1.1); }
.btn-alta { background:linear-gradient(135deg,var(--clr-ok),#059669); color:#fff; border:none; border-radius:9px; padding:7px 16px; font-size:12.5px; font-weight:700; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:all .2s; white-space:nowrap; box-shadow:0 2px 8px rgba(16,185,129,.25); }
.btn-alta:hover { filter:brightness(1.07); transform:translateY(-1px); box-shadow:0 4px 14px rgba(16,185,129,.35); }

/* ── Panel header ─────────────────────────────────────────── */
.panel-head { padding:13px 18px; background:var(--hdr-bg); border-bottom:1px solid var(--bdr); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; transition:background .3s,border-color .3s; }
.panel-title { font-size:13px; font-weight:800; color:var(--txt); display:flex; align-items:center; gap:8px; }
.toolbar { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
.search-input-sm { background:var(--inp); border:1px solid var(--bdr); color:var(--txt); border-radius:9px; padding:7px 12px 7px 32px; font-size:12.5px; width:280px; outline:none; transition:background .3s,border-color .2s,color .3s; }
.search-input-sm:focus { border-color:var(--clr-blue); box-shadow:0 0 0 3px rgba(59,130,246,.12); }
.search-input-sm::placeholder { color:var(--mut); }
.search-wrap { position:relative; }
.search-wrap i.ico { position:absolute; left:10px; top:50%; transform:translateY(-50%); color:var(--mut); font-size:13px; pointer-events:none; }

/* ── Paginación ───────────────────────────────────────────── */
.pag-wrap { padding:11px 18px; border-top:1px solid var(--bdr); background:var(--hdr-bg); transition:background .3s,border-color .3s; }
.tbl-foot { padding:10px 18px; border-top:1px solid var(--bdr); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px; background:var(--hdr-bg); }
.tbl-info { font-size:11.5px; color:var(--mut); }
.pagination-btns { display:flex; gap:4px; }
.pg-btn { background:var(--card-bg); border:1px solid var(--bdr); color:var(--txt); border-radius:7px; padding:4px 10px; font-size:12px; cursor:pointer; transition:.15s; }
.pg-btn:hover,.pg-btn.active { background:var(--clr-blue); color:#fff; border-color:var(--clr-blue); }
.pg-btn:disabled { opacity:.4; cursor:not-allowed; }

/* ── Autocomplete modales ─────────────────────────────────── */
.autocomplete-results { display:none; max-height:200px; overflow-y:auto; border:1px solid var(--bdr); border-radius:9px; margin-top:4px; box-shadow:var(--sh-md); background:var(--card-bg); z-index:9999; position:relative; }
.autocomplete-item { padding:10px 13px; cursor:pointer; border-bottom:1px solid var(--bdr); transition:background .12s; font-size:13px; color:var(--txt); }
.autocomplete-item:hover { background:var(--hov); }
.autocomplete-item:last-child { border-bottom:none; }

/* ── Modal ────────────────────────────────────────────────── */
.modal-content { border-radius:16px; border:none; background:var(--card-bg); box-shadow:0 24px 64px rgba(0,0,0,.25); }
.modal-header  { border-bottom:1px solid var(--bdr); padding:18px 24px; background:var(--hdr-bg); display:flex; align-items:center; justify-content:space-between; }
.modal-body    { padding:24px; background:var(--card-bg); }
.modal-footer  { border-top:1px solid var(--bdr); padding:14px 24px; background:var(--card-bg); border-radius:0 0 16px 16px; display:flex; gap:8px; justify-content:flex-end; }
.modal-add-emp .modal-header { background:linear-gradient(135deg,#10b981,#059669); border-radius:16px 16px 0 0; padding:20px 24px; border:none; }
.modal-add-emp .modal-header .modal-title { color:#fff; font-weight:700; font-size:16px; }
.modal-add-emp .modal-header .btn-close    { filter:invert(1) brightness(2); opacity:.9; }
[data-theme="dark"] .modal-add-emp .modal-header { background:linear-gradient(135deg,#065f46,#047857); }
.form-label-sm { font-weight:700; font-size:11px; color:var(--mut); text-transform:uppercase; letter-spacing:.5px; margin-bottom:5px; display:block; }
.form-label-sm .req { color:var(--clr-red); }
.field-input { padding:10px 14px; border:1.5px solid var(--bdr); border-radius:10px; font-size:13px; background:var(--inp); color:var(--txt); outline:none; width:100%; transition:all .2s; }
.field-input:focus   { border-color:var(--clr-blue); box-shadow:0 0 0 3px rgba(59,130,246,.10); }
.field-input.invalid { border-color:var(--clr-red); }
.field-input::placeholder { color:var(--mut); opacity:.6; }
.field-input[readonly]    { opacity:.7; cursor:not-allowed; }
.section-div { display:flex; align-items:center; gap:10px; margin:16px 0 12px; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.6px; color:var(--mut); }
.section-div::before,.section-div::after { content:''; flex:1; height:1px; background:var(--bdr); }
.switch-wrap { display:flex; align-items:center; gap:10px; padding:10px 14px; border:1.5px solid var(--bdr); border-radius:10px; cursor:pointer; transition:border-color .2s; }
.switch-wrap:hover { border-color:var(--clr-blue); }
.switch-wrap input { display:none; }
.switch-track { width:38px; height:20px; border-radius:20px; background:var(--bdr); position:relative; transition:background .2s; flex-shrink:0; }
.switch-track::after { content:''; position:absolute; top:3px; left:3px; width:14px; height:14px; border-radius:50%; background:#fff; transition:transform .2s; box-shadow:0 1px 3px rgba(0,0,0,.2); }
.switch-wrap input:checked + .switch-track { background:var(--clr-ok); }
.switch-wrap input:checked + .switch-track::after { transform:translateX(18px); }
.switch-label { font-size:13px; color:var(--txt); font-weight:500; user-select:none; }
.add-emp-alert { padding:10px 14px; border-radius:10px; font-size:13px; margin-bottom:14px; display:flex; align-items:center; gap:8px; }
.add-emp-alert.error { background:var(--st-baj-bg); color:var(--st-baj-txt); }
.field-group { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.field-wrap  { display:flex; flex-direction:column; gap:5px; }
.field-wrap.full { grid-column:1/-1; }
@media(max-width:576px) { .field-group { grid-template-columns:1fr; } }
.btn-modal { border:none; border-radius:9px; padding:9px 20px; font-size:13px; font-weight:700; cursor:pointer; display:inline-flex; align-items:center; gap:7px; transition:all .2s; }
.btn-modal.primary { background:var(--clr-blue); color:#fff; }
.btn-modal.success { background:var(--clr-ok);   color:#fff; }
.btn-modal.cancel  { background:transparent; border:1px solid var(--bdr); color:var(--mut); }
.btn-modal.cancel:hover { border-color:var(--txt); color:var(--txt); }

/* ── Toast ────────────────────────────────────────────────── */
#toastWrap { position:fixed; bottom:24px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:8px; }
.toast-item { background:var(--card-bg); border:1px solid var(--bdr); color:var(--txt); border-radius:12px; padding:12px 18px; font-size:13px; font-weight:500; box-shadow:var(--sh-md); display:flex; align-items:center; gap:10px; min-width:250px; animation:tIn .2s ease; }
.toast-item.success,.toast-item.ok  { border-left:4px solid var(--clr-ok); }
.toast-item.error,.toast-item.err   { border-left:4px solid var(--clr-red); }
.toast-item.info,.toast-item.inf    { border-left:4px solid var(--clr-info); }
@keyframes tIn { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:translateX(0)} }

/* ── Misc ─────────────────────────────────────────────────── */
.empty-state { text-align:center; padding:48px 20px; color:var(--mut); }
.empty-state i { font-size:32px; display:block; margin-bottom:10px; opacity:.3; }
.empty-state p { font-size:13px; }
.spin-anim { animation:_sp .7s linear infinite; }
.d-none    { display:none !important; }
@keyframes rowPulse { 0%{outline:none} 15%{outline:2.5px solid var(--clr-blue);outline-offset:2px} 85%{outline:2.5px solid var(--clr-blue);outline-offset:2px} 100%{outline:none} }
.row-hl { animation:rowPulse 2.2s ease; }
*::-webkit-scrollbar { width:5px; height:5px; }
*::-webkit-scrollbar-thumb { background:var(--bdr); border-radius:3px; }
*::-webkit-scrollbar-track { background:transparent; }
</style>
</head>
<body>

