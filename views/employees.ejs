<style>
.theme-toggle-wrap{display:flex;align-items:center;gap:7px;cursor:pointer;user-select:none;padding:4px 10px 4px 8px;border-radius:20px;transition:background .2s;}
.theme-toggle-wrap:hover{background:rgba(0,0,0,.06);}
[data-theme="dark"] .theme-toggle-wrap:hover{background:rgba(255,255,255,.08);}
.theme-toggle-icon{font-size:14px;line-height:1;transition:transform .4s cubic-bezier(.4,0,.2,1);display:flex;align-items:center;}
.theme-toggle-wrap:hover .theme-toggle-icon{transform:rotate(20deg);}
.theme-switch{width:34px;height:18px;background:#cbd5e1;border-radius:9px;position:relative;transition:background .3s ease;flex-shrink:0;}
[data-theme="dark"] .theme-switch{background:#3b82f6;}
.theme-switch-knob{width:13px;height:13px;background:#ffffff;border-radius:50%;position:absolute;top:2.5px;left:3px;box-shadow:0 1px 3px rgba(0,0,0,.25);transition:transform .3s cubic-bezier(.4,0,.2,1);}
[data-theme="dark"] .theme-switch-knob{transform:translateX(16px);}
.theme-toggle-label{font-size:12px;font-weight:600;color:#64748b;letter-spacing:.2px;transition:color .3s;white-space:nowrap;}
[data-theme="dark"] .theme-toggle-label{color:#94a3b8;}
</style>

<script>
(function(){ var t=localStorage.getItem('dashboardTheme')||'light'; document.documentElement.setAttribute('data-theme',t); })();
function toggleTheme(){
    var html=document.documentElement, cur=html.getAttribute('data-theme'), next=cur==='dark'?'light':'dark';
    html.setAttribute('data-theme',next); localStorage.setItem('dashboardTheme',next); _syncToggleUI(next);
    if(typeof updateChartsTheme==='function') updateChartsTheme(next);
}
function _syncToggleUI(theme){
    var icon=document.getElementById('toggleIcon'), label=document.getElementById('toggleLabel');
    if(!icon||!label) return;
    icon.textContent=theme==='dark'?'☀️':'🌙';
    label.textContent=theme==='dark'?'Claro':'Oscuro';
}
document.addEventListener('DOMContentLoaded',function(){ _syncToggleUI(localStorage.getItem('dashboardTheme')||'light'); });
</script>

