/* ════════════════════════════════════════════════════════════════
   TOGGLE BAJA / REACTIVAR
════════════════════════════════════════════════════════════════ */
let _pid=null,_pActive=null;
const cfmModal=new bootstrap.Modal(document.getElementById('confirmModal'));
function promptToggle(id,name,isActive){ _pid=id; _pActive=isActive; document.getElementById('confirmIcon').textContent=isActive?'⚠️':'✅'; document.getElementById('confirmTitle').textContent=isActive?'Dar de baja':'Reactivar empleado'; document.getElementById('confirmMsg').textContent=isActive?`¿Dar de baja a ${name}?`:`¿Reactivar a ${name}?`; const ok=document.getElementById('confirmOkBtn'); ok.textContent=isActive?'Sí, dar de baja':'Sí, reactivar'; ok.className=`btn btn-sm px-4 fw-bold ${isActive?'btn-danger':'btn-success'}`; cfmModal.show(); }
async function executeToggle(){
  cfmModal.hide();
  const id=_pid,wasActive=_pActive,newStatus=!wasActive;
  const btn=document.getElementById(`toggleBtn-${id}`),orig=btn.innerHTML;
  btn.innerHTML='<span class="btn-spin"></span>'; btn.disabled=true;
  try{
    const res=await fetch(`/api/employees/${id}`,{method:'PUT',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({is_active:newStatus})});
    const json=await res.json();
    if(!res.ok||!json.success) throw new Error(json.error||json.message||'Error del servidor');
    const row=document.getElementById(`row-${id}`);
    row.dataset.status=newStatus?'activo':'baja';
    if(newStatus){ row.classList.remove('emp-baja'); row.querySelector('.badge-baja')?.remove(); document.getElementById(`pill-${id}`).outerHTML=`<span class="status-pill activo" id="pill-${id}"><i class="fas fa-circle" style="font-size:6px;"></i> Activo</span>`; btn.className='btn-toggle is-active'; btn.innerHTML='<i class="fas fa-user-slash"></i> Dar de baja'; btn.setAttribute('onclick',`promptToggle(${id},'${json.data?.full_name||''}',true)`); showToast('Empleado reactivado','success'); }
    else{ row.classList.add('emp-baja'); const nc=row.querySelectorAll('td')[1]; if(!nc.querySelector('.badge-baja')){const b=document.createElement('span');b.className='badge-baja';b.textContent='BAJA';nc.appendChild(b);} document.getElementById(`pill-${id}`).outerHTML=`<span class="status-pill baja" id="pill-${id}"><i class="fas fa-circle" style="font-size:6px;"></i> De baja</span>`; btn.className='btn-toggle is-inactive'; btn.innerHTML='<i class="fas fa-user-check"></i> Reactivar'; btn.setAttribute('onclick',`promptToggle(${id},'${json.data?.full_name||''}',false)`); showToast('Empleado dado de baja','info'); }
    await loadAllEmployeesData();
  }catch(e){ showToast('Error: '+e.message,'error'); btn.innerHTML=orig; }
  finally{ btn.disabled=false; _pid=null; _pActive=null; }
}

