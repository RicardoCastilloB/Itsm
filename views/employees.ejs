<script>
/* ════════════════════════════════════════════════════════════════
   UTILITIES
════════════════════════════════════════════════════════════════ */
function isDark(){ return document.documentElement.getAttribute('data-theme')==='dark'; }
function getCC(){
  return {
    grid:   isDark()?'rgba(255,255,255,.04)':'rgba(0,0,0,.04)',
    tick:   isDark()?'#94a3b8':'#64748b',
    border: isDark()?'#1e293b':'#ffffff'
  };
}
function updateChartsTheme(){
  if(EMP_DATA.length) setTimeout(renderEmpCharts,80);
  if(ASG_DATA.length) setTimeout(renderAsgChart,80);
}
function showToast(msg,type='info'){
  const icons={success:'bi-check-circle-fill',ok:'bi-check-circle-fill',error:'bi-exclamation-triangle-fill',err:'bi-exclamation-triangle-fill',info:'bi-info-circle-fill',inf:'bi-info-circle-fill'};
  const clrs ={success:'var(--clr-ok)',ok:'var(--clr-ok)',error:'var(--clr-red)',err:'var(--clr-red)',info:'var(--clr-info)',inf:'var(--clr-info)'};
  const el=document.createElement('div');
  el.className=`toast-item ${type}`;
  el.innerHTML=`<i class="bi ${icons[type]||icons.info}" style="font-size:17px;flex-shrink:0;color:${clrs[type]||clrs.info}"></i> ${msg}`;
  document.getElementById('toastWrap').appendChild(el);
  setTimeout(()=>{ el.style.cssText='opacity:0;transform:translateX(20px);transition:.3s;'; setTimeout(()=>el.remove(),300); },4000);
}
function fmtDate(d){ if(!d)return'—'; const dt=new Date(d); return isNaN(dt)?d:dt.toLocaleDateString('es-PE'); }
function dlChart(id,name){ const c=document.getElementById(id);if(!c)return; const a=document.createElement('a');a.download=`${name}_${new Date().toISOString().split('T')[0]}.png`;a.href=c.toDataURL('image/png');a.click(); }

/* ════════════════════════════════════════════════════════════════
   TABS
════════════════════════════════════════════════════════════════ */
let asgLoaded=false;
function switchTab(name){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  document.getElementById('panel-'+name).classList.add('active');
  if(name==='asg'&&!asgLoaded){ loadAsgData(); initAddModalAC(); initEditModalAC(); asgLoaded=true; }
}

/* ════════════════════════════════════════════════════════════════
   EMPLEADOS — DATOS
════════════════════════════════════════════════════════════════ */
let EMP_DATA=[],EMP_PAGE_DATA=[],EMP_CURRENT_PAGE=1,EMP_TOTAL_PAGES=1,EMP_SEARCH_TERM='';
const CAT_COLORS={'Especialista':'#10b981','Analista':'#f59e0b','Coordinador':'#3b82f6','Gerente':'#8b5cf6','Asistente':'#06b6d4','Técnico':'#6b7280'};
let chartDonut=null,chartBar=null,chartAltasBajas=null;

async function loadAllEmployeesData(){
  try{
    const [rA,rB]=await Promise.all([
      fetch('/api/employees?limit=9999',{credentials:'include'}).then(r=>r.json()),
      fetch('/api/employees/bajas',{credentials:'include'}).then(r=>r.json())
    ]);
    EMP_DATA=[...(rA.data||[]).map(e=>({...e,is_active:true})),...(rB.data||[]).map(e=>({...e,is_active:false}))];
    renderEmpCharts();
  }catch(e){
    console.error('loadAllEmployeesData:',e.message);
    ['kpiActivos','kpiBaja','kpiTotal','kpiTasa','kpiAltasMes','kpiBajasMes'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent='—';});
  }
}

async function loadEmpPage(page=1,search=''){
  EMP_CURRENT_PAGE=page; EMP_SEARCH_TERM=search;
  document.getElementById('empTbody').innerHTML='<tr><td colspan="7" class="empty-state"><i class="bi bi-arrow-repeat spin-anim"></i><p>Cargando…</p></td></tr>';
  try{
    let url=`/api/employees?page=${page}&limit=25`;
    if(search) url+=`&search=${encodeURIComponent(search)}`;
    const res=await fetch(url,{credentials:'include'});
    const json=await res.json();
    EMP_PAGE_DATA=json.data||[]; EMP_TOTAL_PAGES=json.totalPages||1;
    renderEmpTable(); renderEmpPagination();
    const info=document.getElementById('empPageInfo');
    if(info) info.textContent=`Página ${page} / ${EMP_TOTAL_PAGES}`;
    const tc=document.getElementById('tableCount');
    if(tc) tc.textContent=json.total||EMP_PAGE_DATA.length;
    if(search){ const h=document.getElementById('searchHint'),t=document.getElementById('searchHintTerm'); if(h&&t){h.style.display='block';t.textContent=`"${search}"`;} }
    else { const h=document.getElementById('searchHint'); if(h) h.style.display='none'; }
  }catch(e){ showToast('Error cargando empleados: '+e.message,'error'); }
}

function renderEmpTable(){
  if(!EMP_PAGE_DATA.length){ document.getElementById('empTbody').innerHTML='<tr><td colspan="7" class="empty-state"><i class="bi bi-inbox"></i><p>No se encontraron empleados</p></td></tr>'; return; }
  document.getElementById('empTbody').innerHTML=EMP_PAGE_DATA.map(emp=>{
    const isActive=emp.is_active!==false&&emp.is_active!==0;
    return`<tr id="row-${emp.id}" class="${!isActive?'emp-baja':''}" data-status="${isActive?'activo':'baja'}" data-name="${(emp.full_name||'').toLowerCase().replace(/"/g,'')}">
      <td class="left"><span style="font-family:monospace;font-size:11px;background:var(--hov);padding:2px 7px;border-radius:5px;">${emp.cip||'—'}</span></td>
      <td class="left" style="font-weight:600;">${emp.full_name||'—'}${!isActive?'<span class="badge-baja">BAJA</span>':''}</td>
      <td>${emp.email?`<a href="mailto:${emp.email}" style="font-size:12px;">${emp.email}</a>`:'—'}</td>
      <td style="font-size:12px;color:var(--mut);">${emp.position_name||'—'}</td>
      <td style="font-size:12px;color:var(--mut);">${emp.state||'—'}</td>
      <td><span class="status-pill ${isActive?'activo':'baja'}" id="pill-${emp.id}"><i class="fas fa-circle" style="font-size:6px;"></i>${isActive?'Activo':'De baja'}</span></td>
      <td class="emp-actions" style="white-space:nowrap;">
        <a href="/employees/${emp.id}" class="btn btn-sm btn-info me-1" style="font-size:11px;"><i class="bi bi-eye"></i> Ver</a>
        <button class="btn-toggle ${isActive?'is-active':'is-inactive'}" id="toggleBtn-${emp.id}" onclick="promptToggle(${emp.id},'${(emp.full_name||'').replace(/'/g,"\\'")}',${isActive})">${isActive?'<i class="fas fa-user-slash"></i> Dar de baja':'<i class="fas fa-user-check"></i> Reactivar'}</button>
      </td>
    </tr>`;
  }).join('');
}

function renderEmpPagination(){
  const pag=document.getElementById('empPagBtns'),wrap=document.getElementById('empPagWrap');
  if(!pag||EMP_TOTAL_PAGES<=1){if(wrap)wrap.style.display='none';return;}
  if(wrap) wrap.style.display='block';
  const pages=[]; let _prev=null;
  for(let i=1;i<=EMP_TOTAL_PAGES;i++){
    if(i===1||i===EMP_TOTAL_PAGES||(i>=EMP_CURRENT_PAGE-2&&i<=EMP_CURRENT_PAGE+2)){
      if(_prev!==null&&i-_prev>1) pages.push('...');
      pages.push(i); _prev=i;
    }
  }
  pag.innerHTML=
    `<li class="page-item ${EMP_CURRENT_PAGE===1?'disabled':''}"><a class="page-link" href="#" onclick="goEmpPage(${EMP_CURRENT_PAGE-1});return false;">‹</a></li>`
    +pages.map(p=>p==='...'
      ?`<li class="page-item disabled"><span class="page-link">…</span></li>`
      :`<li class="page-item ${p===EMP_CURRENT_PAGE?'active':''}"><a class="page-link" href="#" onclick="goEmpPage(${p});return false;">${p}</a></li>`
    ).join('')
    +`<li class="page-item ${EMP_CURRENT_PAGE===EMP_TOTAL_PAGES?'disabled':''}"><a class="page-link" href="#" onclick="goEmpPage(${EMP_CURRENT_PAGE+1});return false;">›</a></li>`;
}
function goEmpPage(p){ if(p<1||p>EMP_TOTAL_PAGES)return; loadEmpPage(p,EMP_SEARCH_TERM); }

/* ════════════════════════════════════════════════════════════════
   EMPLEADOS — CHARTS + KPIs
════════════════════════════════════════════════════════════════ */
function renderEmpCharts(){
  const activos=EMP_DATA.filter(e=>e.is_active).length;
  const bajas  =EMP_DATA.filter(e=>!e.is_active).length;
  const total  =activos+bajas;
  const cc     =getCC();
  _setEl('kpiActivos',activos); _setEl('kpiBaja',bajas); _setEl('kpiTotal',total);
  _setEl('kpiTasa',total>0?((bajas/total)*100).toFixed(1)+'%':'0%');
  const pctBajaGlobal=total>0?((bajas/total)*100).toFixed(1):'0.0';
  const subBaja=document.getElementById('kpiBajaSub');
  if(subBaja) subBaja.innerHTML=`<span class="down">↑ ${pctBajaGlobal}%</span> del total`;
  const ahora=new Date(), hace30dias=new Date(ahora.getTime()-30*24*60*60*1000);
  const altasMes=EMP_DATA.filter(e=>{ if(!e.created_at)return false; return new Date(e.created_at)>=hace30dias; }).length;
  const bajasMes=EMP_DATA.filter(e=>{ if(e.is_active)return false; const fecha=e.deactivated_at||e.updated_at; if(!fecha)return false; return new Date(fecha)>=hace30dias; }).length;
  _setEl('kpiAltasMes',altasMes); _setEl('kpiBajasMes',bajasMes);
  const pctAltas=activos>0?((altasMes/activos)*100).toFixed(1):'0.0';
  const subAltas=document.getElementById('kpiAltasSub');
  if(subAltas) subAltas.innerHTML=altasMes>0?`<span class="up">↑ ${pctAltas}%</span> vs activos`:'últimos 30 días';
  const pctBajasMes=total>0?((bajasMes/total)*100).toFixed(1):'0.0';
  const subBajasMes=document.getElementById('kpiBajasMesSub');
  if(subBajasMes) subBajasMes.innerHTML=bajasMes>0?`<span class="down">↑ ${pctBajasMes}%</span> del total`:'últimos 30 días';
  // Chart altas vs bajas
  const months=[],altasCnt={},bajasCnt={};
  for(let i=11;i>=0;i--){ const d=new Date();d.setDate(1);d.setMonth(d.getMonth()-i); const key=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`; const label=d.toLocaleDateString('es-PE',{month:'short',year:'2-digit'}); months.push({key,label});altasCnt[key]=0;bajasCnt[key]=0; }
  EMP_DATA.forEach(e=>{ if(e.created_at){const k=(e.created_at||'').substring(0,7);if(altasCnt[k]!==undefined)altasCnt[k]++;} if(!e.is_active){const k=(e.deactivated_at||e.updated_at||'').substring(0,7);if(k&&bajasCnt[k]!==undefined)bajasCnt[k]++;} });
  const lbls=months.map(m=>m.label),dAltas=months.map(m=>altasCnt[m.key]),dBajas=months.map(m=>bajasCnt[m.key]);
  const ctx0=document.getElementById('chartAltasBajas').getContext('2d');
  if(chartAltasBajas)chartAltasBajas.destroy();
  chartAltasBajas=new Chart(ctx0,{type:'bar',data:{labels:lbls,datasets:[{label:'Altas',data:dAltas,backgroundColor:isDark()?'rgba(52,211,153,.7)':'rgba(16,185,129,.75)',borderRadius:6,borderSkipped:false,order:2},{label:'Bajas',data:dBajas,backgroundColor:isDark()?'rgba(248,113,113,.7)':'rgba(239,68,68,.75)',borderRadius:6,borderSkipped:false,order:2},{label:'Tendencia Altas',data:dAltas,type:'line',borderColor:isDark()?'#34d399':'#10b981',borderWidth:2,pointRadius:3,pointBackgroundColor:isDark()?'#34d399':'#10b981',fill:false,tension:.35,order:1},{label:'Tendencia Bajas',data:dBajas,type:'line',borderColor:isDark()?'#f87171':'#ef4444',borderWidth:2,pointRadius:3,pointBackgroundColor:isDark()?'#f87171':'#ef4444',fill:false,tension:.35,order:1}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11},color:cc.tick,boxWidth:12}},tooltip:{callbacks:{label:c=>` ${c.dataset.label}: ${c.parsed.y}`}}},scales:{x:{grid:{display:false},ticks:{font:{size:10},color:cc.tick}},y:{beginAtZero:true,ticks:{stepSize:1,font:{size:10},color:cc.tick,precision:0},grid:{color:cc.grid}}}}});
  // Donut
  if(chartDonut)chartDonut.destroy();
  chartDonut=new Chart(document.getElementById('donutEmp').getContext('2d'),{type:'doughnut',data:{labels:['Activos','De Baja'],datasets:[{data:[activos,bajas],backgroundColor:['#10b981','#ef4444'],borderWidth:3,borderColor:cc.border,hoverOffset:8}]},options:{cutout:'66%',plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>` ${c.label}: ${c.raw} (${total>0?((c.raw/total)*100).toFixed(1):0}%)`}}}}});
  document.getElementById('donutLegend').innerHTML=['Activos','De Baja'].map((l,i)=>`<div class="legend-row"><div class="legend-dot" style="background:${['#10b981','#ef4444'][i]}"></div><span class="legend-lbl">${l}</span><span class="legend-num">${[activos,bajas][i]}</span><span class="legend-pct">${total>0?(([activos,bajas][i]/total)*100).toFixed(1):0}%</span></div>`).join('');
  // Bar categoría
  const cats={};
  EMP_DATA.forEach(e=>{ const c=e.category||'Sin categoría'; if(!cats[c])cats[c]={activos:0,bajas:0}; e.is_active?cats[c].activos++:cats[c].bajas++; });
  const cl=Object.keys(cats).sort();
  if(chartBar)chartBar.destroy();
  chartBar=new Chart(document.getElementById('barCat').getContext('2d'),{type:'bar',data:{labels:cl,datasets:[{label:'Activos',data:cl.map(l=>cats[l].activos),backgroundColor:'#10b981',borderRadius:6},{label:'De Baja',data:cl.map(l=>cats[l].bajas),backgroundColor:'#ef4444',borderRadius:6}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11},color:cc.tick}}},scales:{x:{grid:{display:false},ticks:{font:{size:10},color:cc.tick}},y:{beginAtZero:true,ticks:{stepSize:1,font:{size:10},color:cc.tick,precision:0},grid:{color:cc.grid}}}}});
}
