const searchField=document.getElementById('searchField');
const acDrop=document.getElementById('acDrop');
const searchX=document.getElementById('searchX');
let acTimer=null;
function goSearch(term){ if(!term.trim()){clearEmpSearch();return;} loadEmpPage(1,term.trim()); searchX.classList.add('show'); }
function clearEmpSearch(){ searchField.value=''; searchX.classList.remove('show'); document.getElementById('searchHint').style.display='none'; loadEmpPage(1,''); }
searchField.addEventListener('input',function(){ const t=this.value.trim(); searchX.classList.toggle('show',t.length>0); clearTimeout(acTimer); if(t.length<2){acDrop.classList.remove('open');return;} acTimer=setTimeout(()=>showAC(t),220); });
searchField.addEventListener('keydown',function(e){ if(e.key==='Enter'){acDrop.classList.remove('open');goSearch(this.value);} if(e.key==='Escape'){acDrop.classList.remove('open');this.blur();} });
document.addEventListener('click',e=>{ if(!e.target.closest('.search-inner'))acDrop.classList.remove('open'); });
function hlText(str,term){ if(!str)return''; return str.replace(new RegExp(`(${term.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`,'gi'),'<mark class="hl">$1</mark>'); }
function showAC(term){
  const t=term.toLowerCase();
  const results=EMP_DATA.filter(e=>(e.full_name||'').toLowerCase().includes(t)||(e.cip||'').toLowerCase().includes(t)||(e.email||'').toLowerCase().includes(t)).slice(0,8);
  const footer=`<div class="ac-footer" onclick="goSearch('${term.replace(/'/g,"\\'")}')"><i class="bi bi-search"></i> Buscar <strong>"${term}"</strong> en todos los registros</div>`;
  if(!results.length){ acDrop.innerHTML=`<div class="ac-empty"><i class="bi bi-search" style="font-size:22px;opacity:.3;display:block;margin-bottom:8px;"></i>Sin coincidencias en memoria</div>${footer}`; acDrop.classList.add('open'); return; }
  acDrop.innerHTML=`<div class="ac-header">${results.length} resultado${results.length!==1?'s':''}</div>`
    +results.map(emp=>{ const color=CAT_COLORS[emp.category]||'#64748b'; const init=(emp.full_name||'').trim().split(/\s+/).slice(0,2).map(w=>w[0]||'').join('').toUpperCase(); return`<div class="ac-row" onclick="selectEmp(${emp.id},'${(emp.full_name||'').replace(/'/g,"\\'")}')"><div class="ac-avatar" style="background:${color}">${init}</div><div class="ac-info"><div class="ac-name">${hlText(emp.full_name,term)}</div><div class="ac-meta">${emp.cip||'—'} · ${emp.position_name||'Sin cargo'}</div></div><span class="ac-pill ${emp.is_active?'on':'off'}">${emp.is_active?'Activo':'Baja'}</span></div>`; }).join('')+footer;
  acDrop.classList.add('open');
}
function selectEmp(id,name){ acDrop.classList.remove('open'); const row=document.getElementById(`row-${id}`); if(row){ searchField.value=name; searchX.classList.add('show'); row.scrollIntoView({behavior:'smooth',block:'center'}); row.classList.add('row-hl'); setTimeout(()=>row.classList.remove('row-hl'),2300); } else { goSearch(name); } }

