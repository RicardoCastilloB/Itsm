</div>

<%# ══ MODAL — Alta de Empleado ═══════════════════════════════════ %>
<div class="modal fade modal-add-emp" id="addEmployeeModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:580px;">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-person-check-fill me-2"></i>Alta de Empleado</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="addAlert" style="display:none;" class="add-emp-alert error">
          <i class="bi bi-exclamation-circle-fill"></i>
          <span id="addAlertMsg"></span>
        </div>
        <form id="addForm" novalidate>
          <div class="section-div"><i class="bi bi-person"></i> Datos Personales</div>
          <div class="field-group">
            <div class="field-wrap full">
              <label class="form-label-sm">Nombre Completo <span class="req">*</span></label>
              <input type="text" id="new_full_name" class="field-input" placeholder="Ej: García López, Juan Carlos" required autocomplete="off">
            </div>
            <div class="field-wrap">
              <label class="form-label-sm">Email <span class="req">*</span></label>
              <input type="email" id="new_email" class="field-input" placeholder="usuario@empresa.com" required autocomplete="off">
            </div>
            <div class="field-wrap">
              <label class="form-label-sm">CIP</label>
              <input type="text" id="new_cip" class="field-input" placeholder="Código interno" autocomplete="off">
            </div>
          </div>
          <div class="section-div"><i class="bi bi-briefcase"></i> Posición y Departamento</div>
          <div class="field-group">
            <div class="field-wrap">
              <label class="form-label-sm">Posición / Cargo</label>
              <input type="text" id="new_position" class="field-input" placeholder="Ej: Analista Senior" autocomplete="off">
            </div>
            <div class="field-wrap">
              <label class="form-label-sm">Departamento</label>
              <select id="new_department_id" class="field-input">
                <option value="">— Sin departamento —</option>
              </select>
            </div>
          </div>
          <div class="section-div"><i class="bi bi-toggle-on"></i> Estado</div>
          <label class="switch-wrap">
            <input type="checkbox" id="new_is_active" checked>
            <span class="switch-track"></span>
            <span class="switch-label" id="switchLabel">Empleado activo al dar de alta</span>
          </label>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary btn-sm px-4" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-success btn-sm px-4 fw-bold" id="submitAdd">
          <span id="addSpinner" class="spinner-border spinner-border-sm me-1 d-none"></span>
          <i class="bi bi-person-check-fill me-1" id="addIcon"></i>
          <span id="addBtnTxt">Registrar Alta</span>
        </button>
      </div>
    </div>
  </div>
</div>

<%# ══ MODAL — Nueva Asignación ═══════════════════════════════════ %>
<div class="modal fade" id="addAssignmentModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <div style="font-size:15px;font-weight:800;display:flex;align-items:center;gap:8px;color:var(--txt);">
          <i class="bi bi-plus-circle" style="color:var(--clr-ok);"></i> Nueva Asignación
        </div>
        <button type="button" class="btn-ghost" data-bs-dismiss="modal" style="padding:4px 8px;"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-8">
            <label class="form-label-sm">Empleado <span style="color:var(--clr-red)">*</span></label>
            <input type="text" class="field-input" id="addEmployeeName" placeholder="Escribe para buscar..." autocomplete="off">
            <div id="addEmployeeResults" class="autocomplete-results"></div>
          </div>
          <div class="col-md-4">
            <label class="form-label-sm">CIP</label>
            <input type="text" class="field-input" id="addEmployeeCip" readonly>
          </div>
          <div class="col-md-8">
            <label class="form-label-sm">Equipo <span style="color:var(--clr-red)">*</span></label>
            <input type="text" class="field-input" id="addEquipmentCode" placeholder="Código o modelo..." autocomplete="off">
            <div id="addEquipmentResults" class="autocomplete-results"></div>
          </div>
          <div class="col-md-4">
            <label class="form-label-sm">Modelo</label>
            <input type="text" class="field-input" id="addEquipmentModel" readonly>
          </div>
          <div class="col-md-6">
            <label class="form-label-sm">Departamento <span style="font-weight:400;color:var(--mut)">(Opcional)</span></label>
            <input type="text" class="field-input" id="addDepartmentName" placeholder="Buscar..." autocomplete="off">
            <input type="hidden" id="addDepartmentId">
            <div id="addDepartmentResults" class="autocomplete-results"></div>
          </div>
          <div class="col-md-6">
            <label class="form-label-sm">Ubicación <span style="font-weight:400;color:var(--mut)">(Opcional)</span></label>
            <input type="text" class="field-input" id="addLocationName" placeholder="Buscar..." autocomplete="off">
            <input type="hidden" id="addLocationId">
            <div id="addLocationResults" class="autocomplete-results"></div>
          </div>
          <div class="col-12">
            <label class="form-label-sm">Fecha <span style="color:var(--clr-red)">*</span></label>
            <input type="date" class="field-input" id="addAssignmentDate">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-modal cancel" data-bs-dismiss="modal">Cancelar</button>
        <button class="btn-modal success" id="btnSaveNewAsg">
          <span class="bi bi-arrow-repeat spin-anim d-none" id="spinnerNewAsg"></span>
          Guardar Asignación
        </button>
      </div>
    </div>
  </div>
</div>

<%# ══ MODAL — Editar Asignación ══════════════════════════════════ %>
<div class="modal fade" id="editAssignmentModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <div style="font-size:15px;font-weight:800;display:flex;align-items:center;gap:8px;color:var(--txt);">
          <i class="bi bi-pencil" style="color:var(--clr-blue);"></i> Editar Asignación
        </div>
        <button type="button" class="btn-ghost" data-bs-dismiss="modal" style="padding:4px 8px;"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label-sm">ID</label>
            <input type="text" class="field-input" id="editAsgId" readonly>
          </div>
          <div class="col-md-8">
            <label class="form-label-sm">Empleado</label>
            <input type="text" class="field-input" id="editAsgEmployee" placeholder="Buscar..." autocomplete="off">
            <div id="editEmployeeResults" class="autocomplete-results"></div>
          </div>
          <div class="col-md-4">
            <label class="form-label-sm">CIP</label>
            <input type="text" class="field-input" id="editAsgCip" readonly>
          </div>
          <div class="col-md-8">
            <label class="form-label-sm">Equipo</label>
            <input type="text" class="field-input" id="editAsgEquipment" placeholder="Buscar..." autocomplete="off">
            <div id="editEquipmentResults" class="autocomplete-results"></div>
          </div>
          <div class="col-md-4">
            <label class="form-label-sm">Modelo</label>
            <input type="text" class="field-input" id="editAsgModel" readonly>
          </div>
          <div class="col-md-6">
            <label class="form-label-sm">Departamento</label>
            <input type="text" class="field-input" id="editAsgDept" placeholder="Buscar..." autocomplete="off">
            <input type="hidden" id="editAsgDeptId">
            <div id="editDepartmentResults" class="autocomplete-results"></div>
          </div>
          <div class="col-md-6">
            <label class="form-label-sm">Ubicación</label>
            <input type="text" class="field-input" id="editAsgLoc" placeholder="Buscar..." autocomplete="off">
            <input type="hidden" id="editAsgLocId">
            <div id="editLocationResults" class="autocomplete-results"></div>
          </div>
          <div class="col-12">
            <label class="form-label-sm">Fecha</label>
            <input type="date" class="field-input" id="editAsgDate">
          </div>
        </div>
      </div>
