function openEditAsg(a){ document.getElementById('editAsgId').value=a.assignment_id; document.getElementById('editAsgEmployee').value=a.employee_name||''; document.getElementById('editAsgCip').value=a.employee_cip||''; document.getElementById('editAsgEquipment').value=a.equipment_code||''; document.getElementById('editAsgModel').value=a.equipment_model||''; document.getElementById('editAsgDept').value=a.department_name||''; document.getElementById('editAsgDeptId').value=a.department_id||''; document.getElementById('editAsgLoc').value=a.location_name||''; document.getElementById('editAsgLocId').value=a.location_id||''; document.getElementById('editAsgDate').value=a.assignment_date?a.assignment_date.substring(0,10):''; new bootstrap.Modal(document.getElementById('editAssignmentModal')).show(); }
document.getElementById('btnSaveNewAsg').addEventListener('click',async()=>{
  const spinner=document.getElementById('spinnerNewAsg'); spinner.classList.remove('d-none');
  try{
    const body={employee_cip:document.getElementById('addEmployeeCip').value,equipment_code:document.getElementById('addEquipmentCode').value,department_id:document.getElementById('addDepartmentId').value||null,location_id:document.getElementById('addLocationId').value||null,assignment_date:document.getElementById('addAssignmentDate').value};
    if(!body.employee_cip||!body.equipment_code||!body.assignment_date){showToast('Completa los campos obligatorios','err');return;}
    const res=await fetch('/api/assignments',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const json=await res.json();
    if(!json.success)throw new Error(json.message||'Error');
    bootstrap.Modal.getInstance(document.getElementById('addAssignmentModal'))?.hide();
    showToast('Asignación creada','success'); loadAsgData();
  }catch(e){showToast('Error: '+e.message,'err');}
  finally{spinner.classList.add('d-none');}
});
document.getElementById('btnSaveEditAsg').addEventListener('click',async()=>{
