document.getElementById('addEmployeeModal').addEventListener('hidden.bs.modal',function(){ document.getElementById('addForm').reset(); document.getElementById('addAlert').style.display='none'; document.querySelectorAll('#addForm .field-input').forEach(el=>el.classList.remove('invalid')); });
document.getElementById('new_is_active').addEventListener('change',function(){ document.getElementById('switchLabel').textContent=this.checked?'Empleado activo al dar de alta':'Empleado inactivo al dar de alta'; });
document.getElementById('new_email').addEventListener('blur',function(){ const ok=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.value); this.classList.toggle('invalid',this.value.length>0&&!ok); });
function showAddAlert(show,msg='',type='error'){ const box=document.getElementById('addAlert'); if(!show){box.style.display='none';return;} box.className=`add-emp-alert ${type}`; document.getElementById('addAlertMsg').textContent=msg; box.style.display='flex'; }
document.getElementById('submitAdd').addEventListener('click',async function(){
  showAddAlert(false);
  const name=document.getElementById('new_full_name').value.trim(),email=document.getElementById('new_email').value.trim();
  if(!name){document.getElementById('new_full_name').classList.add('invalid');document.getElementById('new_full_name').focus();showAddAlert(true,'El nombre completo es obligatorio.');return;}
  if(!email||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){document.getElementById('new_email').classList.add('invalid');document.getElementById('new_email').focus();showAddAlert(true,'Ingresa un email válido.');return;}
  const btn=this,sp=document.getElementById('addSpinner'),ic=document.getElementById('addIcon'),tx=document.getElementById('addBtnTxt');
  btn.disabled=true;sp.classList.remove('d-none');ic.classList.add('d-none');tx.textContent='Registrando…';
  try{
    const res=await fetch('/api/employees',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({full_name:name,email,cip:document.getElementById('new_cip').value.trim()||null,position:document.getElementById('new_position').value.trim()||null,department_id:document.getElementById('new_department_id').value||null,is_active:document.getElementById('new_is_active').checked})});
    const data=await res.json();
    if(res.ok&&data.success){ bootstrap.Modal.getInstance(document.getElementById('addEmployeeModal')).hide(); showToast(`Alta registrada: "${name}" ✅`,'success'); setTimeout(()=>{loadAllEmployeesData();loadEmpPage(1,EMP_SEARCH_TERM);},1000); }
    else throw new Error(data.error||data.message||'Error al crear');
  }catch(e){ showAddAlert(true,e.message); }
  finally{ btn.disabled=false;sp.classList.add('d-none');ic.classList.remove('d-none');tx.textContent='Registrar Alta'; }
});

/* ════════════════════════════════════════════════════════════════
   ASIGNACIONES
════════════════════════════════════════════════════════════════ */
let ASG_DATA=[],ASG_FILTERED=[],ASG_PAGE=1;
const ASG_PER_PAGE=25;
let asgChart=null,asgActivePill='all',asgSearchTerm='';

async function loadAsgData(){
  document.getElementById('asgTableBody').innerHTML='<tr><td colspan="10" class="empty-state"><i class="bi bi-arrow-repeat spin-anim"></i><p>Cargando asignaciones...</p></td></tr>';
  try{
    const headers={};
    const t=localStorage.getItem('token')||localStorage.getItem('authToken')||localStorage.getItem('jwt');
    if(t) headers['Authorization']=`Bearer ${t}`;
    const res=await fetch('/api/assignments',{headers,credentials:'include'});
    const json=await res.json();
    if(!json.success) throw new Error(json.message||json.error||'Error API');
    ASG_DATA=json.data||[]; renderAsgKPIs(); renderAsgChart(); renderAsgTopModels(); applyAsgFilters();
  }catch(e){ document.getElementById('asgTableBody').innerHTML=`<tr><td colspan="10" class="empty-state"><i class="bi bi-exclamation-triangle-fill"></i><p>Error: ${e.message}</p></td></tr>`; showToast('Error al cargar: '+e.message,'err'); }
}

function renderAsgKPIs(){
  const now=new Date(),y=now.getFullYear(),m=now.getMonth();
  const esteMes=ASG_DATA.filter(a=>{const d=new Date(a.assignment_date);return d.getFullYear()===y&&d.getMonth()===m;}).length;
  const byEmp={};ASG_DATA.forEach(a=>{byEmp[a.employee_cip]=(byEmp[a.employee_cip]||0)+1;});
  const multi=Object.values(byEmp).filter(v=>v>1).length;
  const sorted=[...ASG_DATA].sort((a,b)=>new Date(b.assignment_date)-new Date(a.assignment_date));
  const ultima=sorted[0]?fmtDate(sorted[0].assignment_date):'—';
  const byModel={};ASG_DATA.forEach(a=>{byModel[a.equipment_model]=(byModel[a.equipment_model]||0)+1;});
  const modelTop=Object.entries(byModel).sort((a,b)=>b[1]-a[1])[0];
  const byDept={};ASG_DATA.forEach(a=>{const d=a.department_name||'Sin depto';if(d!=='Sin departamento')byDept[d]=(byDept[d]||0)+1;});
  const deptTop=Object.entries(byDept).sort((a,b)=>b[1]-a[1])[0];
  _setEl('asgTotal',ASG_DATA.length);_setEl('asgEsteMes',esteMes);_setEl('asgMulti',multi);
  _setEl('asgUltima',ultima);_setEl('asgModeloTop',modelTop?modelTop[0]:'—');
  _setEl('asgDeptoTop',deptTop?deptTop[0].substring(0,18)+(deptTop[0].length>18?'…':''):'—');
}

function renderAsgChart(){
  const cc=getCC(),months=[],counts={};
  for(let i=11;i>=0;i--){const d=new Date();d.setMonth(d.getMonth()-i);const key=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;const label=d.toLocaleDateString('es-PE',{month:'short',year:'2-digit'});months.push({key,label});counts[key]=0;}
  ASG_DATA.forEach(a=>{if(!a.assignment_date)return;const k=a.assignment_date.substring(0,7);if(counts[k]!==undefined)counts[k]++;});
  const labels=months.map(m=>m.label),data=months.map(m=>counts[m.key]),maxVal=Math.max(...data);
  const pClr=isDark()?'#60a5fa':'#3b82f6',dClr=isDark()?'rgba(96,165,250,.25)':'rgba(59,130,246,.2)';
  const colors=data.map(v=>v===maxVal&&v>0?pClr:dClr);
  const ctx=document.getElementById('asgChartBar').getContext('2d');
  if(asgChart)asgChart.destroy();
  asgChart=new Chart(ctx,{type:'bar',data:{labels,datasets:[{data,backgroundColor:colors,borderRadius:6,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:true,plugins:{legend:{display:false},tooltip:{backgroundColor:isDark()?'#1e293b':'#fff',borderColor:isDark()?'#2d3f55':'#e2e8f0',borderWidth:1,titleColor:isDark()?'#e2e8f0':'#1e293b',bodyColor:cc.tick,callbacks:{label:c=>` ${c.parsed.y} asignaciones`}}},scales:{y:{beginAtZero:true,grid:{color:cc.grid},ticks:{color:cc.tick,font:{size:11},precision:0}},x:{grid:{display:false},ticks:{color:cc.tick,font:{size:11}}}}}});
}
function dlAsgChart(){ if(!asgChart)return; const a=document.createElement('a');a.download=`asignaciones_chart_${new Date().toISOString().split('T')[0]}.png`;a.href=asgChart.toBase64Image();a.click(); }
function renderAsgTopModels(){
  const byModel={};ASG_DATA.forEach(a=>{const k=a.equipment_model||'Sin modelo';byModel[k]=(byModel[k]||0)+1;});
  const top=Object.entries(byModel).sort((a,b)=>b[1]-a[1]).slice(0,8),maxCount=top[0]?top[0][1]:1;
  document.getElementById('asgTopModelos').innerHTML=top.map(([name,count],i)=>`<li class="top-list-item"><span class="rank-badge rank-${i+1}">${i+1}</span><span class="top-name" title="${name}">${name}</span><div class="top-bar-wrap"><div class="top-bar" style="width:${Math.round(count/maxCount*100)}%"></div></div><span class="top-count">${count}</span></li>`).join('');
}

function setPill(pill){ asgActivePill=pill; ['all','month','multi'].forEach(p=>document.getElementById(`pill-${p}`).classList.toggle('active',p===pill)); ASG_PAGE=1; applyAsgFilters(); }
function applyAsgFilters(){
  const term=asgSearchTerm.toLowerCase(),now=new Date(),monthAgo=new Date(now.getFullYear(),now.getMonth()-1,now.getDate());
  const byEmp={};ASG_DATA.forEach(a=>{byEmp[a.employee_cip]=(byEmp[a.employee_cip]||0)+1;});
  ASG_FILTERED=ASG_DATA.filter(a=>{
    if(asgActivePill==='month'&&new Date(a.assignment_date)<monthAgo)return false;
    if(asgActivePill==='multi'&&(byEmp[a.employee_cip]||0)<=1)return false;
    if(term){const hay=[a.employee_name,a.employee_cip,a.equipment_code,a.equipment_model,a.department_name,a.location_name,a.assignment_id].join(' ').toLowerCase();if(!hay.includes(term))return false;}
    return true;
  });
  document.getElementById('asgTableCount').textContent=ASG_FILTERED.length;
  renderAsgTable(); renderAsgPagination();
}

function eqIcon(type){const map={Laptop:'eq-laptop bi-laptop',Desktop:'eq-desktop bi-pc-display',Monitor:'eq-monitor bi-display',Tablet:'eq-tablet bi-tablet'};const cls=map[type]||'eq-other bi-device-hdd';const[bg,ic]=cls.split(' ');return`<span class="eq-icon ${bg}"><i class="bi ${ic}"></i></span>`;}
function typePill(type){const map={Laptop:'p-blue',Desktop:'p-green',Monitor:'p-yellow',Tablet:'p-purple'};return`<span class="pill ${map[type]||'p-gray'}">${type||'—'}</span>`;}
function renderAsgTable(){
  const start=(ASG_PAGE-1)*ASG_PER_PAGE,page=ASG_FILTERED.slice(start,start+ASG_PER_PAGE);
  const sevenDaysAgo=new Date(Date.now()-7*24*60*60*1000);
  if(!page.length){document.getElementById('asgTableBody').innerHTML='<tr><td colspan="10" class="empty-state"><i class="bi bi-inbox"></i><p>No se encontraron asignaciones</p></td></tr>';return;}
  document.getElementById('asgTableBody').innerHTML=page.map(a=>{const isRecent=a.assignment_date&&new Date(a.assignment_date)>=sevenDaysAgo;return`<tr class="${isRecent?'row-recent':''}"><td><span style="font-family:monospace;font-size:11px;color:var(--mut)">#${a.assignment_id}</span></td><td style="text-align:left;"><strong style="font-size:13px">${a.employee_name||'—'}</strong></td><td><span style="font-family:monospace;font-size:12px">${a.employee_cip||'—'}</span></td><td style="text-align:left;">${eqIcon(a.equipment_type)}<strong>${a.equipment_code||'—'}</strong></td><td>${a.equipment_model||'—'}</td><td>${typePill(a.equipment_type)}</td><td style="font-size:12px;color:var(--mut)">${fmtDate(a.assignment_date)}</td><td style="font-size:12px">${a.department_name||'—'}</td><td style="font-size:12px">${a.location_name||'—'}</td><td><button class="btn-primary-sm" style="padding:4px 10px;font-size:11px;" onclick='openEditAsg(${JSON.stringify(a)})'><i class="bi bi-pencil-fill"></i></button></td></tr>`;}).join('');
}
function renderAsgPagination(){
  const total=ASG_FILTERED.length,pages=Math.ceil(total/ASG_PER_PAGE);
  const start=Math.min((ASG_PAGE-1)*ASG_PER_PAGE+1,total),end=Math.min(ASG_PAGE*ASG_PER_PAGE,total);
  document.getElementById('asgPagInfo').textContent=total>0?`${start.toLocaleString()}–${end.toLocaleString()} de ${total.toLocaleString()} asignaciones`:'Sin resultados';
  const btns=document.getElementById('asgPagBtns');
  if(pages<=1){btns.innerHTML='';return;}
  let h=`<button class="pg-btn" onclick="goAsgPage(${ASG_PAGE-1})" ${ASG_PAGE===1?'disabled':''}>‹</button>`;
  const s=Math.max(1,ASG_PAGE-2),e2=Math.min(pages,ASG_PAGE+2);
  if(s>1)h+=`<button class="pg-btn" onclick="goAsgPage(1)">1</button>${s>2?'<span style="padding:0 4px;color:var(--mut)">…</span>':''}`;
  for(let p=s;p<=e2;p++)h+=`<button class="pg-btn ${p===ASG_PAGE?'active':''}" onclick="goAsgPage(${p})">${p}</button>`;
  if(e2<pages)h+=`${e2<pages-1?'<span style="padding:0 4px;color:var(--mut)">…</span>':''}<button class="pg-btn" onclick="goAsgPage(${pages})">${pages}</button>`;
  h+=`<button class="pg-btn" onclick="goAsgPage(${ASG_PAGE+1})" ${ASG_PAGE>=pages?'disabled':''}>›</button>`;
  btns.innerHTML=h;
}
function goAsgPage(p){ ASG_PAGE=p; renderAsgTable(); renderAsgPagination(); }

function exportAsg(fmt){
  if(!ASG_FILTERED.length){showToast('No hay datos','inf');return;}
  const rows=ASG_FILTERED.map(a=>({ID:a.assignment_id,Empleado:a.employee_name,CIP:a.employee_cip,Equipo:a.equipment_code,Modelo:a.equipment_model,Tipo:a.equipment_type,Fecha:a.assignment_date,Departamento:a.department_name,Ubicacion:a.location_name}));
  const ws=XLSX.utils.json_to_sheet(rows),wb=XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb,ws,'Asignaciones');
  XLSX.writeFile(wb,`asignaciones_${new Date().toISOString().split('T')[0]}.${fmt==='excel'?'xlsx':'csv'}`);
  showToast('Exportación completada','success');
}

/* ════════════════════════════════════════════════════════════════
   AUTOCOMPLETE MODALES ASIGNACIONES
════════════════════════════════════════════════════════════════ */
let asgDebounceTimer=null;
function setupAC(inputId,resultsId,url,handlers,minLen=2){
  const input=document.getElementById(inputId),results=document.getElementById(resultsId);
  if(!input||!results)return;
  input.addEventListener('input',()=>{
    clearTimeout(asgDebounceTimer);
    const val=input.value.trim();
    if(val.length<minLen){results.style.display='none';return;}
    asgDebounceTimer=setTimeout(async()=>{
      try{
        const res=await fetch(url+encodeURIComponent(val),{credentials:'include'});
        const json=await res.json();
        const items=json.data||[];
        results.innerHTML=items.length?items.slice(0,8).map((item,i)=>handlers.render(item,i)).join(''):'<div class="autocomplete-item" style="color:var(--mut);cursor:default">Sin resultados</div>';
        results.querySelectorAll('[data-idx]').forEach((el,idx)=>{el.dataset.idx=idx;el.addEventListener('click',()=>{handlers.pick(items[parseInt(el.dataset.idx)]);results.style.display='none';});});
        results.style.display='block';
      }catch(e){results.style.display='none';}
    },300);
  });
  document.addEventListener('click',e=>{if(!input.contains(e.target)&&!results.contains(e.target))results.style.display='none';});
}
