<%# ══ MODAL — Confirmar toggle ═══════════════════════════════════ %>
<div class="modal fade" id="confirmModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered" style="max-width:390px">
    <div class="modal-content" style="border-radius:14px;overflow:hidden;">
      <div class="modal-header border-0 justify-content-center pt-4 pb-0" style="flex-direction:column;text-align:center;gap:6px;">
        <span style="font-size:40px;" id="confirmIcon">⚠️</span>
        <h5 class="fw-bold mt-1 mb-0" id="confirmTitle" style="font-size:15px;color:var(--txt);">¿Confirmar?</h5>
      </div>
      <div class="modal-body text-center pb-1" id="confirmMsg" style="font-size:13px;color:var(--mut);"></div>
      <div class="modal-footer justify-content-center border-0 pb-4 gap-2">
        <button class="btn btn-outline-secondary btn-sm px-4" data-bs-dismiss="modal">Cancelar</button>
