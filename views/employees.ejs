  setupAC('addDepartmentName','addDepartmentResults','/api/departments/search?term=',{render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.department_name}</span></div>`,pick:e=>{document.getElementById('addDepartmentName').value=e.department_name;document.getElementById('addDepartmentId').value=e.id;}},3);
  setupAC('addLocationName','addLocationResults','/api/locations/search?term=',{render:(e,i)=>`<div class="autocomplete-item" data-idx="${i}"><span class="ac-name">${e.location_name}</span></div>`,pick:e=>{document.getElementById('addLocationName').value=e.location_name;document.getElementById('addLocationId').value=e.id;}},3);
}
