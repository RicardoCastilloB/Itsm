                            <div id="equipmentSearchResults" style="display:none; max-height:200px; overflow-y:auto; border:1px solid var(--border-soft); border-radius:4px; margin-top:5px;"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Modelo</label>
                            <input type="text" class="form-control" id="editEquipmentModel" readonly>
                            <div id="equipmentUpdateMessage" class="alert mt-2" style="display:none; padding:8px; font-size:12px;">✅ Equipo actualizado</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Departamento</label>
                            <input type="text" class="form-control" id="editDepartmentName" placeholder="Escribe para buscar...">
                            <input type="hidden" id="editDepartmentId">
                            <small class="form-text text-muted" id="departmentSearchStatus">Opcional...</small>
                            <div id="departmentSearchResults" style="display:none; max-height:200px; overflow-y:auto; border:1px solid var(--border-soft); border-radius:4px; margin-top:5px;"></div>
                            <div id="departmentUpdateMessage" class="alert mt-2" style="display:none; padding:8px; font-size:12px;">✅ Departamento actualizado</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ubicación</label>
                            <input type="text" class="form-control" id="editLocationName" placeholder="Escribe para buscar...">
                            <input type="hidden" id="editLocationId">
                            <small class="form-text text-muted" id="locationSearchStatus">Opcional...</small>
                            <div id="locationSearchResults" style="display:none; max-height:200px; overflow-y:auto; border:1px solid var(--border-soft); border-radius:4px; margin-top:5px;"></div>
                            <div id="locationUpdateMessage" class="alert mt-2" style="display:none; padding:8px; font-size:12px;">✅ Ubicación actualizada</div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Fecha de Asignación</label>
                            <input type="date" class="form-control" id="editAssignmentDate">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="saveAssignmentChanges">Guardar</button>
            </div>
        </div>
    </div>
</div>

