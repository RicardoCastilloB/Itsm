async function exportReport() {
    showLoading();
    try {
        const filters = getFilters();
        
        const response = await fetch(`${API_BASE}/export-data?${new URLSearchParams(filters)}`);
        const result = await response.json();
        
        if (!result.success) {
            throw new Error(result.message || 'Error al obtener datos');
        }
        
        const wb = XLSX.utils.book_new();
        
        // Hoja 1: Métricas
        const metricsData = [
            ['Métrica', 'Valor'],
            ['Total Empleados', $('#totalEmployees').text()],
            ['Total Equipos', $('#totalEquipment').text()],
            ['Asignaciones Activas', $('#activeAssignments').text()],
            ['Fecha Generación', new Date().toLocaleString('es-PE')]
        ];
        const wsMetrics = XLSX.utils.aoa_to_sheet(metricsData);
        XLSX.utils.book_append_sheet(wb, wsMetrics, 'Métricas');
        
        // Hoja 2: Asignaciones
        if (result.data && result.data.assignments) {
            const wsAssignments = XLSX.utils.json_to_sheet(result.data.assignments);
            XLSX.utils.book_append_sheet(wb, wsAssignments, 'Asignaciones');
        }
        
        // Hoja 3: Equipos por Estado
        if (result.data && result.data.equipmentByStatus) {
            const wsStatus = XLSX.utils.json_to_sheet(result.data.equipmentByStatus);
            XLSX.utils.book_append_sheet(wb, wsStatus, 'Equipos por Estado');
        }
        
        XLSX.writeFile(wb, `reporte_indicadores_${formatDate(new Date())}.xlsx`);
        
    } catch (error) {
        console.error('Error exporting Excel:', error);
        alert('Error al exportar: ' + error.message);
    } finally {
        hideLoading();
    }
}

