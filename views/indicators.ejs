<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Indicadores y Reportes - Equipment Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/date-fns@2.30.0/index.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    <style>
        :root {
            --primary-color: #4f46e5;
            --secondary-color: #10b981;
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --info-color: #3b82f6;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        .main-container {
            padding: 2rem;
            max-width: 1600px;
            margin: 0 auto;
        }

        .page-header {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }

        .page-header h1 {
            color: #1f2937;
            font-weight: 700;
            margin: 0;
            font-size: 2rem;
        }

        .page-header p {
            color: #6b7280;
            margin: 0.5rem 0 0 0;
        }

        /* Panel de filtros */
        .filters-panel {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }

        .filters-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }

        .filters-header h3 {
            color: #1f2937;
            font-weight: 600;
            margin: 0;
            font-size: 1.25rem;
        }

        .filter-group {
            margin-bottom: 1rem;
        }

        .filter-group label {
            font-weight: 500;
            color: #374151;
            margin-bottom: 0.5rem;
            display: block;
        }

        .filter-group select,
        .filter-group input {
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            padding: 0.75rem;
            transition: all 0.3s;
        }

        .filter-group select:focus,
        .filter-group input:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
            outline: none;
        }

        /* Cards de métricas */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .metric-card {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            position: relative;
            overflow: hidden;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .metric-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 50px rgba(0,0,0,0.15);
        }

        .metric-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            opacity: 0.1;
            transform: translate(30%, -30%);
        }

        .metric-card.pink::before { background: #ec4899; }
        .metric-card.cyan::before { background: #06b6d4; }
        .metric-card.yellow::before { background: #f59e0b; }
        .metric-card.purple::before { background: #8b5cf6; }

        .metric-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .metric-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .metric-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        .metric-card.pink .metric-icon { background: #fce7f3; color: #ec4899; }
        .metric-card.cyan .metric-icon { background: #cffafe; color: #06b6d4; }
        .metric-card.yellow .metric-icon { background: #fef3c7; color: #f59e0b; }
        .metric-card.purple .metric-icon { background: #ede9fe; color: #8b5cf6; }

        .metric-value {
            font-size: 2.5rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 0.5rem;
        }

        .metric-subtitle {
            font-size: 0.875rem;
            color: #6b7280;
        }

        /* Chart containers */
        .charts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .chart-card {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }

        .chart-header {
            margin-bottom: 1.5rem;
        }

        .chart-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #1f2937;
            margin: 0 0 0.5rem 0;
        }

        .chart-subtitle {
            font-size: 0.875rem;
            color: #6b7280;
            margin: 0;
        }

        .chart-container {
            position: relative;
            height: 300px;
        }

        /* Botones de acción */
        .btn-filter {
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 0.75rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-filter:hover {
            background: #4338ca;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(79, 70, 229, 0.3);
        }

        .btn-reset {
            background: #f3f4f6;
            color: #374151;
            border: none;
            border-radius: 10px;
            padding: 0.75rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-reset:hover {
            background: #e5e7eb;
        }

        .btn-export {
            background: var(--secondary-color);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 0.75rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-export:hover {
            background: #059669;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(16, 185, 129, 0.3);
        }

        /* Loading state */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .loading-overlay.active {
            display: flex;
        }

        .loading-spinner {
            background: white;
            padding: 2rem;
            border-radius: 20px;
            text-align: center;
        }

        .spinner-border {
            width: 3rem;
            height: 3rem;
            border-width: 0.3rem;
        }

        /* Tabla de detalles */
        .details-table {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            margin-top: 2rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }

        .table {
            margin: 0;
        }

        .table thead th {
            border-bottom: 2px solid #e5e7eb;
            color: #374151;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f3f4f6;
        }

        .badge {
            padding: 0.5rem 1rem;
            border-radius: 10px;
            font-weight: 500;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .charts-grid {
                grid-template-columns: 1fr;
            }
            
            .metrics-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="main-container">
        <!-- Header -->
        <div class="page-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1><i class="bi bi-graph-up"></i> Indicadores y Reportes</h1>
                    <p>Análisis detallado de equipos, asignaciones y tendencias</p>
                </div>
                <div>
                    <button class="btn btn-export" onclick="exportReport()">
                        <i class="bi bi-download"></i> Exportar Excel
                    </button>
                    <button class="btn btn-export ms-2" onclick="exportPDFWithCharts()">
                        <i class="bi bi-file-pdf"></i> Exportar PDF
                    </button>
                </div>
            </div>
        </div>

        <!-- Panel de Filtros -->
        <div class="filters-panel">
            <div class="filters-header">
                <h3><i class="bi bi-funnel"></i> Filtros de Búsqueda</h3>
                <div>
                    <button class="btn btn-secondary me-2" onclick="toggleComparison()">
                        <i class="bi bi-graph-up-arrow"></i> Comparar Períodos
                    </button>
                    <button class="btn btn-reset" onclick="resetFilters()">
                        <i class="bi bi-arrow-clockwise"></i> Limpiar Filtros
                    </button>
                </div>
            </div>

            <form id="filtersForm">
                <div class="row">
                    <div class="col-md-3 filter-group">
                        <label for="startDate">Fecha Inicio</label>
                        <input type="date" class="form-control" id="startDate" name="startDate">
                    </div>
                    
                    <div class="col-md-3 filter-group">
                        <label for="endDate">Fecha Fin</label>
                        <input type="date" class="form-control" id="endDate" name="endDate">
                    </div>

                    <div class="col-md-3 filter-group">
                        <label for="equipmentType">Tipo de Equipo</label>
                        <select class="form-select" id="equipmentType" name="equipmentType">
                            <option value="">Todos</option>
                            <option value="Desktop">Desktop</option>
                            <option value="Laptop">Laptop</option>
                            <option value="Tablet">Tablet</option>
                            <option value="Smartphone">Smartphone</option>
                            <option value="Monitor">Monitor</option>
                        </select>
                    </div>

                    <div class="col-md-3 filter-group">
                        <label for="status">Estado</label>
                        <select class="form-select" id="status" name="status">
                            <option value="">Todos</option>
                            <option value="Asignado">Asignado</option>
                            <option value="Disponible">Disponible</option>
                            <option value="Mantenimiento">Mantenimiento</option>
                            <option value="Obsoleto">Obsoleto</option>
                        </select>
                    </div>

                    <div class="col-md-3 filter-group">
                        <label for="department">Departamento</label>
                        <select class="form-select" id="department" name="department">
                            <option value="">Todos</option>
                        </select>
                    </div>

                    <div class="col-md-3 filter-group">
                        <label for="location">Ubicación</label>
                        <select class="form-select" id="location" name="location">
                            <option value="">Todas</option>
                        </select>
                    </div>

                    <div class="col-md-3 filter-group">
                        <label for="brand">Marca</label>
                        <select class="form-select" id="brand" name="brand">
                            <option value="">Todas</option>
                        </select>
                    </div>

                    <div class="col-md-3 filter-group d-flex align-items-end">
                        <button type="submit" class="btn btn-filter w-100">
                            <i class="bi bi-search"></i> Aplicar Filtros
                        </button>
                    </div>
                </div>

                <!-- Panel de Comparación (oculto inicialmente) -->
                <div id="comparisonPanel" class="mt-3" style="display: none;">
                    <div class="alert alert-info">
                        <strong><i class="bi bi-info-circle"></i> Modo Comparación:</strong> 
                        Selecciona un segundo período para comparar con el actual
                    </div>
                    <div class="row">
                        <div class="col-md-4 filter-group">
                            <label for="compareStartDate">Fecha Inicio (Comparación)</label>
                            <input type="date" class="form-control" id="compareStartDate" name="compareStartDate">
                        </div>
                        
                        <div class="col-md-4 filter-group">
                            <label for="compareEndDate">Fecha Fin (Comparación)</label>
                            <input type="date" class="form-control" id="compareEndDate" name="compareEndDate">
                        </div>

                        <div class="col-md-4 filter-group d-flex align-items-end">
                            <button type="button" class="btn btn-info w-100" onclick="comparePeríods()">
                                <i class="bi bi-bar-chart-line"></i> Comparar
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>



        <!-- Gráficos -->
        <div class="charts-grid">
            <!-- Gráfico de Aplicados con Predicción -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3 class="chart-title">
                        <i class="bi bi-bar-chart-line"></i> Análisis y Tendencias
                    </h3>
                    <p class="chart-subtitle">Distribución de asignaciones con predicción de tendencia</p>
                </div>
                <div class="chart-container">
                    <canvas id="applicadosChart"></canvas>
                </div>
                <div class="mt-3" id="trendInfo" style="display: none;">
                    <div class="alert alert-success">
                        <strong><i class="bi bi-graph-up"></i> Tendencia:</strong>
                        <span id="trendText"></span>
                    </div>
                </div>
            </div>

            <!-- Gráfico de Estado Actual con Comparación -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3 class="chart-title">
                        <i class="bi bi-graph-up"></i> Estado Actual
                    </h3>
                    <p class="chart-subtitle">Distribución de equipos por estado</p>
                </div>
                <div class="chart-container">
                    <canvas id="estadoChart"></canvas>
                </div>
                <div class="mt-3" id="comparisonInfo" style="display: none;">
                    <div class="alert alert-info">
                        <strong><i class="bi bi-arrow-left-right"></i> Comparación:</strong>
                        <span id="comparisonText"></span>
                    </div>
                </div>
            </div>

            <!-- Gráfico de Distribución General -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3 class="chart-title">
                        <i class="bi bi-pie-chart"></i> Distribución General
                    </h3>
                    <p class="chart-subtitle">Equipos por tipo y categoría</p>
                </div>
                <div class="chart-container">
                    <canvas id="equiposChart"></canvas>
                </div>
            </div>

            <!-- Gauge de Aplicados -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3 class="chart-title">
                        <i class="bi bi-speedometer2"></i> Índice de Asignación
                    </h3>
                    <p class="chart-subtitle">Porcentaje de equipos asignados</p>
                </div>
                <div class="chart-container">
                    <canvas id="gaugeChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Nuevas Secciones de Análisis Avanzado -->
        
        <!-- Comparación de Períodos -->
        <div id="comparisonSection" style="display: none;">
            <div class="chart-card mb-4">
                <div class="chart-header">
                    <h3 class="chart-title">
                        <i class="bi bi-arrow-left-right"></i> Comparación de Períodos
                    </h3>
                    <p class="chart-subtitle">Análisis comparativo entre dos períodos seleccionados</p>
                </div>
                <div class="chart-container" style="height: 400px;">
                    <canvas id="comparisonChart"></canvas>
                </div>
                <div class="row mt-4">
                    <div class="col-md-6">
                        <div class="alert alert-primary">
                            <h5>Período Principal</h5>
                            <div id="period1Summary"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="alert alert-secondary">
                            <h5>Período de Comparación</h5>
                            <div id="period2Summary"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de Detalles -->

    </div>

    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner">A
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-3 mb-0">Procesando datos...</p>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
// ============================================================================
// INDICADORES.HTML - JAVASCRIPT CORREGIDO CON FILTROS FUNCIONALES
// ============================================================================
// INSTRUCCIONES: Reemplazar el <script> del archivo indicadores.html
// con este código (desde línea ~500 hasta el final)
// ============================================================================

// ============================================================================
// CONFIGURACIÓN GENERAL Y VARIABLES GLOBALES
// ============================================================================

const API_BASE = 'http://localhost:3000/api/indicators';

let charts = {};
let currentFilters = {};
let comparisonMode = false;
let trendData = null;

// ============================================================================
// INICIALIZACIÓN
// ============================================================================

$(document).ready(function() {
    initializeDateFilters();
    loadInitialData();
    loadFilterOptions();
    setupEventListeners();
});

function initializeDateFilters() {
    const today = new Date();
    const firstDayOfMonth = new Date(today.getFullYear(), today.getMonth(), 1);
    const lastMonth = new Date(today.getFullYear(), today.getMonth() - 1, 1);
    const lastMonthEnd = new Date(today.getFullYear(), today.getMonth(), 0);
    
    $('#startDate').val(formatDate(firstDayOfMonth));
    $('#endDate').val(formatDate(today));
    $('#compareStartDate').val(formatDate(lastMonth));
    $('#compareEndDate').val(formatDate(lastMonthEnd));
}

function setupEventListeners() {
    $('#filtersForm').on('submit', function(e) {
        e.preventDefault();
        applyFilters();
    });
}

// ============================================================================
// FUNCIONES DE CARGA DE DATOS
// ============================================================================

async function loadInitialData() {
    showLoading();
    try {
        await Promise.all([
            loadMetrics(),
            loadChartData(),
            loadAssignmentsTable()
        ]);
    } catch (error) {
        console.error('Error loading data:', error);
        alert('Error al cargar los datos');
    } finally {
        hideLoading();
    }
}

async function loadMetrics() {
    try {
        const filters = getFilters();
        const params = new URLSearchParams(filters);
        
        // ⭐ CAMBIO: Usar el endpoint correcto
        const response = await fetch(`${API_BASE}/metrics?${params}`);
        const result = await response.json();
        
        if (result.success && result.data) {
            // Actualizar las métricas en el HTML
            $('#totalEmployees').text(result.data.totalEmployees.toLocaleString());
            $('#totalEquipment').text(result.data.totalEquipment.toLocaleString());
            $('#activeAssignments').text(result.data.activeAssignments.toLocaleString());
            
            console.log('✅ Métricas cargadas:', result.data);
        }
    } catch (error) {
        console.error('Error loading metrics:', error);
    }
}

async function loadFilterOptions() {
    try {
        // Cargar departamentos
        const deptResponse = await fetch('http://localhost:3000/api/departments');
        const deptResult = await deptResponse.json();
        if (deptResult.success) {
            deptResult.data.forEach(dept => {
                $('#department').append(`<option value="${dept.id}">${dept.department_name}</option>`);
            });
        }

        // Cargar ubicaciones
        const locResponse = await fetch('http://localhost:3000/api/locations');
        const locResult = await locResponse.json();
        if (locResult.success) {
            locResult.data.forEach(loc => {
                $('#location').append(`<option value="${loc.id}">${loc.location_name}</option>`);
            });
        }

        // Cargar marcas únicas
        const equipResponse = await fetch('http://localhost:3000/api/equipment');
        const equipResult = await equipResponse.json();
        if (equipResult.success) {
            const uniqueBrands = [...new Set(equipResult.data.map(eq => eq.brand).filter(Boolean))];
            uniqueBrands.sort().forEach(brand => {
                $('#brand').append(`<option value="${brand}">${brand}</option>`);
            });
        }
    } catch (error) {
        console.error('Error loading filter options:', error);
    }
}

async function loadChartData() {
    const filters = getFilters();
    const params = new URLSearchParams(filters);
    
    try {
        // ⭐ CAMBIO: Usar los endpoints correctos
        const [timelineData, statusData, distributionData, rateData] = await Promise.all([
            fetch(`${API_BASE}/assignments-timeline?${params}`).then(r => r.json()),
            fetch(`${API_BASE}/equipment-by-status?${params}`).then(r => r.json()),
            fetch(`${API_BASE}/equipment-distribution?${params}`).then(r => r.json()),
            fetch(`${API_BASE}/assignment-rate?${params}`).then(r => r.json())
        ]);
        
        if (timelineData.success) {
            createApplicadosChart(timelineData.data);
        }
        
        if (statusData.success) {
            createEstadoChart(statusData.data);
        }
        
        if (distributionData.success) {
            createEquiposChart(distributionData.data);
        }
        
        if (rateData.success) {
            createGaugeChart(rateData.data.rate);
        }
        
        console.log('✅ Gráficos actualizados con filtros');
        
    } catch (error) {
        console.error('Error loading chart data:', error);
    }
}

async function loadAssignmentsTable() {
    try {
        const filters = getFilters();
        const params = new URLSearchParams({ ...filters, limit: 50 });
        
        // ⭐ CAMBIO: Usar el endpoint correcto
        const response = await fetch(`${API_BASE}/assignments-detailed?${params}`);
        const result = await response.json();
        
        if (result.success) {
            renderAssignmentsTable(result.data);
            console.log(`✅ Tabla cargada: ${result.data.length} asignaciones`);
        }
    } catch (error) {
        console.error('Error loading assignments:', error);
    }
}

function renderAssignmentsTable(assignments) {
    const tbody = $('#assignmentsTableBody');
    tbody.empty();
    
    if (!assignments || assignments.length === 0) {
        tbody.append('<tr><td colspan="8" class="text-center">No se encontraron asignaciones</td></tr>');
        return;
    }
    
    assignments.forEach(assignment => {
        const statusColor = {
            'Asignado': 'success',
            'Disponible': 'info',
            'Mantenimiento': 'warning',
            'Obsoleto': 'danger'
        }[assignment.equipment_status] || 'secondary';
        
        const row = `
            <tr>
                <td><strong>${assignment.assignment_id}</strong></td>
                <td>
                    <div>${assignment.employee_name}</div>
                    <small class="text-muted">${assignment.employee_cip}</small>
                </td>
                <td>
                    <div>${assignment.equipment_code}</div>
                    <small class="text-muted">${assignment.brand || ''} ${assignment.model || ''}</small>
                </td>
                <td><span class="badge bg-info">${assignment.equipment_type || 'N/A'}</span></td>
                <td>${assignment.department_name || 'N/A'}</td>
                <td>
                    <div>${assignment.location_name || 'N/A'}</div>
                    <small class="text-muted">${assignment.city || ''}</small>
                </td>
                <td>
                    <div>${formatDate(assignment.assignment_date)}</div>
                    <small class="text-muted">${assignment.days_assigned} días</small>
                </td>
                <td><span class="badge bg-${statusColor}">${assignment.equipment_status}</span></td>
            </tr>
        `;
        tbody.append(row);
    });
}

