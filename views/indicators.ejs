function getFilters() {
    return {
        startDate: $('#startDate').val(),
        endDate: $('#endDate').val(),
        equipmentType: $('#equipmentType').val(),
        status: $('#status').val(),
        department: $('#department').val(),
        location: $('#location').val(),
        brand: $('#brand').val()
    };
}

async function applyFilters() {
    showLoading();
    try {
        console.log('🔍 Aplicando filtros:', getFilters());
        
        // Recargar todos los datos con filtros
        await Promise.all([
            loadMetrics(),
            loadChartData(),
            loadAssignmentsTable()
        ]);
        
        console.log('✅ Filtros aplicados correctamente');
        
    } catch (error) {
        console.error('Error applying filters:', error);
        alert('Error al aplicar filtros');
    } finally {
        hideLoading();
    }
}

function resetFilters() {
    $('#filtersForm')[0].reset();
    initializeDateFilters();
    applyFilters();
}

// ============================================================================
// MODO COMPARACIÓN
// ============================================================================

function toggleComparison() {
    comparisonMode = !comparisonMode;
    $('#comparisonPanel').slideToggle();
    
    if (!comparisonMode) {
        $('#comparisonSection').hide();
    }
}

async function comparePeríods() {
    showLoading();
    try {
        const filters1 = {
            startDate: $('#startDate').val(),
            endDate: $('#endDate').val(),
            ...getFilters()
        };
        
        const filters2 = {
            startDate: $('#compareStartDate').val(),
            endDate: $('#compareEndDate').val(),
            ...getFilters()
        };
        
        const [data1, data2] = await Promise.all([
            fetch(`${API_BASE}/comparison-data?${new URLSearchParams(filters1)}`).then(r => r.json()),
            fetch(`${API_BASE}/comparison-data?${new URLSearchParams(filters2)}`).then(r => r.json())
        ]);
        
        if (data1.success && data2.success) {
            createComparisonChart(data1.data, data2.data, filters1, filters2);
            $('#comparisonSection').show();
            displayComparisonSummary(data1.data, data2.data);
        }
    } catch (error) {
        console.error('Error comparing periods:', error);
        alert('Error al comparar períodos');
    } finally {
        hideLoading();
    }
}

function createComparisonChart(data1, data2, filters1, filters2) {
    const ctx = document.getElementById('comparisonChart');
    if (charts.comparison) charts.comparison.destroy();
    
    const period1Label = `${filters1.startDate} a ${filters1.endDate}`;
    const period2Label = `${filters2.startDate} a ${filters2.endDate}`;
    
    charts.comparison = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Asignaciones', 'Equipos Nuevos', 'Devoluciones', 'Mantenimientos'],
            datasets: [
                {
                    label: period1Label,
                    data: [
                        data1.total_assignments || 0,
                        data1.new_equipment || 0,
                        data1.returns || 0,
                        data1.maintenance || 0
                    ],
                    backgroundColor: '#3b82f6',
                },
                {
                    label: period2Label,
                    data: [
                        data2.total_assignments || 0,
                        data2.new_equipment || 0,
                        data2.returns || 0,
                        data2.maintenance || 0
                    ],
                    backgroundColor: '#10b981',
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'top' },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return `${context.dataset.label}: ${context.parsed.y}`;
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { precision: 0 }
                }
            }
        }
    });
}

function displayComparisonSummary(data1, data2) {
    const calc = (val1, val2) => {
        const diff = val1 - val2;
        const pct = val2 !== 0 ? ((diff / val2) * 100).toFixed(1) : 0;
        const icon = diff > 0 ? '▲' : diff < 0 ? '▼' : '━';
        const color = diff > 0 ? 'success' : diff < 0 ? 'danger' : 'secondary';
        return { diff, pct, icon, color };
    };
    
    const assignmentsCmp = calc(data1.total_assignments, data2.total_assignments);
    const equipmentCmp = calc(data1.new_equipment, data2.new_equipment);
    
    $('#period1Summary').html(`
        <p><strong>Asignaciones:</strong> ${data1.total_assignments || 0}</p>
        <p><strong>Equipos Nuevos:</strong> ${data1.new_equipment || 0}</p>
        <p><strong>Devoluciones:</strong> ${data1.returns || 0}</p>
    `);
    
    $('#period2Summary').html(`
        <p><strong>Asignaciones:</strong> ${data2.total_assignments || 0} 
           <span class="badge bg-${assignmentsCmp.color}">${assignmentsCmp.icon} ${assignmentsCmp.pct}%</span>
        </p>
        <p><strong>Equipos Nuevos:</strong> ${data2.new_equipment || 0}
           <span class="badge bg-${equipmentCmp.color}">${equipmentCmp.icon} ${equipmentCmp.pct}%</span>
        </p>
        <p><strong>Devoluciones:</strong> ${data2.returns || 0}</p>
    `);
}

// ============================================================================
// CREACIÓN DE GRÁFICOS
