<script>
/* ── Aliases de seguridad: cubren el caso de JS viejo en caché ── */
document.addEventListener('DOMContentLoaded', function() {
    if (typeof window.rec_abrirModalNuevo !== 'function') {
        window.rec_abrirModalNuevo = function() {
            var m = document.getElementById('newRecoveryModal');
            if (m) new bootstrap.Modal(m).show();
        };
    }
    if (typeof window.rec_aplicarFiltro !== 'function' && typeof window.aplicarFiltro === 'function')
        window.rec_aplicarFiltro = window.aplicarFiltro;
    if (typeof window.rec_recargarTabla !== 'function' && typeof window.recargarTabla === 'function')
        window.rec_recargarTabla = window.recargarTabla;
    if (typeof window.rec_abrirModalEdicion !== 'function' && typeof window.abrirModalEdicion === 'function')
        window.rec_abrirModalEdicion = window.abrirModalEdicion;
    if (typeof window.rec_eliminarRecupero !== 'function' && typeof window.eliminarRecupero === 'function')
        window.rec_eliminarRecupero = window.eliminarRecupero;
});
</script>

<script>
/* ════════════════════════════════════════════════════
   MAIN TAB SWITCHER
════════════════════════════════════════════════════ */
function switchMainTab(name, btn) {
    document.querySelectorAll('.main-tab-pane').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.main-tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('maintab-' + name).classList.add('active');
    btn.classList.add('active');

    // Si se activa recuperos, recargar la tabla
    if (name === 'recuperos' && typeof rec_recargarTabla === 'function') {
        setTimeout(() => { if (typeof $.fn.DataTable !== 'undefined') rec_recargarTabla(); }, 100);
    }
}

/* ════════════════════════════════════════════════════
   CHARTS — init después de que los JS carguen datos
════════════════════════════════════════════════════ */
let chartStockTipo      = null;
let chartFallasComp     = null;
let chartRecuperosEst   = null;

function initCharts() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const gridColor  = isDark ? 'rgba(255,255,255,.06)' : 'rgba(0,0,0,.05)';
    const tickColor  = isDark ? '#94a3b8' : '#64748b';

    // ── Stock por tipo (doughnut) ──
    const ctxStock = document.getElementById('chartStockTipo').getContext('2d');
    if (chartStockTipo) chartStockTipo.destroy();
    chartStockTipo = new Chart(ctxStock, {
        type: 'doughnut',
        data: {
            labels: ['Laptops','Desktops','Monitores','Otros'],
            datasets: [{ data: [0,0,0,0], backgroundColor: ['#06b6d4','#10b981','#f59e0b','#8b5cf6'], borderWidth: 0, hoverOffset: 6 }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { color: tickColor, font: { size: 11 }, padding: 10 } } }, cutout: '65%' }
    });

    // ── Fallas por componente (bar horizontal) ──
    const ctxFallas = document.getElementById('chartFallasComp').getContext('2d');
    if (chartFallasComp) chartFallasComp.destroy();
    chartFallasComp = new Chart(ctxFallas, {
        type: 'bar',
        data: {
            labels: [],
            datasets: [{ data: [], backgroundColor: '#f59e0b', borderRadius: 5 }]
        },
        options: {
            indexAxis: 'y', responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: gridColor }, ticks: { color: tickColor, font: { size: 10 } } },
                y: { grid: { display: false }, ticks: { color: tickColor, font: { size: 10 } } }
            }
        }
    });

    // ── Recuperos por estado (bar) ──
    const ctxRec = document.getElementById('chartRecuperosEstado').getContext('2d');
    if (chartRecuperosEst) chartRecuperosEst.destroy();
    chartRecuperosEst = new Chart(ctxRec, {
        type: 'bar',
        data: {
            labels: ['Por recuperar','En gestión','Recogido','En oficina','En revisión','Listo','Recuperado'],
            datasets: [{ data: [0,0,0,0,0,0,0], backgroundColor: ['#ef4444','#f59e0b','#6366f1','#6366f1','#8b5cf6','#10b981','#94a3b8'], borderRadius: 5 }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { color: tickColor, font: { size: 9 } } },
                y: { grid: { color: gridColor }, ticks: { color: tickColor, font: { size: 10 } } }
            }
        }
    });
}

/* ════════════════════════════════════════════════════
   ACTUALIZAR CHARTS con datos reales
════════════════════════════════════════════════════ */
function updateChartStock(stats) {
    if (!chartStockTipo || !stats) return;
    const laptop  = stats.find(s => s.tipo === 'Laptop')?.total  || 0;
    const desktop = stats.find(s => s.tipo === 'Desktop')?.total || 0;
    const monitor = stats.find(s => s.tipo === 'Monitor')?.total || 0;
    const otros   = stats.reduce((a, s) => !['Laptop','Desktop','Monitor'].includes(s.tipo) ? a + (s.total||0) : a, 0);
    chartStockTipo.data.datasets[0].data = [laptop, desktop, monitor, otros];
    chartStockTipo.update();
}

function updateChartFallas(rows) {
    if (!chartFallasComp || !rows?.length) return;
    const counts = {};
    rows.forEach(r => { counts[r.component] = (counts[r.component] || 0) + 1; });
    const sorted = Object.entries(counts).sort((a,b) => b[1]-a[1]).slice(0,6);
    chartFallasComp.data.labels   = sorted.map(e => e[0]);
    chartFallasComp.data.datasets[0].data = sorted.map(e => e[1]);
    chartFallasComp.update();
}

function updateChartRecuperos(kpis) {
    if (!chartRecuperosEst || !kpis) return;
    chartRecuperosEst.data.datasets[0].data = [
        kpis.por_recuperar||0, kpis.en_proceso||0, 0, 0,
        kpis.en_revision||0, kpis.listos||0, kpis.recuperados_mes||0
    ];
    chartRecuperosEst.update();
}

/* ════════════════════════════════════════════════════
   COUNTER TABS
════════════════════════════════════════════════════ */
function updateMainTabCounts(disponibles, recuperos) {
    if (disponibles !== undefined) document.getElementById('mtc-almacen').textContent  = disponibles;
    if (recuperos   !== undefined) document.getElementById('mtc-recuperos').textContent = recuperos;
}

/* ════════════════════════════════════════════════════
   INIT
════════════════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', () => {
    initCharts();

    // Hook: cuando almacen-dashboard.js cargue KPIs, actualizar chart
    const origLoadStats = window.cargarStats;
    if (typeof origLoadStats === 'function') {
        window.cargarStats = async function() {
            const result = await origLoadStats.apply(this, arguments);
            return result;
        };
    }

    // Hook: escuchar cuando disponibles se carguen para actualizar tab count
    const _origCargarDisponibles = window.cargarDisponibles;
    if (typeof _origCargarDisponibles === 'function') {
        window.cargarDisponibles = async function() {
            const r = await _origCargarDisponibles.apply(this, arguments);
            const cnt = document.getElementById('cnt-disponibles');
            if (cnt) updateMainTabCounts(cnt.textContent, undefined);
            return r;
        };
    }

    // Hook: KPIs de recuperos para chart
    const _origCargarKPIs = window.cargarKPIs;
    if (typeof _origCargarKPIs === 'function') {
        window.cargarKPIs = async function() {
            const r = await _origCargarKPIs.apply(this, arguments);
            // Leer los valores ya renderizados
            setTimeout(() => {
                const kpis = {
                    por_recuperar:   parseInt(document.getElementById('kpiPorRecuperar')?.textContent) || 0,
                    en_proceso:      parseInt(document.getElementById('kpiEnProceso')?.textContent)    || 0,
                    en_revision:     parseInt(document.getElementById('kpiEnRevision')?.textContent)   || 0,
                    listos:          parseInt(document.getElementById('kpiListos')?.textContent)        || 0,
                    recuperados_mes: parseInt(document.getElementById('kpiRecuperadosMes')?.textContent)|| 0,
                };
                updateChartRecuperos(kpis);
                const total = kpis.por_recuperar + kpis.en_proceso + kpis.en_revision + kpis.listos;
                updateMainTabCounts(undefined, total);
            }, 300);
            return r;
        };
    }

    // Observar cambios en el totalCount (DataTable recoveries)
    const totalCount = document.getElementById('totalCount');
    if (totalCount) {
        new MutationObserver(() => {
            updateMainTabCounts(undefined, totalCount.textContent);
        }).observe(totalCount, { childList: true, characterData: true, subtree: true });
    }

    // Observar fallas para chart
    const tblFallas = document.getElementById('tbl-fallas');
    if (tblFallas) {
        new MutationObserver(() => {
            const rows = [];
            tblFallas.querySelectorAll('tr[data-component]').forEach(tr => {
                rows.push({ component: tr.dataset.component });
            });
            // fallback: leer celdas
            tblFallas.querySelectorAll('tr:not(.empty-row)').forEach(tr => {
                const td = tr.querySelectorAll('td')[1];
                if (td && td.textContent.trim()) rows.push({ component: td.textContent.trim() });
            });
            if (rows.length) updateChartFallas(rows);
        }).observe(tblFallas, { childList: true, subtree: true });
    }

    // Observar KPI stock para chart
    ['kpi-laptop','kpi-desktop','kpi-monitor'].forEach(id => {
        const el = document.getElementById(id);
        if (el) new MutationObserver(() => {
            const laptop  = parseInt(document.getElementById('kpi-laptop')?.textContent)  || 0;
            const desktop = parseInt(document.getElementById('kpi-desktop')?.textContent) || 0;
            const monitor = parseInt(document.getElementById('kpi-monitor')?.textContent) || 0;
            const total   = parseInt(document.getElementById('kpi-total')?.textContent)   || 0;
            const otros   = Math.max(0, total - laptop - desktop - monitor);
            if (chartStockTipo) {
                chartStockTipo.data.datasets[0].data = [laptop, desktop, monitor, otros];
                chartStockTipo.update();
            }
        }).observe(el, { childList: true, characterData: true, subtree: true });
    });
});
</script>

</body>
</html>
