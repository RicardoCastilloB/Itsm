<!DOCTYPE html>
<html lang="es" data-theme="light"> 
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Almacén Workplace</title>

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<style>
/* ════════════════════════════════════════════════════
   VARIABLES
════════════════════════════════════════════════════ */
:root,[data-theme="light"]{
    --bg:#f0f4f8;--card:#ffffff;--hdr:#f8fafc;--border:#e2e8f0;
    --text:#1e293b;--muted:#64748b;--primary:#3b82f6;--success:#10b981;
    --warning:#f59e0b;--info:#06b6d4;--danger:#ef4444;--purple:#8b5cf6;
    --hover:#f1f5f9;--input-bg:#ffffff;
    --sh-sm:0 1px 3px rgba(0,0,0,.06);--sh-md:0 4px 12px rgba(0,0,0,.08);--sh-lg:0 8px 24px rgba(0,0,0,.10);
    --mono:'JetBrains Mono',monospace;
}
[data-theme="dark"]{
    --bg:#0f172a;--card:#1e293b;--hdr:#162032;--border:#2d3f55;
    --text:#e2e8f0;--muted:#94a3b8;--primary:#60a5fa;--success:#34d399;
    --warning:#fbbf24;--info:#22d3ee;--danger:#f87171;--purple:#a78bfa;
    --hover:#243348;--input-bg:#1e293b;
    --sh-sm:0 1px 3px rgba(0,0,0,.3);--sh-md:0 4px 12px rgba(0,0,0,.4);--sh-lg:0 8px 24px rgba(0,0,0,.5);
}

/* ════════════════════════════════════════════════════
   BASE
════════════════════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;}
body{margin:0;background:var(--bg);color:var(--text);font-family:'DM Sans',-apple-system,sans-serif;transition:background .3s,color .3s;overflow-x:hidden;}
.pg{max-width:1700px;margin:0 auto;padding:24px 20px;margin-top:64px;}

/* ════════════════════════════════════════════════════
   PAGE HEADER
════════════════════════════════════════════════════ */
.page-hdr{display:flex;align-items:center;gap:16px;margin-bottom:28px;}
.page-hdr-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;box-shadow:var(--sh-md);}
.page-hdr h1{font-size:22px;font-weight:800;margin:0;color:var(--text);}
.page-hdr p{margin:3px 0 0;font-size:13px;color:var(--muted);}

/* ════════════════════════════════════════════════════
   SECTION TITLE
════════════════════════════════════════════════════ */
.sec-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);margin:0 0 14px;display:flex;align-items:center;gap:8px;}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border);}

/* ════════════════════════════════════════════════════
   KPI GRID — dos grupos
════════════════════════════════════════════════════ */
.kpi-grid-almacen{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:8px;}
.kpi-grid-recoveries{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px;}
@media(max-width:1100px){.kpi-grid-almacen{grid-template-columns:repeat(2,1fr);}.kpi-grid-recoveries{grid-template-columns:repeat(3,1fr);}}
@media(max-width:600px){.kpi-grid-almacen,.kpi-grid-recoveries{grid-template-columns:repeat(2,1fr);}}

.kpi{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 18px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:all .2s;box-shadow:var(--sh-sm);position:relative;overflow:hidden;}
.kpi::before{content:'';position:absolute;inset:0;background:var(--kc);opacity:0;transition:opacity .2s;}
.kpi:hover::before,.kpi.active::before{opacity:.06;}
.kpi.active{border-color:var(--kc)!important;box-shadow:0 0 0 2px var(--kc)!important;}
.kpi.no-click{cursor:default;}
.kpi-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin-bottom:5px;}
.kpi-val{font-size:28px;font-weight:800;line-height:1;color:var(--kc);}
.kpi-sub{font-size:11px;color:var(--muted);margin-top:4px;}
.kpi-icon{font-size:32px;opacity:.18;color:var(--kc);}
.kpi-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:5px;}

/* ════════════════════════════════════════════════════
   CHARTS ROW
════════════════════════════════════════════════════ */
.charts-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:24px;}
@media(max-width:1100px){.charts-row{grid-template-columns:1fr 1fr;}}
@media(max-width:680px){.charts-row{grid-template-columns:1fr;}}

.chart-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:18px;box-shadow:var(--sh-sm);}
.chart-title{font-size:12px;font-weight:700;color:var(--text);margin-bottom:14px;display:flex;align-items:center;gap:6px;}
.chart-canvas-wrap{position:relative;height:160px;}

/* ════════════════════════════════════════════════════
   MAIN TABS
════════════════════════════════════════════════════ */
.main-tabs{display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:20px;}
.main-tab-btn{padding:12px 22px;font-size:13px;font-weight:700;color:var(--muted);background:none;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;margin-bottom:-2px;display:flex;align-items:center;gap:7px;}
.main-tab-btn:hover{color:var(--text);}
.main-tab-btn.active{color:var(--primary);border-bottom-color:var(--primary);}
.main-tab-btn .tab-count{background:var(--border);color:var(--muted);padding:1px 7px;border-radius:10px;font-size:11px;font-weight:700;}
.main-tab-btn.active .tab-count{background:rgba(59,130,246,.15);color:var(--primary);}

.main-tab-pane{display:none;}
.main-tab-pane.active{display:block;}

/* ════════════════════════════════════════════════════
   SUB-TABS (almacén)
════════════════════════════════════════════════════ */
.tabs{display:flex;gap:4px;border-bottom:2px solid var(--border);margin-bottom:16px;}
.tab-btn{padding:9px 16px;font-size:13px;font-weight:600;color:var(--muted);background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;transition:all .15s;margin-bottom:-2px;}
.tab-btn:hover{color:var(--text);}
.tab-btn.active{color:var(--primary);border-bottom-color:var(--primary);}
.tab-pane{display:none;}
.tab-pane.active{display:block;}

/* ════════════════════════════════════════════════════
   CARD BASE
════════════════════════════════════════════════════ */
.card-ui{background:var(--card);border:1px solid var(--border);border-radius:14px;box-shadow:var(--sh-sm);overflow:hidden;margin-bottom:20px;}
.card-head{padding:13px 18px;background:var(--hdr);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.card-head .title{font-size:13px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px;}

/* ════════════════════════════════════════════════════
   TABLE
════════════════════════════════════════════════════ */
.tbl-wrap{overflow:auto;max-height:480px;}
.tbl{width:100%;border-collapse:collapse;font-size:13px;}
.tbl thead th{background:var(--hdr);color:var(--muted);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;padding:11px 14px;border-bottom:1px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;}
.tbl tbody td{padding:11px 14px;border-bottom:1px solid var(--border);vertical-align:middle;color:var(--text);}
.tbl tbody tr:last-child td{border-bottom:none;}
.tbl tbody tr{transition:background .12s;cursor:pointer;}
.tbl tbody tr:hover td{background:var(--hover);}
.mono{font-family:var(--mono);font-size:12px;}
.link-cell{color:var(--primary);cursor:pointer;font-weight:600;}

/* ════════════════════════════════════════════════════
   DATATABLES — recoveries (dark compat)
════════════════════════════════════════════════════ */
#recoveriesTable thead th{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);background:var(--hdr);border-bottom:1px solid var(--border);padding:11px 14px;}
#recoveriesTable tbody td{padding:11px 14px;vertical-align:middle;font-size:13px;color:var(--text);background:var(--card);}
#recoveriesTable tbody tr:hover td{background:var(--hover)!important;}
.dataTables_wrapper{padding:12px 16px 16px;color:var(--text);}
.dataTables_wrapper .dataTables_length select,
.dataTables_wrapper .dataTables_filter input{background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:8px;padding:4px 8px;}
.dataTables_wrapper .dataTables_info,.dataTables_wrapper .dataTables_paginate{color:var(--muted);}
.dataTables_paginate .paginate_button.current{background:var(--primary)!important;color:#fff!important;border-color:var(--primary)!important;border-radius:6px;}
.dataTables_paginate .paginate_button:hover{background:var(--hover)!important;color:var(--text)!important;}

/* ════════════════════════════════════════════════════
   BADGES
════════════════════════════════════════════════════ */
.badge{display:inline-flex;align-items:center;gap:4px;padding:4px 9px;border-radius:6px;font-size:11px;font-weight:700;border:1px solid transparent;}
.bg-success{background:rgba(16,185,129,.12);color:#059669;border-color:rgba(16,185,129,.25);}
.bg-info{background:rgba(6,182,212,.12);color:#0891b2;border-color:rgba(6,182,212,.25);}
.bg-warning{background:rgba(245,158,11,.12);color:#d97706;border-color:rgba(245,158,11,.25);}
.bg-danger{background:rgba(239,68,68,.12);color:#dc2626;border-color:rgba(239,68,68,.25);}
.bg-secondary{background:rgba(100,116,139,.1);color:var(--muted);border-color:rgba(100,116,139,.2);}
.bg-purple{background:rgba(139,92,246,.12);color:#7c3aed;border-color:rgba(139,92,246,.25);}
.bg-primary-soft{background:rgba(59,130,246,.12);color:#2563eb;border-color:rgba(59,130,246,.25);}

/* ── Recoveries status badges ── */
.status-badge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;}
.status-por_recuperar   {background:rgba(239,68,68,.12); color:#dc2626;}
.status-en_gestion      {background:rgba(245,158,11,.12);color:#d97706;}
.status-recogido_tecnico{background:rgba(99,102,241,.12);color:#6366f1;}
.status-traido_oficina  {background:rgba(99,102,241,.12);color:#6366f1;}
.status-en_revision     {background:rgba(139,92,246,.12);color:#7c3aed;}
.status-listo_para_asignar{background:rgba(16,185,129,.12);color:#059669;}
.status-envio_provincia {background:rgba(59,130,246,.12);color:#2563eb;}
.status-recuperado      {background:rgba(100,116,139,.12);color:#475569;}
.method-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600;background:var(--hdr);color:var(--muted);border:1px solid var(--border);}

/* ════════════════════════════════════════════════════
   BUTTONS
════════════════════════════════════════════════════ */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:10px;font-size:13px;font-weight:600;border:1px solid transparent;cursor:pointer;transition:all .15s;text-decoration:none;}
.btn-sm{padding:5px 12px;font-size:12px;border-radius:8px;}
.btn-primary{background:var(--primary);color:#fff;border-color:var(--primary);}
.btn-primary:hover{filter:brightness(1.1);}
.btn-success{background:var(--success);color:#fff;border-color:var(--success);}
.btn-warning{background:var(--warning);color:#fff;border-color:var(--warning);}
.btn-danger{background:var(--danger);color:#fff;border-color:var(--danger);}
.btn-outline{background:none;border:1px solid var(--border);color:var(--muted);}
.btn-outline:hover{border-color:var(--primary);color:var(--primary);}
.btn-action{width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--muted);display:inline-flex;align-items:center;justify-content:center;font-size:13px;cursor:pointer;transition:all .2s;}
.btn-action:hover{border-color:var(--primary);color:var(--primary);background:rgba(59,130,246,.08);}
.btn-action.btn-advance:hover{border-color:var(--success);color:var(--success);background:rgba(16,185,129,.08);}
.btn-action.btn-delete:hover{border-color:var(--danger);color:var(--danger);background:rgba(239,68,68,.08);}

/* ════════════════════════════════════════════════════
   FORM CONTROLS
════════════════════════════════════════════════════ */
.form-control,.form-select{width:100%;padding:9px 13px;border:1.5px solid var(--border);border-radius:9px;font-size:13px;background:var(--input-bg);color:var(--text);outline:none;transition:border-color .2s,box-shadow .2s;}
.form-control:focus,.form-select:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.12);}
.form-control::placeholder{color:var(--muted);}
.form-label{font-size:12px;font-weight:600;color:var(--text);margin-bottom:5px;display:block;}
.form-label .req{color:var(--danger);}

/* ════════════════════════════════════════════════════
   SEARCH BAR
════════════════════════════════════════════════════ */
.search-bar{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.search-wrap{position:relative;flex:1;min-width:200px;}
.search-wrap .ico{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:14px;pointer-events:none;}
.search-inp{width:100%;padding:8px 12px 8px 36px;border:1.5px solid var(--border);border-radius:9px;font-size:13px;background:var(--input-bg);color:var(--text);outline:none;transition:border-color .2s;}
.search-inp:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.1);}

/* ════════════════════════════════════════════════════
   FILTERS BAR (recoveries)
════════════════════════════════════════════════════ */
.filters-bar{background:var(--card);border-radius:12px;padding:13px 16px;margin-bottom:16px;display:flex;flex-wrap:wrap;gap:8px;align-items:center;box-shadow:var(--sh-sm);border:1px solid var(--border);}
.filter-pill{padding:5px 14px;border-radius:20px;font-size:12px;font-weight:600;border:1.5px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all .2s;}
.filter-pill:hover,.filter-pill.active{border-color:var(--primary);color:var(--primary);background:rgba(59,130,246,.08);}
.filter-pill.f-amber.active{border-color:var(--warning);color:var(--warning);background:rgba(245,158,11,.08);}
.filter-pill.f-blue.active{border-color:#6366f1;color:#6366f1;background:rgba(99,102,241,.08);}
.filter-pill.f-purple.active{border-color:var(--purple);color:var(--purple);background:rgba(139,92,246,.08);}
.filter-pill.f-green.active{border-color:var(--success);color:var(--success);background:rgba(16,185,129,.08);}
.filter-pill.f-red.active{border-color:var(--danger);color:var(--danger);background:rgba(239,68,68,.08);}

/* ════════════════════════════════════════════════════
   PAGINATION
════════════════════════════════════════════════════ */
.pag{display:flex;align-items:center;gap:6px;padding:12px 16px;border-top:1px solid var(--border);}
.pag-info{font-size:12px;color:var(--muted);flex:1;}
.pag-btn{padding:5px 11px;border:1px solid var(--border);border-radius:7px;background:none;color:var(--text);font-size:12px;cursor:pointer;transition:all .15s;}
.pag-btn:hover:not(:disabled){border-color:var(--primary);color:var(--primary);}
.pag-btn:disabled{opacity:.4;cursor:not-allowed;}
.pag-btn.active{background:var(--primary);border-color:var(--primary);color:#fff;}

/* ════════════════════════════════════════════════════
   TRANSFER FORM
════════════════════════════════════════════════════ */
.transfer-form{background:var(--hdr);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:20px;}
.transfer-arrow{display:flex;align-items:center;justify-content:center;font-size:22px;color:var(--primary);}

/* ════════════════════════════════════════════════════
   FLOW STEPPER (recoveries)
════════════════════════════════════════════════════ */
.flow-stepper{display:flex;align-items:center;overflow-x:auto;padding:8px 0 12px;scrollbar-width:thin;}
.flow-step{display:flex;flex-direction:column;align-items:center;min-width:90px;position:relative;}
.flow-step::after{content:'';position:absolute;top:14px;left:calc(50% + 14px);width:calc(100% - 28px);height:2px;background:var(--border);}
.flow-step:last-child::after{display:none;}
.flow-step-dot{width:28px;height:28px;border-radius:50%;background:var(--border);color:var(--muted);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;z-index:1;border:2px solid var(--border);transition:all .3s;}
.flow-step.completed .flow-step-dot{background:var(--success);border-color:var(--success);color:#fff;}
.flow-step.active .flow-step-dot{background:var(--primary);border-color:var(--primary);color:#fff;box-shadow:0 0 0 4px rgba(59,130,246,.2);}
.flow-step.completed::after{background:var(--success);}
.flow-step-label{font-size:9px;font-weight:600;text-align:center;margin-top:4px;color:var(--muted);max-width:80px;line-height:1.2;}
.flow-step.completed .flow-step-label,.flow-step.active .flow-step-label{color:var(--text);}

/* ════════════════════════════════════════════════════
   SEARCH AUTOCOMPLETE (recoveries modals)
════════════════════════════════════════════════════ */
.search-results-dropdown{position:absolute;z-index:1050;width:100%;background:var(--card);border:1px solid var(--border);border-radius:10px;box-shadow:var(--sh-md);max-height:220px;overflow-y:auto;display:none;}
.search-result-item{padding:10px 14px;cursor:pointer;font-size:13px;border-bottom:1px solid var(--border);transition:background .15s;}
.search-result-item:last-child{border-bottom:none;}
.search-result-item:hover{background:var(--hover);}
.search-result-item strong{display:block;font-weight:600;color:var(--text);}
.search-result-item small{color:var(--muted);}

/* ════════════════════════════════════════════════════
   LOG TIMELINE
════════════════════════════════════════════════════ */
.log-timeline{padding:8px 0;}
.log-entry{display:flex;gap:12px;padding:8px 0;border-bottom:1px solid var(--border);}
.log-entry:last-child{border-bottom:none;}
.log-dot{width:10px;height:10px;border-radius:50%;background:var(--primary);flex-shrink:0;margin-top:4px;}
.log-text{font-size:12px;color:var(--text);}
.log-meta{font-size:11px;color:var(--muted);}

/* ════════════════════════════════════════════════════
   MODAL (almacén — custom)
════════════════════════════════════════════════════ */
.modal-backdrop-custom{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1040;display:none;align-items:center;justify-content:center;}
.modal-backdrop-custom.open{display:flex;}
.modal-box{background:var(--card);border:1px solid var(--border);border-radius:18px;width:100%;margin:20px;box-shadow:var(--sh-lg);overflow:hidden;max-height:90vh;display:flex;flex-direction:column;}
.modal-box.sm{max-width:480px;}
.modal-box.md{max-width:640px;}
.modal-box.lg{max-width:900px;}
.modal-hdr{padding:16px 22px;border-bottom:1px solid var(--border);background:var(--hdr);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.modal-hdr-left{display:flex;align-items:center;gap:10px;}
.modal-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.modal-title-txt{font-size:14px;font-weight:700;color:var(--text);}
.modal-sub-txt{font-size:11px;color:var(--muted);}
.modal-close-btn{background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;line-height:1;padding:2px 6px;border-radius:6px;transition:background .15s;}
.modal-close-btn:hover{background:var(--hover);}
.modal-body-custom{padding:22px;overflow-y:auto;flex:1;}
.modal-ftr{padding:14px 22px;border-top:1px solid var(--border);background:var(--hdr);display:flex;gap:10px;justify-content:flex-end;flex-shrink:0;}

/* ════════════════════════════════════════════════════
   DETAIL GRID
════════════════════════════════════════════════════ */
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.detail-cell{background:var(--hdr);border:1px solid var(--border);border-radius:10px;padding:12px 14px;}
.detail-cell.span2{grid-column:1/-1;}
.detail-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);margin-bottom:4px;}
.detail-val{font-size:13px;color:var(--text);font-weight:600;}

/* ════════════════════════════════════════════════════
   EMPTY / LOADING / TOAST
════════════════════════════════════════════════════ */
.empty-row td{text-align:center;padding:32px;color:var(--muted);font-size:13px;}
.spinner-sm{display:inline-block;width:16px;height:16px;border:2px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:spin .65s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

#toastZone{position:fixed;bottom:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;}
.toast-item{padding:12px 18px;border-radius:12px;color:#fff;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:var(--sh-md);animation:toastIn .25s ease;max-width:360px;}
@keyframes toastIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.toast-ok{background:#10b981;}.toast-err{background:#ef4444;}.toast-inf{background:#3b82f6;}.toast-warn{background:#f59e0b;}

/* toast-container-custom para recoveries */
.toast-container-custom{position:fixed;top:72px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;}

*::-webkit-scrollbar{width:5px;height:5px;}
*::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
</style>

