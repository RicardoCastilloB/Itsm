<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SCCM Inventario — Panda EPDR</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="../css/style.css">

<style>
/* ── Variables ──────────────────────────────────────────── */
:root,[data-theme="light"]{
  --bg:#f0f4f8; --card:#ffffff; --header:#f8fafc;
  --border:#e2e8f0; --text:#1e293b; --muted:#64748b;
  --primary:#3b82f6; --success:#10b981; --warning:#f59e0b;
  --danger:#ef4444; --info:#06b6d4; --purple:#8b5cf6;
  --row-hover:#f1f5f9; --shadow:0 1px 3px rgba(0,0,0,.07);
  --shadow-md:0 4px 16px rgba(0,0,0,.10); --input-bg:#f8fafc;
}
[data-theme="dark"]{
  --bg:#0f172a; --card:#1e293b; --header:#162032;
  --border:#2d3f55; --text:#e2e8f0; --muted:#94a3b8;
  --primary:#60a5fa; --success:#34d399; --warning:#fbbf24;
  --danger:#f87171; --info:#22d3ee; --purple:#a78bfa;
  --row-hover:#243348; --shadow:0 1px 3px rgba(0,0,0,.3);
  --shadow-md:0 4px 16px rgba(0,0,0,.4); --input-bg:#162032;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:"DM Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;transition:background .3s,color .3s;font-size:13.5px;}

/* ── Layout ─── */
.pg{margin-top:60px;padding:20px 24px;display:flex;flex-direction:column;gap:20px;}
.ph{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
.ph-title{font-size:21px;font-weight:800;display:flex;align-items:center;gap:10px;letter-spacing:-.3px;}
.ph-title i{color:var(--primary);}
.ph-sub{font-size:12px;color:var(--muted);margin-top:3px;}
.ph-actions{display:flex;gap:8px;}

/* ── Sync strip ─── */
.sync-strip{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 20px;display:flex;align-items:center;gap:24px;flex-wrap:wrap;box-shadow:var(--shadow);transition:background .3s,border-color .3s;}
.si-label{font-size:10px;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:700;margin-bottom:3px;}
.si-val{font-size:13.5px;font-weight:700;color:var(--text);}
.si-val.dim{color:var(--muted);font-weight:500;}
.si-chips{display:flex;gap:6px;flex-wrap:wrap;}
.chip{display:inline-flex;align-items:center;gap:5px;border-radius:30px;padding:4px 12px;font-size:11px;font-weight:700;border:1.5px solid var(--border);color:var(--muted);background:var(--input-bg);transition:all .2s;}
.chip.hw  {border-color:#10b981;color:#10b981;background:rgba(16,185,129,.08);}
.chip.sec {border-color:var(--primary);color:var(--primary);background:rgba(59,130,246,.08);}
.chip.both{border-color:var(--purple);color:var(--purple);background:rgba(139,92,246,.08);}

/* ── Buttons ─── */
.btn-primary{background:var(--primary);color:#fff;border:none;border-radius:10px;padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;white-space:nowrap;}
.btn-primary:hover{filter:brightness(1.1);transform:translateY(-1px);}
.btn-primary:disabled{opacity:.6;cursor:not-allowed;transform:none;}
.btn-ghost{background:transparent;color:var(--primary);border:1.5px solid var(--primary);border-radius:10px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;}
.btn-ghost:hover{background:var(--primary);color:#fff;}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:7px 12px;font-size:12px;cursor:pointer;display:inline-flex;align-items:center;gap:5px;transition:all .15s;}
.btn-outline:hover{border-color:var(--primary);color:var(--primary);}
@keyframes spin{to{transform:rotate(360deg);}}
.spin-anim{animation:spin .7s linear infinite;}

/* ── KPI grid ─── */
.kpi-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;}
@media(max-width:1200px){.kpi-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:640px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 18px;box-shadow:var(--shadow);transition:transform .2s,background .3s,border-color .3s;cursor:default;position:relative;overflow:hidden;}
.kpi:hover{transform:translateY(-2px);box-shadow:var(--shadow-md);}
.kpi-label{font-size:10px;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:700;margin-bottom:8px;}
.kpi-val{font-size:32px;font-weight:900;line-height:1;letter-spacing:-1px;}
.kpi-icon{font-size:30px;opacity:.15;position:absolute;right:16px;top:50%;transform:translateY(-50%);}
.c-primary{color:var(--primary);}.c-success{color:var(--success);}.c-warning{color:var(--warning);}
.c-danger{color:var(--danger);}.c-info{color:var(--info);}.c-muted{color:var(--muted);}

/* ── Charts ─── */
.charts-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}
@media(max-width:1100px){.charts-row{grid-template-columns:1fr 1fr;}}
@media(max-width:700px){.charts-row{grid-template-columns:1fr;}}
.chart-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow);transition:background .3s,border-color .3s;}
.chart-title{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:14px;display:flex;align-items:center;gap:7px;}
.chart-title i{font-size:15px;}
.chart-wrap{height:210px;position:relative;}

/* ── Main panel ─── */
.main-panel{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:var(--shadow);display:flex;transition:background .3s,border-color .3s;}
.tbl-side{flex:1;min-width:0;display:flex;flex-direction:column;}
.tbl-head{padding:14px 18px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;transition:background .3s,border-color .3s;}
.tbl-head h6{font-size:14px;font-weight:800;color:var(--text);margin:0;display:flex;align-items:center;gap:8px;letter-spacing:-.2px;}
.toolbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.search-wrap{position:relative;}
.search-wrap i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none;}
.search-input{background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:9px;padding:7px 12px 7px 32px;font-size:12.5px;width:210px;outline:none;transition:background .3s,border-color .2s,color .3s;}
.search-input:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.12);}
.search-input::placeholder{color:var(--muted);}
.filter-select{background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:9px;padding:7px 10px;font-size:12px;outline:none;cursor:pointer;transition:all .2s;}
.filter-select:focus{border-color:var(--primary);}
.tbl-scroll{overflow-x:auto;overflow-y:auto;max-height:500px;flex:1;}
.tbl{width:100%;border-collapse:collapse;font-size:12.5px;}
.tbl thead th{font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);font-weight:700;padding:10px 14px;background:var(--header);border-bottom:1px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;cursor:pointer;user-select:none;transition:background .3s,color .3s,border-color .3s;}
.tbl thead th:hover{color:var(--text);}
.tbl thead th.sorted{color:var(--primary);}
.tbl thead th .sort-icon{font-size:9px;margin-left:4px;opacity:.6;}
.tbl tbody td{padding:10px 14px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;transition:border-color .3s,color .3s;}
.tbl tbody tr:last-child td{border-bottom:none;}
.tbl tbody tr{cursor:pointer;transition:background .1s;}
.tbl tbody tr:hover td{background:var(--row-hover);}
.tbl tbody tr.row-active td{background:rgba(59,130,246,.08);border-left:3px solid var(--primary);}
[data-theme="dark"] .tbl tbody tr.row-active td{background:rgba(96,165,250,.12);}
.tbl-foot{padding:10px 18px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.tbl-info{font-size:11.5px;color:var(--muted);}
.pagination{display:flex;gap:4px;}
.pg-btn{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:7px;padding:4px 10px;font-size:12px;cursor:pointer;transition:.15s;}
.pg-btn:hover,.pg-btn.active{background:var(--primary);color:#fff;border-color:var(--primary);}
.pg-btn:disabled{opacity:.4;cursor:not-allowed;}

/* ── Drawer ─── */
.drawer{width:0;overflow:hidden;border-left:1px solid transparent;transition:width .3s cubic-bezier(.4,0,.2,1),border-color .3s;flex-shrink:0;display:flex;flex-direction:column;}
.drawer.open{width:340px;border-left-color:var(--border);}
.drawer-header{padding:14px 16px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;transition:background .3s,border-color .3s;}
.drawer-header h6{font-size:13px;font-weight:800;color:var(--text);margin:0;font-family:monospace;letter-spacing:.5px;}
.drawer-body{flex:1;overflow-y:auto;padding:0;}
.drawer-section{padding:14px 16px;border-bottom:1px solid var(--border);}
.drawer-section:last-child{border-bottom:none;}
.ds-title{font-size:9.5px;text-transform:uppercase;letter-spacing:.7px;font-weight:800;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.ds-title.hw{color:#10b981;}.ds-title.sec{color:var(--primary);}.ds-title.gen{color:var(--muted);}
.ds-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.ds-item{background:var(--input-bg);border-radius:8px;padding:8px 10px;}
.ds-item.full{grid-column:1/-1;}
.ds-key{font-size:9.5px;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);font-weight:700;margin-bottom:3px;}
.ds-val{font-size:12px;font-weight:600;color:var(--text);word-break:break-all;line-height:1.4;}
.ds-val.mono{font-family:monospace;font-size:11px;}
.ds-val.dim{color:var(--muted);font-weight:400;}
.drawer-close{background:none;border:none;color:var(--muted);cursor:pointer;padding:4px;border-radius:6px;display:flex;align-items:center;transition:.15s;}
.drawer-close:hover{background:var(--row-hover);color:var(--text);}

/* ── Pills ─── */
.pill{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;line-height:1.6;}
.p-blue{background:rgba(59,130,246,.13);color:var(--primary);}
.p-green{background:rgba(16,185,129,.13);color:var(--success);}
.p-yellow{background:rgba(245,158,11,.13);color:var(--warning);}
.p-red{background:rgba(239,68,68,.13);color:var(--danger);}
.p-gray{background:rgba(100,116,139,.1);color:var(--muted);}
.p-purple{background:rgba(139,92,246,.13);color:var(--purple);}

/* ── Source badge ─── */
.src-hw{color:#10b981;font-size:11px;font-weight:700;}
.src-sec{color:var(--primary);font-size:11px;font-weight:700;}
.src-both{color:var(--purple);font-size:11px;font-weight:700;}

/* ── Toast ─── */
.toast-wrap{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;}
.toast-item{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:12px;padding:12px 18px;font-size:13px;font-weight:500;box-shadow:var(--shadow-md);display:flex;align-items:center;gap:10px;min-width:280px;animation:toastIn .25s ease;}
.toast-item.ok{border-left:4px solid var(--success);}
.toast-item.err{border-left:4px solid var(--danger);}
.toast-item.inf{border-left:4px solid var(--info);}
@keyframes toastIn{from{opacity:0;transform:translateX(24px);}to{opacity:1;transform:translateX(0);}}

/* ── Modal ─── */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1050;align-items:center;justify-content:center;}
.modal-bg.open{display:flex;}
.modal-box{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:28px;width:100%;max-width:580px;box-shadow:0 24px 64px rgba(0,0,0,.25);animation:mIn .2s ease;}
@keyframes mIn{from{opacity:0;transform:scale(.95);}to{opacity:1;transform:scale(1);}}
.modal-box h5{font-size:16px;font-weight:800;color:var(--text);margin-bottom:18px;display:flex;align-items:center;gap:9px;letter-spacing:-.2px;}
.m-row{display:flex;gap:10px;margin-bottom:10px;font-size:13px;}
.m-row .lbl{color:var(--muted);min-width:80px;font-weight:700;flex-shrink:0;}
.m-row .val{color:var(--text);}
.file-list{margin-top:12px;display:flex;flex-direction:column;gap:8px;}
.file-item{background:var(--input-bg);border:1px solid var(--border);border-radius:12px;padding:12px 16px;display:flex;align-items:center;gap:12px;}
.fi-icon{font-size:22px;flex-shrink:0;}
.fi-name{font-size:13px;font-weight:700;color:var(--text);}
.fi-meta{font-size:11px;color:var(--muted);margin-top:2px;}
.fi-ok{margin-left:auto;color:var(--success);font-size:18px;}
.m-actions{margin-top:20px;display:flex;gap:10px;justify-content:flex-end;}
.btn-mcancel{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:9px;padding:8px 18px;font-size:13px;cursor:pointer;transition:.15s;}
.btn-mcancel:hover{border-color:var(--text);color:var(--text);}

/* ── Misc ─── */
*::-webkit-scrollbar{width:5px;height:5px;}
*::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
*::-webkit-scrollbar-track{background:transparent;}
.empty-state{text-align:center;padding:60px 20px;color:var(--muted);}
.empty-state i{font-size:36px;display:block;margin-bottom:12px;opacity:.35;}
.empty-state p{font-size:13px;}
.mini-bar{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:4px;}
.mini-bar-fill{height:100%;border-radius:2px;transition:width .6s ease;}
</style>
</head>
