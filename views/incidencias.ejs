/* ════════ CONSTANTES ════════ */
const PL = { p1:'P1 Crítico', p2:'P2 Alto', p3:'P3 Medio', p4:'P4 Bajo' };
const PC = { p1:'prio-p1', p2:'prio-p2', p3:'prio-p3', p4:'prio-p4' };
const SL = { abierto:'Abierto', en_progreso:'En progreso', pendiente:'Pendiente', resuelto:'Resuelto', cerrado:'Cerrado' };
const SC = { abierto:'status-abierto', en_progreso:'status-en_progreso', pendiente:'status-pendiente', resuelto:'status-resuelto', cerrado:'status-cerrado' };
const PER = 10;

let fStatus = 'todos', fPrio = '', fPage = 1;
let ticketActual = null;

/* ════════ HELPERS ════════ */
function slaHtml(h) {
    if (h === null || h === undefined) return '<span class="sla-none">—</span>';
    if (h < 1)  return `<span class="sla-breach"><i class="bi bi-exclamation-triangle-fill"></i> ${Math.round(h*60)}m</span>`;
    if (h < 3)  return `<span class="sla-warning"><i class="bi bi-clock-fill"></i> ${h.toFixed(1)}h</span>`;
    return `<span class="sla-ok"><i class="bi bi-clock"></i> ${h.toFixed(1)}h</span>`;
}
function agtHtml(t) {
    if (!t.agente) return '<span style="font-size:12px;color:var(--muted);">Sin asignar</span>';
    return `<div class="agent-wrap"><div class="agent-avatar">${t.aInit}</div><span style="font-size:12px;">${t.agente}</span></div>`;
}
function initials(name) { return (name||'').split(' ').map(w=>w[0]||'').join('').toUpperCase().substring(0,2); }

function getFiltered() {
    const q   = (document.getElementById('searchTickets')?.value||'').toLowerCase();
    const cat = document.getElementById('fCat')?.value||'';
    const agt = document.getElementById('fAgt')?.value||'';
    return TICKETS.filter(t => {
        if (fStatus !== 'todos' && t.status !== fStatus) return false;
        if (fPrio && t.prio !== fPrio) return false;
        if (cat && t.cat !== cat) return false;
        if (agt === 'sin' && t.agente) return false;
        if (agt && agt !== 'sin' && t.agente !== agt) return false;
        if (q && !t.titulo.toLowerCase().includes(q) && !t.id.toLowerCase().includes(q) && !t.cat.toLowerCase().includes(q)) return false;
        return true;
    });
}

/* ════════ RENDER TABLA PRINCIPAL ════════ */
function renderTabla() {
    const data  = getFiltered();
    const pages = Math.ceil(data.length / PER);
    const slice = data.slice((fPage-1)*PER, fPage*PER);
    const tbody = document.getElementById('tblTickets');
    document.getElementById('cntTickets').textContent = data.length;

    tbody.innerHTML = slice.length
    ? slice.map(t => `
        <tr onclick="abrirDetalle('${t.id}')">
            <td onclick="event.stopPropagation()"><input type="checkbox" class="chk-row"></td>
            <td><span class="mono link-cell">#${t.id}</span></td>
            <td>
                <div class="tt">${t.titulo}</div>
                <div class="ts">${t.cat}</div>
            </td>
            <td><span class="status-badge ${t.tipo==='incidente'?'type-incidente':'type-solicitud'}">${t.tipo==='incidente'?'🔥 Incidente':'📋 Solicitud'}</span></td>
            <td><span class="badge ${PC[t.prio]}">${PL[t.prio]}</span></td>
            <td><span class="status-badge ${SC[t.status]}">${SL[t.status]}</span></td>
            <td style="font-size:12px;color:var(--muted);">${t.cat}</td>
            <td>${agtHtml(t)}</td>
            <td>${slaHtml(t.slaH)}</td>
            <td style="font-size:12px;color:var(--muted);font-family:var(--mono);">${t.crd}</td>
            <td onclick="event.stopPropagation()">
                <div style="display:flex;gap:4px;">
                    <button class="btn-action" title="Ver detalle"  onclick="abrirDetalle('${t.id}')"><i class="bi bi-eye"></i></button>
                    <button class="btn-action btn-resolve" title="Resolver" onclick="abrirCerrar('${t.id}')"><i class="bi bi-check-lg"></i></button>
                    <button class="btn-action btn-delete" title="Eliminar"  onclick="elimRow('${t.id}',event)"><i class="bi bi-trash3"></i></button>
                </div>
            </td>
        </tr>`).join('')
    : `<tr class="empty-row"><td colspan="11"><i class="bi bi-inbox" style="font-size:26px;display:block;margin-bottom:8px;"></i>No se encontraron tickets</td></tr>`;

    renderPag('pagTickets', data.length, fPage, p => { fPage = p; renderTabla(); });
    kpis();
}

function renderSubTabla(tipo, searchId, tbodyId, cntId, mtcId, pagId) {
    const q    = (document.getElementById(searchId)?.value||'').toLowerCase();
    const data = TICKETS.filter(t => t.tipo === tipo && (tipo === 'solicitud' || ['abierto','en_progreso','pendiente'].includes(t.status)))
                        .filter(t => !q || t.titulo.toLowerCase().includes(q) || t.id.toLowerCase().includes(q));
    document.getElementById(cntId).textContent = data.length;
    document.getElementById(mtcId).textContent = data.length;
    document.getElementById(tbodyId).innerHTML = data.length
    ? data.map(t => `
        <tr onclick="abrirDetalle('${t.id}')">
            <td><span class="mono link-cell">#${t.id}</span></td>
            <td><div class="tt">${t.titulo}</div><div class="ts">${t.cat}</div></td>
            <td><span class="badge ${PC[t.prio]}">${PL[t.prio]}</span></td>
            <td><span class="status-badge ${SC[t.status]}">${SL[t.status]}</span></td>
            <td>${agtHtml(t)}</td>
            <td>${slaHtml(t.slaH)}</td>
            <td style="font-size:12px;color:var(--muted);font-family:var(--mono);">${t.crd}</td>
            <td onclick="event.stopPropagation()">
                <div style="display:flex;gap:4px;">
                    <button class="btn-action" onclick="abrirDetalle('${t.id}')"><i class="bi bi-eye"></i></button>
                    <button class="btn-action btn-resolve" onclick="abrirCerrar('${t.id}')"><i class="bi bi-check-lg"></i></button>
                </div>
            </td>
        </tr>`).join('')
    : `<tr class="empty-row"><td colspan="8">Sin resultados</td></tr>`;
}

function renderInc() { renderSubTabla('incidente','sInc','tblInc','cntInc','mtc-incidentes','pagInc'); }
function renderSol() { renderSubTabla('solicitud','sSol','tblSol','cntSol','mtc-solicitudes','pagSol'); }

function renderHist() {
    const q = (document.getElementById('sHist')?.value||'').toLowerCase();
    const data = HISTORIAL.filter(h => !q || h.tid.toLowerCase().includes(q) || h.quien.toLowerCase().includes(q));
    document.getElementById('cntHist').textContent = data.length;
    document.getElementById('mtc-historial').textContent = data.length;
    document.getElementById('tblHist').innerHTML = data.length
    ? data.map(h => `
        <tr>
            <td><span class="mono link-cell">#${h.tid}</span></td>
            <td style="font-size:12px;font-weight:600;">${h.accion}</td>
            <td>${h.sAnt ? `<span class="status-badge ${SC[h.sAnt]||''}">${SL[h.sAnt]||h.sAnt}</span>` : '<span style="color:var(--muted)">—</span>'}</td>
            <td>${h.sNuevo ? `<span class="status-badge ${SC[h.sNuevo]||''}">${SL[h.sNuevo]||h.sNuevo}</span>` : '<span style="color:var(--muted)">—</span>'}</td>
            <td>${agtHtml({agente:h.quien, aInit:initials(h.quien)})}</td>
            <td style="font-size:12px;font-family:var(--mono);color:var(--muted);">${h.fecha}</td>
            <td style="font-size:12px;color:var(--muted);">${h.nota}</td>
        </tr>`).join('')
    : `<tr class="empty-row"><td colspan="7">Sin historial</td></tr>`;
}

/* ════════ KPIs ════════ */
function kpis() {
    const abiertos  = TICKETS.filter(t => t.status==='abierto').length;
    const progreso  = TICKETS.filter(t => t.status==='en_progreso').length;
    const slaRiesgo = TICKETS.filter(t => t.slaH !== null && t.slaH < 2).length;
    const resueltos = TICKETS.filter(t => t.status==='resuelto').length;
    const total     = TICKETS.filter(t => t.status !== 'cerrado').length;
    document.getElementById('kpiAbiertos').textContent  = abiertos;
    document.getElementById('kpiProgreso').textContent  = progreso;
    document.getElementById('kpiSLA').textContent       = slaRiesgo;
    document.getElementById('kpiResueltos').textContent = resueltos;
    document.getElementById('kpiTotal').textContent     = total;
    document.getElementById('mtc-todos').textContent    = total;
}

/* ════════ PAGINACIÓN ════════ */
function renderPag(id, total, cur, cb) {
    const pages = Math.ceil(total/PER);
    const el    = document.getElementById(id);
    if (!el) return;
    const s = (cur-1)*PER+1, e = Math.min(cur*PER, total);
    let btns = '';
    for (let i=1; i<=pages; i++) {
        if (pages>7 && i>2 && i<pages-1 && Math.abs(i-cur)>1) {
            if (i===3||i===pages-2) btns += `<button class="pag-btn" disabled>…</button>`;
            continue;
        }
        btns += `<button class="pag-btn${i===cur?' active':''}" onclick="(${cb.toString()})(${i})">${i}</button>`;
    }
    el.innerHTML = `
        <span class="pag-info">Mostrando ${total?s:0}–${e} de ${total} tickets</span>
        <button class="pag-btn" onclick="(${cb.toString()})(${cur-1})" ${cur===1?'disabled':''}>‹</button>
        ${btns}
        <button class="pag-btn" onclick="(${cb.toString()})(${cur+1})" ${cur>=pages||!pages?'disabled':''}>›</button>`;
}

/* ════════ FILTROS ════════ */
function apStatus(btn, s) {
    document.querySelectorAll('[data-status]').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    fStatus = s; fPage = 1; renderTabla();
}
function apPrio(btn, p) {
    if (fPrio === p) { fPrio=''; btn.classList.remove('active'); }
    else { document.querySelectorAll('[data-prio]').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); fPrio=p; }
    fPage = 1; renderTabla();
}
function filtrarKPI(tipo) {
    switchMainTab('todos', document.querySelector('.main-tab-btn'));
    fStatus = tipo === 'sla' ? 'todos' : tipo;
    if (tipo !== 'sla') {
        document.querySelectorAll('[data-status]').forEach(b => b.classList.toggle('active', b.dataset.status===tipo));
    }
    fPage = 1; renderTabla();
}
function onSearch() { fPage = 1; renderTabla(); }
function limpiarFiltros() {
    fStatus='todos'; fPrio=''; fPage=1;
    ['searchTickets','fCat','fAgt','fFecha'].forEach(id => { const e=document.getElementById(id); if(e) e.value=''; });
    document.querySelectorAll('[data-status]').forEach(b=>b.classList.remove('active'));
    document.querySelector('[data-status="todos"]')?.classList.add('active');
    document.querySelectorAll('[data-prio]').forEach(b=>b.classList.remove('active'));
    renderTabla();
}
function chkAllFn(m) { document.querySelectorAll('.chk-row').forEach(c => c.checked=m.checked); }

/* ════════ MAIN TABS ════════ */
function switchMainTab(name, btn) {
    document.querySelectorAll('.main-tab-pane').forEach(p=>p.classList.remove('active'));
    document.querySelectorAll('.main-tab-btn').forEach(b=>b.classList.remove('active'));
    document.getElementById('maintab-'+name).classList.add('active');
    if (btn) btn.classList.add('active');
    if (name==='incidentes') renderInc();
    if (name==='solicitudes') renderSol();
    if (name==='historial') renderHist();
}

/* ════════ MODALES ════════ */
function openM(id) { document.getElementById(id).classList.add('open'); document.body.style.overflow='hidden'; }
function closeM(id){ document.getElementById(id).classList.remove('open'); document.body.style.overflow=''; }
function openModalNuevoTicket() { openM('modalNuevoTicket'); }

function guardarNuevo() {
    const titulo = document.getElementById('nTitulo').value.trim();
    const tipo   = document.getElementById('nTipo').value;
    const desc   = document.getElementById('nDescripcion').value.trim();
    const cat    = document.getElementById('nCategoria').value;
    const alertEl = document.getElementById('alertNuevo');
    if (!titulo||!tipo||!desc||!cat) {
        alertEl.textContent='Por favor completa todos los campos obligatorios (*)';
        alertEl.style.display='block'; return;
    }
    alertEl.style.display='none';
    const agente = document.getElementById('nAgente').value;
    const nuevo = {
        id: 'TKT-' + String(TICKETS.length + 33).padStart(4,'0'),
        titulo, tipo, prio: document.getElementById('nPrioridad').value,
        status:'abierto', cat, agente, aInit:initials(agente),
        slaH: null, crd:'hace un momento', desc, adj:[]
    };
    TICKETS.unshift(nuevo);
    HISTORIAL.unshift({ tid:nuevo.id, accion:'Creación', sAnt:null, sNuevo:'abierto', quien:'Usuario actual', fecha:'ahora', nota:'Ticket creado.' });
    closeM('modalNuevoTicket');
    ['nTitulo','nTipo','nCategoria','nAgente','nDescripcion'].forEach(id => { const e=document.getElementById(id); if(e) e.value=''; });
    renderTabla();
    toast('Ticket '+nuevo.id+' creado exitosamente','ok');
}

/* ── DETALLE ── */
function abrirDetalle(id) {
    const t = TICKETS.find(x=>x.id===id);
    if (!t) return;
    ticketActual = id;
    document.getElementById('dTitulo').textContent = t.titulo;
    document.getElementById('dSub').innerHTML =
        `<span class="mono">#${t.id}</span> &nbsp;·&nbsp; <span class="status-badge ${t.tipo==='incidente'?'type-incidente':'type-solicitud'}">${t.tipo==='incidente'?'🔥 Incidente':'📋 Solicitud'}</span>`;
    document.getElementById('dDesc').textContent = t.desc;
    document.getElementById('editEstado').value = t.status;
    document.getElementById('editAgente').value = t.agente||'';

    // Celdas de detalle
    const cells = [
        { l:'Estado',    v:`<span class="status-badge ${SC[t.status]}">${SL[t.status]}</span>` },
        { l:'Prioridad', v:`<span class="badge ${PC[t.prio]}">${PL[t.prio]}</span>` },
        { l:'Categoría', v:t.cat },
        { l:'Asignado',  v:t.agente||'<span style="color:var(--muted)">Sin asignar</span>' },
        { l:'SLA',       v:slaHtml(t.slaH) },
        { l:'Creado',    v:`<span style="font-family:var(--mono);font-size:11px;">${t.crd}</span>` },
    ];
    document.getElementById('dGrid').innerHTML = cells.map(c=>`
        <div class="detail-cell">
            <div class="detail-lbl">${c.l}</div>
            <div class="detail-val">${c.v}</div>
        </div>`).join('');

    // Timeline historial
    const hist = HISTORIAL.filter(h=>h.tid===id);
    const dotCls = { 'Cambio de estado':'dot-status','Comentario':'dot-comment','Reasignación':'dot-assign','Creación':'dot-create' };
    document.getElementById('dTimeline').innerHTML = hist.length
    ? hist.map(h=>`
        <div class="log-entry">
            <div class="log-dot ${dotCls[h.accion]||'dot-status'}"></div>
            <div>
                <div class="log-text">
                    <strong>${h.quien}</strong> — ${h.accion}
                    ${h.sNuevo ? ` → <span class="status-badge ${SC[h.sNuevo]||''}" style="font-size:10px;padding:2px 7px;">${SL[h.sNuevo]||h.sNuevo}</span>` : ''}
                </div>
                <div class="log-meta">${h.nota}&nbsp;·&nbsp;${h.fecha}</div>
            </div>
        </div>`).join('')
    : '<div style="font-size:12px;color:var(--muted);padding:8px 0;">Sin historial de cambios registrado.</div>';

    // Adjuntos
    const extIcon = { log:'bi-file-text',png:'bi-image',jpg:'bi-image',har:'bi-file-zip',txt:'bi-file-earmark',pdf:'bi-file-pdf' };
    document.getElementById('dAdjuntos').innerHTML = t.adj.length
    ? t.adj.map(a=>`
        <div class="attach-item">
            <i class="bi ${extIcon[a.split('.').pop()]||'bi-paperclip'}"></i>
            <span class="attach-name">${a}</span>
            <span class="attach-size">—</span>
        </div>`).join('')
    : '<div style="font-size:12px;color:var(--muted);">Sin adjuntos.</div>';

    openM('modalDetalle');
}

function actualizarEstado() {
    if (!ticketActual) return;
    const t    = TICKETS.find(x=>x.id===ticketActual);
    const prev = t.status;
    const nw   = document.getElementById('editEstado').value;
    const nota = document.getElementById('editNota').value||'Sin nota.';
    t.status   = nw;
    HISTORIAL.unshift({ tid:ticketActual, accion:'Cambio de estado', sAnt:prev, sNuevo:nw, quien:'Usuario actual', fecha:'ahora', nota });
    closeM('modalDetalle');
    renderTabla(); renderHist();
    toast(`Estado de ${ticketActual} → "${SL[nw]}"`, 'ok');
}

function reasignar() {
    if (!ticketActual) return;
    const t   = TICKETS.find(x=>x.id===ticketActual);
    const nw  = document.getElementById('editAgente').value;
    t.agente  = nw; t.aInit = initials(nw);
    HISTORIAL.unshift({ tid:ticketActual, accion:'Reasignación', sAnt:null, sNuevo:null, quien:'Usuario actual', fecha:'ahora', nota:`Reasignado a ${nw||'Sin asignar'}` });
    closeM('modalDetalle');
    renderTabla();
    toast(`Ticket reasignado a ${nw||'Sin asignar'}`, 'ok');
}

function enviarComentario() {
    const nota = document.getElementById('nuevoComentario').value.trim();
    if (!nota || !ticketActual) return;
    HISTORIAL.unshift({ tid:ticketActual, accion:'Comentario', sAnt:null, sNuevo:null, quien:'Usuario actual', fecha:'ahora', nota });
    document.getElementById('nuevoComentario').value='';
    abrirDetalle(ticketActual);
    renderHist();
    toast('Comentario agregado','ok');
}

function eliminarActual() { if (ticketActual) { elimRow(ticketActual,null); closeM('modalDetalle'); } }
function elimRow(id, ev) {
    if (ev) ev.stopPropagation();
    const i = TICKETS.findIndex(t=>t.id===id);
    if (i>-1) TICKETS.splice(i,1);
    renderTabla();
    toast(`Ticket ${id} eliminado`,'warn');
}

/* ── CERRAR / RESOLVER ── */
function abrirCerrar(id) {
    const t = TICKETS.find(x=>x.id===id);
    if (!t) return;
    ticketActual = id;
    document.getElementById('cerrarSub').innerHTML = `<span class="mono">#${t.id}</span> — ${t.titulo.substring(0,52)}${t.titulo.length>52?'…':''}`;
    document.getElementById('cerrarId').value = id;
    document.getElementById('cerrarNota').value='';
    openM('modalCerrar');
}
function confirmarCierre() {
    const id    = document.getElementById('cerrarId').value;
    const accion= document.getElementById('cerrarAccion').value;
    const nota  = document.getElementById('cerrarNota').value.trim();
    if (!nota) { toast('Debes describir la solución aplicada','err'); return; }
    const t = TICKETS.find(x=>x.id===id);
    const prev = t.status;
    t.status = accion; t.slaH = null;
    HISTORIAL.unshift({ tid:id, accion:'Cambio de estado', sAnt:prev, sNuevo:accion, quien:'Usuario actual', fecha:'ahora', nota });
    closeM('modalCerrar');
    renderTabla(); renderHist();
    toast(`${id} marcado como "${SL[accion]}"`, 'ok');
}

/* ════════ TOAST ════════ */
function toast(msg, type='ok') {
    const icons = { ok:'✅', err:'❌', warn:'⚠️', inf:'ℹ️' };
    const el = document.createElement('div');
    el.className = `toast-item toast-${type}`;
    el.innerHTML = `<span>${icons[type]}</span><span>${msg}</span>`;
    document.getElementById('toastZone').appendChild(el);
    setTimeout(()=>el.remove(), 3500);
}

/* ════════ ESC CLOSE ════════ */
document.addEventListener('keydown', e => {
    if (e.key==='Escape')
        document.querySelectorAll('.modal-backdrop-custom.open').forEach(m=>closeM(m.id));
});

/* ════════ INIT ════════ */
document.addEventListener('DOMContentLoaded', () => {
    renderTabla();
    renderInc();
    renderSol();
});
</script>

<!-- ══ ITSM JS ══ -->
<script>
// Estado del módulo ITSM
const itsmState = { status: null, sla: null, priority: null, page: 1, limit: 25 };

// Colores SLA
const SLA_BADGE = {
    ok:      '<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:12px;font-size:11px;font-weight:700;background:rgba(16,185,129,.12);color:#059669;">🟢 Ok</span>',
    riesgo:  '<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:12px;font-size:11px;font-weight:700;background:rgba(245,158,11,.12);color:#d97706;">🟡 Riesgo</span>',
    vencido: '<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:12px;font-size:11px;font-weight:700;background:rgba(239,68,68,.12);color:#dc2626;">🔴 Vencido</span>',
};
const PRIO_BADGE = {
    P1: '<span style="padding:2px 8px;border-radius:5px;font-size:11px;font-weight:700;background:rgba(239,68,68,.15);color:#dc2626;">P1</span>',
    P2: '<span style="padding:2px 8px;border-radius:5px;font-size:11px;font-weight:700;background:rgba(249,115,22,.15);color:#ea580c;">P2</span>',
    P3: '<span style="padding:2px 8px;border-radius:5px;font-size:11px;font-weight:700;background:rgba(245,158,11,.15);color:#d97706;">P3</span>',
    P4: '<span style="padding:2px 8px;border-radius:5px;font-size:11px;font-weight:700;background:rgba(16,185,129,.15);color:#059669;">P4</span>',
};
const STATUS_BADGE = {
    abierto:     '<span style="padding:3px 9px;border-radius:12px;font-size:11px;font-weight:700;background:rgba(59,130,246,.12);color:#2563eb;">Abierto</span>',
    en_progreso: '<span style="padding:3px 9px;border-radius:12px;font-size:11px;font-weight:700;background:rgba(245,158,11,.12);color:#d97706;">En progreso</span>',
    pendiente:   '<span style="padding:3px 9px;border-radius:12px;font-size:11px;font-weight:700;background:rgba(139,92,246,.12);color:#7c3aed;">Pendiente</span>',
    resuelto:    '<span style="padding:3px 9px;border-radius:12px;font-size:11px;font-weight:700;background:rgba(16,185,129,.12);color:#059669;">Resuelto</span>',
    cerrado:     '<span style="padding:3px 9px;border-radius:12px;font-size:11px;font-weight:700;background:rgba(100,116,139,.12);color:#475569;">Cerrado</span>',
};

function itsmFilter(type, value, btn) {
    // Toggle: si ya estaba activo, desactivar
    const prev = itsmState[type];
    document.querySelectorAll(`[data-i${type}]`).forEach(b => b.classList.remove('active'));
    if (prev === value) {
        itsmState[type] = null;
    } else {
        itsmState[type] = value;
        if (btn) btn.classList.add('active');
    }
    itsmState.page = 1;
    loadItsm();
}

async function loadItsm() {
    const params = new URLSearchParams();
    if (itsmState.status)   params.set('status',     itsmState.status);
    if (itsmState.sla)      params.set('sla_status', itsmState.sla);
    if (itsmState.priority) params.set('priority',   itsmState.priority);
    params.set('page',  itsmState.page);
    params.set('limit', itsmState.limit);
    const search = document.getElementById('itsmSearch')?.value?.trim();
    if (search) params.set('search', search);

    try {
        const r = await fetch(`/api/itsm/tickets?${params}`);
        const j = await r.json();
        if (!j.success) throw new Error(j.error);

        const tbody = document.getElementById('itsmTbody');
        document.getElementById('itsmCount').textContent = j.meta.total;
        document.getElementById('mtc-itsm').textContent  = j.meta.total;

        if (!j.data.length) {
            tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:24px;color:var(--muted);">Sin tickets</td></tr>';
            document.getElementById('itsmPag').innerHTML = '';
            return;
        }

        tbody.innerHTML = j.data.map(t => {
            const id    = t.id.substring(0, 8).toUpperCase();
            const fecha = new Date(t.createdAt).toLocaleDateString('es', { day:'2-digit', month:'short' });
            const cat   = t.categoria?.nombre || '—';
            return `<tr>
                <td><code style="font-size:11px;color:var(--muted);">#${id}</code></td>
                <td style="max-width:240px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:600;">${t.titulo}</td>
                <td><span style="font-size:11px;color:var(--muted);">${t.tipo}</span></td>
                <td>${PRIO_BADGE[t.priority] || t.priority}</td>
                <td>${STATUS_BADGE[t.status] || t.status}</td>
                <td>${SLA_BADGE[t.slaStatus] || t.slaStatus}</td>
                <td style="font-size:12px;color:var(--muted);">${cat}</td>
                <td style="font-size:12px;color:var(--muted);">${fecha}</td>
                <td>
                    <button class="btn-action" title="Resolver" onclick="cambiarEstadoItsm('${t.id}','resuelto')"><i class="bi bi-check-circle"></i></button>
                    <button class="btn-action" title="Cerrar"   onclick="cambiarEstadoItsm('${t.id}','cerrado')"><i class="bi bi-x-circle"></i></button>
                </td>
            </tr>`;
        }).join('');

        renderItsmPag(j.meta);
    } catch (e) {
        console.error('Error cargando ITSM:', e);
    }
}

function renderItsmPag({ page, pages }) {
    const pag = document.getElementById('itsmPag');
    if (pages <= 1) { pag.innerHTML = ''; return; }
    let html = `<button class="pag-btn" ${page<=1?'disabled':''} onclick="itsmPage(${page-1})">‹</button>`;
    for (let i = 1; i <= pages; i++) {
        if (i === 1 || i === pages || Math.abs(i - page) <= 2) {
            html += `<button class="pag-btn ${i===page?'active':''}" onclick="itsmPage(${i})">${i}</button>`;
        } else if (Math.abs(i - page) === 3) {
            html += `<span style="padding:5px 4px;color:var(--muted);">…</span>`;
        }
    }
    html += `<button class="pag-btn" ${page>=pages?'disabled':''} onclick="itsmPage(${page+1})">›</button>`;
    pag.innerHTML = html;
}

function itsmPage(p) { itsmState.page = p; loadItsm(); }

async function cambiarEstadoItsm(id, status) {
    try {
        const r = await fetch(`/api/itsm/tickets/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status }),
        });
        const j = await r.json();
        if (!j.success) throw new Error(j.error);
        loadItsm();
    } catch (e) { alert('Error: ' + e.message); }
}

// ── Modal nuevo ticket ─────────────────────────────────────────────────────
async function openItsmModal() {
    // Cargar categorías
    const r = await fetch('/api/itsm/categories');
    const j = await r.json();
    const sel = document.getElementById('itsmCategory');
    sel.innerHTML = '<option value="">Categoría (opcional)</option>' +
        (j.data || []).map(c => `<option value="${c.id}">${c.nombre}</option>`).join('');
    document.getElementById('modalItsm').style.display = 'flex';
}

function closeItsmModal() {
    document.getElementById('modalItsm').style.display = 'none';
    document.getElementById('itsmTitulo').value = '';
    document.getElementById('itsmDesc').value   = '';
}

async function crearItsmTicket() {
    const titulo = document.getElementById('itsmTitulo').value.trim();
    if (!titulo) { alert('El título es requerido'); return; }

    const body = {
        titulo,
        descripcion: document.getElementById('itsmDesc').value.trim() || null,
        tipo:        document.getElementById('itsmTipo').value,
        priority:    document.getElementById('itsmPriority').value,
        category_id: document.getElementById('itsmCategory').value || null,
    };

    try {
        const r = await fetch('/api/itsm/tickets', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
        });
        const j = await r.json();
        if (!j.success) throw new Error(j.error);
        closeItsmModal();
        loadItsm();
    } catch (e) { alert('Error: ' + e.message); }
}

// Cargar al abrir el tab
document.querySelector('[onclick*="itsm"]')?.addEventListener('click', loadItsm);
</script>
</body>
</html>
