// ── VIP Manager ───────────────────────────────────────────
const openVipManager=async()=>{document.getElementById('vipModal').classList.add('open');await refreshVipList();};
const closeVipModal=()=>document.getElementById('vipModal').classList.remove('open');

async function refreshVipList(){
  const list=document.getElementById('vipList');
  try{
    const j=await fetch('/api/print-queue/vip-users').then(r=>r.json());
    if(!j.success||!j.data.length){
      list.innerHTML=`<div style="text-align:center;padding:20px;color:var(--muted);font-size:13px;"><i class="bi bi-star" style="font-size:28px;display:block;margin-bottom:8px;opacity:.3;"></i>Sin usuarios VIP aún</div>`;
      return;
    }
    list.innerHTML=j.data.map(u=>`
      <div class="vip-row">
        <div style="width:36px;height:36px;background:var(--gold-bg);border:1.5px solid rgba(245,158,11,.3);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="bi bi-star-fill" style="color:var(--gold);font-size:14px;"></i></div>
        <div class="vip-row-info"><div class="vip-row-name">${esc(u.name||'Sin nombre')}</div><div class="vip-row-email">${esc(u.email)}</div></div>
        <button class="btn-sm danger" onclick="removeVip(${u.id})"><i class="bi bi-star"></i> Quitar</button>
      </div>`).join('');
  }catch(e){list.innerHTML=`<div style="color:var(--danger);padding:12px;font-size:13px;">Error: ${e.message}</div>`;}
}

async function addVip(){
  const email=(document.getElementById('vipEmail').value||'').trim();
  const name =(document.getElementById('vipName').value||'').trim();
  if(!email){toast('Introduce un email','inf');return;}
  try{
    const j=await fetch('/api/print-queue/vip-users',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,name})}).then(r=>r.json());
    if(!j.success)throw new Error(j.error);
    document.getElementById('vipEmail').value='';
    document.getElementById('vipName').value='';
    const docsMsg=j.docs_marked>0?` · ${j.docs_marked} doc(s) marcados`:' · sin documentos en cola aún';
    toast(`⭐ ${email} ahora es VIP${docsMsg}`,'ok',6000);
    await Promise.all([refreshVipList(),loadStats()]);
    await loadData(currentPage);
  }catch(e){toast('Error: '+e.message,'err');}
}

async function removeVip(id){
  try{
    const j=await fetch(`/api/print-queue/vip-users/${id}`,{method:'DELETE'}).then(r=>r.json());
    if(!j.success)throw new Error(j.error);
    toast('Usuario quitado de VIP','ok');
    await Promise.all([refreshVipList(),loadStats()]);
    await loadData(currentPage);
  }catch(e){toast('Error: '+e.message,'err');}
}

