<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cola de Impresión</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="../css/style.css">
<style>
:root,[data-theme="light"]{
  --bg:#f0f4f8;--card:#ffffff;--header:#f8fafc;
  --border:#e2e8f0;--text:#1e293b;--muted:#64748b;
  --primary:#3b82f6;--success:#10b981;--warning:#f59e0b;
  --danger:#ef4444;--info:#06b6d4;--purple:#8b5cf6;--orange:#f97316;
  --gold:#f59e0b;--gold-bg:rgba(245,158,11,.08);
  --row-hover:#f1f5f9;--shadow:0 1px 3px rgba(0,0,0,.07);
  --shadow-md:0 4px 16px rgba(0,0,0,.10);--input-bg:#f8fafc;
}
[data-theme="dark"]{
  --bg:#0f172a;--card:#1e293b;--header:#162032;--border:#2d3f55;--text:#e2e8f0;--muted:#94a3b8;
  --primary:#60a5fa;--success:#34d399;--warning:#fbbf24;--danger:#f87171;--info:#22d3ee;
  --purple:#a78bfa;--orange:#fb923c;--gold:#fbbf24;--gold-bg:rgba(251,191,36,.08);
  --row-hover:#243348;--shadow:0 1px 3px rgba(0,0,0,.3);--shadow-md:0 4px 16px rgba(0,0,0,.4);--input-bg:#162032;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:"DM Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;transition:background .3s,color .3s;font-size:13.5px;}
.pg{margin-top:60px;padding:20px 24px;display:flex;flex-direction:column;gap:20px;}
.ph{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
.ph-title{font-size:21px;font-weight:800;display:flex;align-items:center;gap:10px;letter-spacing:-.3px;}
.ph-title i{color:var(--primary);}
.ph-sub{font-size:12px;color:var(--muted);margin-top:3px;}
.ph-actions{display:flex;gap:8px;align-items:center;}

/* Buttons */
.btn-primary{background:var(--primary);color:#fff;border:none;border-radius:10px;padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;white-space:nowrap;}
.btn-primary:hover{filter:brightness(1.1);transform:translateY(-1px);}
.btn-primary:disabled{opacity:.6;cursor:not-allowed;transform:none;}
.btn-ghost{background:transparent;color:var(--primary);border:1.5px solid var(--primary);border-radius:10px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .2s;}
.btn-ghost:hover{background:var(--primary);color:#fff;}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:7px 12px;font-size:12px;cursor:pointer;display:inline-flex;align-items:center;gap:5px;transition:all .15s;}
.btn-outline:hover{border-color:var(--primary);color:var(--primary);}
.btn-sm{padding:5px 9px;font-size:11.5px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;display:inline-flex;align-items:center;gap:4px;transition:all .15s;white-space:nowrap;}
.btn-sm:hover{border-color:var(--primary);color:var(--primary);}
.btn-sm.danger:hover{border-color:var(--danger);color:var(--danger);}
.btn-sm.success-h:hover{border-color:var(--success);color:var(--success);}
.btn-sm.warn-h:hover{border-color:var(--warning);color:var(--warning);}
@keyframes spin{to{transform:rotate(360deg);}}
.spin-anim{animation:spin .7s linear infinite;}

/* Strip */
.queue-strip{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 20px;display:flex;align-items:center;gap:24px;flex-wrap:wrap;box-shadow:var(--shadow);}
.si-label{font-size:10px;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:700;margin-bottom:3px;}
.si-val{font-size:13.5px;font-weight:700;color:var(--text);}
.si-val.dim{color:var(--muted);font-weight:500;}

/* KPIs */
.kpi-grid{display:grid;grid-template-columns:repeat(8,1fr);gap:12px;}
@media(max-width:1400px){.kpi-grid{grid-template-columns:repeat(4,1fr);}}
@media(max-width:800px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;box-shadow:var(--shadow);transition:transform .2s;cursor:default;position:relative;overflow:hidden;}
.kpi:hover{transform:translateY(-2px);box-shadow:var(--shadow-md);}
.kpi-label{font-size:10px;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:700;margin-bottom:6px;}
.kpi-val{font-size:28px;font-weight:900;line-height:1;letter-spacing:-1px;}
.kpi-sub{font-size:10px;color:var(--muted);margin-top:4px;}
.kpi-icon{font-size:28px;opacity:.13;position:absolute;right:14px;top:50%;transform:translateY(-50%);}
.c-primary{color:var(--primary);}.c-success{color:var(--success);}.c-warning{color:var(--warning);}
.c-danger{color:var(--danger);}.c-info{color:var(--info);}.c-muted{color:var(--muted);}.c-gold{color:var(--gold);}

/* Progress bars */
.queue-progress{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:18px 22px;box-shadow:var(--shadow);}
.qp-title{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;gap:7px;}
.qp-bars{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;}
@media(max-width:900px){.qp-bars{grid-template-columns:1fr 1fr;}}
.qp-bar-item{display:flex;flex-direction:column;gap:5px;}
.qp-bar-label{font-size:10.5px;font-weight:600;color:var(--muted);display:flex;justify-content:space-between;}
.qp-bar-track{height:6px;background:var(--border);border-radius:3px;overflow:hidden;}
.qp-bar-fill{height:100%;border-radius:3px;transition:width .7s ease;}

/* Analytics row */
.analytics-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
@media(max-width:1100px){.analytics-row{grid-template-columns:1fr 1fr;}}
@media(max-width:700px){.analytics-row{grid-template-columns:1fr;}}
.an-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:18px 20px;box-shadow:var(--shadow);}
.an-title{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:14px;display:flex;align-items:center;gap:7px;}
.rank-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.rank-row:last-child{margin-bottom:0;}
.rank-num{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0;}
.r1{background:rgba(245,158,11,.2);color:var(--gold);}
.r2{background:rgba(100,116,139,.15);color:var(--muted);}
.r3{background:rgba(249,115,22,.15);color:var(--orange);}
.rn{background:var(--input-bg);color:var(--muted);}
.rank-bar-track{flex:1;height:5px;background:var(--border);border-radius:3px;overflow:hidden;}
.rank-bar-fill{height:100%;border-radius:3px;transition:width .6s ease;}

/* Tabs */
.tab-strip{display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:0;}
.tab-btn{padding:10px 22px;font-size:13px;font-weight:700;border:none;background:transparent;color:var(--muted);cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;transition:all .2s;display:inline-flex;align-items:center;gap:8px;border-radius:0;}
.tab-btn:hover{color:var(--text);}
.tab-btn.active{color:var(--primary);border-bottom-color:var(--primary);}
.tab-btn.vip-tab.active{color:var(--gold);border-bottom-color:var(--gold);}
.tab-badge{display:inline-flex;align-items:center;justify-content:center;min-width:20px;height:20px;border-radius:10px;font-size:10px;font-weight:800;padding:0 5px;background:var(--border);color:var(--muted);}
.tab-btn.active .tab-badge{background:rgba(59,130,246,.15);color:var(--primary);}
.tab-btn.vip-tab.active .tab-badge{background:rgba(245,158,11,.15);color:var(--gold);}
.tab-btn.vip-tab .tab-badge{background:rgba(245,158,11,.1);color:var(--gold);}

/* Main panel */
.main-panel{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:var(--shadow);display:flex;}
.tbl-side{flex:1;min-width:0;display:flex;flex-direction:column;}
.toolbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.search-wrap{position:relative;}
.search-wrap i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none;}
.search-input{background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:9px;padding:7px 12px 7px 32px;font-size:12.5px;width:190px;outline:none;transition:border-color .2s;}
.search-input:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.12);}
.search-input::placeholder{color:var(--muted);}
.filter-select{background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:9px;padding:7px 10px;font-size:12px;outline:none;cursor:pointer;}
.filter-select:focus{border-color:var(--primary);}
.tbl-scroll{overflow-x:auto;overflow-y:auto;max-height:520px;flex:1;}
.tbl{width:100%;border-collapse:collapse;font-size:12.5px;}
.tbl thead th{font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);font-weight:700;padding:10px 11px;background:var(--header);border-bottom:1px solid var(--border);white-space:nowrap;position:sticky;top:0;z-index:5;cursor:pointer;user-select:none;}
.tbl thead th:hover{color:var(--text);}
.tbl thead th.sorted{color:var(--primary);}
.tbl tbody td{padding:9px 11px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;}
.tbl tbody tr:last-child td{border-bottom:none;}
.tbl tbody tr{cursor:pointer;transition:background .1s;}
.tbl tbody tr:hover td{background:var(--row-hover);}
.tbl tbody tr.row-active td{background:rgba(59,130,246,.08);border-left:3px solid var(--primary);}
.tr-vip td{background:var(--gold-bg)!important;}
.tr-vip:hover td{background:rgba(245,158,11,.14)!important;}
.tr-vip.row-active td{background:rgba(245,158,11,.18)!important;border-left:3px solid var(--gold)!important;}
.tr-vip td:first-child::before{content:'⭐ ';font-size:11px;}
@keyframes urgentPulse{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.4);}50%{box-shadow:0 0 0 4px rgba(239,68,68,0);}}
.tr-urgente:not(.tr-vip) td:first-child{border-left:3px solid var(--danger)!important;}
.tbl-foot{padding:10px 18px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.tbl-info{font-size:11.5px;color:var(--muted);}
.pagination{display:flex;gap:4px;}
.pg-btn{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:7px;padding:4px 10px;font-size:12px;cursor:pointer;transition:.15s;}
.pg-btn:hover,.pg-btn.active{background:var(--primary);color:#fff;border-color:var(--primary);}
.pg-btn:disabled{opacity:.4;cursor:not-allowed;}

/* Botón imprimir con código */
.btn-print{display:inline-flex;align-items:center;gap:4px;border-radius:7px;padding:4px 8px;font-size:11px;font-weight:700;background:rgba(59,130,246,.1);color:var(--primary);border:1px solid rgba(59,130,246,.25);cursor:pointer;transition:all .2s;white-space:nowrap;}
.btn-print:hover{background:var(--primary);color:#fff;}
.btn-print:disabled{opacity:.5;cursor:not-allowed;}
/* Botón eliminar buzón */
.btn-mailbox{display:inline-flex;align-items:center;gap:4px;border-radius:7px;padding:4px 8px;font-size:11px;font-weight:700;border:none;cursor:pointer;transition:all .2s;white-space:nowrap;}
.btn-mailbox.pendiente{background:rgba(239,68,68,.1);color:var(--danger);border:1px solid rgba(239,68,68,.25);}
.btn-mailbox.pendiente:hover{background:var(--danger);color:#fff;}
.btn-mailbox.eliminado{background:rgba(16,185,129,.1);color:var(--success);border:1px solid rgba(16,185,129,.25);cursor:default;}
/* Modal código */
.code-modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:2000;align-items:center;justify-content:center;backdrop-filter:blur(3px);}
.code-modal-bg.open{display:flex;}
.code-modal-box{background:var(--card);border:1px solid var(--border);border-radius:18px;width:100%;max-width:380px;box-shadow:0 24px 64px rgba(0,0,0,.3);animation:mIn .2s ease;overflow:hidden;}
.code-modal-head{padding:18px 22px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;font-weight:800;font-size:15px;}
.code-modal-body{padding:22px;}
.code-input{width:100%;text-align:center;font-size:32px;font-weight:900;letter-spacing:10px;padding:14px;border:2px solid var(--border);border-radius:12px;background:var(--input-bg);color:var(--text);outline:none;transition:border-color .2s;}
.code-input:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.12);}
.code-input.shake{animation:shk .4s ease;border-color:var(--danger);}
.code-hint{font-size:12px;color:var(--muted);text-align:center;margin-top:10px;line-height:1.5;}
.code-actions{display:flex;gap:8px;margin-top:18px;}
.btn-code-cancel{flex:1;background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:9px;padding:9px;font-size:13px;cursor:pointer;}
.btn-code-cancel:hover{border-color:var(--text);color:var(--text);}
.btn-code-ok{flex:2;background:var(--primary);color:#fff;border:none;border-radius:9px;padding:9px;font-size:13px;font-weight:700;cursor:pointer;}
.btn-code-ok:hover{filter:brightness(1.1);}
.btn-code-ok:disabled{opacity:.55;cursor:not-allowed;}

/* Drawer */
.drawer{width:0;overflow:hidden;border-left:1px solid transparent;transition:width .3s cubic-bezier(.4,0,.2,1),border-color .3s;flex-shrink:0;display:flex;flex-direction:column;}
.drawer.open{width:340px;border-left-color:var(--border);}
.drawer-header{padding:14px 16px;background:var(--header);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.drawer-header h6{font-size:12px;font-weight:800;color:var(--text);margin:0;font-family:monospace;max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.drawer-body{flex:1;overflow-y:auto;padding:0;}
.drawer-section{padding:14px 16px;border-bottom:1px solid var(--border);}
.drawer-section:last-child{border-bottom:none;}
.ds-title{font-size:9.5px;text-transform:uppercase;letter-spacing:.7px;font-weight:800;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.ds-title.hw{color:#10b981;}.ds-title.sec{color:var(--primary);}.ds-title.gen{color:var(--muted);}
.ds-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.ds-item{background:var(--input-bg);border-radius:8px;padding:8px 10px;}
.ds-item.full{grid-column:1/-1;}
.ds-key{font-size:9.5px;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);font-weight:700;margin-bottom:3px;}
.ds-val{font-size:12px;font-weight:600;color:var(--text);word-break:break-all;line-height:1.4;}
.ds-val.mono{font-family:monospace;font-size:11px;}
.ds-val.dim{color:var(--muted);font-weight:400;}
.drawer-close{background:none;border:none;color:var(--muted);cursor:pointer;padding:4px;border-radius:6px;display:flex;align-items:center;transition:.15s;}
.drawer-close:hover{background:var(--row-hover);color:var(--text);}
.drawer-actions{display:flex;flex-direction:column;gap:6px;padding:14px 16px;border-bottom:1px solid var(--border);}
.drawer-actions .d-row{display:flex;gap:6px;}

/* Pills */
.pill{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;line-height:1.6;}
.p-blue{background:rgba(59,130,246,.13);color:var(--primary);}
.p-green{background:rgba(16,185,129,.13);color:var(--success);}
.p-yellow{background:rgba(245,158,11,.13);color:var(--warning);}
.p-red{background:rgba(239,68,68,.13);color:var(--danger);}
.p-gray{background:rgba(100,116,139,.1);color:var(--muted);}
.p-orange{background:rgba(249,115,22,.13);color:var(--orange);}
.p-gold{background:rgba(245,158,11,.15);color:var(--gold);}
.copies-badge{display:inline-flex;align-items:center;gap:3px;background:rgba(59,130,246,.1);color:var(--primary);border-radius:20px;padding:2px 9px;font-size:11px;font-weight:700;}
.pages-badge{display:inline-flex;align-items:center;gap:3px;background:rgba(16,185,129,.1);color:var(--success);border-radius:20px;padding:2px 9px;font-size:11px;font-weight:700;}
.copies-editor{display:inline-flex;align-items:center;gap:4px;}
.copies-editor input{width:44px;text-align:center;background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:6px;padding:3px 5px;font-size:12px;font-weight:700;}
.copies-editor button{background:none;border:1px solid var(--border);color:var(--muted);border-radius:5px;width:22px;height:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:.15s;}
.copies-editor button:hover{border-color:var(--primary);color:var(--primary);}
.ft-icon{font-size:18px;}
.ft-pdf{color:#ef4444;}.ft-word{color:#3b82f6;}.ft-excel{color:#10b981;}
.ft-ppt{color:#f97316;}.ft-image{color:#8b5cf6;}.ft-text,.ft-other{color:var(--muted);}

/* Toast */
.toast-wrap{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;}
.toast-item{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:12px;padding:12px 18px;font-size:13px;font-weight:500;box-shadow:var(--shadow-md);display:flex;align-items:center;gap:10px;min-width:280px;animation:toastIn .25s ease;}
.toast-item.ok{border-left:4px solid var(--success);}
.toast-item.err{border-left:4px solid var(--danger);}
.toast-item.inf{border-left:4px solid var(--info);}
@keyframes toastIn{from{opacity:0;transform:translateX(24px);}to{opacity:1;transform:translateX(0);}}

/* Modales */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1050;align-items:center;justify-content:center;}
.modal-bg.open{display:flex;}
.modal-box{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:28px;width:100%;max-width:480px;box-shadow:0 24px 64px rgba(0,0,0,.25);animation:mIn .2s ease;}
.modal-box.wide{max-width:620px;}
@keyframes mIn{from{opacity:0;transform:scale(.95);}to{opacity:1;transform:scale(1);}}
.modal-box h5{font-size:16px;font-weight:800;color:var(--text);margin-bottom:18px;display:flex;align-items:center;gap:9px;}
.modal-box p{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.6;}
.m-actions{margin-top:20px;display:flex;gap:10px;justify-content:flex-end;}
.btn-mcancel{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:9px;padding:8px 18px;font-size:13px;cursor:pointer;}
.btn-mcancel:hover{border-color:var(--text);color:var(--text);}
.btn-mconfirm{background:var(--danger);color:#fff;border:none;border-radius:9px;padding:8px 18px;font-size:13px;font-weight:700;cursor:pointer;}
.btn-mconfirm:hover{filter:brightness(1.1);}
.vip-list{display:flex;flex-direction:column;gap:6px;max-height:280px;overflow-y:auto;margin-bottom:16px;}
.vip-row{display:flex;align-items:center;gap:10px;background:var(--input-bg);border:1px solid var(--border);border-radius:10px;padding:10px 14px;}
.vip-row-info{flex:1;}
.vip-row-name{font-size:13px;font-weight:700;color:var(--text);}
.vip-row-email{font-size:11.5px;color:var(--muted);font-family:monospace;}
.vip-add-form{display:flex;gap:8px;flex-wrap:wrap;}
.vip-input{background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:9px;padding:8px 12px;font-size:12.5px;flex:1;min-width:160px;outline:none;}
.vip-input:focus{border-color:var(--gold);}
#printFrame{display:none;}
*::-webkit-scrollbar{width:5px;height:5px;}
*::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
@keyframes shk{0%,100%{transform:translateX(0);}20%,60%{transform:translateX(-6px);}40%,80%{transform:translateX(6px);}}
.empty-state{text-align:center;padding:60px 20px;color:var(--muted);}
.empty-state i{font-size:36px;display:block;margin-bottom:12px;opacity:.35;}
.empty-state p{font-size:13px;}
</style>
</head>
<body>
<%- include("partials/sidebar_top") %>
<div class="pg">

  <!-- ── Header ── -->
  <div class="ph">
    <div>
