<iframe id="printFrame" style="display:none;"></iframe>
<div class="toast-wrap" id="toastWrap"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/sidebar.js"></script>
<script>
// ── State ──────────────────────────────────────────────────
let currentPage=1, currentTab='all', searchTimer=null;
let sortField='queued_at', sortDir='desc';
let activeRowId=null, confirmCb=null, chartMonthly=null;
const COLORS=['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#f97316'];

// ── Utils ──────────────────────────────────────────────────
function toast(msg,type='inf',dur=4500){
  const icons={ok:'bi-check-circle-fill',err:'bi-x-circle-fill',inf:'bi-info-circle-fill'};
  const clrs ={ok:'var(--success)',err:'var(--danger)',inf:'var(--info)'};
  const el=document.createElement('div');
  el.className=`toast-item ${type}`;
  el.innerHTML=`<i class="bi ${icons[type]}" style="color:${clrs[type]};font-size:18px;flex-shrink:0;"></i><span>${msg}</span>`;
  document.getElementById('toastWrap').appendChild(el);
  setTimeout(()=>{el.style.cssText='opacity:0;transform:translateX(20px);transition:.3s;';setTimeout(()=>el.remove(),300);},dur);
}
const fmtDate=d=>{if(!d)return'—';const dt=new Date(d);return isNaN(dt)?d:dt.toLocaleString('es-PE',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});};
const fmtDateS=d=>{if(!d)return'—';const dt=new Date(d);return isNaN(dt)?d:dt.toLocaleDateString('es-PE',{day:'2-digit',month:'2-digit',year:'numeric'});};
const fmtSize=b=>{if(!b)return'—';if(b<1024)return b+'B';if(b<1048576)return(b/1024).toFixed(1)+'KB';return(b/1048576).toFixed(1)+'MB';};
const n=v=>(+v||0).toLocaleString('es-PE');
const esc=s=>(s||'').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const val=s=>s?esc(s):'<span style="color:var(--muted);font-weight:400">—</span>';
const fmtMonth=m=>{if(!m)return'—';const[y,mo]=m.split('-');const nm=['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];return`${nm[+mo-1]} ${y}`;};

const STATUS_MAP={pendiente:{cls:'p-yellow',lbl:'⏳ Pendiente'},imprimiendo:{cls:'p-blue',lbl:'🖨️ Imprimiendo'},completado:{cls:'p-green',lbl:'✅ Completado'},cancelado:{cls:'p-gray',lbl:'⛔ Cancelado'},error:{cls:'p-red',lbl:'❌ Error'}};
const PRIO_MAP={urgente:{cls:'p-red',lbl:'🔴 Urgente'},alta:{cls:'p-orange',lbl:'🟠 Alta'},normal:{cls:'p-yellow',lbl:'🟡 Normal'},baja:{cls:'p-gray',lbl:'⚪ Baja'}};
const FT_MAP={pdf:{icon:'bi-file-earmark-pdf',cls:'ft-pdf',lbl:'PDF'},word:{icon:'bi-file-earmark-word',cls:'ft-word',lbl:'Word'},excel:{icon:'bi-file-earmark-excel',cls:'ft-excel',lbl:'Excel'},powerpoint:{icon:'bi-file-earmark-ppt',cls:'ft-ppt',lbl:'PPT'},image:{icon:'bi-file-image',cls:'ft-image',lbl:'Imagen'},text:{icon:'bi-file-text',cls:'ft-text',lbl:'Texto'},other:{icon:'bi-file-earmark',cls:'ft-other',lbl:'Otro'}};
const statusBadge=s=>{const m=STATUS_MAP[s]||{cls:'p-gray',lbl:s||'—'};return`<span class="pill ${m.cls}">${m.lbl}</span>`;};
const prioBadge=p=>{const m=PRIO_MAP[p]||{cls:'p-gray',lbl:p||'—'};return`<span class="pill ${m.cls}">${m.lbl}</span>`;};
const ftIcon=t=>{const m=FT_MAP[t]||FT_MAP.other;return`<i class="bi ${m.icon} ft-icon ${m.cls}"></i>`;};
const ftBadge=t=>{const m=FT_MAP[t]||FT_MAP.other;return`<span class="pill p-gray" style="font-size:10px;">${m.lbl}</span>`;};

// ── Botón buzón ───────────────────────────────────────────
function mailboxButton(r){
  if(+r.email_deleted===1)
    return`<button class="btn-mailbox eliminado" disabled title="Correo ya eliminado del buzón"><i class="bi bi-check-circle-fill"></i> Eliminado</button>`;
  return`<button class="btn-mailbox pendiente" onclick="event.stopPropagation();deleteMailbox(${r.id})" id="mbBtn_${r.id}" title="Eliminar del buzón de Outlook"><i class="bi bi-envelope-x-fill"></i> Del buzón</button>`;
}

// ── Stats/KPIs ────────────────────────────────────────────
async function loadStats(){
  try{
    const j=await fetch('/api/print-queue/stats').then(r=>r.json());
    if(!j.success)return;
    const k=j.kpis;
    document.getElementById('kpiTotal').textContent      =n(k.total);
    document.getElementById('kpiPendientes').textContent  =n(k.pendientes);
    document.getElementById('kpiImprimiendo').textContent =n(k.imprimiendo);
    document.getElementById('kpiCompletados').textContent =n(k.completados);
    document.getElementById('kpiVip').textContent         =n(j.vip_users_count);
    document.getElementById('kpiErrores').textContent     =n(k.errores);
    document.getElementById('kpiTotalPages').textContent  =n(k.total_pages_to_print);
    document.getElementById('kpiMonthPages').textContent  =n(k.pages_this_month);
    document.getElementById('kpiTotalPagesSub').textContent=`${n(k.total_copias)} copias total`;
    document.getElementById('kpiMonthPagesSub').textContent=`${n(k.docs_this_month||0)} docs este mes`;
    // Strip
    document.getElementById('stripEnCola').textContent    =n(k.en_cola);
    document.getElementById('stripVipPend').textContent   =n(k.vip_pendientes);
    document.getElementById('stripUrgentes').textContent  =n(k.urgentes);
    document.getElementById('stripSP').textContent        =n(k.emails_eliminados);
    document.getElementById('stripPagesMonth').textContent=n(k.pages_this_month);
    document.getElementById('stripCopias').textContent    =n(k.total_copias);
    document.getElementById('vipCountBadge').textContent  =j.vip_users_count?`(${j.vip_users_count})`:'';
    if(k.ultima_encola) document.getElementById('stripLastFetch').textContent=fmtDate(k.ultima_encola);
    // Tab badges
    document.getElementById('badgeAll').textContent=n(k.total);
    document.getElementById('badgeVip').textContent=n(k.vip_total);
    document.getElementById('badgeStd').textContent=n((+k.total||0)-(+k.vip_total||0));
    const vipBadge=document.querySelector('#tabVip .tab-badge');
    if(vipBadge&&+k.vip_pendientes>0){vipBadge.style.background='rgba(239,68,68,.15)';vipBadge.style.color='var(--danger)';}
    // Barras
    const tot=+k.total||1;
    [['Pendiente',+k.pendientes],['Imprimiendo',+k.imprimiendo],['Completado',+k.completados],['Cancelado',+k.cancelados],['Error',+k.errores]]
      .forEach(([id,v])=>{
        const pct=Math.round((v/tot)*100);
        const el=document.getElementById('bar'+id),ep=document.getElementById('barPct'+id);
        if(el)el.style.width=pct+'%'; if(ep)ep.textContent=pct+'%';
      });
  }catch(e){console.error(e);}
}

// ── Analytics panel ───────────────────────────────────────
async function loadAnalytics(){
  try{
    const j=await fetch('/api/print-queue/analytics/top-senders?months=6').then(r=>r.json());
    if(!j.success)return;
    renderTopSenders(j.monthly, j.top);
    renderMonthChart(j.monthly_global);
    renderMonthTable(j.monthly_global);
  }catch(e){console.error('analytics:',e);}
}

function renderTopSenders(monthly, top){
  const curMonth=new Date().toISOString().slice(0,7);
  const thisM=[...(monthly||[])].filter(m=>m.month===curMonth).sort((a,b)=>(+b.pages||0)-(+a.pages||0)).slice(0,5);
  const nameMap={};(top||[]).forEach(r=>{nameMap[r.email_from_addr]={name:r.email_from_name,vip:+r.is_vip};});
  const panel=document.getElementById('topSendersPanel');
  if(!thisM.length){
    panel.innerHTML=`<div style="text-align:center;padding:20px;color:var(--muted);font-size:12px;"><i class="bi bi-inbox" style="display:block;font-size:24px;margin-bottom:6px;opacity:.3;"></i>Sin actividad este mes</div>`;
    return;
  }
  const maxP=+thisM[0].pages||1;
  panel.innerHTML=thisM.map((r,i)=>{
    const pct=Math.round(((+r.pages||0)/maxP)*100);
    const info=nameMap[r.email_from_addr]||{};
    const sname=esc((info.name||r.email_from_addr||'').split(' ').slice(0,2).join(' '));
    const vip=info.vip?`<span class="pill p-gold" style="font-size:9px;padding:1px 5px;margin-left:3px;">⭐</span>`:'';
    const rnk=['r1','r2','r3','rn','rn'][i]||'rn';
    return`<div class="rank-row">
      <div class="rank-num ${rnk}">${i+1}</div>
      <div style="flex:1;min-width:0;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;">
          <span style="font-size:12px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${sname}${vip}</span>
          <span style="font-size:12px;font-weight:800;color:${COLORS[i]};margin-left:8px;white-space:nowrap;">${n(r.pages)} hjs</span>
        </div>
        <div class="rank-bar-track"><div class="rank-bar-fill" style="width:${pct}%;background:${COLORS[i]};"></div></div>
        <div style="font-size:10px;color:var(--muted);margin-top:2px;">${n(r.docs)} docs · ${n(r.copies)} copias</div>
      </div>
    </div>`;
  }).join('');
}

function renderMonthChart(monthly_global){
  if(!monthly_global||!monthly_global.length)return;
  const isDark=()=>document.documentElement.getAttribute('data-theme')==='dark';
  const sorted=[...monthly_global].sort((a,b)=>a.month.localeCompare(b.month));
  const labels=sorted.map(m=>fmtMonth(m.month));
  const pages=sorted.map(m=>+m.pages||0);
  const ctx=document.getElementById('chartMonthly').getContext('2d');
  if(chartMonthly)chartMonthly.destroy();
  chartMonthly=new Chart(ctx,{
    type:'bar',
    data:{labels,datasets:[{label:'Hojas',data:pages,backgroundColor:'rgba(59,130,246,.7)',borderRadius:5,borderSkipped:false}]},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{backgroundColor:isDark()?'#1e293b':'#fff',borderColor:isDark()?'#2d3f55':'#e2e8f0',borderWidth:1,titleColor:isDark()?'#e2e8f0':'#1e293b',bodyColor:isDark()?'#94a3b8':'#64748b',callbacks:{label:c=>`${n(c.raw)} hojas`}}},
      scales:{
        x:{grid:{display:false},ticks:{color:isDark()?'#94a3b8':'#64748b',font:{size:10}}},
        y:{grid:{color:isDark()?'rgba(255,255,255,.04)':'rgba(0,0,0,.04)'},ticks:{color:isDark()?'#94a3b8':'#64748b',font:{size:10}}}
      }
    }
  });
}

function renderMonthTable(monthly_global){
  const tbody=document.getElementById('monthTableBody');
  if(!monthly_global||!monthly_global.length){
    tbody.innerHTML=`<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--muted);">Sin datos</td></tr>`;
    return;
  }
  tbody.innerHTML=monthly_global.map(m=>`
    <tr style="cursor:default;">
      <td style="padding:8px 14px;border-bottom:1px solid var(--border);font-weight:700;">${fmtMonth(m.month)}</td>
      <td style="padding:8px 14px;border-bottom:1px solid var(--border);font-weight:700;color:var(--primary);">${n(m.pages)}</td>
      <td style="padding:8px 14px;border-bottom:1px solid var(--border);color:var(--muted);">${n(m.docs)}</td>
      <td style="padding:8px 14px;border-bottom:1px solid var(--border);color:var(--muted);">${n(m.senders)}</td>
    </tr>`).join('');
}

// ── Tabla principal ───────────────────────────────────────
async function loadData(page=1){
  currentPage=page;
  const search=document.getElementById('searchInput').value.trim();
  const status=document.getElementById('filterStatus').value;
  const prio  =document.getElementById('filterPriority').value;
  const ftype =document.getElementById('filterType').value;
  let url=`/api/print-queue/data?page=${page}&limit=50&sort=${sortField}&dir=${sortDir}&tab=${currentTab}`;
  if(search)url+=`&search=${encodeURIComponent(search)}`;
  if(status)url+=`&status=${encodeURIComponent(status)}`;
  if(prio)  url+=`&priority=${encodeURIComponent(prio)}`;
  if(ftype) url+=`&file_type=${encodeURIComponent(ftype)}`;
  try{
    const j=await fetch(url).then(r=>r.json());
    if(!j.success){toast('Error cargando datos','err');return;}
    renderTable(j.data);
    renderPagination(j.pagination);
    const{page:p,limit:l,total}=j.pagination;
    const from=(p-1)*l+1,to=Math.min(p*l,total);
    document.getElementById('tableInfo').textContent=total?`${n(from)}–${n(to)} de ${n(total)} documentos`:'Sin resultados';
  }catch(e){console.error(e);}
}

function renderTable(rows){
  const tbody=document.getElementById('tableBody');
  if(!rows.length){
    tbody.innerHTML=`<tr><td colspan="10" class="empty-state"><i class="bi bi-inbox"></i><p>Sin documentos${currentTab==='vip'?' VIP':''} con los filtros aplicados</p></td></tr>`;
    return;
  }
  tbody.innerHTML=rows.map(r=>{
    const isVip=+r.is_vip===1;
    const isUrgent=r.priority==='urgente'&&r.status==='pendiente';
    const isActive=r.id===activeRowId;
    const fname=r.file_original||r.file_name||'—';
    const fnameShort=fname.length>28?fname.substring(0,26)+'…':fname;
    const sender=r.email_from_name||r.email_from_addr||'—';
    const senderShort=sender.length>24?sender.substring(0,22)+'…':sender;
    const pagesCell=r.num_pages
      ?`<span class="pages-badge"><i class="bi bi-file-earmark-text"></i> ${n(r.num_pages)}</span><span style="font-size:10px;color:var(--muted);margin-left:3px;">×${r.copies||1}=${n(r.total_print_pages)}</span>`
      :`<span style="color:var(--muted);font-size:11px;">—</span>`;
    let actions='';
    if(r.status==='pendiente'){
      actions+=`<button class="btn-sm success-h" onclick="event.stopPropagation();changeStatus(${r.id},'imprimiendo')" title="Iniciar impresión"><i class="bi bi-play-fill"></i></button>`;
      actions+=`<button class="btn-sm warn-h" onclick="event.stopPropagation();changeStatus(${r.id},'cancelado')" title="Cancelar"><i class="bi bi-x-circle"></i></button>`;
    } else if(r.status==='imprimiendo'){
      actions+=`<button class="btn-sm success-h" onclick="event.stopPropagation();changeStatus(${r.id},'completado')" title="Marcar completado"><i class="bi bi-check-lg"></i></button>`;
      actions+=`<button class="btn-sm danger" onclick="event.stopPropagation();changeStatus(${r.id},'error')" title="Marcar error"><i class="bi bi-exclamation-triangle"></i></button>`;
    } else if(r.status==='error'||r.status==='cancelado'){
      actions+=`<button class="btn-sm" onclick="event.stopPropagation();changeStatus(${r.id},'pendiente')" title="Reabrir como pendiente"><i class="bi bi-arrow-counterclockwise"></i></button>`;
    }
    actions+=`<button class="btn-print" onclick="event.stopPropagation();openCodeModal(${r.id},'${esc(r.file_type)}')" title="Imprimir — requiere código"><i class="bi bi-printer-fill"></i> Imprimir</button>`;
    actions+=`<button class="btn-sm" onclick="event.stopPropagation();downloadFile(${r.id})" title="Descargar"><i class="bi bi-download"></i></button>`;
    if(r.status!=='completado')
      actions+=`<button class="btn-sm danger" onclick="event.stopPropagation();confirmDelete(${r.id},'${esc(fname)}')" title="Eliminar"><i class="bi bi-trash"></i></button>`;
    const trCls=`${isVip?'tr-vip':''} ${isUrgent&&!isVip?'tr-urgente':''} ${isActive?'row-active':''}`.trim();
    return`<tr class="${trCls}" onclick="openDrawer(${JSON.stringify(r).replace(/'/g,'&#39;')})">
      <td style="font-family:monospace;font-size:11px;color:var(--muted);">${r.id}</td>
      <td>
        <div style="font-size:12.5px;font-weight:700;">${esc(senderShort)}${isVip?` <span class="pill p-gold" style="font-size:10px;padding:1px 6px;">⭐ VIP</span>`:''}</div>
        <div style="font-size:11px;color:var(--muted);">${esc(r.email_from_addr||'')}</div>
      </td>
      <td>
        <div style="display:flex;align-items:center;gap:7px;">
          ${ftIcon(r.file_type)}
          <div>
            <div style="font-size:12px;font-weight:600;" title="${esc(fname)}">${esc(fnameShort)}</div>
            <div style="font-size:11px;color:var(--muted);">${fmtSize(r.file_size)}</div>
          </div>
        </div>
      </td>
      <td>${ftBadge(r.file_type)}</td>
      <td>${pagesCell}</td>
      <td><span class="copies-badge"><i class="bi bi-copy"></i> ${r.copies||1}</span></td>
      <td>${prioBadge(r.priority)}</td>
      <td>${statusBadge(r.status)}</td>
      <td>${mailboxButton(r)}</td>
      <td><div style="display:flex;gap:3px;flex-wrap:wrap;">${actions}</div></td>
    </tr>`;
  }).join('');
}

function renderPagination({page,pages}){
  const pg=document.getElementById('pagination');
  if(pages<=1){pg.innerHTML='';return;}
  let h=`<button class="pg-btn" onclick="loadData(${page-1})" ${page<=1?'disabled':''}>‹</button>`;
  const s=Math.max(1,page-2),e=Math.min(pages,page+2);
  if(s>1)h+=`<button class="pg-btn" onclick="loadData(1)">1</button>${s>2?'<span style="padding:0 4px;color:var(--muted);">…</span>':''}`;
  for(let i=s;i<=e;i++)h+=`<button class="pg-btn ${i===page?'active':''}" onclick="loadData(${i})">${i}</button>`;
  if(e<pages)h+=`${e<pages-1?'<span style="padding:0 4px;color:var(--muted);">…</span>':''}<button class="pg-btn" onclick="loadData(${pages})">${pages}</button>`;
  h+=`<button class="pg-btn" onclick="loadData(${page+1})" ${page>=pages?'disabled':''}>›</button>`;
  pg.innerHTML=h;
}

// ── Sort ──────────────────────────────────────────────────
function sortBy(field){
  sortDir=sortField===field?(sortDir==='asc'?'desc':'asc'):'desc'; sortField=field;
  document.querySelectorAll('.tbl thead th').forEach(th=>{th.classList.remove('sorted');const ic=th.querySelector('.sort-icon');if(ic)ic.textContent='⇅';});
  document.querySelectorAll('.tbl thead th[onclick]').forEach(th=>{
    if(th.getAttribute('onclick').includes(`'${field}'`)){th.classList.add('sorted');const ic=th.querySelector('.sort-icon');if(ic)ic.textContent=sortDir==='asc'?'↑':'↓';}
  });
  loadData(1);
}

// ── Tabs ──────────────────────────────────────────────────
function switchTab(tab){
  currentTab=tab; currentPage=1;
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>{if(b.getAttribute('onclick')===`switchTab('${tab}')`)b.classList.add('active');});
  loadData(1);
}

// ── Drawer ────────────────────────────────────────────────
function openDrawer(r){
  activeRowId=r.id;
  document.querySelectorAll('.tbl tbody tr').forEach(t=>t.classList.remove('row-active'));
  event?.currentTarget?.classList.add('row-active');
  document.getElementById('drawerFileName').textContent=r.file_original||r.file_name||'—';
  document.getElementById('drawerBody').innerHTML=buildDrawer(r);
  document.getElementById('drawer').classList.add('open');
}
function closeDrawer(){
  document.getElementById('drawer').classList.remove('open');
  activeRowId=null;
  document.querySelectorAll('.tbl tbody tr').forEach(t=>t.classList.remove('row-active'));
}

function buildDrawer(r){
  const fname=r.file_original||r.file_name||'—';
  const isVip=+r.is_vip===1;
  let actionBtns='';
  if(r.status==='pendiente')
    actionBtns+=`<button class="btn-primary" style="flex:1;justify-content:center;" onclick="changeStatus(${r.id},'imprimiendo')"><i class="bi bi-play-fill"></i> Iniciar impresión</button>
    <button class="btn-outline" onclick="changeStatus(${r.id},'cancelado')"><i class="bi bi-x-circle"></i></button>`;
  else if(r.status==='imprimiendo')
    actionBtns+=`<button class="btn-primary" style="flex:1;justify-content:center;background:var(--success);" onclick="changeStatus(${r.id},'completado')"><i class="bi bi-check-lg"></i> Completado</button>
    <button class="btn-outline" onclick="changeStatus(${r.id},'error')" style="color:var(--danger);border-color:var(--danger)"><i class="bi bi-exclamation-triangle"></i></button>`;
  const printBtn=`<button class="btn-print" style="flex:1;justify-content:center;padding:8px;" onclick="openCodeModal(${r.id},'${esc(r.file_type)}')"><i class="bi bi-printer-fill"></i> Imprimir (requiere código)</button>`;
  const mbDrawer=+r.email_deleted===1
    ?`<button class="btn-mailbox eliminado" style="flex:1;justify-content:center;padding:8px;" disabled><i class="bi bi-check-circle-fill"></i> Correo eliminado del buzón</button>`
    :`<button class="btn-mailbox pendiente" style="flex:1;justify-content:center;padding:8px;" onclick="deleteMailbox(${r.id})" id="mbBtnD_${r.id}"><i class="bi bi-envelope-x-fill"></i> Eliminar del buzón</button>`;
  const copiesEditor=`<div class="copies-editor">
    <button onclick="addCopies(${r.id},-1)">−</button>
    <input type="number" id="copiesInput_${r.id}" value="${r.copies||1}" min="1" max="999" onchange="saveCopies(${r.id})">
    <button onclick="addCopies(${r.id},1)">+</button>
  </div>`;
  const pagesInfo=r.num_pages
    ?`<span class="pages-badge"><i class="bi bi-file-earmark-text"></i> ${n(r.num_pages)} páginas</span><div style="font-size:10.5px;color:var(--muted);margin-top:4px;">× ${r.copies||1} copias = <strong>${n(r.total_print_pages)}</strong> hojas totales</div>`
    :`<span style="color:var(--muted);font-size:12px;">No disponible para este tipo</span>`;

  return`
  ${isVip?`<div style="background:var(--gold-bg);border-bottom:1px solid rgba(245,158,11,.2);padding:10px 16px;display:flex;align-items:center;gap:8px;font-size:12px;font-weight:700;color:var(--gold);"><i class="bi bi-star-fill"></i> Usuario VIP — prioridad garantizada</div>`:''}
  <div class="drawer-actions">
    <div class="d-row">${actionBtns}</div>
    <div class="d-row">${printBtn}</div>
    <div class="d-row">${mbDrawer}</div>
    <div class="d-row"><button class="btn-outline" style="flex:1;justify-content:center;" onclick="downloadFile(${r.id})"><i class="bi bi-download"></i> Descargar</button></div>
  </div>
  <div class="drawer-section">
    <div class="ds-title gen"><i class="bi bi-envelope"></i> Correo origen</div>
    <div class="ds-grid">
      <div class="ds-item full"><div class="ds-key">Asunto</div><div class="ds-val">${val(r.email_subject)}</div></div>
      <div class="ds-item full"><div class="ds-key">Remitente</div><div class="ds-val">${val(r.email_from_name)}</div></div>
      <div class="ds-item full"><div class="ds-key">Email</div><div class="ds-val mono">${val(r.email_from_addr)}</div></div>
      <div class="ds-item"><div class="ds-key">Recibido</div><div class="ds-val dim">${fmtDate(r.received_at)}</div></div>
      <div class="ds-item"><div class="ds-key">Correo buzón</div><div class="ds-val">${+r.email_deleted===1?'<span class="pill p-green">✅ Eliminado</span>':'<span class="pill p-yellow">📬 En buzón</span>'}</div></div>
    </div>
  </div>
  <div class="drawer-section">
    <div class="ds-title hw"><i class="bi bi-file-earmark"></i> Archivo</div>
    <div class="ds-grid">
      <div class="ds-item full"><div class="ds-key">Nombre</div><div class="ds-val">${val(fname)}</div></div>
      <div class="ds-item"><div class="ds-key">Tipo</div><div class="ds-val">${ftBadge(r.file_type)}</div></div>
      <div class="ds-item"><div class="ds-key">Tamaño</div><div class="ds-val">${fmtSize(r.file_size)}</div></div>
      <div class="ds-item full"><div class="ds-key">Páginas del documento</div><div class="ds-val">${pagesInfo}</div></div>
      <div class="ds-item"><div class="ds-key">Copias</div><div class="ds-val">${copiesEditor}</div></div>
      <div class="ds-item"><div class="ds-key">Prioridad</div><div class="ds-val">${prioBadge(r.priority)}</div></div>
    </div>
  </div>
  <div class="drawer-section">
    <div class="ds-title gen"><i class="bi bi-printer"></i> Estado impresión</div>
    <div class="ds-grid">
      <div class="ds-item full"><div class="ds-key">Estado</div><div class="ds-val">${statusBadge(r.status)}</div></div>
      <div class="ds-item"><div class="ds-key">Encolado</div><div class="ds-val dim">${fmtDate(r.queued_at)}</div></div>
      <div class="ds-item"><div class="ds-key">Impreso</div><div class="ds-val dim">${fmtDate(r.printed_at)}</div></div>
      ${r.printed_by?`<div class="ds-item full"><div class="ds-key">Impreso por</div><div class="ds-val dim">${val(r.printed_by)}</div></div>`:''}
      ${r.notes?`<div class="ds-item full"><div class="ds-key">Notas</div><div class="ds-val dim">${val(r.notes)}</div></div>`:''}
    </div>
  </div>`;
}

// ── Acciones ──────────────────────────────────────────────
async function changeStatus(id,status){
  try{
    const j=await fetch(`/api/print-queue/${id}/status`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status})}).then(r=>r.json());
    if(!j.success)throw new Error(j.error);
    toast(`Documento #${id} → ${STATUS_MAP[status]?.lbl||status}`,'ok');
    await loadAll();
    if(activeRowId===id)closeDrawer();
  }catch(e){toast('Error: '+e.message,'err');}
}

async function addCopies(id,delta){
  const inp=document.getElementById(`copiesInput_${id}`);
  if(!inp)return;
  inp.value=Math.max(1,Math.min(999,(parseInt(inp.value)||1)+delta));
  await saveCopies(id);
}
async function saveCopies(id){
  const inp=document.getElementById(`copiesInput_${id}`);
  if(!inp)return;
  const copies=Math.max(1,parseInt(inp.value)||1);
  try{
    const j=await fetch(`/api/print-queue/${id}/copies`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({copies})}).then(r=>r.json());
    if(!j.success)throw new Error(j.error);
    toast(`Copias: ${copies}`,'ok',2000);
  }catch(e){toast('Error: '+e.message,'err');}
}

function confirmDelete(id,fname){
  document.getElementById('confirmMsg').textContent=`¿Eliminar "${fname}" de la cola? Esta acción no se puede deshacer.`;
  confirmCb=async()=>{
    try{
      const j=await fetch(`/api/print-queue/${id}`,{method:'DELETE'}).then(r=>r.json());
      if(!j.success)throw new Error(j.error);
      toast('Documento eliminado','ok');
      await loadAll();
      if(activeRowId===id)closeDrawer();
    }catch(e){toast('Error: '+e.message,'err');}
  };
  document.getElementById('confirmModal').classList.add('open');
}
const doConfirm=()=>{closeConfirm();if(confirmCb)confirmCb();};
const closeConfirm=()=>{document.getElementById('confirmModal').classList.remove('open');confirmCb=null;};
const downloadFile=id=>{window.location.href=`/api/print-queue/download/${id}`;};

// ── Modal de código de seguridad ──────────────────────────
let codeModalDocId = null, codeModalFileType = null;

function openCodeModal(id, fileType){
  codeModalDocId   = id;
  codeModalFileType = fileType;
  document.getElementById('codeInput').value = '';
  document.getElementById('codeInput').classList.remove('shake');
  document.getElementById('codeModalInfo').textContent = `Doc #${id}`;
  document.getElementById('codeModal').classList.add('open');
  setTimeout(()=>document.getElementById('codeInput').focus(), 150);
}
function closeCodeModal(){
  document.getElementById('codeModal').classList.remove('open');
  codeModalDocId = null; codeModalFileType = null;
}
document.addEventListener('DOMContentLoaded',()=>{
  document.getElementById('codeInput')?.addEventListener('keydown', e => {
    if(e.key === 'Enter') submitCode();
  });
  document.getElementById('codeModal')?.addEventListener('click', e => {
    if(e.target === document.getElementById('codeModal')) closeCodeModal();
  });
});

async function submitCode(){
  const code = document.getElementById('codeInput').value.trim();
  if(!code){ shakeCode(); return; }

  // Guardar ANTES de cualquier async
  const docId    = codeModalDocId;
  const fileType = codeModalFileType;

  const btn = document.getElementById('btnCodeOk');
  btn.disabled = true;
  btn.innerHTML = '<span style="display:inline-block;width:13px;height:13px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:6px;"></span> Verificando…';

  try{
    const j = await fetch(`/api/print-queue/${docId}/validate-code`, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ code })
    }).then(r=>r.json());

    if(!j.success){
      shakeCode();
      toast(j.error || 'Código incorrecto — intenta de nuevo','err', 4000);
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-printer-fill"></i> 🖨️ Imprimir';
      return;
    }

    // Código correcto → cerrar modal y lanzar impresión
    toast('✅ Código correcto — abriendo impresión…','ok', 3000);
    closeCodeModal();
    launchPrint(docId, fileType, code);

  }catch(e){
    toast('Error de conexión: '+e.message,'err');
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-printer-fill"></i> 🖨️ Imprimir';
  }
}

function shakeCode(){
  const inp = document.getElementById('codeInput');
  inp.classList.remove('shake');
  void inp.offsetWidth;
  inp.classList.add('shake');
  setTimeout(()=>inp.classList.remove('shake'), 500);
}

function launchPrint(id, fileType, code){
  const url = `/api/print-queue/download/${id}`;

  // ── Registrar en BD como impreso (NO borra el archivo) ───
  const markPrinted = () => {
    fetch(`/api/print-queue/${id}/confirm-printed`, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ code })
    })
    .then(() => loadAll())
    .catch(e => console.warn('confirm-printed:', e.message));
  };

  if(['pdf','image'].includes(fileType)){
    // ── Fetch blob → pestaña nueva → diálogo impresora Windows ──
    // Cargamos el archivo completo en memoria antes de abrir la ventana.
    // Así el asistente de impresión de Windows se abre correctamente.
    toast('Cargando archivo para imprimir…','inf',3000);

    fetch(url)
      .then(r => {
        if(!r.ok) throw new Error('Archivo no disponible (cod ' + r.status + ')');
        return r.blob();
      })
      .then(blob => {
        const blobUrl = URL.createObjectURL(blob);
        const win = window.open(blobUrl, '_blank');

        if(!win){
          // Popup bloqueado por el navegador → descarga directa como fallback
          toast('⚠️ Ventana emergente bloqueada. Permite pop-ups para este sitio o usa el botón Descargar e imprime manualmente.','inf',8000);
          const a = document.createElement('a');
          a.href = blobUrl;
          a.download = '';
          a.click();
          setTimeout(() => URL.revokeObjectURL(blobUrl), 60000);
          markPrinted();
          return;
        }

        // Disparar window.print() cuando la pestaña termine de cargar
        win.addEventListener('load', () => {
          try { win.focus(); win.print(); } catch(e) { console.warn('win.print():', e); }
        });

        // Liberar blob de memoria después de 10 minutos
        setTimeout(() => URL.revokeObjectURL(blobUrl), 10 * 60 * 1000);

        toast('✅ PDF abierto — elige la impresora en la ventana que se abrió','ok', 5000);
        markPrinted();
      })
      .catch(err => {
        toast('❌ ' + err.message,'err', 6000);
      });

  } else {
    // ── Word / Excel / PPT → descarga directa para imprimir desde app nativa ──
    window.open(url, '_blank');
    toast('Archivo abierto — imprime desde la aplicación nativa (Ctrl+P)','inf', 5000);
    markPrinted();
  }
}

