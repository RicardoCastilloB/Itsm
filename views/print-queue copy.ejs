async function deleteMailbox(id){
  const btn = document.getElementById('mbBtn_'+id) || document.getElementById('mbBtnD_'+id);
  if(btn){ btn.disabled=true; btn.innerHTML='<i class="bi bi-arrow-repeat spin-anim"></i> Eliminando…'; }
  try{
    const j = await fetch(`/api/print-queue/${id}/mailbox`,{method:'DELETE'}).then(r=>r.json());
    if(!j.success) throw new Error(j.error);
    toast('✅ Correo eliminado del buzón','ok');
    await loadAll();
    if(activeRowId===id){
      const rows = await fetch(`/api/print-queue/data?page=1&limit=200`).then(r=>r.json());
      const updated = (rows.data||[]).find(r=>r.id===id);
      if(updated) document.getElementById('drawerBody').innerHTML = buildDrawer(updated);
    }
  }catch(e){
    toast('Error: '+e.message,'err');
    if(btn){ btn.disabled=false; btn.innerHTML='<i class="bi bi-envelope-x-fill"></i> Del buzón'; }
  }
}

