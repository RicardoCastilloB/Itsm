// ── Auto-sincronización ────────────────────────────────────
const AUTO_FETCH_INTERVAL = 3; // minutos
let autoFetchTimer = null;
let autoCountdownTimer = null;
let autoFetchRunning = false;

function startAutoFetch() {
  stopAutoFetch();
  updateCountdownLabel(AUTO_FETCH_INTERVAL * 60);
  autoFetchTimer = setInterval(async () => {
    if (autoFetchRunning) return; // evitar solapamientos
    autoFetchRunning = true;
    try { await fetchEmails(true); } // true = modo silencioso
    catch(e) { console.warn('Auto-fetch error:', e.message); }
    finally { autoFetchRunning = false; }
  }, AUTO_FETCH_INTERVAL * 60 * 1000);
}

function stopAutoFetch() {
  clearInterval(autoFetchTimer);
  clearInterval(autoCountdownTimer);
  autoFetchTimer = null;
  autoCountdownTimer = null;
}

function updateCountdownLabel(secondsLeft) {
  clearInterval(autoCountdownTimer);
  let secs = secondsLeft;
  const update = () => {
    const el = document.getElementById('autoFetchCountdown');
    if (!el) return;
    const m = Math.floor(secs / 60);
    const s = secs % 60;
    el.textContent = `Sync en ${m}:${String(s).padStart(2,'0')}`;
    if (secs <= 0) { el.textContent = 'Sincronizando…'; return; }
    secs--;
  };
  update();
  autoCountdownTimer = setInterval(update, 1000);
}

async function fetchEmails(silent = false){
  const btn  = document.getElementById('btnFetch');
  const icon = document.getElementById('fetchIcon');
  const lbl  = document.getElementById('fetchLabel');
  btn.disabled = true; icon.classList.add('spin-anim'); lbl.textContent = 'Buscando...';
  if (!silent) toast('Conectando con Outlook…','inf',10000);
  try{
    const j = await fetch('/api/print-queue/fetch',{method:'POST'}).then(r=>r.json());
    if (!j.success) throw new Error(j.error||'Error desconocido');
    const vips  = (j.log||[]).filter(l=>l.vip&&l.status==='encolado').length;
    const pages = (j.log||[]).filter(l=>l.pages).reduce((s,l)=>s+(l.pages||0),0);
    // Solo mostrar toast si hay correos nuevos o es llamada manual
    if (!silent || j.encolados > 0) {
      toast(`✅ ${j.emails_found} correos · ${j.encolados} nuevos${vips?` · ⭐ ${vips} VIP`:''}${pages?` · ${n(pages)} hojas`:''} · ${j.duplicados} dup.`,'ok',7000);
    }
    document.getElementById('stripLastFetch').textContent = fmtDate(new Date());
    await loadAll();
  }catch(e){
    if (!silent) toast('❌ '+e.message,'err',8000);
    else console.warn('Auto-fetch:', e.message);
  }finally{
    btn.disabled = false; icon.classList.remove('spin-anim'); lbl.textContent = 'Buscar correos';
    // Reiniciar cuenta atrás
    updateCountdownLabel(AUTO_FETCH_INTERVAL * 60);
  }
}

async function loadAll(){
  const icon=document.getElementById('refreshIcon');
  icon.classList.add('spin-anim');
  await Promise.all([loadStats(), loadData(currentPage), loadAnalytics()]);
  icon.classList.remove('spin-anim');
}

