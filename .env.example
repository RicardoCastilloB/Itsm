# Configuración del servidor
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# Base de datos
EQUIPMENT_HOST=localhost
EQUIPMENT_USER=tu_usuario
EQUIPMENT_PASSWORD=tu_password
EQUIPMENT_DATABASE=equipment_management
EQUIPMENT_PORT=3306

# JWT
JWT_SECRET=cambia_esto_en_produccion
JWT_REFRESH_SECRET=cambia_esto_en_produccion
JWT_EXPIRE=59m

# Sesión
SESSION_SECRET=cambia_esto_en_produccion

# Rate Limiting
RATE_LIMIT_WINDOW=15000000
RATE_LIMIT_MAX_REQUESTS=10000000

# Jira
JIRA_HOST=https://tu-empresa.atlassian.net
JIRA_EMAIL=tu@email.com
JIRA_API_TOKEN=tu_token

# Microsoft
MS_CLIENT_ID=
MS_TENANT_ID=
